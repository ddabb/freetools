/**packages/unit/pages/base-converter/base-converter.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 16rpx 0;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 表单区域样式 */
.form-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 16rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  flex: 1;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #e9ecef;
}

.label-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-right: 10rpx;
}

.required-mark {
  color: #ff4757;
  font-size: 28rpx;
}

/* 输入框样式 */
.input-with-unit {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-with-unit:focus-within {
  border-color: #667eea;
  background: white;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.1);
}

.input-field {
  flex: 1;
  font-size: 34rpx;
  border: none;
  outline: none;
  color: #333;
  font-weight: 500;
  background: transparent;
  padding: 28rpx 0;
  font-family: 'Monaco', 'Menlo', monospace;
}

.input-field::placeholder {
  color: #999;
}

/* 单位列表 */
.unit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 单位项 */
.unit-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
  padding: 24rpx;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.unit-item-hover {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
  transform: translateY(-2rpx);
}

/* 单位标签 */
.unit-label {
  font-size: 28rpx;
  color: #6c757d;
  font-weight: 500;
  min-width: 140rpx;
}

/* 单位输入框 */
.unit-input {
  flex: 1;
  padding: 16rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  background: #fff;
  border: 2rpx solid #e9ecef;
  border-radius: 12rpx;
  outline: none;
  text-align: right;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  font-family: 'Monaco', 'Menlo', monospace;
}

.unit-input::placeholder {
  color: #adb5bd;
}

/* 禁用状态的输入框样式 */
.unit-input.disabled {
  background: #f8f9fa;
  color: #666;
  border-color: #dee2e6;
  opacity: 0.8;
}

/* 选择器样式 */
.form-picker {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 28rpx 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-picker-hover {
  border-color: #667eea;
  background: white;
}

.picker-display {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.picker-display.placeholder {
  color: #999;
}

/* 按钮样式 */
.btn-item {
  margin-top: 60rpx;
  margin-bottom: 0;
}

.calculate-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 32rpx;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 15rpx 40rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.calculate-btn-active {
  transform: translateY(-2rpx) scale(1.02);
  box-shadow: 0 20rpx 50rpx rgba(102, 126, 234, 0.5);
}

.calculate-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

.full-width-btn {
  width: 100%;
}

.swap-btn {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 20rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.swap-btn-hover {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  transform: translateY(-2rpx) scale(1.02);
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
}

.btn-text {
  color: inherit;
  font-size: inherit;
  font-weight: inherit;
}

/* 结果展示样式 */
.result-section {
  margin-bottom: 40rpx;
  animation: fadeInScale 0.6s ease-out;
}

.result-box {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
}

.conversion-chain {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 30rpx;
}

.conversion-step {
  flex: 1;
  text-align: center;
}

.step-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.step-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  word-break: break-all;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-family: 'Monaco', 'Menlo', monospace;
}

.step-value.original {
  color: #667eea;
  border-left: 4rpx solid #667eea;
}

.step-value.result {
  color: #764ba2;
  border-left: 4rpx solid #764ba2;
}

.conversion-arrow {
  font-size: 36rpx;
  color: #667eea;
  font-weight: 800;
}

/* Base64特殊显示 */
.base64-section {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.base64-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.base64-preview {
  display: block;
  font-size: 26rpx;
  color: #28a745;
  background: rgba(40, 167, 69, 0.1);
  padding: 20rpx;
  border-radius: 12rpx;
  word-break: break-all;
  border-left: 4rpx solid #28a745;
}

.base64-error {
  display: block;
  font-size: 26rpx;
  color: #dc3545;
  background: rgba(220, 53, 69, 0.1);
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #dc3545;
}

/* 信息科普区域 */
.info-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 16rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  animation: fadeInUp 0.6s ease-out;
  flex: 1;
  width: 80%;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.info-title::before {
  content: '💡';
  margin-right: 12rpx;
  font-size: 24rpx;
}

.info-content {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #e9ecef;
  max-height: 400rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.base-info {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.base-info:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.base-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 4rpx;
}

.base-desc {
  font-size: 22rpx;
  color: #6c757d;
  line-height: 1.4;
}

/* 示例区域 */
.examples-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  animation: fadeInUp 0.6s ease-out;
  flex: 1;
}

.examples-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.examples-title::before {
  content: '📋';
  margin-right: 12rpx;
  font-size: 24rpx;
}

.examples-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.example-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
  padding: 24rpx;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.example-item-hover {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
  transform: translateY(-2rpx);
}

.example-text {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
}

/* 滚动条样式 */
.info-content::-webkit-scrollbar {
  width: 8rpx;
}

.info-content::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 4rpx;
}

.info-content::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 4rpx;
}

.info-content::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}

/* 动画效果 */
@keyframes fadeInScale {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
