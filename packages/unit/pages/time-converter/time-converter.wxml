<!--packages/unit/pages/time-converter/time-converter.wxml-->
<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 单位值输入区域 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">时间单位</text>
        <text class="required-mark">*</text>
      </view>
      <view class="unit-list">
        <view wx:for="{{units}}" wx:key="{{index}}" class="unit-item" hover-class="unit-item-hover">
          <view class="unit-label">{{item}}</view>
          <input 
            type="digit" 
            value="{{unitValues[item]}}" 
            bindinput="onUnitValueChange" 
            data-unit="{{item}}"
            class="unit-input" 
            placeholder="输入值"
           placeholder-class="input-placeholder"/>
        </view>
      </view>
    </view>
    
    <!-- 概念说明 -->
    <view class="concept-section">
      <view class="concept-title">时间单位概念</view>
      <view class="concept-content">
        <view class="concept-item">
          <text class="concept-term">秒 (s)</text>
          <text class="concept-desc">国际标准单位，定义为铯-133原子基态的两个超精细能级之间跃迁所对应的辐射的9,192,631,770个周期的持续时间</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">分钟 (min)</text>
          <text class="concept-desc">1分钟 = 60秒，常用时间单位</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">小时 (h)</text>
          <text class="concept-desc">1小时 = 60分钟，常用时间单位</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">天 (d)</text>
          <text class="concept-desc">1天 = 24小时，常用时间单位</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">周 (week)</text>
          <text class="concept-desc">1周 = 7天，常用时间单位</text>
        </view>
      </view>
    </view>
  </view>
</view>
