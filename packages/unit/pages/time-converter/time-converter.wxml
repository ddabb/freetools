<!--packages/unit/pages/time-converter/time-converter.wxml-->
<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 单位值输入区域 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">时间单位</text>
        <text class="required-mark">*</text>
      </view>
      <view class="unit-list">
        <view wx:for="{{units}}" wx:key="{{index}}" class="unit-item">
          <view class="unit-label">{{item}}</view>
          <input 
            type="digit" 
            value="{{unitValues[item]}}" 
            bindinput="onUnitValueChange" 
            data-unit="{{item}}"
            class="unit-input" 
            placeholder="输入值"
          />
        </view>
      </view>
    </view>
  </view>
  
  <!-- 概念说明 -->
  <view class="concept-section">
    <view class="concept-title">时间单位概念</view>
    <view class="concept-content">
      <view class="concept-item">
        <view class="concept-item-title">秒 (s)</view>
        <view class="concept-item-desc">国际标准单位，定义为铯-133原子基态的两个超精细能级之间跃迁所对应的辐射的9,192,631,770个周期的持续时间。</view>
      </view>
      <view class="concept-item">
        <view class="concept-item-title">分钟 (min)</view>
        <view class="concept-item-desc">常用时间单位，1分钟等于60秒。</view>
      </view>
      <view class="concept-item">
        <view class="concept-item-title">小时 (h)</view>
        <view class="concept-item-desc">常用时间单位，1小时等于60分钟。</view>
      </view>
      <view class="concept-item">
        <view class="concept-item-title">天 (d)</view>
        <view class="concept-item-desc">常用时间单位，1天等于24小时。</view>
      </view>
      <view class="concept-item">
        <view class="concept-item-title">周 (week)</view>
        <view class="concept-item-desc">常用时间单位，1周等于7天。</view>
      </view>
    </view>
  </view>
</view>
