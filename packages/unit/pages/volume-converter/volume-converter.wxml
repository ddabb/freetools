<!--packages/unit/pages/volume-converter/volume-converter.wxml-->
<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 单位值输入区域 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">体积单位</text>
        <text class="required-mark">*</text>
      </view>
      <view class="unit-list">
        <view wx:for="{{units}}" wx:key="{{index}}" class="unit-item" hover-class="unit-item-hover">
          <view class="unit-label">{{item}}</view>
          <input 
            type="digit" 
            value="{{unitValues[item]}}" 
            bindinput="onUnitValueChange" 
            data-unit="{{item}}"
            class="unit-input" 
            placeholder="输入值"
           placeholder-class="input-placeholder"/>
        </view>
      </view>
    </view>
    
    <!-- 概念说明 -->
    <view class="concept-section">
      <view class="concept-title">体积单位概念</view>
      <view class="concept-content">
        <view class="concept-item">
          <text class="concept-term">立方米 (m³)</text>
          <text class="concept-desc">国际标准单位，定义为边长为1米的立方体的体积</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">立方厘米 (cm³)</text>
          <text class="concept-desc">1立方厘米 = 0.000001立方米，常用于表示较小体积</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">升 (L)</text>
          <text class="concept-desc">1升 = 0.001立方米，常用的容量单位</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">毫升 (mL)</text>
          <text class="concept-desc">1毫升 = 0.001升，常用于表示液体体积</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">立方英尺 (cu ft)</text>
          <text class="concept-desc">英制体积单位，1立方英尺 ≈ 0.0283立方米</text>
        </view>
      </view>
    </view>
  </view>
</view>
