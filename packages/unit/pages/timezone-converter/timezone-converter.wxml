<!--packages/unit/pages/timezone-converter/timezone-converter.wxml-->
<view class="container">

  <!-- 标签切换 -->
  <view class="tab-bar">
    <view class="{{tabConverterClass}}" bindtap="switchTab" data-tab="converter">
      <text class="tab-icon">🌍</text>
      <text class="tab-text">时区转换</text>
    </view>
    <view class="{{tabMeetingClass}}" bindtap="switchTab" data-tab="meeting">
      <text class="tab-icon">📅</text>
      <text class="tab-text">会议协调</text>
    </view>
  </view>

  <!-- 城市选择器弹窗（始终渲染，内容控制显示） -->
  <view class="{{pickerModalClass}}">
    <view class="picker-content" catchtap="preventClose">
      <view class="picker-header">
        <text class="picker-title">选择城市</text>
        <text class="picker-close" bindtap="closeCityPicker">✕</text>
      </view>
      <view class="search-box">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="搜索城市或国家" value="{{searchKeyword}}" bindinput="onSearchInput"/>
      </view>
      <scroll-view scroll-y class="city-scroll">
        <!-- 收藏城市 -->
        <view class="city-group">
          <view class="group-title">{{cityGroupFavTitle}}</view>
          <view class="city-options">
            <view class="city-option" wx:for="{{favoriteCitiesWithState}}" wx:key="name" bindtap="selectCity" data-city="{{item.name}}">
              <text class="option-name">{{item.name}}</text>
              <text class="{{item.checkClass}}">{{item.checkIcon}}</text>
            </view>
          </view>
        </view>
        <!-- 所有城市 -->
        <view class="city-group">
          <view class="group-title">{{cityGroupAllTitle}}</view>
          <view class="city-options">
            <view class="city-option" wx:for="{{filteredCities}}" wx:key="city" bindtap="selectCity" data-city="{{item.city}}">
              <view class="option-info">
                <text class="option-name">{{item.city}}</text>
                <text class="option-detail">{{item.country}} {{item.abbr}} {{item.offsetText}}h</text>
              </view>
              <text class="{{item.checkClass}}">{{item.checkIcon}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 时区转换页面（JS控制） -->
  <view class="{{converterPageClass}}">
    <!-- 基准时间设置 -->
    <view class="base-time-card">
      <view class="card-title">
        <text class="title-icon">📍</text>
        <text>基准时间</text>
      </view>
      <view class="base-city" bindtap="showCityPicker" data-mode="base">
        <view class="city-info">
          <text class="city-name">{{baseCity.city}}</text>
          <text class="city-detail">{{baseCity.country}} {{baseCity.offsetText}}h</text>
        </view>
        <text class="change-btn">切换</text>
      </view>
      <view class="time-inputs">
        <picker mode="date" value="{{baseDate}}" bindchange="onBaseDateChange" class="date-picker">
          <view class="picker-box">
            <text class="picker-label">日期</text>
            <text class="picker-value">{{baseDate}}</text>
          </view>
        </picker>
        <picker mode="time" value="{{baseTime}}" bindchange="onBaseTimeChange" class="time-picker">
          <view class="picker-box">
            <text class="picker-label">时间</text>
            <text class="picker-value">{{baseTime}}</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 快速时间选择 -->
    <view class="quick-time-section">
      <text class="section-label">快速设置</text>
      <view class="quick-times">
        <view class="quick-item" bindtap="setQuickTime" data-time="09:00" hover-class="quick-item-hover">09:00</view>
        <view class="quick-item" bindtap="setQuickTime" data-time="14:00" hover-class="quick-item-hover">14:00</view>
        <view class="quick-item" bindtap="setQuickTime" data-time="20:00" hover-class="quick-item-hover">20:00</view>
        <view class="quick-item" bindtap="setQuickTime" data-time="22:00" hover-class="quick-item-hover">22:00</view>
      </view>
    </view>

    <!-- 转换结果 -->
    <view class="results-card">
      <view class="card-header">
        <view class="card-title">
          <text class="title-icon">🌐</text>
          <text>转换结果</text>
        </view>
        <view class="add-btn" bindtap="showCityPicker" data-mode="add">
          <text class="add-icon">+</text>
          <text>添加城市</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-tip" wx:if="{{convertedTimes.length === 0}}">
        <text>点击"添加城市"开始转换</text>
      </view>

      <!-- 城市列表 -->
      <view class="city-list" wx:if="{{convertedTimes.length > 0}}">
        <view class="{{item.itemClass}}" wx:for="{{convertedTimes}}" wx:key="city">
          <view class="city-main">
            <view class="city-flag">{{item.itemFlag}}</view>
            <view class="city-details">
              <view class="city-name-row">
                <text class="name">{{item.city}}</text>
                <text class="country">{{item.country}}</text>
              </view>
              <view class="offset-info">
                <text class="offset-badge">{{item.offsetText}}h</text>
                <text class="{{item.itemStatusClass}}">{{item.itemStatusText}}</text>
              </view>
            </view>
          </view>
          <view class="city-time">
            <text class="time-value">{{item.localTime}}</text>
            <text class="date-value">{{item.localDate}}</text>
          </view>
          <view class="city-actions">
            <text class="{{item.itemFavClass}}" bindtap="toggleFavorite" data-city="{{item.city}}">{{item.itemFavIcon}}</text>
            <text class="action-btn" bindtap="removeSelectedCity" data-city="{{item.city}}">✕</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 收藏城市 -->
    <view class="favorites-card" wx:if="{{favoriteTagsWithState.length > 0}}">
      <view class="card-title">
        <text class="title-icon">⭐</text>
        <text>收藏城市</text>
      </view>
      <view class="favorite-tags">
        <view class="{{item.tagClass}}" wx:for="{{favoriteTagsWithState}}" wx:key="name" bindtap="setAsBase" data-city="{{item.name}}">{{item.name}}</view>
      </view>
    </view>

    <!-- 分享按钮 -->
    <view class="share-section" wx:if="{{convertedTimes.length > 0}}">
      <button class="btn-share" bindtap="shareResult"><text>📋 复制结果</text></button>
    </view>
  </view>

  <!-- 会议协调页面 -->
  <view class="{{meetingPageClass}}">
    <!-- 基准设置 -->
    <view class="base-time-card">
      <view class="card-title">
        <text class="title-icon">📍</text>
        <text>基准时间</text>
      </view>
      <view class="base-city" bindtap="showCityPicker" data-mode="base">
        <view class="city-info">
          <text class="city-name">{{baseCity.city}}</text>
          <text class="city-detail">{{baseCity.country}}</text>
        </view>
        <text class="change-btn">切换</text>
      </view>
      <view class="time-inputs">
        <picker mode="date" value="{{baseDate}}" bindchange="onBaseDateChange" class="date-picker">
          <view class="picker-box">
            <text class="picker-label">日期</text>
            <text class="picker-value">{{baseDate}}</text>
          </view>
        </picker>
        <picker mode="time" value="{{baseTime}}" bindchange="onBaseTimeChange" class="time-picker">
          <view class="picker-box">
            <text class="picker-label">时间</text>
            <text class="picker-value">{{baseTime}}</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 会议时长 -->
    <view class="duration-section">
      <text class="section-label">会议时长</text>
      <view class="duration-options">
        <view class="{{item.itemClass}}" wx:for="{{durationOptions}}" wx:key="value" bindtap="onDurationChange" data-value="{{item.value}}" hover-class="duration-item-hover">{{item.label}}</view>
      </view>
    </view>

    <!-- 参与城市 -->
    <view class="meeting-cities-card">
      <view class="card-header">
        <view class="card-title">
          <text class="title-icon">👥</text>
          <text>参与城市</text>
        </view>
        <view class="add-btn" bindtap="addMeetingCity">
          <text class="add-icon">+</text>
          <text>添加</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-tip" wx:if="{{meetingCities.length === 0}}">
        <text>添加参与会议的城市</text>
      </view>

      <!-- 城市标签 -->
      <view class="meeting-city-list" wx:if="{{meetingCities.length > 0}}">
        <view class="meeting-city-item" wx:for="{{meetingCities}}" wx:key="*this">
          <text class="city-name">{{item}}</text>
          <text class="remove-btn" bindtap="removeMeetingCity" data-city="{{item}}">✕</text>
        </view>
      </view>
    </view>

    <!-- 会议时间分析 -->
    <view class="analysis-card" wx:if="{{meetingResults.length > 0}}">
      <view class="card-title">
        <text class="title-icon">📊</text>
        <text>时间分析</text>
      </view>
      <view class="analysis-list">
        <view class="{{item.itemClass}}" wx:for="{{meetingResults}}" wx:key="city">
          <view class="analysis-city">
            <text class="city-flag">{{item.itemFlag}}</text>
            <text class="city-name">{{item.city}}</text>
            <text class="country">{{item.country}}</text>
          </view>
          <view class="analysis-time">
            <text class="local-time">{{item.localTime}}</text>
            <text class="{{item.itemTimeTagClass}}">{{item.itemTimeTagText}}</text>
          </view>
        </view>
      </view>
      <!-- 建议 -->
      <view class="suggestion-box">
        <view class="suggestion-title">💡 建议</view>
        <view class="{{suggestionClass}}">{{suggestionText}}</view>
      </view>
    </view>
  </view>

</view>
