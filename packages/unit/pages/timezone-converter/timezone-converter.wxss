/* packages/unit/pages/timezone-converter/timezone-converter.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #e8e8e8;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  position: relative;
}

.tab-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tab-text {
  font-size: 30rpx;
  color: #666;
}

/* 页面内容 */
.converter-page {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* 卡片样式 */
.base-time-card,
.results-card,
.favorites-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-header .card-title {
  margin-bottom: 0;
}

/* 基准城市 */
.base-city {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #eef2f7;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.city-info {
  display: flex;
  align-items: center;
}

.city-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.city-detail {
  font-size: 24rpx;
  color: #6b7280;
}

.change-btn {
  font-size: 26rpx;
  color: #096dd9;
  padding: 8rpx 20rpx;
  background: #d6e8fa;
  border-radius: 24rpx;
}

/* 时间输入 */
.time-inputs {
  display: flex;
  gap: 20rpx;
}

.date-picker,
.time-picker {
  flex: 1;
}

.picker-box {
  background: #eef2f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.picker-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.picker-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 快速时间 */
.quick-time-section {
  margin-bottom: 24rpx;
}

.section-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.quick-times {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.quick-item {
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid #e8e8e8;
}

.quick-item-hover {
  background: #f0f0f0;
}

/* 添加按钮 */
.add-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #d6e8fa;
  border-radius: 24rpx;
}

.add-icon {
  font-size: 28rpx;
  color: #096dd9;
  margin-right: 8rpx;
}

.add-btn text:last-child {
  font-size: 26rpx;
  color: #096dd9;
}

/* 空提示 */
.empty-tip {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 城市列表 */
.city-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.city-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #eef2f7;
  border-radius: 16rpx;
  border-left: 6rpx solid #ddd;
}

.city-item.worktime {
  border-left-color: #389e0d;
  background: #e8f8d4;
}

.city-item.night {
  border-left-color: #531dab;
  background: #efdbff;
}

.city-main {
  flex: 1;
  display: flex;
  align-items: center;
}

.city-flag {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.city-details {
  flex: 1;
}

.city-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.city-name-row .name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-right: 12rpx;
}

.city-name-row .country {
  font-size: 24rpx;
  color: #6b7280;
}

.offset-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.offset-badge {
  font-size: 22rpx;
  color: #1d4ed8;
  background: #dbeafe;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.time-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.time-status.work {
  color: #389e0d;
  background: #d9f7be;
}

.time-status.night {
  color: #531dab;
  background: #efdbff;
}

.time-status.normal {
  color: #d46b08;
  background: #ffe7ba;
}

.city-time {
  text-align: right;
  margin-right: 20rpx;
}

.time-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.date-value {
  font-size: 22rpx;
  color: #999;
}

.city-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 32rpx;
  color: #ccc;
  padding: 8rpx;
}

.action-btn.favorited {
  color: #faad14;
}

/* 收藏城市 */
.favorite-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.favorite-tag {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.favorite-tag.selected {
  background: #e6f7ff;
  color: #1890ff;
  border-color: #1890ff;
}

/* 分享按钮 */
.share-section {
  margin-top: 32rpx;
}

.btn-share {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-share::after {
  border: none;
}



/* 城市选择器弹窗 */
.city-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.picker-content {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.search-box {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #f5f5f5;
  margin: 24rpx 32rpx;
  border-radius: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.city-scroll {
  flex: 1;
  max-height: 60vh;
  padding: 0 32rpx 32rpx;
}

.city-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.city-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.city-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.option-info {
  display: flex;
  flex-direction: column;
}

.option-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.option-detail {
  font-size: 24rpx;
  color: #999;
}

.option-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.option-check.checked {
  background: #1890ff;
}
