/* packages/unit/pages/timezone-converter/timezone-converter.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-container {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.required-mark {
  color: #ff4d4f;
  margin-left: 8rpx;
}

.time-inputs {
  display: flex;
  gap: 16rpx;
}

.date-picker, .time-input {
  flex: 1;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 32rpx;
  background-color: #fafafa;
}

.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 100%;
}

.picker-text {
  color: #333;
}

.picker-text:empty:before {
  content: '选择日期';
  color: #999;
}

.picker-icon {
  font-size: 28rpx;
  color: #1890ff;
}

.timezone-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  max-height: 600rpx;
  overflow-y: auto;
  padding: 12rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  background-color: #fafafa;
}

.timezone-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background-color: white;
  border-radius: 6rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
}

.timezone-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  margin-right: 16rpx;
}

.timezone-input {
  width: 300rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 6rpx;
  padding: 12rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  text-align: right;
}

.info-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #e8e8e8;
}

.info-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.info-content {
  font-size: 28rpx;
  color: #666;
}

.info-item {
  margin-bottom: 12rpx;
  line-height: 40rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-term {
  font-weight: 500;
  color: #333;
  margin-right: 12rpx;
}

.info-desc {
  color: #666;
}