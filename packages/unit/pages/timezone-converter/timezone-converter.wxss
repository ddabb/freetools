/* packages/unit/pages/timezone-converter/timezone-converter.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #e8e8e8;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

.tab-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tab-text {
  font-size: 30rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #1890ff;
  font-weight: 500;
}

/* 页面内容 */
.converter-page,
.meeting-page {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* 卡片样式 */
.base-time-card,
.results-card,
.favorites-card,
.meeting-cities-card,
.analysis-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-header .card-title {
  margin-bottom: 0;
}

/* 基准城市 */
.base-city {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.city-info {
  display: flex;
  align-items: center;
}

.city-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.city-detail {
  font-size: 24rpx;
  color: #999;
}

.change-btn {
  font-size: 26rpx;
  color: #1890ff;
  padding: 8rpx 20rpx;
  background: #e6f7ff;
  border-radius: 24rpx;
}

/* 时间输入 */
.time-inputs {
  display: flex;
  gap: 20rpx;
}

.date-picker,
.time-picker {
  flex: 1;
}

.picker-box {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.picker-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.picker-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 快速时间 */
.quick-time-section,
.duration-section {
  margin-bottom: 24rpx;
}

.section-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.quick-times,
.duration-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.quick-item,
.duration-item {
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid #e8e8e8;
}

.quick-item-hover,
.duration-item-hover {
  background: #f0f0f0;
}

.duration-item.active {
  background: #1890ff;
  color: #fff;
  border-color: #1890ff;
}

/* 添加按钮 */
.add-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #e6f7ff;
  border-radius: 24rpx;
}

.add-icon {
  font-size: 28rpx;
  color: #1890ff;
  margin-right: 8rpx;
}

.add-btn text:last-child {
  font-size: 26rpx;
  color: #1890ff;
}

/* 空提示 */
.empty-tip {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 城市列表 */
.city-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.city-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border-left: 6rpx solid #ddd;
}

.city-item.worktime {
  border-left-color: #52c41a;
  background: #f6ffed;
}

.city-item.night {
  border-left-color: #722ed1;
  background: #f9f0ff;
}

.city-main {
  flex: 1;
  display: flex;
  align-items: center;
}

.city-flag {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.city-details {
  flex: 1;
}

.city-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.city-name-row .name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-right: 12rpx;
}

.city-name-row .country {
  font-size: 24rpx;
  color: #999;
}

.offset-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.offset-badge {
  font-size: 22rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.time-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.time-status.work {
  color: #52c41a;
  background: #f6ffed;
}

.time-status.night {
  color: #722ed1;
  background: #f9f0ff;
}

.time-status.normal {
  color: #fa8c16;
  background: #fff7e6;
}

.city-time {
  text-align: right;
  margin-right: 20rpx;
}

.time-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.date-value {
  font-size: 22rpx;
  color: #999;
}

.city-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 32rpx;
  color: #ccc;
  padding: 8rpx;
}

.action-btn.favorited {
  color: #faad14;
}

/* 收藏城市 */
.favorite-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.favorite-tag {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.favorite-tag.selected {
  background: #e6f7ff;
  color: #1890ff;
  border-color: #1890ff;
}

/* 分享按钮 */
.share-section {
  margin-top: 32rpx;
}

.btn-share {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-share::after {
  border: none;
}

/* 会议城市 */
.meeting-city-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.meeting-city-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f0f5ff;
  border-radius: 30rpx;
}

.meeting-city-item .city-name {
  font-size: 28rpx;
  color: #1890ff;
  margin-right: 16rpx;
}

.remove-btn {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx;
}

/* 分析结果 */
.analysis-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.analysis-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border-left: 6rpx solid #ddd;
}

.analysis-item.good {
  border-left-color: #52c41a;
  background: #f6ffed;
}

.analysis-item.warning {
  border-left-color: #faad14;
  background: #fffbe6;
}

.analysis-item.bad {
  border-left-color: #ff4d4f;
  background: #fff1f0;
}

.analysis-city {
  display: flex;
  align-items: center;
}

.analysis-city .city-flag {
  margin-right: 16rpx;
}

.analysis-city .city-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-right: 12rpx;
}

.analysis-city .country {
  font-size: 24rpx;
  color: #999;
}

.analysis-time {
  text-align: right;
}

.local-time {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.time-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.time-tag.work {
  color: #52c41a;
  background: #d9f7be;
}

.time-tag.overtime {
  color: #faad14;
  background: #ffe7ba;
}

.time-tag.night {
  color: #ff4d4f;
  background: #ffccc7;
}

/* 建议框 */
.suggestion-box {
  padding: 24rpx;
  background: #f6ffed;
  border-radius: 12rpx;
  border: 2rpx solid #b7eb8f;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #52c41a;
  margin-bottom: 12rpx;
}

.suggestion-good,
.suggestion-warning,
.suggestion-bad {
  font-size: 28rpx;
  line-height: 1.6;
}

.suggestion-good {
  color: #52c41a;
}

.suggestion-warning {
  color: #fa8c16;
}

.suggestion-bad {
  color: #ff4d4f;
}

/* 城市选择器弹窗 */
.city-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.picker-content {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.search-box {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #f5f5f5;
  margin: 24rpx 32rpx;
  border-radius: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.city-scroll {
  flex: 1;
  max-height: 60vh;
  padding: 0 32rpx 32rpx;
}

.city-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.city-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.city-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.option-info {
  display: flex;
  flex-direction: column;
}

.option-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.option-detail {
  font-size: 24rpx;
  color: #999;
}

.option-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.option-check.checked {
  background: #1890ff;
}
