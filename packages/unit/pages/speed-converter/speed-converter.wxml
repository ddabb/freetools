<!-- packages/unit/pages/speed-converter/speed-converter.wxml -->
<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 单位值输入区域 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">速度单位</text>
        <text class="required-mark">*</text>
      </view>
      <view class="unit-list">
        <view wx:for="{{units}}" wx:key="{{index}}" class="unit-item" hover-class="unit-item-hover">
          <view class="unit-label">{{item}}</view>
          <input 
            type="digit" 
            value="{{unitValues[item]}}" 
            bindinput="onUnitValueChange" 
            data-unit="{{item}}"
            class="unit-input" 
            placeholder="输入值"
           placeholder-class="input-placeholder"/>
        </view>
      </view>
    </view>
    
    <!-- 概念说明 -->
    <view class="concept-section">
      <view class="concept-title">速度单位概念</view>
      <view class="concept-content">
        <view class="concept-item">
          <text class="concept-term">米/秒 (m/s)</text>
          <text class="concept-desc">国际单位制中的基本速度单位</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">千米/小时 (km/h)</text>
          <text class="concept-desc">1千米/小时 = 0.277778米/秒，常用于表示车辆速度</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">英里/小时 (mph)</text>
          <text class="concept-desc">1英里/小时 ≈ 0.44704米/秒，常用于表示车辆速度</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">节 (kn)</text>
          <text class="concept-desc">1节 ≈ 0.514444米/秒，常用于表示船舶和飞机速度</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">英尺/秒 (ft/s)</text>
          <text class="concept-desc">1英尺/秒 ≈ 0.3048米/秒，常用于表示物体速度</text>
        </view>
      </view>
    </view>
  </view>
  <!-- 搴曢儴骞垮憡 -->
  <ad unit-id="adunit-07e9c9da9e4b8254" ad-intervals="30" binderror="onAdError" bindclose="onAdClose"></ad>
</view>