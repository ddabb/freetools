<!--packages/unit/pages/area-converter/area-converter.wxml-->
<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 单位值输入区域 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">面积单位</text>
        <text class="required-mark">*</text>
      </view>
      <view class="unit-list">
        <view wx:for="{{units}}" wx:key="{{index}}" class="unit-item">
          <view class="unit-label">{{item}}</view>
          <input 
            type="digit" 
            value="{{unitValues[item]}}" 
            bindinput="onUnitValueChange" 
            data-unit="{{item}}"
            class="unit-input" 
            placeholder="输入值"
          />
        </view>
      </view>
    </view>
    
    <!-- 概念说明 -->
    <view class="concept-section">
      <view class="concept-title">面积单位概念</view>
      <view class="concept-content">
        <view class="concept-item">
          <text class="concept-term">平方米 (㎡)</text>
          <text class="concept-desc">国际标准单位，定义为边长为1米的正方形的面积</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">平方千米 (km²)</text>
          <text class="concept-desc">1平方千米 = 1000000平方米，常用于表示较大面积</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">公顷 (ha)</text>
          <text class="concept-desc">1公顷 = 10000平方米，常用于农业和土地测量</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">亩</text>
          <text class="concept-desc">中国传统面积单位，1亩 ≈ 666.67平方米，常用于农业</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">平方英尺 (sq ft)</text>
          <text class="concept-desc">英制面积单位，1平方英尺 ≈ 0.0929平方米，常用于房地产</text>
        </view>
      </view>
    </view>
  </view>
</view>
