/* packages/unit/pages/area-converter/area-converter.wxss */

/* 容器样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

/* 表单容器 */
.form-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10px);
}

/* 表单标题 */
.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.required-mark {
  color: #ff4d4f;
  margin-left: 8rpx;
}

/* 单位列表 */
.unit-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 单位项 */
.unit-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.unit-item:hover {
  background: #f0f0f0;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

/* 单位标签 */
.unit-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #555;
}

/* 输入框 */
.unit-input {
  width: 100%;
  padding: 16rpx 20rpx;
  font-size: 32rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  background: white;
}

.unit-input:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
  outline: none;
}

/* 概念说明区域 */
.concept-section {
  margin-top: 40rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #e9ecef;
}

.concept-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.concept-title::before {
  content: '📚';
  margin-right: 12rpx;
  font-size: 24rpx;
}

.concept-content {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #e9ecef;
  max-height: 400rpx;
  overflow-y: auto;
}

.concept-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.concept-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.concept-term {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 4rpx;
}

.concept-desc {
  font-size: 22rpx;
  color: #6c757d;
  line-height: 1.4;
}

/* 滚动条样式 */
.concept-content::-webkit-scrollbar {
  width: 8rpx;
}

.concept-content::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 4rpx;
}

.concept-content::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 4rpx;
}

.concept-content::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}