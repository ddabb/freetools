<!--packages/unit/pages/temperature-converter/temperature-converter.wxml-->
<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 单位值输入区域 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">温度单位</text>
        <text class="required-mark">*</text>
      </view>
      <view class="unit-list">
        <view wx:for="{{units}}" wx:key="{{index}}" class="unit-item" hover-class="unit-item-hover">
          <view class="unit-label">{{item}}</view>
          <input 
            type="digit" 
            value="{{unitValues[item]}}" 
            bindinput="onUnitValueChange" 
            data-unit="{{item}}"
            class="unit-input" 
            placeholder="输入值"
           placeholder-class="input-placeholder"/>
        </view>
      </view>
    </view>
    
    <!-- 概念说明 -->
    <view class="concept-section">
      <view class="concept-title">温度单位概念</view>
      <view class="concept-content">
        <view class="concept-item">
          <text class="concept-term">摄氏度 (°C)</text>
          <text class="concept-desc">以水的冰点为0度，沸点为100度的温度标度</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">华氏度 (°F)</text>
          <text class="concept-desc">以水的冰点为32度，沸点为212度的温度标度</text>
        </view>
        <view class="concept-item">
          <text class="concept-term">开尔文 (K)</text>
          <text class="concept-desc">热力学温度单位，以绝对零度为0K，与摄氏度的间隔相同</text>
        </view>
      </view>
    </view>
  </view>
</view>
