/**packages/unit/pages/temperature-converter/temperature-converter.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 16rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 表单容器 */
.form-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  flex: 1;
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

/* 表单标签 */
.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #e9ecef;
}

.label-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.required-mark {
  color: #ff4757;
  font-size: 28rpx;
  margin-left: 8rpx;
}

/* 单位列表布局 */
.unit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 单位项 */
.unit-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
  padding: 24rpx;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.unit-item-hover {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
  transform: translateY(-2rpx);
}

/* 单位标签 */
.unit-label {
  font-size: 28rpx;
  color: #6c757d;
  font-weight: 500;
  min-width: 140rpx;
}

/* 单位输入框 */
.unit-input {
  flex: 1;
  padding: 16rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  background: #fff;
  border: 2rpx solid #e9ecef;
  border-radius: 12rpx;
  outline: none;
  text-align: right;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.unit-input::placeholder {
  color: #adb5bd;
}

/* 概念说明区域 */
.concept-section {
  margin-top: 40rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #e9ecef;
}

.concept-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.concept-title::before {
  content: '📚';
  margin-right: 12rpx;
  font-size: 24rpx;
}

.concept-content {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #e9ecef;
  max-height: 400rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 滚动条样式 */
.concept-content::-webkit-scrollbar {
  width: 8rpx;
}

.concept-content::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 4rpx;
}

.concept-content::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 4rpx;
}

.concept-content::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}

.concept-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.concept-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.concept-term {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 4rpx;
}

.concept-desc {
  font-size: 22rpx;
  color: #6c757d;
  line-height: 1.4;
}
