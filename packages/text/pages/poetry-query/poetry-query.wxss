/* packages/text/pages/poetry-query/poetry-query.wxss */
/* 诗词查询页面 - 适老化优化版 */

/* 页面整体 */
.page { padding: 24rpx; background: #f8f6f2; min-height: 100vh; }

/* 搜索栏 - 放大 */
.search-bar { display: flex; align-items: center; background: #fff; border-radius: 20rpx; padding: 16rpx 24rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08); border: 2rpx solid #e0dcd4; }
.search-input { flex: 1; font-size: 36rpx; color: #333; }
.search-btn { background: #2d7d46; color: #fff; border-radius: 16rpx; padding: 16rpx 32rpx; font-size: 34rpx; margin-left: 16rpx; font-weight: 600; }
.search-btn:active { background: #256b3a; }
.search-clear { color: #888; font-size: 32rpx; margin-left: 16rpx; padding: 12rpx; }

/* 朝代筛选 - 放大 */
.dynasty-bar { white-space: nowrap; margin-bottom: 24rpx; }
.dynasty-item { display: inline-block; padding: 14rpx 28rpx; margin-right: 16rpx; border-radius: 24rpx; background: #fff; font-size: 30rpx; color: #555; border: 2rpx solid #ddd; }
.dynasty-item.active { background: #2d7d46; color: #fff; border-color: #2d7d46; }

/* 标题 - 放大 */
.section-title { font-size: 32rpx; color: #666; margin: 20rpx 0; padding-left: 12rpx; font-weight: 500; }

/* 结果列表 - 放大 */
.result-item, .poet-item { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; border: 2rpx solid #eee; }
.result-item:active, .poet-item:active { background: #f0f7f2; border-color: #2d7d46; }
.result-title, .poet-name { font-size: 36rpx; font-weight: 600; color: #222; }
.result-sub, .poet-info { font-size: 30rpx; color: #666; margin-top: 8rpx; }

/* Loading */
.loading { text-align: center; padding: 48rpx; color: #888; font-size: 32rpx; }

/* 提示文字 */
page { font-size: 30rpx; color: #555; }