<view class="container">

  <!-- 文本输入区域（前置） -->
  <view class="input-card">
    <view class="card-header">
      <text class="card-title">✏️ 输入文本</text>
      <text class="char-hint">{{inputText.length > 0 ? inputText.length + ' 字符' : '最多 50000'}}</text>
    </view>
    <textarea
      value="{{inputText}}"
      bindinput="onTextInput"
      class="main-textarea"
      placeholder="在此输入或粘贴要统计的文本..."
      maxlength="50000"
      show-confirm-bar="false"
      auto-height
    />
    <view class="textarea-footer">
      <view class="textarea-controls">
        <button class="ctrl-btn" hover-class="ctrl-btn-hover" bindtap="clearText">清空</button>
        <button class="ctrl-btn accent" hover-class="ctrl-btn-hover" bindtap="pasteText">粘贴</button>
        <button class="ctrl-btn success" hover-class="ctrl-btn-hover" bindtap="loadSampleText">示例</button>
      </view>
    </view>
  </view>

  <!-- 写作目标 -->
  <view class="goal-card" wx:if="{{targetWords > 0}}">
    <view class="goal-row">
      <text class="goal-label">🎯 目标 {{targetWords}} 字</text>
      <text class="goal-progress-text {{progressPercentage >= 100 ? 'done' : ''}}">{{stats.words}}/{{targetWords}}（{{Math.round(progressPercentage)}}%）</text>
    </view>
    <view class="progress-bar">
      <view class="progress-fill {{progressPercentage >= 100 ? 'done' : ''}}" style="width: {{progressPercentage > 100 ? 100 : progressPercentage}}%"></view>
    </view>
  </view>

  <!-- 统计概览 -->
  <view class="stats-card">
    <view class="card-header">
      <text class="card-title">📊 统计概览</text>
      <view class="goal-set-row">
        <text class="goal-set-label">目标字数</text>
        <input type="number" value="{{targetWords}}" bindinput="setTargetWords" class="goal-input" placeholder="0" placeholder-class="input-placeholder"/>
      </view>
    </view>
    <view class="stats-grid">
      <view class="stat-item primary">
        <text class="stat-num">{{inputText.length > 0 ? stats.characters : '—'}}</text>
        <text class="stat-lbl">总字符</text>
      </view>
      <view class="stat-item info">
        <text class="stat-num">{{inputText.length > 0 ? stats.charactersNoSpace : '—'}}</text>
        <text class="stat-lbl">字符(去空格)</text>
      </view>
      <view class="stat-item green">
        <text class="stat-num">{{inputText.length > 0 ? stats.chineseChars : '—'}}</text>
        <text class="stat-lbl">中文字</text>
      </view>
      <view class="stat-item warning">
        <text class="stat-num">{{inputText.length > 0 ? stats.words : '—'}}</text>
        <text class="stat-lbl">词语数</text>
      </view>
      <view class="stat-item purple">
        <text class="stat-num">{{inputText.length > 0 ? stats.sentences : '—'}}</text>
        <text class="stat-lbl">句子数</text>
      </view>
      <view class="stat-item rose">
        <text class="stat-num">{{inputText.length > 0 ? stats.paragraphs : '—'}}</text>
        <text class="stat-lbl">段落数</text>
      </view>
    </view>
  </view>

  <!-- 详细统计 + 分析（有内容才展示） -->
  <view class="detail-card" wx:if="{{inputText.length > 0}}">
    <view class="card-header">
      <text class="card-title">🔍 详细分析</text>
    </view>
    <view class="detail-grid">
      <view class="detail-row">
        <text class="detail-k">英文字母</text>
        <text class="detail-v">{{stats.englishLetters}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-k">数字</text>
        <text class="detail-v">{{stats.digits}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-k">标点符号</text>
        <text class="detail-v">{{stats.punctuation}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-k">空格</text>
        <text class="detail-v">{{stats.spaces}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-k">行数</text>
        <text class="detail-v">{{stats.lines}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-k">特殊符号</text>
        <text class="detail-v">{{stats.specialChars}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-k">阅读时长</text>
        <text class="detail-v">{{readingTime}} 分钟</text>
      </view>
      <view class="detail-row">
        <text class="detail-k">平均句长</text>
        <text class="detail-v">{{averageSentenceLength}} 字/句</text>
      </view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="actions-card">
    <view class="action-grid">
      <view class="action-item" hover-class="action-item-hover" bindtap="copyText">
        <text class="action-icon">📋</text>
        <text class="action-text">复制文本</text>
      </view>
      <view class="action-item" hover-class="action-item-hover" bindtap="exportReport">
        <text class="action-icon">📤</text>
        <text class="action-text">导出报告</text>
      </view>
      <view class="action-item" hover-class="action-item-hover" bindtap="toggleCase">
        <text class="action-icon">🔤</text>
        <text class="action-text">大小写转换</text>
      </view>
      <view class="action-item" hover-class="action-item-hover" bindtap="shareStats">
        <text class="action-icon">↗️</text>
        <text class="action-text">分享统计</text>
      </view>
    </view>
  </view>

  <!-- 说明 -->
  <view class="tip-section">
    <text class="tip-text">• 词语统计基于中英文分词，准确率约90%</text>
    <text class="tip-text">• 句子以句号/问号/感叹号为分隔符</text>
    <text class="tip-text">• 阅读时长按 250 字/分钟估算</text>
  </view>

</view>
