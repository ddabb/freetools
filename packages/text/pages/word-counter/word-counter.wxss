/**packages/text/pages/word-counter/word-counter.wxss**/
page {
  background: #f0f4f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 24rpx 24rpx 60rpx;
}

/* =====================
   通用卡片
   ===================== */
.input-card,
.stats-card,
.detail-card,
.actions-card,
.goal-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.char-hint {
  font-size: 24rpx;
  color: #6b7280;
}

/* =====================
   输入区域
   ===================== */
.main-textarea {
  width: 100%;
  min-height: 260rpx;
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
  border-radius: 14rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #1f2937;
  line-height: 1.7;
  box-sizing: border-box;
}

.textarea-footer {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.textarea-controls {
  display: flex;
  gap: 16rpx;
}

.ctrl-btn {
  background: #e5e7eb;
  color: #1f2937;
  border: none;
  border-radius: 10rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.ctrl-btn-hover {
  opacity: 0.75;
}

.ctrl-btn.accent {
  background: #3b82f6;
  color: #fff;
}

.ctrl-btn.success {
  background: #10b981;
  color: #fff;
}

/* =====================
   写作目标进度
   ===================== */
.goal-card {
  padding: 24rpx 32rpx;
}

.goal-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.goal-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.goal-progress-text {
  font-size: 26rpx;
  color: #6b7280;
  font-variant-numeric: tabular-nums;
}

.goal-progress-text.done {
  color: #10b981;
  font-weight: 700;
}

.progress-bar {
  height: 14rpx;
  background: #e5e7eb;
  border-radius: 7rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6, #6366f1);
  border-radius: 7rpx;
  transition: width 0.3s ease;
}

.progress-fill.done {
  background: linear-gradient(90deg, #10b981, #059669);
}

/* =====================
   目标字数设置
   ===================== */
.goal-set-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.goal-set-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.goal-input {
  width: 140rpx;
  height: 56rpx;
  background: #f3f4f6;
  border: none;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  text-align: center;
  color: #374151;
}

.input-placeholder {
  color: #9ca3af;
}

/* =====================
   统计概览网格
   ===================== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-item {
  background: #f8fafc;
  border-radius: 14rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border-top: 4rpx solid transparent;
}

.stat-item.primary  { border-top-color: #3b82f6; }
.stat-item.info     { border-top-color: #06b6d4; }
.stat-item.green    { border-top-color: #10b981; }
.stat-item.warning  { border-top-color: #f59e0b; }
.stat-item.purple   { border-top-color: #8b5cf6; }
.stat-item.rose     { border-top-color: #f43f5e; }

.stat-num {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
  font-variant-numeric: tabular-nums;
}

.stat-lbl {
  font-size: 22rpx;
  color: #6b7280;
  font-weight: 500;
}

/* =====================
   详细分析
   ===================== */
.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.detail-row:nth-child(odd) {
  padding-right: 32rpx;
  border-right: 1rpx solid #f3f4f6;
}

.detail-row:nth-child(even) {
  padding-left: 32rpx;
}

.detail-row:nth-last-child(-n+2) {
  border-bottom: none;
}

.detail-k {
  font-size: 26rpx;
  color: #6b7280;
}

.detail-v {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* =====================
   快捷操作
   ===================== */
.actions-card {
  padding: 24rpx 32rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #f8fafc;
  border-radius: 14rpx;
  border: 2rpx solid transparent;
}

.action-item-hover {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 22rpx;
  color: #374151;
  font-weight: 500;
  text-align: center;
}

/* =====================
   底部说明
   ===================== */
.tip-section {
  padding: 0 8rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.6;
}
