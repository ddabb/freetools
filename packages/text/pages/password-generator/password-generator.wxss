/* packages/text/pages/password-generator/password-generator.wxss */
.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

/* 顶部装饰 */
.header-bg {
  background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0.05) 100%);
  padding: 40rpx 30rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}

.header-content {
  text-align: center;
}

.icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  backdrop-filter: blur(10rpx);
}

.main-icon {
  font-size: 60rpx;
}

.main-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 10rpx;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 内容区域 */
.content-wrapper {
  padding: 30rpx;
}

/* 卡片通用样式 */
.card-shadow {
  background: rgba(255,255,255,0.98);
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.15);
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-bottom: 1rpx solid #e9ecef;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.card-body {
  padding: 30rpx;
}

/* 密码显示卡片 */
.password-display {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.password-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.password-text {
  flex: 1;
  font-family: 'Consolas', 'Monaco', monospace;
  font-size: 36rpx;
  color: #00ff88;
  text-align: center;
  word-break: break-all;
  text-shadow: 0 0 20rpx rgba(0,255,136,0.3);
  min-height: 50rpx;
}

.password-actions {
  display: flex;
  gap: 16rpx;
}

.icon-btn {
  background: rgba(255,255,255,0.1);
  border: none;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  line-height: 1;
  color: #fff;
  transition: all 0.3s;
}

.icon-btn.visible {
  background: rgba(0,255,136,0.2);
}

.icon-btn-hover {
  transform: scale(0.95);
}

/* 密码强度 */
.strength-section {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.strength-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.strength-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.strength-badge {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.strength-badge.very-strong {
  background: linear-gradient(135deg, #00b894 0%, #00cec9 100%);
}

.strength-badge.strong {
  background: linear-gradient(135deg, #00b894 0%, #55efc4 100%);
}

.strength-badge.medium {
  background: linear-gradient(135deg, #fdcb6e 0%, #f39c12 100%);
}

.strength-badge.weak {
  background: linear-gradient(135deg, #e17055 0%, #d63031 100%);
}

.strength-badge.very-weak {
  background: linear-gradient(135deg, #d63031 0%, #e84393 100%);
}

.strength-bar {
  height: 12rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.strength-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.strength-fill.very-strong {
  background: linear-gradient(90deg, #00b894 0%, #00cec9 100%);
}

.strength-fill.strong {
  background: linear-gradient(90deg, #00b894 0%, #55efc4 100%);
}

.strength-fill.medium {
  background: linear-gradient(90deg, #fdcb6e 0%, #f39c12 100%);
}

.strength-fill.weak {
  background: linear-gradient(90deg, #e17055 0%, #d63031 100%);
}

.strength-fill.very-weak {
  background: linear-gradient(90deg, #d63031 0%, #e84393 100%);
}

.strength-tips {
  margin-top: 16rpx;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
}

/* 主要操作按钮 */
.primary-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.4);
  transition: all 0.3s;
}

.primary-btn.ready {
  animation: pulse 2s infinite;
}

.primary-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

.primary-btn.btn-primary-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(102,126,234,0.5);
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.4); }
  50% { box-shadow: 0 8rpx 32rpx rgba(102,126,234,0.6); }
}

.secondary-actions {
  display: flex;
  gap: 20rpx;
}

.secondary-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #f8f9fa;
  color: #666;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
  transition: all 0.3s;
}

.secondary-btn.active {
  background: rgba(102,126,234,0.1);
  color: #667eea;
  border-color: #667eea;
}

.secondary-btn.btn-secondary-hover {
  background: rgba(102,126,234,0.15);
}

/* 配置选项卡片 */
.setting-group {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-group:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.setting-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.length-display {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.length-number {
  font-size: 40rpx;
  font-weight: 800;
  color: #667eea;
}

.length-unit {
  font-size: 24rpx;
  color: #999;
}

.length-controls {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.control-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 16rpx;
  border: none;
  transition: all 0.3s;
}

.control-btn.disabled {
  background: #ccc;
}

.control-btn-hover {
  transform: scale(0.95);
}

.modern-slider {
  flex: 1;
}

.preset-lengths {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.preset-label {
  font-size: 24rpx;
  color: #666;
}

.preset-chips {
  display: flex;
  gap: 12rpx;
}

.preset-chip {
  padding: 12rpx 24rpx;
  background: #f8f9fa;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  border: 2rpx solid #e9ecef;
  transition: all 0.3s;
}

.preset-chip.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-color: transparent;
}

.preset-chip:active {
  transform: scale(0.95);
}

/* 字符类型 */
.char-types {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.type-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
}

.type-checkbox {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-content {
  flex: 1;
}

.type-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.type-example {
  display: block;
  font-size: 22rpx;
  color: #999;
  font-family: monospace;
}

/* 高级选项 */
.advanced-section {
  margin-top: 20rpx;
}

.advanced-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  cursor: pointer;
}

.advanced-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.advanced-arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s;
}

.advanced-arrow.expanded {
  transform: rotate(180deg);
}

.advanced-content {
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.advanced-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.advanced-name {
  font-size: 26rpx;
  color: #666;
}

/* 模板卡片 */
.templates-card .card-body {
  padding: 20rpx;
}

.template-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.template-item {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
  transition: all 0.3s;
}

.template-item.active {
  background: linear-gradient(135deg, rgba(102,126,234,0.1) 0%, rgba(118,75,162,0.1) 100%);
  border-color: #667eea;
}

.template-item-hover {
  transform: scale(0.98);
}

.template-info {
  margin-bottom: 12rpx;
}

.template-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.template-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.template-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 22rpx;
  border-radius: 12rpx;
}

/* 提示卡片 */
.tips-card {
  background: linear-gradient(135deg, #fff9e6 0%, #fff5d6 100%);
}

.tips-header {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid rgba(245,154,35,0.2);
}

.tips-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #f59a23;
}

.tips-content {
  padding: 24rpx 30rpx;
}

.tips-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 动画 */
.fade-in-up {
  animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
