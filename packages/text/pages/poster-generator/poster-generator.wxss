.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.content-area {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.input-section {
  width: 100%;
}

.form-group {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
  color: #333;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  resize: none;
}

.count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #555;
  margin-top: 8rpx;
}

.input-placeholder {
  color: #4b5563;
}

.style-selection {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}

.style-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  cursor: pointer;
  transition: all 0.3s;
}

.style-option.active {
  border-color: #07c160;
  background-color: #f0f9ff;
}

.style-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.style-label {
  font-size: 24rpx;
  color: #333;
}

.action-buttons {
  margin-top: 32rpx;
}

.btn-primary {
  width: 100%;
  height: 90rpx;
  background-color: #07c160;
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 45rpx;
  line-height: 90rpx;
}

.preview-section {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  color: #333;
}

.poster-preview {
  width: 100%;
  min-height: 560rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  margin: 0 auto;
}

.poster-header {
  padding: 30rpx;
  text-align: center;
}

.poster-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  line-height: 1.3;
}

.poster-content {
  padding: 30rpx;
  background-color: white;
  min-height: 300rpx;
}

.poster-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.poster-footer {
  padding: 20rpx 30rpx;
  text-align: center;
}

.poster-footer-text {
  font-size: 24rpx;
  color: white;
}

/* 样式1 */
.poster-preview.style1 .poster-header {
  background: linear-gradient(135deg, #4CAF50, #45a049);
}

.poster-preview.style1 .poster-footer {
  background: linear-gradient(135deg, #4CAF50, #45a049);
}

/* 样式2 */
.poster-preview.style2 .poster-header {
  background: linear-gradient(135deg, #2196F3, #1976D2);
}

.poster-preview.style2 .poster-footer {
  background: linear-gradient(135deg, #2196F3, #1976D2);
}

/* 样式3 */
.poster-preview.style3 .poster-header {
  background: linear-gradient(135deg, #FF9800, #F57C00);
}

.poster-preview.style3 .poster-footer {
  background: linear-gradient(135deg, #FF9800, #F57C00);
}