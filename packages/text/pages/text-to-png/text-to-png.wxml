<view class="container">
  <!-- 隐藏的Canvas用于生成PNG图片 -->
  <canvas id="textCanvas" type="2d" style="width: {{canvasWidth}}rpx; height: {{canvasHeight}}rpx; position: absolute; left: -9999px; top: -9999px;"></canvas>
  
  <view class="main-layout">
    <!-- 左侧：输入区域 -->
    <view class="left-panel">
      <section class="input-section">
        <div class="input-group">
          <label for="text-input">输入文本</label>
          <textarea 
            id="text-input" 
            class="text-input" 
            placeholder="输入要生成图片的文本..." 
            value="{{inputText}}" 
            bindinput="onTextInput" 
            auto-height
          ></textarea>
          <p class="hint">支持多行文本，图片高度会根据内容自动调整</p>
        </div>
        
        <!-- 模板和效果选项 -->
        <view class="options-section">
          <!-- 模板选择 -->
          <div class="input-group">
            <div class="section-header compact" bindtap="toggleTemplateExpanded">
              <label>模板样式</label>
              <span class="expand-icon">{{templateExpanded ? '▼' : '▶'}}</span>
            </div>
            <scroll-view class="templates-grid {{templateExpanded ? 'expanded' : 'collapsed'}}" scroll-x="true" enhanced="true" show-scrollbar="false">
              <view class="templates-row">
                <view class="template-option" wx:for="{{['template1', 'template2', 'template3', 'template4', 'template5', 'template6', 'template7', 'template8', 'template9']}}" wx:key="*this">
                  <view class="template-label {{selectedTemplate === item ? 'checked' : ''}}" bindtap="onTemplateSelect" data-value="{{item}}">
                    <view class="template-preview" style="{{item === 'template1' ? 'background: #ffffff; border: 1px solid #e0e0e0' : item === 'template2' ? 'background: #333333' : item === 'template3' ? 'background: linear-gradient(135deg, #3498db, #2980b9)' : item === 'template4' ? 'background: linear-gradient(135deg, #2ecc71, #27ae60)' : item === 'template5' ? 'background: linear-gradient(135deg, #e74c3c, #c0392b)' : item === 'template6' ? 'background: linear-gradient(135deg, #9b59b6, #8e44ad)' : item === 'template7' ? 'background: linear-gradient(135deg, #f39c12, #e67e22)' : item === 'template8' ? 'background: #f5f5f5; border: 2px solid #95a5a6' : 'background: #ffffff; border: 1px solid #e0e0e0; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1)'}}"></view>
                    <view class="template-name">{{item === 'template1' ? '简约白' : item === 'template2' ? '深色' : item === 'template3' ? '蓝渐变' : item === 'template4' ? '绿渐变' : item === 'template5' ? '红渐变' : item === 'template6' ? '紫渐变' : item === 'template7' ? '橙渐变' : item === 'template8' ? '商务灰' : '卡片'}}</view>
                  </view>
                </view>
              </view>
            </scroll-view>
          </div>
          
          <!-- 文字效果 -->
          <div class="input-group">
            <div class="section-header compact" bindtap="toggleTextEffectExpanded">
              <label>文字效果</label>
              <span class="expand-icon">{{textEffectExpanded ? '▼' : '▶'}}</span>
            </div>
            <scroll-view class="text-effect-options {{textEffectExpanded ? 'expanded' : 'collapsed'}}" scroll-x="true" enhanced="true" show-scrollbar="false">
              <view class="effects-row">
                <view class="text-effect-option" wx:for="{{['normal', 'gradient', 'shadow', 'stroke', 'glow', '3d']}}" wx:key="*this">
                  <view class="text-effect-label {{selectedTextEffect === item ? 'checked' : ''}}" bindtap="onTextEffectSelect" data-value="{{item}}">
                    <view class="text-effect-preview" style="{{item === 'normal' ? 'background: #f5f5f5; color: #000000; text-shadow: none' : item === 'gradient' ? 'background: #f5f5f5; color: #ffffff; text-shadow: none' : item === 'shadow' ? 'background: #f5f5f5; color: #000000; text-shadow: 4px 4px 8px rgba(0,0,0,0.5)' : item === 'stroke' ? 'background: #f5f5f5; color: #ffffff; text-shadow: 1px 1px 0 #2c3e50, -1px -1px 0 #2c3e50, 1px -1px 0 #2c3e50, -1px 1px 0 #2c3e50' : item === 'glow' ? 'background: #2c3e50; color: #ffffff; text-shadow: 0 0 10px #00ff9d, 0 0 20px #00ff9d' : 'background: #f5f5f5; color: #000000; text-shadow: 2px 2px 0 #2c3e50, 4px 4px 0 rgba(0,0,0,0.2)'}}">文</view>
                    <view>{{item === 'normal' ? '普通' : item === 'gradient' ? '渐变' : item === 'shadow' ? '阴影' : item === 'stroke' ? '描边' : item === 'glow' ? '发光' : '立体'}}</view>
                  </view>
                </view>
              </view>
            </scroll-view>
          </div>
        </view>
      </section>
    </view>
    
    <!-- 右侧：预览区域 -->
    <view class="right-panel">
      <section class="preview-section">
        <div class="preview-header">
          <div class="preview-title">预览效果</div>
          <div class="preview-info">实时预览，导出图片宽度与手机屏幕一致</div>
        </div>
        <view id="text-preview" class="text-preview" style="{{previewStyle}}">
          <rich-text nodes="{{previewText}}"></rich-text>
        </view>
        
        <!-- 操作按钮 -->
        <div class="actions">
          <div class="action-group">
            <navigator url="/packages/text/pages/copywriting/copywriting" class="btn btn-secondary">
              <span class="btn-icon">📝</span>
              <span class="btn-text">文案素材</span>
            </navigator>
            <button class="btn btn-secondary" bindtap="resetForm">
              <span class="btn-icon">↺</span>
              <span class="btn-text">重置</span>
            </button>
            <button class="btn btn-primary" bindtap="exportAsPNG" disabled="{{!canExport}}">
              <span class="btn-icon">⤓</span>
              <span class="btn-text">导出PNG</span>
            </button>
          </div>
        </div>
      </section>
    </view>
  </view>

  <view class="loading" wx:if="{{isLoading}}">
    <view class="spinner"></view>
    <p>正在生成高清图片，请稍候...</p>
  </view>
</view>