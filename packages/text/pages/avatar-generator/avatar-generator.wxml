<view class="container">
  <section class="input-section">
    <div class="input-group">
      <label for="text-input">输入字符</label>
      <input type="text" id="text-input" class="text-input" placeholder="输入1-4个字符" maxlength="4" value="{{inputText}}" bindinput="onTextInput" />
      <p class="hint">注意：支持1-4个字符（汉字、字母、数字、emoji等）</p>
    </div>
    
    <div class="templates-section">
      <div class="input-group">
        <div class="section-header" bindtap="toggleTemplateExpanded">
          <label>选择头像模板（共9种）</label>
          <span class="expand-icon">{{templateExpanded ? '▼' : '▶'}}</span>
        </div>
        <div class="templates-grid {{templateExpanded ? 'expanded' : 'collapsed'}}">
          <!-- 模板1：简约圆形 -->
          <div class="template-option">
            <div class="template-label {{selectedTemplate === 'template1' ? 'checked' : ''}}" bindtap="onTemplateSelect" data-value="template1">
              <div class="template-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); border-radius: 50%;"></div>
              <div class="template-name">简约圆形</div>
            </div>
          </div>
          
          <!-- 模板2：方形边框 -->
          <div class="template-option">
            <div class="template-label {{selectedTemplate === 'template2' ? 'checked' : ''}}" bindtap="onTemplateSelect" data-value="template2">
              <div class="template-preview" style="background: linear-gradient(135deg, #2ecc71, #1abc9c); border-radius: 6px; border: 3px solid #2c3e50;"></div>
              <div class="template-name">方形边框</div>
            </div>
          </div>
          
          <!-- 模板3：渐变背景 -->
          <div class="template-option">
            <div class="template-label {{selectedTemplate === 'template3' ? 'checked' : ''}}" bindtap="onTemplateSelect" data-value="template3">
              <div class="template-preview" style="background: linear-gradient(135deg, #ff9a9e, #fad0c4, #fad0c4); border-radius: 50%;"></div>
              <div class="template-name">渐变背景</div>
            </div>
          </div>
          
          <!-- 模板4：阴影效果 -->
          <div class="template-option">
            <div class="template-label {{selectedTemplate === 'template4' ? 'checked' : ''}}" bindtap="onTemplateSelect" data-value="template4">
              <div class="template-preview" style="background: linear-gradient(135deg, #e74c3c, #c0392b); border-radius: 50%; box-shadow: 0 4px 8px rgba(0,0,0,0.3);"></div>
              <div class="template-name">阴影效果</div>
            </div>
          </div>
          
          <!-- 模板5：金色质感 -->
          <div class="template-option">
            <div class="template-label {{selectedTemplate === 'template5' ? 'checked' : ''}}" bindtap="onTemplateSelect" data-value="template5">
              <div class="template-preview" style="background: linear-gradient(135deg, #FFD700, #FFA500); border-radius: 50%; box-shadow: 0 4px 8px rgba(0,0,0,0.2);"></div>
              <div class="template-name">金色质感</div>
            </div>
          </div>
          
          <!-- 模板6：科技蓝 -->
          <div class="template-option">
            <div class="template-label {{selectedTemplate === 'template6' ? 'checked' : ''}}" bindtap="onTemplateSelect" data-value="template6">
              <div class="template-preview" style="background: linear-gradient(135deg, #00b4db, #0083b0); border-radius: 20px;"></div>
              <div class="template-name">科技蓝</div>
            </div>
          </div>
          
          <!-- 模板7：粉色浪漫 -->
          <div class="template-option">
            <div class="template-label {{selectedTemplate === 'template7' ? 'checked' : ''}}" bindtap="onTemplateSelect" data-value="template7">
              <div class="template-preview" style="background: linear-gradient(135deg, #ff6b9d, #ff8e53); border-radius: 50%;"></div>
              <div class="template-name">粉色浪漫</div>
            </div>
          </div>
          
          <!-- 模板8：商务深灰 -->
          <div class="template-option">
            <div class="template-label {{selectedTemplate === 'template8' ? 'checked' : ''}}" bindtap="onTemplateSelect" data-value="template8">
              <div class="template-preview" style="background: linear-gradient(135deg, #485563, #29323c); border-radius: 8px; color: white;"></div>
              <div class="template-name">商务深灰</div>
            </div>
          </div>
          
          <!-- 模板9：纯色背景（专为emoji设计） -->
          <div class="template-option">
            <div class="template-label {{selectedTemplate === 'template9' ? 'checked' : ''}}" bindtap="onTemplateSelect" data-value="template9">
              <div class="template-preview" style="background: #ffffff; border: 2px solid #2c3e50; border-radius: 50%;"></div>
              <div class="template-name">纯色背景</div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="input-group text-effect-section">
        <div class="section-header" bindtap="toggleTextEffectExpanded">
          <label>选择文字艺术效果</label>
          <span class="expand-icon">{{textEffectExpanded ? '▼' : '▶'}}</span>
        </div>
        <div class="text-effect-options {{textEffectExpanded ? 'expanded' : 'collapsed'}}">
          <!-- 文字效果1：普通 -->
          <div class="text-effect-option">
            <div class="text-effect-label {{selectedTextEffect === 'normal' ? 'checked' : ''}}" bindtap="onTextEffectSelect" data-value="normal">
              <div class="text-effect-preview te-normal">文</div>
              <div>普通</div>
            </div>
          </div>
          
          <!-- 文字效果2：渐变文字 -->
          <div class="text-effect-option">
            <div class="text-effect-label {{selectedTextEffect === 'gradient' ? 'checked' : ''}}" bindtap="onTextEffectSelect" data-value="gradient">
              <div class="text-effect-preview te-gradient">文</div>
              <div>渐变</div>
            </div>
          </div>
          
          <!-- 文字效果3：阴影效果 -->
          <div class="text-effect-option">
            <div class="text-effect-label {{selectedTextEffect === 'shadow' ? 'checked' : ''}}" bindtap="onTextEffectSelect" data-value="shadow">
              <div class="text-effect-preview te-shadow">文</div>
              <div>阴影</div>
            </div>
          </div>
          
          <!-- 文字效果4：描边效果 -->
          <div class="text-effect-option">
            <div class="text-effect-label {{selectedTextEffect === 'stroke' ? 'checked' : ''}}" bindtap="onTextEffectSelect" data-value="stroke">
              <div class="text-effect-preview te-stroke">文</div>
              <div>描边</div>
            </div>
          </div>
          
          <!-- 文字效果5：发光效果 -->
          <div class="text-effect-option">
            <div class="text-effect-label {{selectedTextEffect === 'glow' ? 'checked' : ''}}" bindtap="onTextEffectSelect" data-value="glow">
              <div class="text-effect-preview te-glow">文</div>
              <div>发光</div>
            </div>
          </div>
          
          <!-- 文字效果6：立体效果 -->
          <div class="text-effect-option">
            <div class="text-effect-label {{selectedTextEffect === '3d' ? 'checked' : ''}}" bindtap="onTextEffectSelect" data-value="3d">
              <div class="text-effect-preview te-3d">文</div>
              <div>立体</div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- 字体样式选择 -->
      <div class="input-group font-style-section">
        <div class="section-header" bindtap="toggleFontStyleExpanded">
          <label>选择字体样式（共12种）</label>
          <span class="expand-icon">{{fontStyleExpanded ? '▼' : '▶'}}</span>
        </div>
        <div class="font-style-options {{fontStyleExpanded ? 'expanded' : 'collapsed'}}">
          <!-- 字体1：黑体 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'sans' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="sans">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: sans-serif; font-weight: bold;">文</div>
              <div>黑体</div>
            </div>
          </div>
          
          <!-- 字体2：宋体 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'serif' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="serif">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: serif; font-weight: bold;">文</div>
              <div>宋体</div>
            </div>
          </div>
          
          <!-- 字体3：等宽 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'mono' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="mono">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: monospace; font-weight: bold;">文</div>
              <div>等宽</div>
            </div>
          </div>
          
          <!-- 字体4：细体 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'sansLight' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="sansLight">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: sans-serif; font-weight: 300;">文</div>
              <div>细体</div>
            </div>
          </div>
          
          <!-- 字体5：中体 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'sansMedium' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="sansMedium">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: sans-serif; font-weight: 500;">文</div>
              <div>中体</div>
            </div>
          </div>
          
          <!-- 字体6：特粗 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'sansBold' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="sansBold">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: sans-serif; font-weight: 900;">文</div>
              <div>特粗</div>
            </div>
          </div>
          
          <!-- 字体7：斜体 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'sansItalic' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="sansItalic">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: sans-serif; font-weight: bold; font-style: italic;">文</div>
              <div>斜体</div>
            </div>
          </div>
          
          <!-- 字体8：细宋 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'serifLight' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="serifLight">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: serif; font-weight: 300;">文</div>
              <div>细宋</div>
            </div>
          </div>
          
          <!-- 字体9：手写体 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'cursive' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="cursive">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: cursive; font-weight: normal;">文</div>
              <div>手写体</div>
            </div>
          </div>
          
          <!-- 字体10：艺术体 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'fantasy' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="fantasy">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: fantasy; font-weight: bold;">文</div>
              <div>艺术体</div>
            </div>
          </div>
          
          <!-- 字体11：系统粗体 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'systemBold' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="systemBold">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-weight: 800;">文</div>
              <div>系统粗体</div>
            </div>
          </div>
          
          <!-- 字体12：圆润体 -->
          <div class="font-style-option">
            <div class="font-style-label {{selectedFontStyle === 'rounded' ? 'checked' : ''}}" bindtap="onFontStyleSelect" data-value="rounded">
              <div class="font-style-preview" style="background: linear-gradient(135deg, #3498db, #8e44ad); font-family: sans-serif; font-weight: bold;">文</div>
              <div>圆润体</div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="quality-notice">
        <strong>图片质量提示：</strong> 导出PNG图片分辨率为800×800像素，确保高清质量。深色背景搭配浅色文字，浅色背景搭配深色文字，以获得最佳视觉效果。
      </div>
    </div>
  </section>  
  <section class="preview-section">
    <div class="preview-title">预览效果</div>
    <view id="avatar-preview" class="avatar-preview" style="{{previewStyle}}">{{previewText}}</view>
    <p class="preview-info">预览将实时更新，导出图片为800×800像素高清PNG</p>
    
    <div class="actions">
      <button class="btn btn-secondary" bindtap="resetForm">
        <span class="btn-icon">↺</span> 重置
      </button>
      <button class="btn btn-primary" bindtap="exportAsPNG" disabled="{{!canExport}}">
        <span class="btn-icon">⤓</span> 导出PNG
      </button>
    </div>
  </section>  

  <view class="loading" wx:if="{{isLoading}}">
    <view class="spinner"></view>
    <p>正在生成高清图片，请稍候...</p>
  </view>
  
  <!-- 隐藏的Canvas用于生成PNG图片 -->
  <canvas id="avatarCanvas" type="2d" style="width: 200px; height: 200px; position: absolute; left: -9999px; top: -9999px;"></canvas>
</view>