/**packages/text/pages/text-diff/text-diff.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #4ecdc4 0%, #44a08d 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
}

/* 操作区域 */
.operation-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 30rpx;
  text-align: center;
}

.operation-controls {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
}

.control-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: rgba(78, 205, 196, 0.1);
  border-radius: 12rpx;
}

.control-group:last-child {
  margin-bottom: 0;
}

.control-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.mode-picker {
  flex: 1;
  margin-left: 30rpx;
}

.picker-display {
  background: white;
  border: 2rpx solid #4ecdc4;
  border-radius: 8rpx;
  padding: 15rpx 20rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
}

.whitespace-switch {
  transform: scale(1.2);
}

.action-buttons {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-btn {
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid #4ecdc4;
  border-radius: 15rpx;
  padding: 25rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #4ecdc4, #44a08d);
}

.action-btn:active .btn-icon,
.action-btn:active .btn-text {
  color: white;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4ecdc4, #44a08d);
  border-color: #4ecdc4;
}

.action-btn.primary .btn-icon,
.action-btn.primary .btn-text {
  color: white;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 24rpx;
  color: #4ecdc4;
  font-weight: 600;
}

/* 文本输入区域 */
.text-input-section {
  margin-bottom: 40rpx;
}

.text-panels {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.text-panel {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  overflow: hidden;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  background: rgba(78, 205, 196, 0.1);
  border-bottom: 2rpx solid rgba(78, 205, 196, 0.2);
}

.panel-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.panel-controls {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.mini-btn {
  background: #4ecdc4;
  color: white;
  border: none;
  border-radius: 6rpx;
  padding: 8rpx 16rpx;
  font-size: 20rpx;
  transition: all 0.3s ease;
}

.mini-btn:active {
  transform: scale(0.9);
  background: #44a08d;
}

.char-count {
  font-size: 22rpx;
  color: #666;
  font-family: 'Monaco', 'Menlo', monospace;
}

.diff-textarea {
  width: 100%;
  min-height: 300rpx;
  background: transparent;
  border: none;
  padding: 30rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  font-family: 'Monaco', 'Menlo', monospace;
  box-sizing: border-box;
}

.text-a {
  border-left: 4rpx solid #28a745;
}

.text-b {
  border-left: 4rpx solid #dc3545;
}

/* 统计信息区域 */
.stats-section {
  margin-bottom: 40rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.stat-card.added { border-left: 6rpx solid #28a745; }
.stat-card.removed { border-left: 6rpx solid #dc3545; }
.stat-card.modified { border-left: 6rpx solid #ffc107; }
.stat-card.unchanged { border-left: 6rpx solid #6c757d; }
.stat-card.similarity { border-left: 6rpx solid #17a2b8; }

.stat-number {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
  font-family: 'Monaco', 'Menlo', monospace;
}

.stat-card.similarity .stat-number {
  color: #17a2b8;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
}

/* 结果区域 */
.result-section {
  margin-bottom: 40rpx;
}

/* 并排对比视图 */
side-by-side-view {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.comparison-row {
  display: flex;
  background: #f8f9fa;
  border-bottom: 2rpx solid #dee2e6;
}

.header-row {
  background: #343a40 !important;
  color: white;
}

.line-numbers-label {
  width: 100rpx;
  padding: 20rpx;
  text-align: center;
  font-weight: 700;
  background: #495057;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.text-labels {
  display: flex;
  flex: 1;
}

.label-a {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-weight: 700;
  background: #28a745;
  color: white;
  font-size: 24rpx;
}

.label-b {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-weight: 700;
  background: #dc3545;
  color: white;
  font-size: 24rpx;
}

.text-label {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-weight: 700;
  background: #6f42c1;
  color: white;
  font-size: 24rpx;
}

.comparison-scroll {
  height: 600rpx;
}

.comparison-lines {
  font-family: 'Monaco', 'Menlo', monospace;
}

.comparison-line {
  display: flex;
  border-bottom: 1rpx solid #f1f3f4;
}

.unified-line {
  border-left: 4rpx solid transparent;
}

.line-number {
  width: 100rpx;
  padding: 15rpx 10rpx;
  text-align: center;
  background: #f8f9fa;
  color: #6c757d;
  font-size: 22rpx;
  border-right: 2rpx solid #dee2e6;
  font-family: 'Monaco', 'Menlo', monospace;
}

.line-content {
  flex: 1;
  padding: 15rpx 20rpx;
  font-size: 24rpx;
  white-space: pre-wrap;
  word-break: break-all;
  font-family: 'Monaco', 'Menlo', monospace;
  line-height: 1.4;
}

.line-a {
  border-right: 2rpx solid #dee2e6;
}

/* 差异类型样式 */
.line-content.addition {
  background: #d4edda;
  color: #155724;
}

.line-content.deletion {
  background: #f8d7da;
  color: #721c24;
}

.line-content.modification {
  background: #fff3cd;
  color: #856404;
}

.line-content.unchanged {
  background: transparent;
  color: #333;
}

/* 合并视图 */
.unified-view {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.unified-lines {
  font-family: 'Monaco', 'Menlo', monospace;
}

/* 快捷操作区域 */
.quick-actions {
  margin-bottom: 40rpx;
}

.quick-buttons {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-btn {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border: none;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
}

.quick-btn:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #4ecdc4, #44a08d);
}

.quick-btn:active .btn-icon,
.quick-btn:active .btn-text {
  color: white;
}

/* 帮助区域 */
.help-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
  animation: fadeInUp 0.6s ease-out;
}

.help-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 25rpx;
  text-align: center;
}

.help-content {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.help-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  padding-left: 20rpx;
  position: relative;
}

.help-text:before {
  content: "•";
  position: absolute;
  left: 0;
  color: #4ecdc4;
  font-weight: bold;
}

/* 动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}