/* packages/text/pages/text-diff/text-diff.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 设置区域 */
.settings-section {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.setting-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
}

.setting-item:not(:last-child) {
  border-right: 1rpx solid #eee;
}

.setting-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.picker-value {
  font-size: 26rpx;
  color: #333;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
}

.highlight-btn {
  padding: 8rpx 16rpx;
  background: #e8f5e9;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #22c55e;
}

/* 文本输入区域 */
.text-input-section {
  margin-bottom: 20rpx;
}

.text-panel {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 20rpx;
  background: #fafafa;
  border-bottom: 1rpx solid #f0f0f0;
}

.panel-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.panel-actions {
  display: flex;
  gap: 15rpx;
}

.mini-btn {
  font-size: 22rpx;
  color: #666;
  padding: 6rpx 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
}

.mini-btn:active {
  background: #e0e0e0;
}

.diff-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  box-sizing: border-box;
}

.text-a {
  border-left: 4rpx solid #3b82f6;
}

.text-b {
  border-left: 4rpx solid #f59e0b;
}

.char-count {
  text-align: right;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  color: #999;
  background: #fafafa;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.quick-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx;
  background: #fff;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.quick-btn:active {
  background: #f0f0f0;
}

.quick-btn text:first-child {
  font-size: 32rpx;
}

.quick-btn text:last-child {
  font-size: 26rpx;
  color: #666;
}

/* 统计信息 */
.stats-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.stats-row {
  display: flex;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 15rpx;
  border-radius: 15rpx;
}

.stat-item.added {
  background: #dcfce7;
}

.stat-item.removed {
  background: #fee2e2;
}

.stat-item.modified {
  background: #fef3c7;
}

.stat-item.unchanged {
  background: #f3f4f6;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}

.stat-item.added .stat-num {
  color: #22c55e;
}

.stat-item.removed .stat-num {
  color: #ef4444;
}

.stat-item.modified .stat-num {
  color: #f59e0b;
}

.stat-item.unchanged .stat-num {
  color: #666;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-top: 5rpx;
}

.similarity-bar {
  padding-top: 15rpx;
  border-top: 1rpx solid #eee;
}

.similarity-label {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.similarity-value {
  font-weight: bold;
  color: #333;
}

.bar-track {
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 6rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.bar-fill.high {
  background: linear-gradient(90deg, #22c55e, #16a34a);
}

.bar-fill.medium {
  background: linear-gradient(90deg, #f59e0b, #d97706);
}

.bar-fill.low {
  background: linear-gradient(90deg, #ef4444, #dc2626);
}

/* 对比结果 */
.result-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 25rpx;
  background: #fafafa;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.result-actions {
  display: flex;
  gap: 15rpx;
}

.result-btn {
  display: flex;
  align-items: center;
  gap: 5rpx;
  padding: 8rpx 16rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
}

.result-btn text:first-child {
  font-size: 26rpx;
}

.result-btn text:last-child {
  font-size: 22rpx;
  color: #666;
}

/* 并排视图 */
.side-by-side-view {
  padding: 0;
}

.view-header {
  display: flex;
  padding: 15rpx 20rpx;
  background: #f5f5f5;
  font-size: 24rpx;
  font-weight: 500;
}

.label-a {
  flex: 1;
  color: #3b82f6;
  text-align: center;
}

.label-b {
  flex: 1;
  color: #f59e0b;
  text-align: center;
}

.result-scroll {
  max-height: 600rpx;
}

.diff-lines {
  padding: 10rpx;
}

.diff-line {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.diff-line:last-child {
  border-bottom: none;
}

.line-num {
  width: 60rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  flex-shrink: 0;
}

.line-content {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
  padding: 0 10rpx;
}

.line-a {
  border-left: 3rpx solid transparent;
}

.line-b {
  border-left: 3rpx solid transparent;
}

/* 差异高亮 */
.diff-line.addition .line-b {
  background: #dcfce7;
  border-left-color: #22c55e;
  color: #166534;
}

.diff-line.deletion .line-a {
  background: #fee2e2;
  border-left-color: #ef4444;
  color: #991b1b;
  text-decoration: line-through;
}

.diff-line.modification .line-a {
  background: #fef3c7;
  border-left-color: #f59e0b;
}

.diff-line.modification .line-b {
  background: #fef3c7;
  border-left-color: #f59e0b;
}

/* 合并视图 */
.unified-view {
  padding: 20rpx;
}

.diff-lines.unified .diff-line.unified {
  display: flex;
  padding: 8rpx 15rpx;
  margin-bottom: 5rpx;
  border-radius: 8rpx;
}

.diff-line.unified.addition {
  background: #dcfce7;
}

.diff-line.unified.deletion {
  background: #fee2e2;
}

.diff-line.unified.modification {
  background: #fef3c7;
}

.line-prefix {
  width: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.diff-line.addition .line-prefix {
  color: #22c55e;
}

.diff-line.deletion .line-prefix {
  color: #ef4444;
}

.diff-line.modification .line-prefix {
  color: #f59e0b;
}

.line-content.unified {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 40rpx;
}

.loading-state text {
  font-size: 28rpx;
  color: #666;
}
