<view class="container">
  <!-- 设置区域 -->
  <view class="settings-section">
    <view class="setting-item">
      <text class="setting-label">对比模式</text>
      <picker bindchange="setDiffMode" value="{{diffModeIndex}}" range="{{diffModes}}">
        <view class="picker-value">{{diffModes[diffModeIndex]}}</view>
      </picker>
    </view>
    <view class="setting-item">
      <text class="setting-label">忽略空格</text>
      <switch checked="{{ignoreWhitespace}}" bindchange="toggleIgnoreWhitespace" color="#22c55e"/>
    </view>
    <view class="setting-item">
      <text class="setting-label">高亮模式</text>
      <view class="highlight-btn" bindtap="highlightMode">
        <text>{{highlightMode === 'background' ? '背景' : highlightMode === 'foreground' ? '字体' : '边框'}}</text>
      </view>
    </view>
  </view>

  <!-- 文本输入区域 -->
  <view class="text-input-section">
    <!-- 原始文本 -->
    <view class="text-panel">
      <view class="panel-header">
        <text class="panel-title">📄 原文 (A)</text>
        <view class="panel-actions">
          <view class="mini-btn" bindtap="pasteTextA">粘贴</view>
          <view class="mini-btn" bindtap="copyTextA">复制</view>
        </view>
      </view>
      <textarea
        value="{{textA}}"
        bindinput="setTextA"
        class="diff-textarea text-a"
        placeholder="输入原始文本..."
        maxlength="20000"
        show-confirm-bar="false"
        auto-height
      />
      <view class="char-count">字数: {{textA.length}}</view>
    </view>

    <!-- 对比文本 -->
    <view class="text-panel">
      <view class="panel-header">
        <text class="panel-title">📝 对比文本 (B)</text>
        <view class="panel-actions">
          <view class="mini-btn" bindtap="pasteTextB">粘贴</view>
          <view class="mini-btn" bindtap="copyTextB">复制</view>
        </view>
      </view>
      <textarea
        value="{{textB}}"
        bindinput="setTextB"
        class="diff-textarea text-b"
        placeholder="输入要对比的文本..."
        maxlength="20000"
        show-confirm-bar="false"
        auto-height
      />
      <view class="char-count">字数: {{textB.length}}</view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="quick-btn" bindtap="swapTexts">
      <text>🔄</text>
      <text>交换</text>
    </view>
    <view class="quick-btn" bindtap="loadSampleDiff">
      <text>📋</text>
      <text>示例</text>
    </view>
    <view class="quick-btn" bindtap="clearAll">
      <text>🗑️</text>
      <text>清空</text>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-section" wx:if="{{comparisonResult}}">
    <view class="stats-row">
      <view class="stat-item added">
        <text class="stat-num">+{{comparisonResult.additions}}</text>
        <text class="stat-label">新增</text>
      </view>
      <view class="stat-item removed">
        <text class="stat-num">-{{comparisonResult.deletions}}</text>
        <text class="stat-label">删除</text>
      </view>
      <view class="stat-item modified">
        <text class="stat-num">~{{comparisonResult.modifications}}</text>
        <text class="stat-label">修改</text>
      </view>
      <view class="stat-item unchanged">
        <text class="stat-num">{{comparisonResult.unchanged}}</text>
        <text class="stat-label">未变</text>
      </view>
    </view>
    <view class="similarity-bar">
      <view class="similarity-label">
        <text>相似度</text>
        <text class="similarity-value">{{comparisonResult.similarity}}%</text>
      </view>
      <view class="bar-track">
        <view class="bar-fill {{comparisonResult.similarity >= 80 ? 'high' : comparisonResult.similarity >= 50 ? 'medium' : 'low'}}" style="width: {{comparisonResult.similarity}}%"></view>
      </view>
    </view>
  </view>

  <!-- 对比结果 -->
  <view class="result-section" wx:if="{{comparisonResult}}">
    <view class="result-header">
      <text class="result-title">🔍 对比结果</text>
      <view class="result-actions">
        <view class="result-btn" bindtap="exportDiff">
          <text>💾</text>
          <text>导出</text>
        </view>
        <view class="result-btn" bindtap="shareDiff">
          <text>📤</text>
          <text>分享</text>
        </view>
      </view>
    </view>

    <!-- 并排对比视图 -->
    <view class="side-by-side-view" wx:if="{{diffModeIndex === 0}}">
      <view class="view-header">
        <text class="label-a">原文 (A)</text>
        <text class="label-b">对比 (B)</text>
      </view>
      <scroll-view scroll-y="true" class="result-scroll">
        <view class="diff-lines">
          <view class="diff-line {{item.type}}" wx:for="{{comparisonResult.lines}}" wx:key="index">
            <text class="line-num">{{item.lineNumber}}</text>
            <text class="line-content line-a" selectable="true">{{item.contentA || ''}}</text>
            <text class="line-content line-b" selectable="true">{{item.contentB || ''}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 合并视图 -->
    <view class="unified-view" wx:else>
      <scroll-view scroll-y="true" class="result-scroll">
        <view class="diff-lines unified">
          <view class="diff-line unified {{item.type}}" wx:for="{{comparisonResult.lines}}" wx:key="index">
            <text class="line-num">{{item.lineNumber}}</text>
            <text class="line-prefix">{{item.type === 'addition' ? '+' : item.type === 'deletion' ? '-' : item.type === 'modification' ? '~' : ' '}}</text>
            <text class="line-content unified" selectable="true">{{item.contentA || item.contentB || ''}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!comparisonResult && !isComparing}}">
    <text class="empty-icon">📝</text>
    <text class="empty-text">输入文本后自动对比</text>
    <text class="empty-hint">支持代码、配置文件、文档等多种格式</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{isComparing}}">
    <text>⚡ 正在对比...</text>
  </view>
</view>
