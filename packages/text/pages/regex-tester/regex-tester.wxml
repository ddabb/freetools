<view class="container">

  <!-- 正则输入区域 -->
  <view class="card input-card">
    <view class="card-header">
      <text class="card-title">正则表达式</text>
      <view class="quick-buttons">
       <button class="common-btn" hover-class="common-btn-hover" bindtap="showCommonRegexModal" style="width: auto; padding: 0 10rpx;">常用</button>
       
        <button class="common-btn" hover-class="common-btn-hover" bindtap="showOptionsModal" style="width: auto; padding: 0 10rpx;">选项</button>
        <button class="common-btn" hover-class="common-btn-hover" bindtap="showSyntaxModal" style="width: auto; padding: 0 10rpx;">语法</button>
      </view>
    </view>
    <view class="card-body">
      <view class="options-row">
        <textarea value="{{regexPattern}}" bindinput="setRegexPattern" class="regex-textarea" placeholder="输入正则表达式，如 ^[a-zA-Z0-9]+$" maxlength="500" auto-height />
      </view>
    </view>
  </view>

  <!-- 测试文本区域 -->
  <view class="card text-card">
    <view class="card-header">
      <text class="card-title">测试文本</text>
      <text class="char-count">{{testText.length}} 字符</text>
    </view>
    <view class="card-body">
      <textarea value="{{testText}}" bindinput="setTestText" class="test-textarea" placeholder="在此输入要测试的文本内容..." maxlength="10000" />
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="action-btn primary" hover-class="action-btn-hover" bindtap="testRegex">
      <text class="btn-icon">⚡</text>
      <text>测试匹配</text>
    </button>
    <button class="action-btn secondary" hover-class="action-btn-hover" bindtap="clearResults">
      <text class="btn-icon">🗑</text>
      <text>清空</text>
    </button>
  </view>

  <!-- 错误提示 -->
  <view class="error-toast" wx:if="{{errorMessage}}">
    <text class="error-icon">⚠</text>
    <text class="error-content">{{errorMessage}}</text>
    <view class="error-close" bindtap="clearError">×</view>
  </view>

  <!-- 测试结果 -->
  <scroll-view class="results-section" wx:if="{{showResults}}" scroll-y>
    <!-- 结果概览 -->
    <view class="card result-overview-card">
      <view class="result-status {{matches.length > 0 ? 'success' : 'empty'}}">
        <text class="status-icon">{{matches.length > 0 ? '✓' : '✗'}}</text>
        <view class="status-info">
          <text class="status-title">{{matches.length > 0 ? '匹配成功' : '未匹配'}}</text>
          <text class="status-subtitle">{{matches.length > 0 ? '找到 ' + matches.length + ' 个匹配项' : '请尝试调整正则表达式'}}</text>
        </view>
      </view>
    </view>

    <!-- 结果内容区域 -->
    <view class="results-content">
      <!-- 高亮预览 -->
      <view class="card highlight-card" wx:if="{{matches.length > 0}}">
        <view class="card-header">
          <text class="card-title">高亮预览</text>
        </view>
        <view class="card-body">
          <scroll-view class="highlight-preview" scroll-y>
            <text class="highlight-text" wx:for="{{highlightedParts}}" wx:key="index" class="{{item.type === 'match' ? 'matched' : ''}}">{{item.text}}</text>
          </scroll-view>
        </view>
      </view>

      <!-- 匹配详情 -->
      <view class="card matches-card" wx:if="{{matches.length > 0}}">
        <view class="card-header">
          <text class="card-title">匹配详情</text>
          <text class="match-badge">{{matches.length}}</text>
        </view>
        <view class="card-body">
          <scroll-view class="match-list" scroll-y>
            <view class="match-item" wx:for="{{matches}}" wx:key="index">
              <view class="match-header">
                <text class="match-index">#{{index + 1}}</text>
                <text class="match-range">位置 {{item.index}}-{{item.index + item[0].length}}</text>
              </view>
              <view class="match-content">{{item[0]}}</view>
              <view class="match-groups" wx:if="{{item.length > 1}}">
                <text class="group-label">捕获组:</text>
                <text class="group-item" wx:for="{{item}}" wx:for-index="gIndex" wx:for-item="group" wx:key="gIndex" wx:if="{{gIndex > 0}}">
                  ${{gIndex}}: {{group}}
                </text>
              </view>
            </view>
          </scroll-view>
        </view>
      </view>
    </view>

    <!-- 表达式信息 -->
    <view class="card info-card">
      <view class="info-row">
        <text class="info-label">正则表达式</text>
        <text class="info-value regex-display">/{{regexPattern}}/{{flags}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">测试文本</text>
        <text class="info-value">{{testText.length}} 个字符</text>
      </view>
      <view class="info-row">
        <text class="info-label">匹配模式</text>
        <text class="info-value">{{flags.length > 0 ? flags : '无标志位'}}</text>
      </view>
    </view>
  </scroll-view>



  <!-- 常用正则弹窗 -->
  <view class="modal-overlay" wx:if="{{showCommonRegexModal}}" bindtap="closeCommonRegexModal">
    <view class="modal-container" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">常用正则表达式</text>
        <view class="modal-close" bindtap="closeCommonRegexModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="regex-list">
          <view class="regex-item" hover-class="regex-item-hover" wx:for="{{commonRegex}}" wx:key="name" bindtap="selectCommonRegex" data-regex="{{item.pattern}}" data-flags="{{item.flags}}">
            <text class="regex-name">{{item.name}}</text>
            <text class="regex-pattern">{{item.pattern}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 匹配选项弹窗 -->
  <view class="modal-overlay" wx:if="{{showOptionsModal}}" bindtap="closeOptionsModal">
    <view class="modal-container" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">匹配选项</text>
        <view class="modal-close" bindtap="closeOptionsModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="flags-list">
          <label class="flag-item" wx:for="{{availableFlags}}" wx:key="flag">
            <checkbox value="{{item.flag}}" checked="{{item.enabled}}" bindchange="onFlagChange" data-flag="{{item.flag}}" />
            <text class="flag-label">{{item.label}}</text>
          </label>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 语法参考弹窗 -->
  <view class="modal-overlay" wx:if="{{showSyntaxModal}}" bindtap="closeSyntaxModal">
    <view class="modal-container" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">正则表达式语法参考</text>
        <view class="modal-close" bindtap="closeSyntaxModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="help-content">
          <view class="help-section">
            <text class="help-section-title">字符类</text>
            <view class="help-item"><text class="help-code">.</text><text class="help-desc">任意单个字符</text></view>
            <view class="help-item"><text class="help-code">\d</text><text class="help-desc">数字 [0-9]</text></view>
            <view class="help-item"><text class="help-code">\w</text><text class="help-desc">单词字符</text></view>
            <view class="help-item"><text class="help-code">\s</text><text class="help-desc">空白字符</text></view>
          </view>
          <view class="help-section">
            <text class="help-section-title">位置锚点</text>
            <view class="help-item"><text class="help-code">^</text><text class="help-desc">字符串开头</text></view>
            <view class="help-item"><text class="help-code">$</text><text class="help-desc">字符串结尾</text></view>
          </view>
          <view class="help-section">
            <text class="help-section-title">量词</text>
            <view class="help-item"><text class="help-code">*</text><text class="help-desc">0次或多次</text></view>
            <view class="help-item"><text class="help-code">+</text><text class="help-desc">1次或多次</text></view>
            <view class="help-item"><text class="help-code">?</text><text class="help-desc">0次或1次</text></view>
            <view class="help-item"><text class="help-code">{n}</text><text class="help-desc">恰好n次</text></view>
          </view>
          <view class="help-section">
            <text class="help-section-title">分组与逻辑</text>
            <view class="help-item"><text class="help-code">[abc]</text><text class="help-desc">字符集</text></view>
            <view class="help-item"><text class="help-code">a|b</text><text class="help-desc">或运算</text></view>
            <view class="help-item"><text class="help-code">(x)</text><text class="help-desc">捕获组</text></view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

</view>
