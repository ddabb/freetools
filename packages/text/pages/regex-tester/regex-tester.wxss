/** packages/text/pages/regex-tester/regex-tester.wxss **/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  line-height: 1.6;
  padding: 0;
  color: #333;
  box-sizing: border-box;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* 卡片基础样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.1);
}

.card + .card {
  margin-top: 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.card-body {
  padding: 20rpx 28rpx 24rpx;
}

/* 输入卡片布局 */
.input-card {
  flex: 0 0 auto;
  width: 100%;
  margin-top: 10px;
}

.text-card {
  flex: 1;
  width: 100%;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
}

.text-card .card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 16rpx 20rpx 20rpx;
}

.regex-textarea {
  flex: 1;
  min-height: 100rpx;
  max-height: 160rpx;
  padding: 16rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-family: 'Monaco', 'Menlo', monospace;
  background: #fafafa;
  transition: all 0.3s ease;
  box-sizing: border-box;
  line-height: 1.5;
}

.options-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.quick-buttons {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.regex-textarea:focus {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.15);
}

/* 选项卡片 */

.flags-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
}

.flag-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  width: 95%;
  box-sizing: border-box;
  align-self: center;
}

.flag-label {
  color: #666;
}

.common-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}

.common-btn-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 文本输入卡片 */
.char-count {
  font-size: 24rpx;
  color: #999;
}

.test-textarea {
  flex: 1;
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 30rpx;
  background: #fafafa;
  transition: all 0.3s ease;
  box-sizing: border-box;
  line-height: 1.8;
}

.test-textarea:focus {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.15);
}

/* 操作按钮 */
.action-bar {
  display: flex;
  gap: 16rpx;
  flex: 0 0 auto;
  padding: 16rpx 0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 26rpx;
  border: none;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.35);
}

.action-btn.secondary {
  background: #fff;
  color: #666;
  border: 2rpx solid #e8e8e8;
}

.action-btn-hover {
  transform: translateY(2rpx);
}

.btn-icon {
  font-size: 28rpx;
}

/* 错误提示 */
.error-toast {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #fff0f0;
  border: 2rpx solid #ff6b6b;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.error-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.error-content {
  flex: 1;
  font-size: 26rpx;
  color: #c0392b;
}

.error-close {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff6b6b;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* 结果区域 */
.results-section {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.result-overview-card {
  flex: 0 0 auto;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.result-status {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
}

.result-status.empty {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.status-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: bold;
}

.status-info {
  flex: 1;
}

.status-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.status-subtitle {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
}

/* 高亮预览卡片 */
.highlight-card {
  flex: 1;
  min-height: 150rpx;
}

.highlight-card .card-body {
  padding: 0;
}

.highlight-preview {
  height: 100%;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 0 0 20rpx 20rpx;
  font-size: 28rpx;
  line-height: 1.8;
  word-break: break-all;
}

.highlight-text.matched {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
}

/* 匹配列表卡片 */
.matches-card {
  flex: 1;
  min-height: 150rpx;
}

.matches-card .card-body {
  flex: 1;
  overflow: hidden;
  padding: 0;
}

.match-badge {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.match-list {
  height: 100%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  overflow-y: auto;
}

.match-item {
  background: #f8f9fa;
  padding: 16rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #667eea;
}

.match-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.match-index {
  font-size: 26rpx;
  font-weight: 600;
  color: #667eea;
}

.match-range {
  font-size: 24rpx;
  color: #999;
}

.match-content {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  word-break: break-all;
  padding: 12rpx;
  background: #fff;
  border-radius: 8rpx;
}

.match-groups {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.group-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.group-item {
  display: inline-block;
  font-size: 24rpx;
  color: #764ba2;
  background: rgba(118, 75, 162, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin: 4rpx 8rpx 4rpx 0;
}

/* 信息卡片 */
.info-card {
  flex: 0 0 auto;
  background: #f8f9fa;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.regex-display {
  font-family: 'Monaco', 'Menlo', monospace;
  color: #667eea;
  max-width: 55%;
  word-break: break-all;
  text-align: right;
}

/* 帮助卡片 */

.help-arrow.expanded {
  transform: rotate(90deg);
}

.help-content {
  padding: 0 28rpx 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.help-section {
  flex: 1;
  min-width: 45%;
  background: #f8f9fa;
  padding: 16rpx;
  border-radius: 12rpx;
}

.help-section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 12rpx;
}

.help-item {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.help-code {
  font-family: 'Monaco', 'Menlo', monospace;
  font-size: 24rpx;
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.1);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  min-width: 60rpx;
}

.help-desc {
  font-size: 24rpx;
  color: #666;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-container {
  background: #fff;
  border-radius: 24rpx;
  width: 90%;
  max-height: 80vh;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 28rpx;
  color: #666;
}

.modal-body {
  max-height: 60vh;
  padding: 24rpx;
}

.regex-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.regex-item {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border-left: 6rpx solid #667eea;
  transition: all 0.2s ease;
}

.regex-item-hover {
  background: #f0f0f0;
  transform: scale(0.98);
}

.regex-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.regex-pattern {
  display: block;
  font-size: 24rpx;
  font-family: 'Monaco', 'Menlo', monospace;
  color: #764ba2;
  word-break: break-all;
}
