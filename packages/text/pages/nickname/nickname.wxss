/* ================================================
   昵称特效 - PPT卡片风格
   特点：强对比、大卡片、高饱和、清晰层级
   ================================================ */

/* ---------- 全局容器 ---------- */
.container {
  padding: 24rpx;
  background: linear-gradient(160deg, #e8f5e9 0%, #f0f9ff 60%, #fff 100%);
  min-height: 100vh;
}

/* ---------- PPT大卡片基础 ---------- */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}

/* ---------- 预览卡片（最大最突出）---------- */
.preview-card {
  background: linear-gradient(135deg, #07c160 0%, #1aad19 100%);
  padding: 36rpx 32rpx 28rpx;
}

.preview-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.preview-content {
  background: rgba(255,255,255,0.18);
  border-radius: 20rpx;
  padding: 40rpx 24rpx;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
}

.preview-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  word-break: break-all;
  text-align: center;
  line-height: 1.3;
}

.preview-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 预览区输入框 - 白色玻璃风格 */
.preview-input {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 44rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  border: 2rpx solid rgba(255,255,255,0.5);
}

/* 清空按钮 */
.clear-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  color: rgba(255,255,255,0.8);
  font-size: 32rpx;
  flex-shrink: 0;
}

/* 复制按钮 - 白色胶囊 */
.btn-copy {
  height: 88rpx;
  padding: 0 40rpx;
  background: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.btn-copy text {
  font-size: 30rpx;
  font-weight: bold;
  color: #07c160;
}

/* 预览区内联开关 */
.toggle-inline {
  display: flex;
  background: rgba(255,255,255,0.35);
  border-radius: 30rpx;
  padding: 4rpx;
  flex-shrink: 0;
  height: 72rpx;
}

.tbtn {
  padding: 0 16rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  border-radius: 28rpx;
  transition: all 0.2s;
}

.tbtn.active[data-mode="off"] { background: #fff; color: #07c160; font-weight: bold; }
.tbtn.active[data-mode="superscript"] { background: #07c160; color: #fff; font-weight: bold; }
.tbtn.active[data-mode="subscript"] { background: #ff6b35; color: #fff; font-weight: bold; }

/* ---------- 模式切换卡片 ---------- */
.mode-card {
  padding: 24rpx 28rpx;
}

.mode-toggle {
  display: flex;
  gap: 16rpx;
}

.mode-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #999;
  transition: all 0.2s;
}

.mode-btn.active {
  background: #07c160;
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.35);
}

.mode-tip {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 14rpx;
  text-align: center;
}

/* ---------- 上标/下标开关（可滚动区大卡片内） ---------- */
.script-toggle {
  display: flex;
  background: #f0f0f0;
  border-radius: 44rpx;
  padding: 6rpx;
  margin-bottom: 12rpx;
}

.toggle-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  border-radius: 38rpx;
  transition: all 0.2s;
  font-weight: 500;
}

.toggle-btn.active[data-mode="off"] { background: #e0e0e0; color: #333; font-weight: bold; }
.toggle-btn.active[data-mode="superscript"] { background: #07c160; color: #fff; font-weight: bold; }
.toggle-btn.active[data-mode="subscript"] { background: #ff6b35; color: #fff; font-weight: bold; }

.script-hint {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 20rpx;
}

/* ---------- 标签栏 ---------- */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx 4rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.tab-item {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  border-radius: 14rpx;
  transition: all 0.2s;
  letter-spacing: 0.5rpx;
}

.tab-item.active {
  background: #07c160;
  color: #fff;
  font-weight: bold;
  box-shadow: 0 4rpx 14rpx rgba(7,193,96,0.3);
}

/* ---------- 可滚动内容区 ---------- */
.scroll-area {
  flex: 1;
  height: calc(100vh - 420rpx);
}

/* ---------- 模式提示（上标/下标） ---------- */
.mode-tip {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 20rpx 0 8rpx;
}

/* ---------- 内容卡片 ---------- */
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

/* ---------- 选项网格（翅膀/特效字）- 每行2个 ---------- */
.option-grid-2col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.option-item-2col {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 168rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  border: 3rpx solid transparent;
  transition: all 0.18s;
  overflow: hidden;
}

.option-item-2col.selected {
  background: #e8f5e9;
  border-color: #07c160;
}

.option-symbol-2col {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.option-name-2col {
  font-size: 26rpx;
  line-height: 1.2;
  color: #888;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.option-item-2col.selected .option-name-2col {
  color: #07c160;
  font-weight: bold;
}

.extra-item {
  background: #f0f4ff;
}

/* ---------- 颜文字搜索框 ---------- */
.search-box {
  position: relative;
  margin-bottom: 16rpx;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 60rpx 0 24rpx;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-clear {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #aaa;
  font-size: 32rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
}

/* ---------- 分类胶囊标签 ---------- */
.category-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.chip {
  height: 60rpx;
  padding: 0 24rpx;
  background: #f0f0f0;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #777;
  display: flex;
  align-items: center;
  line-height: 1;
}

.chip.active {
  background: #07c160;
  color: #fff;
  font-weight: bold;
}

/* ---------- 颜文字列表 ---------- */
.search-result-info {
  font-size: 24rpx;
  color: #bbb;
  margin-bottom: 14rpx;
}

.kaomoji-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.kaomoji-item {
  padding: 18rpx 28rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 40rpx;
  border: 3rpx solid transparent;
  transition: all 0.15s;
}

.kaomoji-item.selected {
  background: #e8f5e9;
  border-color: #07c160;
  transform: scale(1.08);
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.3);
}

/* ---------- 符号网格 ---------- */
.symbol-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.symbol-item {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 40rpx;
  border: 3rpx solid transparent;
  transition: all 0.15s;
}

.symbol-item.selected {
  background: #e8f5e9;
  border-color: #07c160;
  transform: scale(1.08);
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.3);
}

/* ---------- Toast ---------- */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 24rpx 56rpx;
  background: rgba(0,0,0,0.8);
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  opacity: 0;
  transition: opacity 0.25s;
  z-index: 9999;
  pointer-events: none;
}

.toast.show {
  opacity: 1;
}