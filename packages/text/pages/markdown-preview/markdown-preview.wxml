<view class="container">
  <view class="main-layout">
    <!-- 左侧：编辑器区域 -->
    <view class="left-panel">
      <section class="input-section">
        <div class="section-header" bindtap="toggleEditorExpanded">
          <label>✏️ Markdown编辑器</label>
          <span class="expand-icon">{{editorExpanded ? '▼' : '▶'}}</span>
        </div>
        
        <!-- 工具栏 -->
        <view class="toolbar-row">
          <picker bindchange="setTheme" value="{{themeIndex}}" range="{{themes}}" class="theme-picker">
            <view class="picker-btn">{{themes[themeIndex]}} ▼</view>
          </picker>
          <button class="mini-btn" bindtap="insertTemplate">📋模板</button>
          <button class="mini-btn" bindtap="boldText">B</button>
          <button class="mini-btn" bindtap="italicText">I</button>
          <button class="mini-btn" bindtap="codeText">{ }</button>
        </view>
        
        <textarea 
          value="{{markdownText}}" 
          bindinput="setMarkdownText" 
          class="markdown-editor" 
          placeholder="输入Markdown文本...&#10;&#10;支持语法:&#10;# 标题 | **粗体** | *斜体*&#10;- 列表 | [链接](url) | `代码`" 
          maxlength="50000"
          show-confirm-bar="false"
        />
        
        <view class="char-count">字数: {{markdownText.length}}</view>
      </section>
    </view>
    
    <!-- 右侧：预览区域 -->
    <view class="right-panel">
      <section class="preview-section">
        <div class="section-header" bindtap="togglePreviewExpanded">
          <label>👀 实时预览</label>
          <span class="expand-icon">{{previewExpanded ? '▼' : '▶'}}</span>
        </div>
        
        <!-- 预览操作栏 -->
        <view class="preview-toolbar">
          <button class="mini-btn" bindtap="refreshPreview">🔄 刷新</button>
          <button class="mini-btn" bindtap="copyHtml">📋 复制HTML</button>
        </view>
        
        <scroll-view scroll-y="true" class="preview-scroll">
          <view class="markdown-preview {{theme}}-theme" wx:if="{{renderedHtml}}">
            <rich-text nodes="{{renderedHtml}}"></rich-text>
          </view>
          <view class="empty-preview" wx:else>
            <text class="empty-text">在左侧编辑器中输入Markdown文本</text>
          </view>
        </scroll-view>
      </section>
    </view>
  </view>
  
  <!-- 底部操作区 -->
  <view class="bottom-actions">
    <view class="action-buttons">
      <button class="btn btn-secondary" bindtap="loadSample">
        <span class="btn-icon">📖</span>
        <span class="btn-text">示例</span>
      </button>
      <button class="btn btn-secondary" bindtap="toggleFullscreen">
        <span class="btn-icon">📺</span>
        <span class="btn-text">全屏</span>
      </button>
      <button class="btn btn-primary" bindtap="exportHtml">
        <span class="btn-icon">💾</span>
        <span class="btn-text">导出HTML</span>
      </button>
    </view>
  </view>
  
  <!-- 语法帮助（可折叠） -->
  <view class="help-section" wx:if="{{showHelp}}">
    <view class="help-title">💡 Markdown语法速查</view>
    <view class="syntax-grid">
      <view class="syntax-item">
        <text class="syntax-markdown"># 标题1</text>
        <text class="syntax-result">大标题</text>
      </view>
      <view class="syntax-item">
        <text class="syntax-markdown">## 标题2</text>
        <text class="syntax-result">小标题</text>
      </view>
      <view class="syntax-item">
        <text class="syntax-markdown">**粗体**</text>
        <text class="syntax-result">粗体文本</text>
      </view>
      <view class="syntax-item">
        <text class="syntax-markdown">*斜体*</text>
        <text class="syntax-result">斜体文本</text>
      </view>
      <view class="syntax-item">
        <text class="syntax-markdown">- 列表</text>
        <text class="syntax-result">无序列表</text>
      </view>
      <view class="syntax-item">
        <text class="syntax-markdown">1. 有序</text>
        <text class="syntax-result">有序列表</text>
      </view>
      <view class="syntax-item">
        <text class="syntax-markdown">[链接](url)</text>
        <text class="syntax-result">超链接</text>
      </view>
      <view class="syntax-item">
        <text class="syntax-markdown">`代码`</text>
        <text class="syntax-result">行内代码</text>
      </view>
      <view class="syntax-item">
        <text class="syntax-markdown">> 引用</text>
        <text class="syntax-result">引用块</text>
      </view>
    </view>
  </view>
  
  <!-- 加载提示 -->
  <view class="loading" wx:if="{{isLoading}}">
    <view class="spinner"></view>
    <text>正在渲染预览...</text>
  </view>
</view>
