<view class="container">

  <!-- Tab 切换栏 -->
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === 'edit' ? 'active' : ''}}"
      data-tab="edit"
      bindtap="switchTab"
    >✏️ 编辑</view>
    <view
      class="tab-item {{activeTab === 'preview' ? 'active' : ''}}"
      data-tab="preview"
      bindtap="switchTab"
    >👁 预览</view>
    <view class="tab-extra">
      <picker bindchange="setTheme" value="{{themeIndex}}" range="{{themes}}" class="theme-picker">
        <view class="picker-btn">🎨 {{themes[themeIndex]}}</view>
      </picker>
    </view>
  </view>

  <!-- 编辑器面板 -->
  <view class="panel {{activeTab === 'edit' ? 'show' : 'hide'}}">
    <!-- 工具栏 -->
    <view class="toolbar">
      <view class="tool-btn" hover-class="tool-btn-hover" bindtap="insertBold">
        <text class="tool-text tool-bold">B</text>
      </view>
      <view class="tool-btn" hover-class="tool-btn-hover" bindtap="insertItalic">
        <text class="tool-text tool-italic">I</text>
      </view>
      <view class="tool-btn" hover-class="tool-btn-hover" bindtap="insertCode">
        <text class="tool-text">{ }</text>
      </view>
      <view class="tool-btn" hover-class="tool-btn-hover" bindtap="insertH1">
        <text class="tool-text">H1</text>
      </view>
      <view class="tool-btn" hover-class="tool-btn-hover" bindtap="insertH2">
        <text class="tool-text">H2</text>
      </view>
      <view class="tool-btn" hover-class="tool-btn-hover" bindtap="insertList">
        <text class="tool-text">≡</text>
      </view>
      <view class="tool-btn" hover-class="tool-btn-hover" bindtap="insertQuote">
        <text class="tool-text">"</text>
      </view>
      <view class="tool-btn-text" hover-class="tool-btn-hover" bindtap="loadSample">示例</view>
      <view class="tool-btn-text" hover-class="tool-btn-hover" bindtap="clearEditor">清空</view>
    </view>

    <!-- 编辑区 -->
    <textarea
      value="{{markdownText}}"
      bindinput="setMarkdownText"
      class="markdown-editor"
      placeholder="在此输入 Markdown 文本..."
      maxlength="50000"
      show-confirm-bar="false"
    />
    <view class="editor-footer">
      <text class="char-count">{{markdownText.length}} / 50000</text>
      <view class="footer-btns">
        <view class="footer-btn" hover-class="footer-btn-hover" bindtap="copyMarkdown">📋 复制MD</view>
        <view class="footer-btn primary" hover-class="footer-btn-hover" bindtap="switchToPreview">👁 预览 →</view>
      </view>
    </view>
  </view>

  <!-- 预览面板 -->
  <view class="panel {{activeTab === 'preview' ? 'show' : 'hide'}}">
    <scroll-view scroll-y class="preview-scroll">
      <view class="markdown-body {{themeClass}}" wx:if="{{renderedHtml}}">
        <rich-text nodes="{{renderedHtml}}"></rich-text>
      </view>
      <view class="empty-preview" wx:else>
        <text class="empty-icon">📄</text>
        <text class="empty-tip">请先在编辑器中输入 Markdown 文本</text>
      </view>
    </scroll-view>
    <view class="preview-footer">
      <view class="footer-btn" hover-class="footer-btn-hover" bindtap="copyHtml">📋 复制HTML</view>
      <view class="footer-btn primary" hover-class="footer-btn-hover" bindtap="switchToEdit">← 继续编辑</view>
    </view>
  </view>

  <!-- 语法速查（底部折叠） -->
  <view class="help-toggle" bindtap="toggleHelp">
    <text class="help-toggle-text">💡 Markdown 语法速查 {{showHelp ? '▲' : '▼'}}</text>
  </view>
  <view class="help-panel" wx:if="{{showHelp}}">
    <view class="syntax-grid">
      <view class="syntax-item" wx:for="{{syntaxItems}}" wx:key="index">
        <text class="syntax-md">{{item.md}}</text>
        <text class="syntax-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

</view>
