/**packages/text/pages/markdown-preview/markdown-preview.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

.main-layout {
  display: flex;
  gap: 20rpx;
  height: calc(100vh - 200rpx);
}

/* 左侧/右侧面板通用样式 */
.left-panel,
.right-panel {
  flex: 1;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.input-section,
.preview-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
}

.section-header label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.expand-icon {
  font-size: 24rpx;
  color: #666;
}

/* 工具栏 */
.toolbar-row {
  display: flex;
  gap: 10rpx;
  padding: 15rpx 0;
  flex-wrap: wrap;
}

.theme-picker {
  flex: 1;
  min-width: 150rpx;
}

.picker-btn {
  background: #f0f0f0;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  color: #333;
}

.mini-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.mini-btn:active {
  opacity: 0.8;
}

/* 编辑器 */
.markdown-editor {
  flex: 1;
  width: 100%;
  min-height: 300rpx;
  background: #fafafa;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  font-family: 'Monaco', 'Menlo', monospace;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  margin-top: 15rpx;
}

.char-count {
  font-size: 22rpx;
  color: #999;
  text-align: right;
  padding: 10rpx 0;
}

/* 预览区域 */
.preview-toolbar {
  display: flex;
  gap: 10rpx;
  padding: 15rpx 0;
}

.preview-scroll {
  flex: 1;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
}

.markdown-preview {
  padding: 20rpx;
}

.empty-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
}

.empty-text {
  color: #999;
  font-size: 26rpx;
  text-align: center;
}

/* 底部操作区 */
.bottom-actions {
  margin-top: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.action-buttons {
  display: flex;
  gap: 15rpx;
}

.btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 25rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
}

.btn-secondary {
  background: #f0f0f0;
  color: #333;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 26rpx;
}

/* 帮助区域 */
.help-section {
  margin-top: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 25rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.help-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.syntax-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15rpx;
}

.syntax-item {
  background: #f8f8f8;
  border-radius: 10rpx;
  padding: 15rpx;
}

.syntax-markdown {
  font-family: 'Monaco', 'Menlo', monospace;
  font-size: 22rpx;
  color: #e83e8c;
  margin-bottom: 8rpx;
}

.syntax-result {
  font-size: 22rpx;
  color: #666;
}

/* 加载状态 */
.loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading text {
  color: white;
  font-size: 28rpx;
  margin-top: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Markdown预览主题样式 */
.markdown-preview.default-theme h1,
.markdown-preview.default-theme h2,
.markdown-preview.default-theme h3 {
  color: #333;
  margin: 15rpx 0;
}

.markdown-preview.default-theme h1 { font-size: 36rpx; }
.markdown-preview.default-theme h2 { font-size: 30rpx; }
.markdown-preview.default-theme h3 { font-size: 26rpx; }

/* GitHub主题 */
.markdown-preview.github-theme {
  background: #fff;
  color: #24292e;
}

/* 暗黑主题 */
.markdown-preview.dark-theme {
  background: #1a1a2e;
  color: #eee;
}

/* 护眼主题 */
.markdown-preview.eye-care-theme {
  background: #fdf6e3;
  color: #657b83;
}
