/**packages/text/pages/markdown-preview/markdown-preview.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 30rpx;
  text-align: center;
}

.toolbar-section {
  margin-bottom: 40rpx;
}

.toolbar-controls {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
}

.control-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: rgba(168, 237, 234, 0.2);
  border-radius: 12rpx;
}

.control-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.theme-picker {
  flex: 1;
  margin-left: 30rpx;
}

.picker-display {
  background: white;
  border: 2rpx solid #a8edea;
  border-radius: 8rpx;
  padding: 15rpx 20rpx;
  font-size: 26rpx;
  color: #333;
}

.action-buttons {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-btn {
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid #a8edea;
  border-radius: 15rpx;
  padding: 25rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #a8edea, #fed6e3);
}

.action-btn.primary {
  background: linear-gradient(135deg, #a8edea, #fed6e3);
  border-color: #a8edea;
}

.action-btn.primary .btn-icon,
.action-btn.primary .btn-text {
  color: white;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 24rpx;
  color: #a8edea;
  font-weight: 600;
}

.editor-section {
  margin-bottom: 40rpx;
}

.editor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx 20rpx 0 0;
  border-bottom: 2rpx solid rgba(168, 237, 234, 0.3);
}

.panel-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.editor-controls {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.mini-btn {
  background: #a8edea;
  color: #333;
  border: none;
  border-radius: 6rpx;
  padding: 8rpx 16rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.char-count {
  font-size: 22rpx;
  color: #666;
}

.markdown-editor {
  width: 100%;
  min-height: 400rpx;
  background: white;
  border: none;
  padding: 30rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  font-family: 'Monaco', 'Menlo', monospace;
  box-sizing: border-box;
  border-radius: 0 0 20rpx 20rpx;
}

.preview-section {
  margin-bottom: 40rpx;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx 20rpx 0 0;
  border-bottom: 2rpx solid rgba(254, 214, 227, 0.3);
}

.preview-scroll {
  height: 600rpx;
  background: white;
  border-radius: 0 0 20rpx 20rpx;
}

.markdown-preview {
  padding: 30rpx;
  min-height: 600rpx;
}

.empty-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 600rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  text-align: center;
}

.quick-actions {
  margin-bottom: 40rpx;
}

.quick-buttons {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-btn {
  background: rgba(255, 255, 255, 0.95);
  border: none;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
}

.quick-btn:active {
  transform: scale(0.95);
}

.help-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
}

.help-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 25rpx;
  text-align: center;
}

.syntax-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15rpx;
}

.syntax-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  background: rgba(168, 237, 234, 0.1);
  border-radius: 10rpx;
}

.syntax-markdown {
  font-family: 'Monaco', 'Menlo', monospace;
  font-size: 24rpx;
  color: #d63384;
  margin-bottom: 8rpx;
}

.syntax-result {
  font-size: 24rpx;
  color: #333;
}