<view class="container">
  <!-- 隐藏的Canvas用于生成分享图片 -->
  <canvas id="emojiCanvas" canvas-id="emojiCanvas" style="{{canvasStyle}}"></canvas>
  
  <section class="input-section">
    <div class="input-group">
      <label for="emoji-input">输入Emoji</label>
      <input type="text" id="emoji-input" class="emoji-input" placeholder="输入一个emoji，如😀" maxlength="2" value="{{inputEmoji}}" bindinput="onEmojiInput" />
      <p class="hint">注意：只能输入一个emoji</p>
    </div>
  </section>  
  
  <section class="preview-section">
    <div class="preview-title">预览效果</div>
    <view id="emoji-preview" class="emoji-preview" style="{{previewStyle}}">{{previewEmoji}}</view>
    <p class="preview-info">预览将实时更新，导出图片为200×200像素小文件PNG</p>
    
    <div class="actions">
      <button class="btn btn-secondary" bindtap="resetForm">
        <span class="btn-icon">↺</span> 重置
      </button>
      <button class="btn btn-primary" bindtap="exportAsPNG">
        <span class="btn-icon">⤓</span> 导出PNG
      </button>
    </div>
  </section>  

  <view class="loading" wx:if="{{isLoading}}">
    <view class="spinner"></view>
    <p>正在生成高清图片，请稍候...</p>
  </view>
</view>