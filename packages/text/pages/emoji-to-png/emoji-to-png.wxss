/* emoji-to-png.wxss */

/* 全局样式 - 替换不支持的通配符选择器 */
page {
  margin: 0;
  padding: 0;
}

.container, .input-section, .preview-section {
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 20rpx;
  font-family: 'PingFang SC', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* 输入区域样式 */
.input-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.input-group {
  margin-bottom: 32rpx;
}

.input-group label {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.emoji-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  transition: border-color 0.3s;
}

.emoji-input:focus {
  outline: none;
  border-color: #3498db;
  box-shadow: 0 0 0 4rpx rgba(52, 152, 219, 0.1);
}

.hint {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
}

/* 背景选择样式 */
.background-section {
  margin-top: 32rpx;
}

.background-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.background-option {
  flex: 1 1 calc(33.333% - 14rpx);
  min-width: 120rpx;
}

.background-label {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  cursor: pointer;
  transition: all 0.3s;
}

.background-label.checked {
  border-color: #3498db;
  background-color: rgba(52, 152, 219, 0.05);
}

.background-preview {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.background-label div:last-child {
  font-size: 24rpx;
  color: #333333;
}

/* 预览区域样式 */
.preview-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.preview-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 32rpx;
}

.emoji-preview {
  width: 300rpx;
  height: 300rpx;
  margin: 0 auto 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 120rpx;
  transition: all 0.3s;
  background: #ffffff;
  border: 1px solid #e0e0e0;
}

.preview-info {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 32rpx;
}

/* 按钮样式 */
.actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.btn {
  flex: 1;
  height: 80rpx;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.3s;
  cursor: pointer;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #ffffff;
}

.btn-primary:hover {
  opacity: 0.9;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(52, 152, 219, 0.3);
}

.btn-primary:disabled {
  background: #bdc3c7;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.btn-secondary {
  background: #f8f9fa;
  color: #333333;
  border: 2rpx solid #e0e0e0;
}

.btn-secondary:hover {
  background: #e9ecef;
  transform: translateY(-2rpx);
}

/* 底部信息样式 */
footer {
  margin-top: 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666666;
  padding: 20rpx 0;
}

/* 加载动画样式 */
.loading {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #3498db;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading p {
  font-size: 28rpx;
  color: #333333;
}