<view class="mortgage-container">
  <view class="form-section">
    <view class="form-item">
      <text class="label">贷款类型</text>
      <picker bindchange="onLoanTypeChange" value="{{loanType}}" range="{{['商业贷款', '公积金贷款', '组合贷款']}}">
        <view class="picker">
          {{['商业贷款', '公积金贷款', '组合贷款'][loanType]}} <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">贷款金额</text>
      <input class="input" type="digit" placeholder="请输入贷款金额" value="{{loanAmount}}" bindinput="onLoanAmountInput"  placeholder-class="input-placeholder"/>
      <text class="unit">万元</text>
    </view>

    <view class="form-item">
      <text class="label">贷款年限</text>
      <picker bindchange="onYearsChange" value="{{yearsIndex}}" range="{{[5,10,15,20,25,30]}}">
        <view class="picker">
          {{years}}年 <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">年利率</text>
      <input class="input" type="digit" placeholder="请输入年利率" value="{{rate}}" bindinput="onRateChange"  placeholder-class="input-placeholder"/>
      <text class="unit">%</text>
    </view>
  </view>

  <!-- 结果区域始终显示 -->
  <view class="result-section {{hasValidResult ? '' : 'result-empty'}}">
    <view class="result-header">
      <text class="result-title">计算结果（等额本息）</text>
      <view wx:if="{{hasValidResult}}" class="btn-reset-mini" bindtap="reset">重置</view>
    </view>

    <view wx:if="{{hasValidResult}}" class="result-body">
      <view class="result-primary">
        <text class="primary-label">每月还款</text>
        <text class="primary-value">{{monthlyPayment}}</text>
        <text class="primary-unit">元</text>
      </view>

      <view class="result-detail">
        <view class="result-item">
          <text class="result-label">支付利息</text>
          <text class="result-value">{{totalInterest}} 万元</text>
        </view>
        <view class="result-item">
          <text class="result-label">还款总额</text>
          <text class="result-value">{{totalPayment}} 万元</text>
        </view>
      </view>
    </view>

    <view wx:else class="result-placeholder">
      <text class="placeholder-icon">💡</text>
      <text class="placeholder-text">请输入贷款信息，即可查看计算结果</text>
    </view>
  </view>

  <!-- 分享海报生成 -->
  <view wx:if="{{hasValidResult}}" class="share-section">
    <button class="btn-share" bindtap="MakePosters">生成分享海报</button>
  </view>

  <!-- 隐藏的Canvas用于生成分享图片 -->
  <canvas id="cvs1" type="2d" style="width: {{canvaswidth}}px; height: {{canvasheight}}px; position: absolute; left: -9999px; top: -9999px;"></canvas>
</view>
