/* packages/financial/pages/mortgage/mortgage.wxss */
.mortgage-container {
  padding: 30rpx;
}

.form-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(52, 152, 219, 0.1);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item .label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
}

.form-item .input {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  padding: 0 24rpx;
  background-color: #f5f9fc;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-item .input:focus {
  border-color: #3498db;
  background-color: white;
  box-shadow: 0 0 0 4rpx rgba(52, 152, 219, 0.1);
}

.form-item .picker {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-right: 10rpx;
}

.form-item .arrow {
  color: #c7c7cc;
  font-size: 24rpx;
  transform: rotate(90deg);
}

.form-item .unit {
  width: 80rpx;
  text-align: right;
  font-size: 28rpx;
  color: #666;
}

/* 结果区域 */
.result-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(52, 152, 219, 0.1);
  transition: all 0.3s ease;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #3498db;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.btn-reset-mini {
  font-size: 24rpx;
  color: #666;
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

/* 主要结果展示 */
.result-primary {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.primary-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  margin-right: 16rpx;
}

.primary-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
}

.primary-unit {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  margin-left: 8rpx;
}

.result-detail {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.result-item:last-child {
  border-bottom: none;
}

.result-item .result-label {
  font-size: 28rpx;
  color: #666;
}

.result-item .result-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #3498db;
}

/* 空状态 */
.result-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 50rpx 0;
}

.placeholder-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
}

/* 分享海报 */
.share-section {
  margin-top: 30rpx;
  text-align: center;
}

.btn-share {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: #fff;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(231, 76, 60, 0.3);
}
