/* packages/financial/pages/mortgage/mortgage.wxss */
.mortgage-container {
  padding: 30rpx;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item .label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
}

.form-item .input {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  padding: 0 24rpx;
  background-color: #fafafa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-item .input:focus {
  border-color: #3498db;
  background-color: white;
  box-shadow: 0 0 0 4rpx rgba(52, 152, 219, 0.1);
}

.form-item .picker {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-right: 10rpx;
}

.form-item .arrow {
  color: #c7c7cc;
  font-size: 24rpx;
  transform: rotate(90deg);
}

.form-item .unit {
  width: 80rpx;
  text-align: right;
  font-size: 28rpx;
  color: #999;
}

.button-group {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.btn-calculate,
.btn-reset {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
}

.btn-calculate {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: #fff;
}

.btn-reset {
  background: #f5f5f5;
  color: #666;
}

.result-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #3498db;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.result-item .result-label {
  font-size: 28rpx;
  color: #666;
}

.result-item .result-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #3498db;
}

.share-section {
  margin-top: 30rpx;
  text-align: center;
}

.btn-share {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: #fff;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
}