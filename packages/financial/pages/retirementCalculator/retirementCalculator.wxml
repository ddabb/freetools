<view class="retirement-container">
  <view class="form-section">
    <view class="form-item">
      <text class="label">当前年龄</text>
      <input class="input" type="number" placeholder="请输入当前年龄" value="{{currentAge}}" bindinput="onCurrentAgeInput" />
      <text class="unit">岁</text>
    </view>

    <view class="form-item">
      <text class="label">退休年龄</text>
      <picker bindchange="onRetireAgeChange" value="{{retireAgeIndex}}" range="{{[55,60,65,70]}}">
        <view class="picker">
          {{retireAge}}岁 <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">当前月薪</text>
      <input class="input" type="digit" placeholder="请输入当前月薪" value="{{currentSalary}}" bindinput="onCurrentSalaryInput" />
      <text class="unit">元</text>
    </view>

    <view class="form-item">
      <text class="label">薪资增长率</text>
      <input class="input" type="digit" placeholder="薪资增长率" value="{{salaryIncrease}}" bindinput="onSalaryIncreaseChange" />
      <text class="unit">%</text>
    </view>

    <view class="form-item">
      <text class="label">每月储蓄类型</text>
      <picker bindchange="onSavingTypeChange" value="{{savingTypeIndex}}" range="{{['固定金额', '薪资比例']}}">
        <view class="picker">
          {{savingTypeIndex === 0 ? '固定金额' : '薪资比例'}} <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">每月储蓄</text>
      <input class="input" type="digit" placeholder="{{savingTypeIndex === 0 ? '请输入每月储蓄金额' : '请输入每月储蓄比例'}}" value="{{monthlySaving}}" bindinput="onMonthlySavingInput" />
      <text class="unit">{{savingTypeIndex === 0 ? '元' : '%'}}</text>
    </view>

    <view class="form-item">
      <text class="label">预期年化收益率</text>
      <input class="input" type="digit" placeholder="预期收益率" value="{{expectedReturn}}" bindinput="onExpectedReturnChange" />
      <text class="unit">%</text>
    </view>
  </view>

  <view class="button-group">
    <button class="btn-calculate" bindtap="calculate">计算</button>
    <button class="btn-reset" bindtap="reset">重置</button>
  </view>

  <view wx:if="{{showResult}}" class="result-section">
    <view class="result-title">退休储蓄预测</view>

    <view class="result-item">
      <text class="result-label">退休时预计月储蓄</text>
      <text class="result-value">{{expectedMonthlySaving}} 元</text>
    </view>
    <view class="result-item">
      <text class="result-label">预计退休时储蓄总额</text>
      <text class="result-value">{{retireSavings}} 万元</text>
    </view>
    <view class="result-item">
      <text class="result-label">预计退休时储蓄总额（元）</text>
      <text class="result-value">{{totalSavings}} 元</text>
    </view>
    <view class="tips">
      <text class="tips-text">* 仅供参考，实际情况请咨询专业理财师</text>
    </view>
  </view>

  <!-- 分享海报生成 -->
  <view class="share-section">
    <button class="btn-share" bindtap="MakePosters">生成分享海报</button>
  </view>

  <!-- 隐藏的Canvas用于生成分享图片 -->
  <canvas id="cvs1" type="2d" style="width: {{canvaswidth}}px; height: {{canvasheight}}px; position: absolute; left: -9999px; top: -9999px;"></canvas>
</view>