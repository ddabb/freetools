<view class="retirement-container">
  <view class="form-section">
    <view class="form-item">
      <text class="label">当前年龄</text>
      <input class="input" type="number" placeholder="请输入当前年龄" value="{{currentAge}}" bindinput="onCurrentAgeInput"  placeholder-class="input-placeholder"/>
      <text class="unit">岁</text>
    </view>

    <view class="form-item">
      <text class="label">退休年龄</text>
      <picker bindchange="onRetireAgeChange" value="{{retireAgeIndex}}" range="{{[55,60,65,70]}}">
        <view class="picker">
          {{retireAge}}岁 <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">当前月薪</text>
      <input class="input" type="digit" placeholder="请输入当前月薪" value="{{currentSalary}}" bindinput="onCurrentSalaryInput"  placeholder-class="input-placeholder"/>
      <text class="unit">元</text>
    </view>

    <view class="form-item">
      <text class="label">薪资增长率</text>
      <input class="input" type="digit" placeholder="薪资增长率" value="{{salaryIncrease}}" bindinput="onSalaryIncreaseChange"  placeholder-class="input-placeholder"/>
      <text class="unit">%</text>
    </view>

    <view class="form-item">
      <text class="label">每月储蓄类型</text>
      <picker bindchange="onSavingTypeChange" value="{{savingTypeIndex}}" range="{{['固定金额', '薪资比例']}}">
        <view class="picker">
          {{savingTypeIndex === 0 ? '固定金额' : '薪资比例'}} <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">每月储蓄</text>
      <input class="input" type="digit" placeholder="{{savingTypeIndex === 0 ? '请输入每月储蓄金额' : '请输入每月储蓄比例'}}" value="{{monthlySaving}}" bindinput="onMonthlySavingInput"  placeholder-class="input-placeholder"/>
      <text class="unit">{{savingTypeIndex === 0 ? '元' : '%'}}</text>
    </view>

    <view class="form-item">
      <text class="label">预期年化收益率</text>
      <input class="input" type="digit" placeholder="预期收益率" value="{{expectedReturn}}" bindinput="onExpectedReturnChange"  placeholder-class="input-placeholder"/>
      <text class="unit">%</text>
    </view>
  </view>

  <!-- 结果区域始终显示 -->
  <view class="result-section {{hasValidResult ? '' : 'result-empty'}}">
    <view class="result-header">
      <text class="result-title">退休储蓄预测</text>
      <view wx:if="{{hasValidResult}}" class="btn-reset-mini" bindtap="reset">重置</view>
    </view>

    <view wx:if="{{hasValidResult}}" class="result-body">
      <view class="result-primary">
        <text class="primary-label">退休时储蓄总额</text>
        <text class="primary-value">{{totalSavings}}</text>
        <text class="primary-unit">元</text>
      </view>

      <view class="result-secondary">
        <view class="secondary-item">
          <text class="secondary-value">{{retireSavings}}</text>
          <text class="secondary-unit">万元</text>
          <text class="secondary-label">约合</text>
        </view>
      </view>

      <view class="result-detail">
        <view class="result-item">
          <text class="result-label">距离退休</text>
          <text class="result-value">{{yearsToRetire}} 年</text>
        </view>
        <view class="result-item">
          <text class="result-label">退休时每月储蓄</text>
          <text class="result-value">{{expectedMonthlySaving}} 元</text>
        </view>
      </view>

      <view class="tips">
        <text class="tips-text">* 仅供参考，实际情况请咨询专业理财师</text>
      </view>
    </view>

    <view wx:else class="result-placeholder">
      <text class="placeholder-icon">💡</text>
      <text class="placeholder-text">请输入完整信息，即可查看退休储蓄预测</text>
    </view>
  </view>

  <!-- 分享海报生成 -->
  <view wx:if="{{hasValidResult}}" class="share-section">
    <button class="btn-share" bindtap="MakePosters">生成分享海报</button>
  </view>

  <!-- 隐藏的Canvas用于生成分享图片 -->
  <canvas id="cvs1" type="2d" style="width: {{canvaswidth}}px; height: {{canvasheight}}px; position: absolute; left: -9999px; top: -9999px;"></canvas>
  <!-- 搴曢儴骞垮憡 -->
  <ad unit-id="adunit-07e9c9da9e4b8254" ad-intervals="30" binderror="onAdError" bindclose="onAdClose"></ad>
</view>
