/* packages/financial/pages/price-comparison/price-comparison.wxss */
.price-comparison-container {
  padding: 30rpx;
}

.items-list {
  margin-bottom: 30rpx;
}

.item-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-number {
  font-size: 30rpx;
  font-weight: bold;
  color: #3498db;
}

.btn-remove {
  font-size: 26rpx;
  color: #e74c3c;
  padding: 8rpx 16rpx;
  background: #fee;
  border-radius: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
}

.form-item .label {
  width: 140rpx;
  font-size: 28rpx;
  color: #333;
}

.form-item .input {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  padding: 0 24rpx;
  background-color: #fafafa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-item .input:focus {
  border-color: #3498db;
  background-color: white;
  box-shadow: 0 0 0 4rpx rgba(52, 152, 219, 0.1);
}

.form-item .unit {
  width: 120rpx;
  text-align: right;
  font-size: 28rpx;
  color: #999;
}

.unit-price {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  margin-top: 10rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 20rpx;
}

.unit-price .label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
}

.unit-price .value {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
  color: #3498db;
}

.unit-price .unit {
  width: auto;
  font-size: 26rpx;
  color: #999;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.btn-add,
.btn-calculate,
.btn-reset {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-add {
  background: #e8f4f8;
  color: #3498db;
}

.btn-calculate {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: #fff;
}

.btn-reset {
  background: #f5f5f5;
  color: #666;
}