/* packages/financial/pages/price-comparison/price-comparison.wxss */
.price-comparison-container {
  padding: 24rpx;
  padding-bottom: 60rpx;
  background: #f8f9fa;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 商品列表 */
.items-list {
  margin-bottom: 20rpx;
}

.item-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.item-card.best-deal {
  border-color: #22c55e;
  box-shadow: 0 4rpx 20rpx rgba(34, 197, 94, 0.15);
}

.item-card.has-error {
  border-color: #ef4444;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-title {
  display: flex;
  align-items: center;
  flex: 1;
}

.item-number {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.name-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  padding: 8rpx 0;
}

.btn-remove {
  font-size: 24rpx;
  color: #b91c1c;
  padding: 10rpx 20rpx;
  background: #fecaca;
  border-radius: 24rpx;
  margin-left: 16rpx;
}

/* 表单行 */
.form-row {
  display: flex;
  gap: 16rpx;
}

.form-col {
  display: flex;
  flex-direction: column;
}

.price-col {
  flex: 1.2;
}

.qty-col {
  flex: 1;
}

.unit-col {
  width: 140rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  height: 80rpx;
  font-size: 32rpx;
  padding: 0 20rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #333;
}

.input-placeholder {
  color: #9ca3af;
}

/* 单位选择器 */
.unit-picker {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
}

.unit-text {
  font-size: 28rpx;
  color: #333;
}

.unit-arrow {
  font-size: 20rpx;
  color: #999;
}

/* 错误提示 */
.error-tip {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: #fef2f2;
  border-radius: 10rpx;
}

.error-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.error-text {
  font-size: 24rpx;
  color: #ef4444;
}

/* 结果展示 */
.result-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.unit-price-display {
  display: flex;
  align-items: baseline;
}

.result-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 12rpx;
}

.result-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #3498db;
}

.result-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.best-badge {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.best-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.best-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

/* 添加按钮 */
.add-section {
  margin-bottom: 24rpx;
}

.btn-add {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #fff;
  border: 2rpx dashed #2563eb;
  border-radius: 16rpx;
}

.add-icon {
  font-size: 36rpx;
  color: #2563eb;
  margin-right: 12rpx;
}

.add-text {
  font-size: 30rpx;
  color: #2563eb;
  font-weight: 500;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-buttons button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
  margin: 0;
}

.action-buttons button::after {
  border: none;
}

.btn-calculate {
  flex: 1.5 !important;
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%) !important;
  color: #fff !important;
}

.btn-share {
  background: #dbeafe !important;
  color: #1d4ed8 !important;
}

.btn-share.disabled {
  background: #f3f4f6 !important;
  color: #9ca3af !important;
}

.btn-reset {
  background: #e5e7eb !important;
  color: #374151 !important;
}

.btn-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

/* 历史记录 */
.history-section {
  margin-bottom: 24rpx;
}

.history-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.history-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.history-text {
  font-size: 28rpx;
  color: #666;
}

.toggle-icon {
  font-size: 20rpx;
  color: #999;
  margin-left: 12rpx;
  transition: transform 0.3s ease;
}

.toggle-icon.up {
  transform: rotate(180deg);
}

.history-panel {
  margin-top: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.history-empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.history-list {
  max-height: 400rpx;
}

.history-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.history-item:last-child {
  margin-bottom: 0;
}

.history-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.history-goods {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.goods-tag {
  font-size: 24rpx;
  color: #666;
  background: #fff;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
}

.history-best {
  display: flex;
  align-items: center;
}

.history-best text {
  font-size: 24rpx;
  color: #22c55e;
  font-weight: 500;
}

.history-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.clear-history {
  font-size: 26rpx;
  color: #ef4444;
}

/* 使用提示 */
.tips-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}
