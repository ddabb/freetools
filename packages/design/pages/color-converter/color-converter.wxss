/**packages/design/pages/color-converter/color-converter.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  min-height: 100vh;
  padding: 16rpx 0;
}

/* 通用卡片样式 - 参考 text-to-png */
.card {
  background: #fff;
  border-radius: 8rpx;
  padding: 16rpx;
  margin: 0 16rpx 16rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  width: calc(100% - 32rpx);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* 颜色预览区域 */
.color-preview-section {
  height: 280rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx;
  position: relative;
  transition: background-color 0.2s ease;
}

.color-info-bar {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.color-code {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  font-family: 'SF Mono', Monaco, monospace;
  letter-spacing: 2rpx;
  min-width: 140rpx;
}

.copy-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 6rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
  margin: 0;
}

.copy-btn-hover {
  opacity: 0.9;
  transform: scale(0.96);
}

/* RGB滑块区域 */
.rgb-section {
  margin-top: -24rpx;
  position: relative;
  z-index: 1;
  border: 1rpx solid #d1d5db;
}

.rgb-value-display {
  font-size: 22rpx;
  color: #666;
  font-family: 'SF Mono', Monaco, monospace;
  background: #f5f5f5;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
}

.slider-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.slider-row:last-child {
  margin-bottom: 0;
}

.slider-container {
  flex: 1;
  height: 40rpx;
  display: flex;
  align-items: center;
}

.slider-track {
  width: 100%;
  height: 8rpx;
  border-radius: 4rpx;
  position: relative;
  overflow: hidden;
}

.slider-r-track {
  background: linear-gradient(to right, #2d0000, #ff4757);
}

.slider-g-track {
  background: linear-gradient(to right, #002d00, #2ed573);
}

.slider-b-track {
  background: linear-gradient(to right, #00002d, #3742fa);
}

.color-slider {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  margin: 0 10rpx;
}

.slider-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: 16rpx;
  min-width: 80rpx;
}

.slider-label {
  font-size: 24rpx;
  font-weight: 700;
  width: 28rpx;
  text-align: center;
}

.r-label {
  color: #ff4757;
}

.g-label {
  color: #2ed573;
}

.b-label {
  color: #3742fa;
}

.slider-num {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  font-family: 'SF Mono', Monaco, monospace;
  min-width: 44rpx;
  text-align: right;
}

/* HEX输入区 */
.hex-input-wrapper {
  display: flex;
  align-items: center;
  background: #fafafa;
  border: 1rpx solid #e0e0e0;
  border-radius: 6rpx;
  padding: 12rpx 16rpx;
}

.hex-prefix {
  font-size: 28rpx;
  font-weight: 700;
  color: #4338ca;
  margin-right: 8rpx;
}

.hex-input {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  font-family: 'SF Mono', Monaco, monospace;
  text-transform: uppercase;
}

/* 快捷操作 */
.quick-actions {
  padding: 16rpx;
}

.action-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  border: none;
  border-radius: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 0;
}

.action-btn::after {
  border: none;
}

.action-btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

/* 格式转换区域 */
.format-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.format-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 6rpx;
  transition: all 0.15s ease;
}

.format-item-hover {
  background: #f0f0f0;
  transform: scale(0.99);
}

.format-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.format-name {
  font-size: 20rpx;
  color: #666;
  font-weight: 600;
}

.format-value {
  font-size: 24rpx;
  color: #333;
  font-family: 'SF Mono', Monaco, monospace;
  font-weight: 600;
}

.copy-icon {
  font-size: 28rpx;
  opacity: 0.5;
}

/* 颜色信息区域 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.info-item {
  background: #fafafa;
  border-radius: 6rpx;
  padding: 16rpx;
  text-align: center;
}

.info-label {
  display: block;
  font-size: 20rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
}

.text-preview {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

/* 配色方案区域 */
.schemes-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scheme-item {
  background: #fafafa;
  border-radius: 6rpx;
  padding: 16rpx;
}

.scheme-name {
  display: block;
  font-size: 22rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.scheme-colors {
  display: flex;
  gap: 8rpx;
}

.scheme-color {
  flex: 1;
  height: 60rpx;
  border-radius: 6rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.15s ease;
}

.scheme-color-hover {
  transform: scale(0.94);
}

/* 预设颜色区域 */
.preset-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12rpx;
}

.preset-color {
  aspect-ratio: 1;
  border-radius: 6rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.15s ease;
}

.preset-color-hover {
  transform: scale(0.88);
}

/* 最近使用区域 */
.clear-btn {
  font-size: 22rpx;
  color: #dc2626;
  font-weight: 600;
  padding: 16rpx 24rpx;
  min-width: 80rpx;
  min-height: 60rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.recent-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12rpx;
}

.recent-color {
  aspect-ratio: 1;
  border-radius: 6rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.15s ease;
}

.recent-color-hover {
  transform: scale(0.88);
}

/* 帮助区域 */
.help-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.help-item {
  font-size: 22rpx;
  color: #666;
  line-height: 1.5;
}

/* slider组件样式 */
wx-slider {
  margin: 0;
  width: 100%;
}

/* 自定义滑块样式 */
.custom-slider-container {
  flex: 1;
  height: 40rpx;
  display: flex;
  align-items: center;
  position: relative;
}

.custom-slider-track {
  width: 100%;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  position: relative;
  cursor: pointer;
}

.custom-slider-fill {
  height: 100%;
  border-radius: 4rpx;
  position: absolute;
  left: 0;
  top: 0;
  transition: width 0.1s ease;
}

.custom-slider-thumb {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.25);
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  cursor: pointer;
  z-index: 10;
  transition: left 0.1s ease;
}

.custom-slider-thumb-hover {
  transform: translate(-50%, -50%) scale(1.2);
}
