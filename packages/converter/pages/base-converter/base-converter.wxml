<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 输入数字 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">输入数字</text>
        <text class="required-mark">*</text>
      </view>
      <view class="input-with-unit">
        <input type="text" value="{{inputValue}}" bindinput="setInputValue" class="input-field" placeholder="请输入要转换的数字" />
      </view>
    </view>

    <!-- 源进制选择 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">从</text>
        <text class="required-mark">*</text>
      </view>
      <picker bindchange="setSourceBase" value="{{sourceBaseIndex}}" range="{{sourceBases}}" class="form-picker">
        <view class="picker-display {{sourceBaseIndex === -1 ? 'placeholder' : ''}}">
          {{sourceBases[sourceBaseIndex] || '选择源进制'}}
        </view>
      </picker>
    </view>

    <!-- 交换按钮 -->
    <view class="form-item">
      <button class="swap-btn full-width-btn" bindtap="swapBases">
        <text class="btn-text">交换进制 ⇅</text>
      </button>
    </view>

    <!-- 目标进制选择 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">转换为</text>
        <text class="required-mark">*</text>
      </view>
      <picker bindchange="setTargetBase" value="{{targetBaseIndex}}" range="{{targetBases}}" class="form-picker">
        <view class="picker-display {{targetBaseIndex === -1 ? 'placeholder' : ''}}">
          {{targetBases[targetBaseIndex] || '选择目标进制'}}
        </view>
      </picker>
    </view>
  </view>

  <!-- 结果展示 -->
  <view class="result-section" wx:if="{{showResult}}">
    <view class="result-box">
      <view class="conversion-chain">
        <view class="conversion-step">
          <text class="step-label">原始值 ({{sourceBases[sourceBaseIndex]}})</text>
          <text class="step-value original">{{inputValue}}</text>
        </view>
        <view class="conversion-arrow">➜</view>
        <view class="conversion-step">
          <text class="step-label">转换结果 ({{targetBases[targetBaseIndex]}})</text>
          <text class="step-value result">{{outputValue}}</text>
        </view>
      </view>
      
      <!-- Base64特殊显示 -->
      <view class="base64-section" wx:if="{{targetBase === 'base64'}}">
        <text class="base64-label">解码预览:</text>
        <text class="base64-preview" wx:if="{{base64Decoded}}">{{base64Decoded}}</text>
        <text class="base64-error" wx:else>无法解码为文本内容</text>
      </view>
    </view>
  </view>

  <!-- 进制说明 -->
  <view class="info-section">
    <view class="info-title">💡 进制说明</view>
    <view class="info-content">
      <view class="base-info" wx:for="{{baseInfo}}" wx:key="base" wx:if="{{item.base === sourceBase || item.base === targetBase}}">
        <text class="base-name">{{item.name}} ({{item.symbol}}):</text>
        <text class="base-desc">{{item.description}}</text>
      </view>
    </view>
  </view>

  <!-- 快捷示例 -->
  <view class="examples-section">
    <view class="examples-title">快速示例</view>
    <view class="examples-grid">
      <view class="example-item" wx:for="{{examples}}" wx:key="index" bindtap="useExample" data-value="{{item.value}}" data-source="{{item.source}}" data-target="{{item.target}}">
        <text class="example-text">{{item.value}} ({{item.source}}) → {{item.target}}</text>
      </view>
    </view>
  </view>
</view>