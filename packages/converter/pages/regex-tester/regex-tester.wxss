/**packages/converter/pages/regex-tester/regex-tester.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #ffeaa7 0%, #fab1a0 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 30rpx 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 页面标题 */
.page-title {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
}

.title-text {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 10rpx;
  background: linear-gradient(135deg, #ffeaa7, #fab1a0);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.title-subtext {
  display: block;
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

/* 通用区域样式 */
.regex-section,
.test-section,
.results-section,
.help-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
  box-sizing: border-box;
}

/* 区域头部 */
.section-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.section-subtitle {
  display: block;
  font-size: 20rpx;
  color: #666;
  font-weight: 500;
}

/* 正则输入区域 */
.regex-input-container {
  margin-bottom: 24rpx;
}

.regex-input {
  width: 100%;
  background: #f8f9fa;
  border: 2rpx solid transparent;
  border-radius: 15rpx;
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  font-family: 'Monaco', 'Menlo', monospace;
  box-sizing: border-box;
  transition: all 0.3s ease;
  margin-bottom: 20rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.regex-input:focus {
  border-color: #ffeaa7;
  background: white;
  box-shadow: 0 0 0 6rpx rgba(255, 234, 167, 0.1);
}

/* 标志位选择 */
.flags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.flag-item {
  display: flex;
  align-items: center;
  background: rgba(255, 234, 167, 0.1);
  padding: 12rpx 16rpx;
  border-radius: 10rpx;
  transition: all 0.3s ease;
}

.flag-item:active {
  background: rgba(255, 234, 167, 0.3);
}

.flag-text {
  font-size: 24rpx;
  color: #333;
  margin-left: 8rpx;
  font-weight: 500;
}

/* 常用正则区域 */
.quick-regex-section {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.quick-regex-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.quick-regex-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.quick-regex-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #f8f9fa, #e9ecef);
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  flex-wrap: nowrap;
  overflow: hidden;
}

.quick-regex-item:active {
  background: linear-gradient(135deg, #ffeaa7, #fab1a0);
  transform: scale(0.98);
}

.quick-regex-item:active .regex-name,
.quick-regex-item:active .regex-preview {
  color: white;
}

.regex-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #ffeaa7;
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.regex-preview {
  font-size: 22rpx;
  color: #666;
  font-family: 'Monaco', 'Menlo', monospace;
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: right;
}

/* 测试文本区域 */
.test-textarea {
  width: 100%;
  min-height: 180rpx;
  background: #f8f9fa;
  border: 2rpx solid transparent;
  border-radius: 15rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  box-sizing: border-box;
  transition: all 0.3s ease;
  margin-bottom: 20rpx;
}

.test-textarea:focus {
  border-color: #ffeaa7;
  background: white;
  box-shadow: 0 0 0 6rpx rgba(255, 234, 167, 0.1);
}

.test-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  flex-wrap: nowrap;
}

.test-btn {
  background: linear-gradient(135deg, #ffeaa7 0%, #fab1a0 100%);
  color: #d63031;
  border: none;
  border-radius: 15rpx;
  padding: 20rpx 32rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 30rpx rgba(255, 234, 167, 0.4);
  transition: all 0.3s ease;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.btn-icon {
  font-size: 30rpx;
}

.test-btn:active {
  transform: translateY(-2rpx) scale(1.05);
  box-shadow: 0 15rpx 40rpx rgba(255, 234, 167, 0.5);
}

.test-stats {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  white-space: nowrap;
  overflow: hidden;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
  margin-right: 10rpx;
}

.stat-value {
  font-size: 22rpx;
  color: #d63031;
  font-weight: 700;
  font-family: 'Monaco', 'Menlo', monospace;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 结果区域 */
.results-section {
  animation: fadeInScale 0.6s ease-out;
}

.result-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.matches-list {
  max-height: 400rpx;
}

.match-item {
  background: rgba(255, 234, 167, 0.1);
  border-radius: 15rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #ffeaa7;
  box-sizing: border-box;
}

.match-header {
  margin-bottom: 12rpx;
  flex-wrap: nowrap;
  overflow: hidden;
}

.match-index {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: nowrap;
  overflow: hidden;
}

.index-number {
  font-size: 24rpx;
  font-weight: 700;
  color: #d63031;
  white-space: nowrap;
  margin-right: 16rpx;
}

.index-position {
  font-size: 22rpx;
  color: #666;
  font-family: 'Monaco', 'Menlo', monospace;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
}

.match-content {
  margin-bottom: 12rpx;
}

.match-text {
  font-size: 26rpx;
  color: #333;
  font-family: 'Monaco', 'Menlo', monospace;
  background: rgba(255, 255, 255, 0.7);
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  word-break: break-all;
  box-sizing: border-box;
}

.match-groups {
  border-top: 1rpx solid rgba(255, 234, 167, 0.3);
  padding-top: 12rpx;
}

.groups-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #d63031;
  margin-bottom: 8rpx;
  display: block;
}

.group-item {
  margin-bottom: 6rpx;
}

.group-text {
  font-size: 22rpx;
  color: #666;
  font-family: 'Monaco', 'Menlo', monospace;
  word-break: break-all;
}

/* 高亮显示 */
.highlight-text {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 24rpx;
  line-height: 1.8;
  font-family: 'Monaco', 'Menlo', monospace;
  font-size: 26rpx;
  border: 2rpx solid #f0f0f0;
  box-sizing: border-box;
  word-break: break-all;
}

.text-part {
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  word-break: break-all;
}

.highlight-normal {
  background: transparent;
  color: #333;
}

.highlight-match {
  background: linear-gradient(135deg, #ffeaa7, #fab1a0);
  color: #d63031;
  font-weight: 600;
}

/* 无匹配结果 */
.no-matches {
  text-align: center;
  padding: 50rpx 20rpx;
  background: rgba(255, 234, 167, 0.05);
  border-radius: 15rpx;
  border: 2rpx dashed #ffeaa7;
}

.no-match-icon {
  font-size: 70rpx;
  margin-bottom: 20rpx;
  display: block;
}

.no-match-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 10rpx;
  display: block;
}

.no-match-subtext {
  font-size: 22rpx;
  color: #888;
  font-weight: 500;
  display: block;
}

/* 错误提示区域 */
.error-section {
  margin-bottom: 30rpx;
}

.error-box {
  background: linear-gradient(135deg, #ff9a9e, #fecfef);
  border: 2rpx solid #ff4757;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
  box-sizing: border-box;
}

.error-icon {
  font-size: 36rpx;
}

.error-text {
  flex: 1;
  font-size: 26rpx;
  color: #721c24;
  font-weight: 600;
  word-break: break-all;
}

.close-error-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ff4757;
  color: white;
  border: none;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 帮助区域 */
.help-section {
  animation: fadeInUp 0.6s ease-out;
}

.help-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.help-content {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120rpx, 1fr));
  gap: 16rpx;
}

.help-row {
  background: rgba(255, 234, 167, 0.05);
  border-radius: 10rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: all 0.3s ease;
}

.help-row:active {
  background: rgba(255, 234, 167, 0.2);
  transform: scale(0.98);
}

.help-code {
  font-size: 24rpx;
  font-weight: 700;
  color: #d63031;
  font-family: 'Monaco', 'Menlo', monospace;
  margin-bottom: 8rpx;
  display: block;
}

.help-desc {
  font-size: 20rpx;
  color: #666;
  font-weight: 500;
  display: block;
  word-wrap: break-word;
}

/* 动画效果 */
@keyframes fadeInScale {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}