<view class="container">
  <!-- 页面标题 -->
  <view class="page-title">
    <text class="title-text">正则表达式测试工具</text>
    <text class="title-subtext">快速测试和验证正则表达式</text>
  </view>

  <!-- 正则输入区域 -->
  <view class="regex-section">
    <view class="section-header">
      <text class="section-title">🔍 正则表达式</text>
      <text class="section-subtitle">输入要测试的正则表达式</text>
    </view>
    <view class="regex-input-container">
      <input type="text" value="{{regexPattern}}" bindinput="setRegexPattern" class="regex-input" placeholder="请输入正则表达式，如：^[a-zA-Z0-9]+$" />
      <view class="flags-container">
        <checkbox-group bindchange="setFlags">
          <label class="flag-item" wx:for="{{availableFlags}}" wx:key="flag">
            <checkbox value="{{item.flag}}" checked="{{item.enabled}}" />
            <text class="flag-text">{{item.label}}</text>
          </label>
        </checkbox-group>
      </view>
    </view>
  </view>

  <!-- 常用正则示例 -->
  <view class="quick-regex-section">
    <view class="section-header">
      <text class="section-title">⚡ 常用正则</text>
      <text class="section-subtitle">点击使用常用的正则表达式</text>
    </view>
    <view class="quick-regex-list">
      <view class="quick-regex-item" wx:for="{{commonRegex}}" wx:key="name" bindtap="useCommonRegex" data-regex="{{item.pattern}}" data-flags="{{item.flags}}">
        <text class="regex-name">{{item.name}}</text>
        <text class="regex-preview">{{item.pattern}}</text>
      </view>
    </view>
  </view>

  <!-- 测试文本区域 -->
  <view class="test-section">
    <view class="section-header">
      <text class="section-title">📝 测试文本</text>
      <text class="section-subtitle">输入要测试的文本内容</text>
    </view>
    <textarea value="{{testText}}" bindinput="setTestText" class="test-textarea" placeholder="请输入要测试的文本..." maxlength="10000" />
    <view class="test-controls">
      <button class="test-btn" bindtap="testRegex">
        <text class="btn-icon">🧪</text>
        <text class="btn-text">测试匹配</text>
      </button>
      <view class="test-stats">
        <view class="stat-item">
          <text class="stat-label">匹配数:</text>
          <text class="stat-value">{{matchCount}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">文本长度:</text>
          <text class="stat-value">{{testText.length}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 错误信息 -->
  <view class="error-section" wx:if="{{errorMessage}}">
    <view class="error-box">
      <text class="error-icon">❌</text>
      <text class="error-text">{{errorMessage}}</text>
      <button class="close-error-btn" bindtap="clearError">×</button>
    </view>
  </view>

  <!-- 测试结果区域 -->
  <view class="results-section" wx:if="{{showResults}}">
    <!-- 匹配结果 -->
    <view class="matches-result" wx:if="{{matches.length > 0}}">
      <view class="section-header">
        <text class="section-title">🎯 匹配结果</text>
        <text class="section-subtitle">{{matches.length}}个匹配项</text>
      </view>
      <scroll-view class="matches-list" scroll-y="true">
        <view class="match-item" wx:for="{{matches}}" wx:key="index">
          <view class="match-header">
            <view class="match-index">
              <text class="index-number">#{{index + 1}}</text>
              <text class="index-position">位置: {{item.index}} - {{item.index + item[0].length}}</text>
            </view>
          </view>
          <view class="match-content">
            <text class="match-text">"{{item[0]}}"</text>
          </view>
          <view class="match-groups" wx:if="{{item.length > 1}}">
            <text class="groups-title">捕获组:</text>
            <view class="group-item" wx:for="{{item.slice(1)}}" wx:for-item="group" wx:key="groupIndex">
              <text class="group-index">$1</text>
              <text class="group-text">"{{group}}"</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 高亮显示 -->
    <view class="highlight-result" wx:if="{{testText}}">
      <view class="section-header">
        <text class="section-title">🌈 文本高亮</text>
        <text class="section-subtitle">匹配部分已高亮显示</text>
      </view>
      <view class="highlight-text">
        <text wx:for="{{highlightedParts}}" wx:key="index" class="text-part highlight-{{item.type}}">
          {{item.text}}
        </text>
      </view>
    </view>

    <!-- 无匹配结果 -->
    <view class="no-matches" wx:if="{{showResults && matches.length === 0 && testText}}">
      <view class="no-match-icon">🔍</view>
      <text class="no-match-text">未找到匹配项</text>
      <text class="no-match-subtext">请尝试调整正则表达式或测试文本</text>
    </view>
  </view>

  <!-- 正则说明 -->
  <view class="help-section">
    <view class="section-header">
      <text class="section-title">💡 正则表达式说明</text>
      <text class="section-subtitle">常用正则表达式语法</text>
    </view>
    <view class="help-content">
      <view class="help-row">
        <text class="help-code">^</text>
        <text class="help-desc">开头</text>
      </view>
      <view class="help-row">
        <text class="help-code">$</text>
        <text class="help-desc">结尾</text>
      </view>
      <view class="help-row">
        <text class="help-code">.</text>
        <text class="help-desc">任意字符</text>
      </view>
      <view class="help-row">
        <text class="help-code">*</text>
        <text class="help-desc">零次或多次</text>
      </view>
      <view class="help-row">
        <text class="help-code">+</text>
        <text class="help-desc">一次或多次</text>
      </view>
      <view class="help-row">
        <text class="help-code">?</text>
        <text class="help-desc">零次或一次</text>
      </view>
      <view class="help-row">
        <text class="help-code">\d</text>
        <text class="help-desc">数字</text>
      </view>
      <view class="help-row">
        <text class="help-code">\w</text>
        <text class="help-desc">字母数字</text>
      </view>
      <view class="help-row">
        <text class="help-code">[abc]</text>
        <text class="help-desc">字符集</text>
      </view>
      <view class="help-row">
        <text class="help-code">(abc)</text>
        <text class="help-desc">分组</text>
      </view>
      <view class="help-row">
        <text class="help-code">|</text>
        <text class="help-desc">或操作符</text>
      </view>
      <view class="help-row">
        <text class="help-code">i</text>
        <text class="help-desc">忽略大小写</text>
      </view>
      <view class="help-row">
        <text class="help-code">g</text>
        <text class="help-desc">全局匹配</text>
      </view>
      <view class="help-row">
        <text class="help-code">m</text>
        <text class="help-desc">多行模式</text>
      </view>
    </view>
  </view>
</view>