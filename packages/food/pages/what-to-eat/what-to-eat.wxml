<view class="container">
  <!-- 餐型选择 -->
  <view class="meal-type-container">
    <view class="meal-type-title">选择餐型</view>
    <view class="meal-type-buttons">
      <block wx:for="{{mealTypes}}" wx:key="*this">
        <view
          class="meal-type-button {{selectedMealType === item ? 'active' : ''}}"
          bindtap="selectMealType"
          data-type="{{item}}"
        >
          {{item}}
        </view>
      </block>
    </view>
  </view>

  <!-- 分类排除开关 -->
  <view class="category-filter-container">
    <view class="filter-title">排除类别（点击关闭）</view>
    <view class="filter-tags">
      <block wx:for="{{foodCategories}}" wx:key="*this">
        <view
          class="filter-tag {{categoryEnabled[item] ? 'enabled' : 'disabled'}}"
          bindtap="toggleCategory"
          data-cat="{{item}}"
        >
          {{categoryMap[item].emoji}} {{categoryMap[item].name}}
        </view>
      </block>
    </view>
  </view>

  <!-- 随机按钮 -->
  <view class="random-container">
    <button
      class="random-button"
      bindtap="startRandom"
      disabled="{{isSpinning}}"
    >
      <view class="button-content">
        <text>{{isSpinning ? '选选中...' : '🎲 开始抽取'}}</text>
      </view>
    </button>
  </view>

  <!-- 转盘动画 -->
  <block wx:if="{{isSpinning}}">
    <view class="spin-wheel-container">
      <view class="spin-wheel">
        <view class="spin-food">
          <text class="spin-emoji">{{spinFoods[spinIndex] ? spinFoods[spinIndex].emoji : '🍽️'}}</text>
          <text class="spin-name">{{spinFoods[spinIndex] ? spinFoods[spinIndex].name : '正在思考...'}}</text>
        </view>
      </view>
      <view class="spin-hint">正在思考吃什么...</view>
    </view>
  </block>

  <!-- 结果显示 -->
  <view class="result-container" wx:if="{{showResult && result}}">
    <view class="result-header">
      <text class="result-emoji">🍽️</text>
      <text class="result-title">{{selectedMealType}}推荐</text>
    </view>

    <!-- 餐食卡片 -->
    <view class="meal-cards">
      <view class="meal-card" wx:if="{{result.meal.staple}}">
        <text class="card-emoji">{{result.meal.staple.emoji}}</text>
        <text class="card-name">{{result.meal.staple.name}}</text>
        <text class="card-portion">{{result.meal.staple.portionText}}</text>
        <view class="card-info">
          <text class="card-tag">主食</text>
          <text class="card-cal">{{result.meal.staple.actualCalories}}大卡</text>
        </view>
      </view>
      <view class="meal-card" wx:if="{{result.meal.protein}}">
        <text class="card-emoji">{{result.meal.protein.emoji}}</text>
        <text class="card-name">{{result.meal.protein.name}}</text>
        <text class="card-portion">{{result.meal.protein.portionText}}</text>
        <view class="card-info">
          <text class="card-tag">蛋白质</text>
          <text class="card-cal">{{result.meal.protein.actualCalories}}大卡</text>
        </view>
      </view>
      <view class="meal-card" wx:if="{{result.meal.vegetable}}">
        <text class="card-emoji">{{result.meal.vegetable.emoji}}</text>
        <text class="card-name">{{result.meal.vegetable.name}}</text>
        <text class="card-portion">{{result.meal.vegetable.portionText}}</text>
        <view class="card-info">
          <text class="card-tag">蔬菜</text>
          <text class="card-cal">{{result.meal.vegetable.actualCalories}}大卡</text>
        </view>
      </view>
      <view class="meal-card" wx:if="{{result.meal.fruit}}">
        <text class="card-emoji">{{result.meal.fruit.emoji}}</text>
        <text class="card-name">{{result.meal.fruit.name}}</text>
        <text class="card-portion">{{result.meal.fruit.portionText}}</text>
        <view class="card-info">
          <text class="card-tag">水果</text>
          <text class="card-cal">{{result.meal.fruit.actualCalories}}大卡</text>
        </view>
      </view>
      <view class="meal-card" wx:if="{{result.meal.drink}}">
        <text class="card-emoji">{{result.meal.drink.emoji}}</text>
        <text class="card-name">{{result.meal.drink.name}}</text>
        <text class="card-portion">{{result.meal.drink.portionText}}</text>
        <view class="card-info">
          <text class="card-tag">饮品</text>
          <text class="card-cal">{{result.meal.drink.actualCalories}}大卡</text>
        </view>
      </view>
    </view>

    <!-- 热量统计 -->
    <view class="calories-container">
      <view class="calories-item">
        <text class="calories-num">{{result.totalCalories}}</text>
        <text class="calories-unit">大卡</text>
      </view>
      <view class="calories-tip">{{result.suggestion}}</view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="action-button re-random" bindtap="reRandom">
        🔄 再来一次
      </button>
      <button class="action-button poster" bindtap="MakePosters">
        🖼️ 生成海报
      </button>
      <button class="action-button list" bindtap="showAllFoods">
        📋 食物清单
      </button>
    </view>
  </view>

  <!-- 初始提示 -->
  <view class="initial-tip" wx:if="{{!showResult && !isSpinning}}">
    <view class="tip-emoji">🤔</view>
    <text class="tip-text">选择餐型，点击抽取</text>
    <text class="tip-subtext">不想吃某类？点击上方标签排除</text>
  </view>

  <!-- 食物清单模态框 -->
  <view class="modal" wx:if="{{showFoodModal}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">🍽️ 全部食物清单</text>
        <text class="modal-close" bindtap="closeFoodModal">×</text>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <block wx:for="{{foodCategories}}" wx:key="*this">
          <view class="category-section">
            <text class="category-title">{{categoryMap[item].emoji}} {{categoryMap[item].name}}</text>
            <view class="food-grid">
              <block wx:for="{{foodData[item]}}" wx:for-item="foodItem" wx:key="index">
                <view class="food-item">
                  <text class="food-emoji">{{foodItem.emoji}}</text>
                  <text class="food-name">{{foodItem.name}}</text>
                  <text class="food-portion">{{foodItem.portionDesc}}</text>
                  <text class="food-calories">约{{foodItem.caloriesPerPortion}}大卡</text>
                </view>
              </block>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>

  <!-- 海报生成Canvas -->
  <canvas
    id="foodPosterCanvas"
    type="2d"
    style="position:absolute;left:-9999rpx;width:{{canvaswidth}}px;height:{{canvasheight}}px;"
    canvas-id="foodPosterCanvas"
  ></canvas>
  <!-- 搴曢儴骞垮憡 -->
  <ad unit-id="adunit-07e9c9da9e4b8254" ad-intervals="30" binderror="onAdError" bindclose="onAdClose"></ad>
</view>
