.container {
  padding: 24rpx;
  background: linear-gradient(135deg, #fff9f0 0%, #fff5eb 100%);
  min-height: 100vh;
}

/* 餐型选择 */
.meal-type-container {
  margin-bottom: 24rpx;
}

.meal-type-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 12rpx;
}

.meal-type-buttons {
  display: flex;
  gap: 16rpx;
}

.meal-type-button {
  flex: 1;
  padding: 16rpx 0;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  transition: all 0.2s;
}

.meal-type-button.active {
  background: linear-gradient(135deg, #ff9a56, #ff6b35);
  color: #fff;
  border-color: #ff6b35;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

/* 分类排除开关 */
.category-filter-container {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
}

.filter-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-tag {
  padding: 8rpx 18rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  transition: all 0.2s;
}

.filter-tag.enabled {
  background: #fff0e6;
  color: #ff6b35;
  border: 1px solid #ffd4b8;
}

.filter-tag.disabled {
  background: #f5f5f5;
  color: #bbb;
  border: 1px solid #e0e0e0;
  text-decoration: line-through;
}

/* 随机按钮 */
.random-container {
  display: flex;
  justify-content: center;
  margin: 16rpx 0 24rpx;
}

.random-button {
  width: 90%;
  height: 96rpx;
  background: linear-gradient(135deg, #ff9a56, #ff6b35);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 53, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.random-button::after {
  border: none;
}

.random-button:disabled {
  background: linear-gradient(135deg, #ccc, #aaa);
  box-shadow: none;
}

.button-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

/* 转盘动画 */
.spin-wheel-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.spin-wheel {
  width: 280rpx;
  height: 280rpx;
  background: linear-gradient(135deg, #fff, #fff5eb);
  border-radius: 50%;
  border: 6rpx solid #ff9a56;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.2);
  animation: spin-pulse 1s ease-in-out infinite;
}

.spin-food {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.spin-emoji {
  font-size: 80rpx;
  animation: bounce-emoji 0.5s ease-in-out infinite;
}

.spin-name {
  font-size: 26rpx;
  color: #ff6b35;
  font-weight: bold;
  margin-top: 8rpx;
  animation: fade-in-out 1s ease-in-out infinite;
}

.spin-hint {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
  animation: fade-in-out 1.5s ease-in-out infinite;
}

@keyframes spin-pulse {
  0%, 100% { transform: scale(1); box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.2); }
  50% { transform: scale(1.03); box-shadow: 0 12rpx 40rpx rgba(255, 107, 53, 0.35); }
}

@keyframes bounce-emoji {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-8rpx) rotate(5deg); }
}

@keyframes fade-in-out {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* 结果卡片 */
.result-container {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.result-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.result-emoji {
  font-size: 40rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 餐食卡片网格 */
.meal-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.meal-card {
  background: #fff9f5;
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  border: 1px solid #ffe8d6;
  transition: transform 0.2s;
}

.meal-card:active {
  transform: scale(0.95);
}

.card-emoji {
  font-size: 48rpx;
}

.card-name {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  text-align: center;
}

.card-tag {
  font-size: 18rpx;
  color: #ff9a56;
  background: #fff0e6;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
}

/* 热量统计 */
.calories-container {
  background: linear-gradient(135deg, #fff5eb, #fff0e6);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.calories-item {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
}

.calories-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6b35;
}

.calories-unit {
  font-size: 22rpx;
  color: #ff6b35;
}

.calories-tip {
  font-size: 22rpx;
  color: #666;
  line-height: 1.5;
  flex: 1;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 12rpx;
}

.action-button {
  flex: 1;
  height: 76rpx;
  border-radius: 38rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin: 0;
  padding: 0;
}

.action-button::after {
  border: none;
}

.action-button.re-random {
  background: #fff0e6;
  color: #ff6b35;
  border: 1px solid #ffd4b8;
}

.action-button.poster {
  background: linear-gradient(135deg, #ff9a56, #ff6b35);
  color: #fff;
}

.action-button.list {
  background: #f5f5f5;
  color: #666;
  border: 1px solid #e0e0e0;
}

/* 初始提示 */
.initial-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 20rpx;
  gap: 16rpx;
}

.tip-emoji {
  font-size: 80rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #666;
}

.tip-subtext {
  font-size: 22rpx;
  color: #bbb;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1px solid #f0f0f0;
}

.modal-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #bbb;
  line-height: 1;
  padding: 0 8rpx;
}

.modal-body {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.category-section {
  margin-bottom: 28rpx;
}

.category-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.food-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.food-item {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 14rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  transition: background 0.2s;
}

.food-item:active {
  background: #f0f0f0;
}

.food-emoji {
  font-size: 36rpx;
}

.food-name {
  font-size: 20rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
}

.food-calories {
  font-size: 16rpx;
  color: #999;
}
