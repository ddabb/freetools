<view class="container">
  <view class="section-title">📊 数据统计器</view>
  
  <!-- 数据输入区域 -->
  <view class="input-section">
    <view class="section-header">
      <text class="section-label">数据输入</text>
      <button class="load-sample-btn" bindtap="loadSample">加载示例</button>
    </view>
    <textarea value="{{inputData}}" bindinput="setInputData" class="data-textarea" placeholder="请输入数据，用空格、逗号、分号或换行分隔，例如：12 15 18 20 22 25 28 30 35 40" maxlength="2000" />
    <view class="input-hint">支持数字、文本和混合数据类型</view>
  </view>
  
  <!-- 数据类型选择 -->
  <view class="type-section">
    <view class="section-header">
      <text class="section-label">数据类型</text>
    </view>
    <picker bindchange="setDataType" value="{{dataTypeIndex}}" range="{{dataTypes}}" class="type-picker">
      <view class="picker-display">
        {{dataTypes[dataTypeIndex]}}
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>
  
  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="action-btn primary-btn" bindtap="analyzeData">
      <text class="btn-icon">📈</text>
      <text class="btn-text">分析数据</text>
    </button>
    <button class="action-btn secondary-btn" bindtap="exportResult">
      <text class="btn-icon">📋</text>
      <text class="btn-text">导出结果</text>
    </button>
    <button class="action-btn secondary-btn" bindtap="exportResultWithInput">
      <text class="btn-icon">📝</text>
      <text class="btn-text">导出含数据</text>
    </button>
  </view>
  
  <!-- 分析结果 -->
  <view class="result-section" wx:if="{{analysisResult}}">
    <view class="section-header">
      <text class="section-label">分析结果</text>
    </view>
    <view class="result-grid">
      <view class="result-item">
        <text class="result-label">样本数量</text>
        <text class="result-value">{{analysisResult.count}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">总和</text>
        <text class="result-value">{{analysisResult.sum}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">平均值</text>
        <text class="result-value">{{analysisResult.mean}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">中位数</text>
        <text class="result-value">{{analysisResult.median}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">方差</text>
        <text class="result-value">{{analysisResult.variance}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">标准差</text>
        <text class="result-value">{{analysisResult.stdDev}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">最小值</text>
        <text class="result-value">{{analysisResult.min}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">最大值</text>
        <text class="result-value">{{analysisResult.max}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">极差</text>
        <text class="result-value">{{analysisResult.range}}</text>
      </view>
    </view>
  </view>
  
  <!-- 使用帮助 -->
  <view class="help-section">
    <view class="section-header">
      <text class="section-label">使用帮助</text>
    </view>
    <view class="help-content">
      <text class="help-text">• 支持输入数字、文本和混合数据类型</text>
      <text class="help-text">• 数据之间用空格、逗号、分号或换行分隔</text>
      <text class="help-text">• 分析结果包括基本统计量和分布特征</text>
      <text class="help-text">• 可以导出分析结果或含数据的完整报告到剪贴板</text>
    </view>
  </view>
</view>