/**packages/data/pages/data-analyzer/data-analyzer.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 20rpx 16rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  width: 100%;
}

/* 顶部标题栏 */
.header-section {
  padding: 20rpx 0 30rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 通用section样式 */
.input-section,
.result-section,
.help-section {
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  width: 100%;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

/* 头部操作按钮 */
.header-actions {
  display: flex;
  gap: 6rpx;
  flex-wrap: nowrap;
}

.icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 12rpx;
  background: #f0f2f5;
  border: none;
  border-radius: 12rpx;
  font-size: 20rpx;
  min-width: 70rpx;
  max-width: 70rpx;
  transition: all 0.2s;
  flex-shrink: 0;
}

.icon-btn.danger {
  background: #ffe6e6;
  color: #ff4444;
}

.icon-btn-hover {
  background: #e0e2e5;
  transform: scale(0.95);
}

.icon-text {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.icon-label {
  font-size: 20rpx;
  color: #666;
}

.icon-btn.danger .icon-label {
  color: #ff4444;
}

/* 数据类型标签 */
.type-tabs {
  display: flex;
  gap: 8rpx;
  margin-bottom: 20rpx;
  flex-wrap: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 4rpx;
}

.type-tab {
  flex: 1;
  min-width: 120rpx;
  padding: 14rpx 6rpx;
  text-align: center;
  background: #f0f2f5;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #666;
  transition: all 0.3s;
  border: 2rpx solid transparent;
  flex-shrink: 0;
}

.type-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: 600;
  border-color: #667eea;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.tab-text {
  font-size: 22rpx;
  white-space: nowrap;
}

/* 数据输入区域 */
.data-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #333;
  resize: none;
  box-sizing: border-box;
  line-height: 1.5;
  transition: all 0.3s;
}

.data-textarea:focus {
  border-color: #667eea;
  background: white;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.input-hint {
  font-size: 20rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
}

/* 操作按钮区域 */
.action-section {
  margin-top: 20rpx;
}

.primary-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
}

.primary-btn-hover {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.export-buttons {
  display: flex;
  gap: 12rpx;
}

.secondary-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.secondary-btn-hover {
  background: #667eea;
  color: white;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 26rpx;
}

.btn-text {
  font-size: 24rpx;
}

/* 分析结果 */
.key-stats {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.stat-item {
  flex: 1;
  min-width: 180rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 16rpx 10rpx;
  text-align: center;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  flex-shrink: 0;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  margin-bottom: 8rpx;
  opacity: 0.9;
}

.stat-value {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  font-family: 'Monaco', 'Menlo', monospace;
}

.detail-stats {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-row {
  display: flex;
  gap: 12rpx;
}

.detail-row.highlight {
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  border-radius: 12rpx;
  padding: 12rpx;
  border: 2rpx solid #667eea40;
}

.detail-item {
  flex: 1;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx 8rpx;
  text-align: center;
  border: 2rpx solid #e9ecef;
  min-width: 0;
}

.detail-label {
  display: block;
  font-size: 20rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.detail-value {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #667eea;
  font-family: 'Monaco', 'Menlo', monospace;
}

.detail-row.highlight .detail-value {
  color: #764ba2;
}

/* 复制按钮 */
.copy-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.copy-icon {
  font-size: 20rpx;
}

.copy-text {
  font-size: 22rpx;
}

/* 使用帮助 */
.help-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.help-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.help-icon {
  font-size: 24rpx;
  min-width: 32rpx;
}

.help-text {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}
