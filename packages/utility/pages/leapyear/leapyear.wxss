/**leapyear.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 16rpx;
  min-height: 100vh;
}

/* 标题区域 */
.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}



/* 表单容器 */
.form-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

/* 表单标签 */
.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.required-mark {
  color: #ff4757;
  font-size: 28rpx;
  margin-left: 8rpx;
}

/* 带单位的输入框 */
.input-with-unit {
  position: relative;
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
  overflow: hidden;
  transition: all 0.3s ease;
}

.input-with-unit:active {
  border-color: #667eea;
  background: #fff;
}

.input-field {
  flex: 1;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  background: transparent;
  border: none;
  outline: none;
}

.input-field::placeholder {
  color: #adb5bd;
}

.unit-text {
  padding-right: 28rpx;
  font-size: 26rpx;
  color: #6c757d;
  font-weight: 500;
  background: #e9ecef;
  padding: 24rpx 28rpx;
  border-left: 2rpx solid #dee2e6;
}

/* 按钮表单项 */
.btn-item {
  margin-bottom: 0;
}

.full-width-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.full-width-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.btn-text {
  margin-left: 8rpx;
}

/* 结果显示框 */
.result-box {
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
  padding: 24rpx;
}

.output-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 800;
  text-align: center;
  display: block;
}