<!--leapyear.wxml-->
<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 标题 -->
    <view class="header">
      <text class="title">判断是否闰年</text>
    </view>

    <!-- 年份输入 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">请输入年份</text>
        <text class="required-mark">*</text>
      </view>
      <view class="input-with-unit">
        <input type="number" value="{{year}}" bindinput="inputChange" class="input-field" placeholder="例如：2024"/>
        <text class="unit-text">年</text>
      </view>
    </view>

    <!-- 判断按钮 -->
    <view class="form-item btn-item">
      <button class="calculate-btn full-width-btn" bindtap="checkLeapYear">
        <text class="btn-text">判断</text>
      </button>
    </view>

    <!-- 结果显示 -->
    <view class="form-item" wx:if="{{result !== ''}}">
      <view class="form-label">
        <text class="label-text">判断结果</text>
      </view>
      <view class="result-box">
        <text class="output-text">{{result}}</text>
      </view>
    </view>
  </view>
  
  <!-- 概念说明 -->
  <view class="concept-container dock-bottom">
    <view class="concept-header">
      <text class="concept-title">概念说明</text>
    </view>
    <view class="concept-content">
      <text class="concept-text">闰年：能被4整除但不能被100整除，或者能被400整除的年份。</text>
      <text class="concept-text">平年：不能被4整除，或者能被100整除但不能被400整除的年份。</text>
      <text class="concept-text">闰年有366天，2月有29天；平年有365天，2月有28天。</text>
    </view>
  </view>
</view>