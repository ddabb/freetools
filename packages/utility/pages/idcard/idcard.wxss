/**packages/utility/pages/idcard/idcard.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 20rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 输入框 */
.input-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
}

.input {
  width: 100%;
  font-size: 32rpx;
  border: none;
  outline: none;
  color: #333;
  font-weight: 500;
  font-family: monospace;
  letter-spacing: 4rpx;
}

/* 验证按钮 */
.validate-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
}

.validate-btn:active {
  transform: scale(0.98);
}

/* 结果显示 */
.result-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.result-box.success::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #11998e, #38ef7d);
}

.result-box.error::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #f093fb, #f5576c);
}

.result-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.result-icon {
  font-size: 80rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.result-box.success .result-icon {
  color: #11998e;
}

.result-box.error .result-icon {
  color: #f5576c;
}

.result-message {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  display: block;
}

.result-box.success .result-message {
  color: #11998e;
}

.result-box.error .result-message {
  color: #f5576c;
}

/* 详细信息 */
.result-details {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 12rpx;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.detail-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 700;
}

/* 错误信息 */
.error-message {
  text-align: center;
  padding: 30rpx;
}

.error-message text {
  font-size: 28rpx;
  color: #f5576c;
  line-height: 1.6;
}

/* 重置按钮 */
.reset-btn {
  width: 100%;
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 30rpx rgba(250, 112, 154, 0.4);
}

.reset-btn:active {
  transform: scale(0.98);
}
