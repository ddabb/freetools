.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
}

/* 顶部装饰区域 */
.header-bg {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.main-icon {
  font-size: 60rpx;
}

.main-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 内容包装器 */
.content-wrapper {
  padding: 40rpx 30rpx;
}

/* 通用卡片样式 */
.card-shadow {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  margin-bottom: 30rpx;
}

.input-card {
  animation: slideInUp 0.6s ease-out;
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in-up {
  animation: fadeInUp 0.6s ease-out both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 卡片头部 */
.card-header {
  padding: 40rpx 40rpx 20rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.card-body {
  padding: 30rpx 40rpx 40rpx;
}

/* 输入框样式 */
.input-section {
  margin-bottom: 40rpx;
}

.input-wrapper {
  margin-bottom: 30rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.input-container {
  position: relative;
  display: flex;
  align-items: center;
}

.modern-input {
  width: 100%;
  height: 88rpx;
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 16rpx;
  padding: 0 80rpx 0 30rpx;
  font-size: 32rpx;
  color: #333;
  transition: all 0.3s ease;
}

.modern-input:focus {
  border-color: #667eea;
  background: white;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.1);
}

.input-status {
  position: absolute;
  right: 25rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input-status.typing {
  background: #ffc107;
}

.input-status.valid {
  background: #28a745;
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  background: white;
  border-radius: 50%;
}

/* 快捷输入区域 */
.quick-input-section {
  margin-top: 30rpx;
}

.section-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 15rpx;
  display: block;
}

.quick-buttons {
  display: flex;
  gap: 20rpx;
}

.quick-btn {
  flex: 1;
  height: 60rpx;
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.quick-btn.active {
  background: #667eea;
  border-color: #667eea;
  color: white;
}

/* 操作按钮区域 */
.action-section {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.primary-btn {
  flex: 2;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border: none;
  border-radius: 20rpx;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  opacity: 0.6;
}

.primary-btn.ready {
  opacity: 1;
}

.primary-btn:not([disabled]):hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 25rpx rgba(102, 126, 234, 0.4);
}

.btn-icon {
  font-size: 36rpx;
}

.btn-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: shine 2s infinite;
}

@keyframes shine {
  0% { left: -100%; }
  100% { left: 100%; }
}

.secondary-btn {
  flex: 1;
  height: 96rpx;
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

/* 加载状态 */
.loading-card {
  padding: 60rpx;
  text-align: center;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* 结果卡片 */
.result-card {
  overflow: hidden;
}

.success-card {
  border-left: 8rpx solid #28a745;
}

.error-card {
  border-left: 8rpx solid #dc3545;
}

.result-header {
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.success-icon, .error-icon {
  font-size: 48rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  flex: 1;
}

.success-badge, .error-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: white;
}

.success-badge {
  background: #28a745;
}

.error-badge {
  background: #dc3545;
}

/* 成功结果内容 */
.info-grid {
  padding: 30rpx 40rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f8f9fa;
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 40rpx;
  margin-right: 25rpx;
  width: 60rpx;
  text-align: center;
}

.info-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.highlight {
  color: #667eea;
  font-weight: bold;
}

/* 错误结果内容 */
.error-content {
  padding: 30rpx 40rpx;
}

.error-message {
  display: block;
  font-size: 28rpx;
  color: #dc3545;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.error-help {
  display: flex;
  align-items: center;
  gap: 15rpx;
  padding: 20rpx;
  background: #fff3cd;
  border-radius: 12rpx;
}

.help-icon {
  font-size: 32rpx;
}

.help-text {
  font-size: 26rpx;
  color: #856404;
}

/* 结果操作按钮 */
.result-actions {
  padding: 30rpx 40rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: none;
  transition: all 0.3s ease;
}

.copy-btn {
  background: #17a2b8;
  color: white;
}

.retry-btn {
  background: #6c757d;
  color: white;
}

/* 提示卡片 */
.tips-card {
  background: rgba(255, 193, 7, 0.1);
  border: 1rpx solid rgba(255, 193, 7, 0.3);
}

.tips-header {
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 15rpx;
  background: rgba(255, 193, 7, 0.05);
}

.tips-icon {
  font-size: 32rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #856404;
}

.tips-content {
  padding: 30rpx 40rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #856404;
  line-height: 1.6;
}

/* 悬停效果 */
.btn-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-primary-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 35rpx rgba(102, 126, 234, 0.5);
}

.btn-secondary-hover {
  background: #e9ecef;
}

.btn-action-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}