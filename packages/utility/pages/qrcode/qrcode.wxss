/* packages/utility/pages/qrcode/qrcode.wxss */
.qrcode-container {
  padding: 30rpx;
}

.input-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.form-item {
  padding: 10rpx 0;
}

.textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.button-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.btn-generate,
.btn-clear {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-generate {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: #fff;
}

.btn-clear {
  background: #f5f5f5;
  color: #666;
}

.qrcode-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  text-align: center;
}

.qrcode-wrapper {
  margin-bottom: 30rpx;
}

.qrcode-canvas {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto;
  display: block;
}

.qrcode-text {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 20rpx;
  word-break: break-all;
  max-width: 500rpx;
  margin-left: auto;
  margin-right: auto;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #27ae60 0%, #219a52 100%);
  color: #fff;
}

.tips {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fff9e6;
  border-radius: 8rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #f59a23;
}