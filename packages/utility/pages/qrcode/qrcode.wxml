<view class="qrcode-container">
  <view class="input-section">
    <view class="form-item">
      <input
        class="input"
        placeholder="输入文本以生成二维码"
        value="{{text}}"
        bindinput="onTextInput"
        maxlength="500"
      />
    </view>
  </view>

  <view class="action-buttons">
    <button class="btn-generate" bindtap="generate">生成</button>
    <button class="btn-save" bindtap="saveImage">保存</button>
    <button class="btn-clear" bindtap="clear">清空</button>
  </view>

  <view wx:if="{{showQrcode && qrcodeText}}" class="qrcode-section">
    <view class="qrcode-wrapper">
      <canvas type="2d" id="qrcodeCanvas" class="qrcode-canvas" />
      <text class="qrcode-text">{{qrcodeText}}</text>
    </view>
  </view>

  <view class="tips">
    <text class="tips-text">* 支持文本、网址等内容生成二维码</text>
  </view>
</view>