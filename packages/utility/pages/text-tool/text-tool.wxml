<!--text-tool.wxml-->
<view class="container">
  <!-- 文本输入 -->
  <view class="section">
    <text class="section-title">输入文本</text>
    <view class="input-box">
      <textarea placeholder="请输入文本" value="{{inputText}}" bindinput="setInputText" class="textarea"></textarea>
    </view>
  </view>
  
  <!-- 操作按钮 -->
  <view class="section">
    <view class="button-grid">
      <button class="action-btn" bindtap="reverseText">文本反转</button>
      <button class="action-btn" bindtap="toUpperCase">转为大写</button>
      <button class="action-btn" bindtap="toLowerCase">转为小写</button>
      <button class="action-btn" bindtap="countWords">字数统计</button>
    </view>
  </view>
  
  <!-- 结果展示 -->
  <view class="section" wx:if="{{outputText}}">
    <text class="section-title">处理结果</text>
    <view class="output-box">
      <text class="output-text">{{outputText}}</text>
      <button class="copy-btn" bindtap="copyText">复制</button>
    </view>
  </view>
  
  <!-- 字数统计结果 -->
  <view class="section" wx:if="{{wordCount}}">
    <text class="section-title">字数统计</text>
    <view class="count-box">
      <view class="count-item">
        <text class="count-label">字符数：</text>
        <text class="count-value">{{wordCount.characters}}</text>
      </view>
      <view class="count-item">
        <text class="count-label">单词数：</text>
        <text class="count-value">{{wordCount.words}}</text>
      </view>
      <view class="count-item">
        <text class="count-label">行数：</text>
        <text class="count-value">{{wordCount.lines}}</text>
      </view>
    </view>
  </view>
</view>