<!--text-tool.wxml-->
<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 标题 -->
    <view class="header">
      <text class="title">文本工具</text>
    </view>

    <!-- 文本输入 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">输入文本</text>
        <text class="required-mark">*</text>
      </view>
      <view class="input-with-unit">
        <textarea placeholder="请输入文本" value="{{inputText}}" bindinput="setInputText" class="input-field textarea-field"></textarea>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="form-item">
      <view class="button-grid">
        <button class="action-btn full-width-btn" bindtap="reverseText">文本反转</button>
        <button class="action-btn full-width-btn" bindtap="toUpperCase">转为大写</button>
        <button class="action-btn full-width-btn" bindtap="toLowerCase">转为小写</button>
        <button class="action-btn full-width-btn" bindtap="countWords">字数统计</button>
      </view>
    </view>

    <!-- 结果显示 -->
    <view class="form-item" wx:if="{{outputText}}">
      <view class="form-label">
        <text class="label-text">处理结果</text>
      </view>
      <view class="result-box">
        <text class="output-text">{{outputText}}</text>
        <button class="copy-btn" bindtap="copyText">复制</button>
      </view>
    </view>

    <!-- 字数统计结果 -->
    <view class="form-item" wx:if="{{wordCount}}">
      <view class="form-label">
        <text class="label-text">字数统计</text>
      </view>
      <view class="count-box">
        <view class="count-item">
          <text class="count-label">字符数：</text>
          <text class="count-value">{{wordCount.characters}}</text>
        </view>
        <view class="count-item">
          <text class="count-label">单词数：</text>
          <text class="count-value">{{wordCount.words}}</text>
        </view>
        <view class="count-item">
          <text class="count-label">行数：</text>
          <text class="count-value">{{wordCount.lines}}</text>
        </view>
      </view>
    </view>
  </view>
</view>