/**text-tool.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 16rpx;
  min-height: 100vh;
}

/* 标题区域 */
.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 表单容器 */
.form-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

/* 表单标签 */
.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.required-mark {
  color: #ff4757;
  font-size: 28rpx;
  margin-left: 8rpx;
}

/* 带单位的输入框 */
.input-with-unit {
  position: relative;
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
  overflow: hidden;
  transition: all 0.3s ease;
}

.input-with-unit:active {
  border-color: #667eea;
  background: #fff;
}

.input-field {
  flex: 1;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  background: transparent;
  border: none;
  outline: none;
}

.textarea-field {
  width: 100%;
  height: 300rpx;
  resize: none;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: #adb5bd;
}

/* 按钮网格 */
.button-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.action-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 全宽按钮 */
.full-width-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.full-width-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 结果显示框 */
.result-box {
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.output-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  word-break: break-all;
  margin-right: 20rpx;
  font-weight: 500;
}

.copy-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.copy-btn:active {
  transform: translateY(1rpx);
  box-shadow: 0 3rpx 8rpx rgba(102, 126, 234, 0.3);
}

/* 统计框 */
.count-box {
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
  padding: 24rpx;
}

.count-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #e9ecef;
}

.count-item:last-child {
  border-bottom: none;
}

.count-label {
  font-size: 30rpx;
  color: #666;
  font-weight: 600;
}

.count-value {
  font-size: 30rpx;
  font-weight: 800;
  color: #667eea;
}