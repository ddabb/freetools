/**text-tool.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
}

.container {
  padding: 20rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.input-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
}

.textarea {
  width: 100%;
  height: 300rpx;
  font-size: 32rpx;
  border: none;
  outline: none;
  resize: none;
  color: #333;
  font-weight: 500;
}

.button-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.action-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.98);
}

.output-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  position: relative;
  overflow: hidden;
}

.output-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #a18cd1, #fbc2eb);
}

.output-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  word-break: break-all;
  margin-right: 20rpx;
  font-weight: 600;
}

.copy-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 20rpx rgba(245, 87, 108, 0.3);
  transition: all 0.3s ease;
}

.copy-btn:active {
  transform: scale(0.95);
}

.count-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.count-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #a18cd1, #fbc2eb);
}

.count-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.count-item:last-child {
  border-bottom: none;
}

.count-label {
  font-size: 32rpx;
  color: #666;
  font-weight: 600;
}

.count-value {
  font-size: 32rpx;
  font-weight: 800;
  color: #a18cd1;
}
