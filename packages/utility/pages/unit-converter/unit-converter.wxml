<!--packages/utility/pages/unit-converter/unit-converter.wxml-->
<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 分类选择 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">转换分类</text>
        <text class="required-mark">*</text>
      </view>
      <picker bindchange="onCategoryChange" value="{{categoryIndex}}" range="{{categories}}" class="form-picker">
        <view class="picker-display {{categoryIndex === -1 ? 'placeholder' : ''}}">
          {{categories[categoryIndex] || '请选择转换分类'}}
        </view>
      </picker>
    </view>

    <!-- 源单位 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">从</text>
        <text class="required-mark">*</text>
      </view>
      <view class="input-with-unit">
        <input type="digit" value="{{inputValue}}" bindinput="onInputChange" class="input-field" placeholder="请输入数值" focus="{{inputFocus}}"/>
        <picker 
          range="{{currentUnits}}" 
          value="{{fromUnitIndex}}"
          bindchange="onFromUnitChange"
          class="unit-picker"
        >
          <view class="unit-picker-display">
            {{currentUnits[fromUnitIndex]}}
          </view>
        </picker>
      </view>
    </view>

    <!-- 目标单位 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">到</text>
        <text class="required-mark">*</text>
      </view>
      <view class="input-with-unit">
        <text class="result-display">{{resultValue || '0'}}</text>
        <picker 
          range="{{currentUnits}}" 
          value="{{toUnitIndex}}"
          bindchange="onToUnitChange"
          class="unit-picker"
        >
          <view class="unit-picker-display">
            {{currentUnits[toUnitIndex]}}
          </view>
        </picker>
      </view>
    </view>

    <!-- 交换按钮 -->
    <view class="form-item">
      <button class="swap-btn full-width-btn" bindtap="swapUnits">
        <text class="btn-text">交换单位 ⇅</text>
      </button>
    </view>

    <!-- 计算按钮 -->
    <view class="form-item btn-item">
      <button class="calculate-btn full-width-btn" bindtap="calculate">
        <text class="btn-text">开始转换</text>
      </button>
    </view>

    <!-- 结果展示 -->
    <view class="result-section" wx:if="{{showResult}}">
      <view class="result-box">
        <view class="result-item">
          <text class="result-label">转换结果</text>
          <text class="result-value bmi">{{resultValue}}</text>
          <text class="bmi-status">{{resultFormula}}</text>
        </view>
        <view class="result-divider"></view>
        <view class="result-row">
          <view class="result-item">
            <text class="result-label">从</text>
            <text class="result-value ideal-weight">{{inputValue}} {{currentUnits[fromUnitIndex]}}</text>
          </view>
          <view class="result-item">
            <text class="result-label">到</text>
            <text class="result-value ideal-weight">{{resultValue}} {{currentUnits[toUnitIndex]}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
