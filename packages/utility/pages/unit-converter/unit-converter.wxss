/**packages/utility/pages/unit-converter/unit-converter.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 16rpx;
  min-height: 100vh;
}

.result-section {
  margin-bottom: 32rpx;
}

/* 表单容器 */
.form-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 表单项 */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

/* 表单标签 */
.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.required-mark {
  color: #ff4757;
  font-size: 28rpx;
  margin-left: 8rpx;
}

/* 性别选择 - 选择框样式 */
.form-picker {
  margin-top: 0;
}

.picker-display {
  background: #f8f9fa;
  padding: 24rpx 28rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  transition: all 0.3s ease;
}

.picker-display.placeholder {
  color: #adb5bd;
}

.picker-display:active {
  border-color: #667eea;
  background: #fff;
}

/* 带单位的输入框 */
.input-with-unit {
  position: relative;
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
  overflow: hidden;
  transition: all 0.3s ease;
}

.input-with-unit:active {
  border-color: #667eea;
  background: #fff;
}

.input-field {
  flex: 1;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  background: transparent;
  border: none;
  outline: none;
}

.input-field::placeholder {
  color: #adb5bd;
}

.result-display {
  flex: 1;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #51cf66;
  font-weight: 700;
  background: transparent;
  text-align: left;
}

.unit-picker {
  margin-top: 0;
}

.unit-picker-display {
  padding: 24rpx 28rpx;
  font-size: 26rpx;
  color: #6c757d;
  font-weight: 500;
  background: #e9ecef;
  border-left: 2rpx solid #dee2e6;
  min-width: 120rpx;
  text-align: center;
}

/* 按钮表单项 */
.btn-item {
  margin-bottom: 0;
}

.full-width-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.full-width-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.swap-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.swap-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
  background: linear-gradient(135deg, #5a6fd8 0%, #6a4393 100%);
}

.btn-text {
  margin-left: 8rpx;
}

.calculate-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.calculate-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.result-box {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
  margin-top: 24rpx;
}

.result-item {
  text-align: center;
  margin-bottom: 16rpx;
}

.result-label {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.result-value {
  font-size: 36rpx;
  font-weight: 800;
}

.result-value.bmi {
  color: #667eea;
  font-size: 48rpx;
}

.bmi-status {
  font-size: 28rpx;
  color: #38ef7d;
  margin-top: 10rpx;
  display: block;
  font-weight: 600;
}

.result-value.ideal-weight {
  color: #667eea;
}

.result-value.suggestion {
  color: #666;
  font-size: 24rpx;
  font-weight: normal;
}

.result-divider {
  height: 2rpx;
  background: rgba(102, 126, 234, 0.5);
  margin: 20rpx 0;
}

.result-row {
  display: flex;
  justify-content: space-between;
}

.result-row .result-item {
  flex: 1;
  margin-bottom: 0;
}
