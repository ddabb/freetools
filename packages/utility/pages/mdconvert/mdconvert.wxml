<!--mdconvert.wxml-->
<view class="container">
  <view class="header">
    <text class="title">MD转换</text>
  </view>
  <view class="content">
    <view class="input-section">
      <text class="label">请输入Markdown文本：</text>
      <textarea placeholder="请输入Markdown文本" bindinput="mdInputChange" class="textarea"/>
    </view>
    <view class="button-section">
      <button bindtap="convertToHtml" class="button">转换为HTML</button>
    </view>
    <view wx:if="{{htmlResult !== ''}}" class="result-section">
      <text class="result-label">转换结果：</text>
      <text class="result-text">{{htmlResult}}</text>
    </view>
  </view>
</view>