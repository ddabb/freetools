<view class="page-container">
  <!-- 顶部装饰 -->
  <view class="header-bg">
    <view class="header-content">
      <view class="icon-wrapper">
        <text class="main-icon">🔐</text>
      </view>
      <text class="main-title">密码生成器</text>
      <text class="subtitle">创建安全可靠的密码</text>
    </view>
  </view>

  <view class="content-wrapper">
    <!-- 密码显示卡片 -->
    <view class="password-card card-shadow fade-in-up">
      <view class="card-header">
        <view class="card-icon">🎯</view>
        <text class="card-title">生成的密码</text>
      </view>
      
      <view class="card-body">
        <!-- 密码显示区域 -->
        <view class="password-display">
          <view class="password-wrapper">
            <text class="password-text">{{password || '点击下方生成安全密码'}}</text>
            <view class="password-actions">
              <button 
                class="icon-btn {{password ? 'visible' : ''}}" 
                bindtap="toggleVisibility"
                wx:if="{{password}}"
              >
                {{showPassword ? '🙈' : '👁️'}}
              </button>
            </view>
          </view>
          
          <!-- 密码强度指示器 -->
          <view class="strength-section" wx:if="{{password}}">
            <view class="strength-header">
              <text class="strength-label">安全强度</text>
              <view class="strength-badge {{strengthClass}}">
                {{strength}}
              </view>
            </view>
            <view class="strength-bar">
              <view class="strength-fill {{strengthClass}}" style="width: {{strengthPercent}}%"></view>
            </view>
            <view class="strength-tips">
              <text class="tip-text">{{strengthTip}}</text>
            </view>
          </view>
        </view>

        <!-- 主要操作按钮 -->
        <view class="primary-actions">
          <button 
            class="primary-btn {{canGenerate ? 'ready' : 'disabled'}}" 
            bindtap="generate"
            disabled="{{!canGenerate}}"
            hover-class="btn-primary-hover"
          >
            <text class="btn-icon">✨</text>
            <text class="btn-text">生成新密码</text>
          </button>
          
          <view class="secondary-actions">
            <button 
              class="secondary-btn {{password ? 'active' : ''}}" 
              bindtap="copyPassword"
              disabled="{{!password}}"
              hover-class="btn-secondary-hover"
            >
              <text class="btn-icon">📋</text>
              <text>复制</text>
            </button>
            
            <button 
              class="secondary-btn {{password ? 'active' : ''}}" 
              bindtap="savePassword"
              disabled="{{!password}}"
              hover-class="btn-secondary-hover"
            >
              <text class="btn-icon">💾</text>
              <text>保存</text>
            </button>
          </view>
        </view>
      </view>
    </view>

    <!-- 配置设置卡片 -->
    <view class="config-card card-shadow fade-in-up" style="animation-delay: 0.1s">
      <view class="card-header">
        <view class="card-icon">⚙️</view>
        <text class="card-title">配置选项</text>
      </view>
      
      <view class="card-body">
        <!-- 密码长度设置 -->
        <view class="setting-group">
          <view class="setting-header">
            <text class="setting-label">密码长度</text>
            <view class="length-display">
              <text class="length-number">{{length}}</text>
              <text class="length-unit">位</text>
            </view>
          </view>
          
          <view class="length-controls">
            <button 
              class="control-btn {{length <= 6 ? 'disabled' : ''}}" 
              bindtap="decreaseLength"
              disabled="{{length <= 6}}"
            >
              −
            </button>
            
            <slider
              class="modern-slider"
              min="6"
              max="32"
              value="{{length}}"
              bindchange="onLengthChange"
              activeColor="#667eea"
              backgroundColor="#e9ecef"
              block-size="24"
              block-color="#667eea"
            />
            
            <button 
              class="control-btn {{length >= 32 ? 'disabled' : ''}}" 
              bindtap="increaseLength"
              disabled="{{length >= 32}}"
            >
              +
            </button>
          </view>
          
          <view class="preset-lengths">
            <text class="preset-label">常用长度：</text>
            <view class="preset-chips">
              <view 
                class="preset-chip {{length === 8 ? 'selected' : ''}}" 
                bindtap="setLength" 
                data-length="8"
              >
                8位
              </view>
              <view 
                class="preset-chip {{length === 12 ? 'selected' : ''}}" 
                bindtap="setLength" 
                data-length="12"
              >
                12位
              </view>
              <view 
                class="preset-chip {{length === 16 ? 'selected' : ''}}" 
                bindtap="setLength" 
                data-length="16"
              >
                16位
              </view>
              <view 
                class="preset-chip {{length === 20 ? 'selected' : ''}}" 
                bindtap="setLength" 
                data-length="20"
              >
                20位
              </view>
            </view>
          </view>
        </view>

        <!-- 字符类型设置 -->
        <view class="setting-group">
          <text class="setting-label">字符类型</text>
          
          <view class="char-types">
            <view class="type-item">
              <label class="type-checkbox">
                <checkbox checked="{{includeUppercase}}" bindchange="onUppercaseChange" />
                <view class="type-content">
                  <text class="type-name">大写字母</text>
                  <text class="type-example">A-Z</text>
                </view>
              </label>
            </view>
            
            <view class="type-item">
              <label class="type-checkbox">
                <checkbox checked="{{includeLowercase}}" bindchange="onLowercaseChange" />
                <view class="type-content">
                  <text class="type-name">小写字母</text>
                  <text class="type-example">a-z</text>
                </view>
              </label>
            </view>
            
            <view class="type-item">
              <label class="type-checkbox">
                <checkbox checked="{{includeNumbers}}" bindchange="onNumbersChange" />
                <view class="type-content">
                  <text class="type-name">数字</text>
                  <text class="type-example">0-9</text>
                </view>
              </label>
            </view>
            
            <view class="type-item">
              <label class="type-checkbox">
                <checkbox checked="{{includeSymbols}}" bindchange="onSymbolsChange" />
                <view class="type-content">
                  <text class="type-name">特殊符号</text>
                  <text class="type-example">!@#$%</text>
                </view>
              </label>
            </view>
          </view>
        </view>

        <!-- 高级选项 -->
        <view class="advanced-section">
          <view class="advanced-header" bindtap="toggleAdvanced">
            <text class="advanced-label">高级选项</text>
            <text class="advanced-arrow {{showAdvanced ? 'expanded' : ''}}">▼</text>
          </view>
          
          <view class="advanced-content" wx:if="{{showAdvanced}}">
            <view class="advanced-item">
              <text class="advanced-name">避免相似字符</text>
              <switch checked="{{avoidSimilar}}" bindchange="onAvoidSimilarChange" />
            </view>
            <view class="advanced-item">
              <text class="advanced-name">必须包含每种类型</text>
              <switch checked="{{requireEachType}}" bindchange="onRequireEachTypeChange" />
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 预设模板卡片 -->
    <view class="templates-card card-shadow fade-in-up" style="animation-delay: 0.2s">
      <view class="card-header">
        <view class="card-icon">📋</view>
        <text class="card-title">快捷模板</text>
      </view>
      
      <view class="card-body">
        <view class="template-grid">
          <view 
            class="template-item {{template.active ? 'active' : ''}}" 
            wx:for="{{templates}}" 
            wx:key="name"
            bindtap="applyTemplate" 
            data-index="{{index}}"
          >
            <view class="template-info">
              <text class="template-name">{{item.name}}</text>
              <text class="template-desc">{{item.desc}}</text>
            </view>
            <view class="template-badge">
              {{item.length}}位
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 使用提示 -->
    <view class="tips-card card-shadow fade-in-up" style="animation-delay: 0.3s">
      <view class="tips-header">
        <view class="tips-icon">💡</view>
        <text class="tips-title">安全建议</text>
      </view>
      <view class="tips-content">
        <text class="tips-text">
          • 使用12位以上密码，包含多种字符类型
          • 定期更换重要账户密码
          • 避免在多个网站使用相同密码
          • 建议使用密码管理器存储复杂密码
        </text>
      </view>
    </view>
  </view>
</view>