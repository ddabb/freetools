<view class="password-container">
  <view class="password-display">
    <text class="password-text">{{password || '点击下方选项生成密码'}}</text>
    <view class="password-strength" wx:if="{{password}}">
      <text class="strength-label">密码强度：</text>
      <text class="strength-value {{strength === '强' ? 'strong' : strength === '中等' ? 'medium' : 'weak'}}">{{strength}}</text>
    </view>
  </view>

  <view class="settings-section">
    <view class="setting-item">
      <text class="label">密码长度</text>
      <slider
        class="slider"
        min="6"
        max="32"
        value="{{length}}"
        bindchange="onLengthChange"
        show-value
      />
    </view>

    <view class="setting-item checkbox-item">
      <text class="label">包含大写字母</text>
      <checkbox checked="{{includeUppercase}}" bindchange="onUppercaseChange" />
    </view>

    <view class="setting-item checkbox-item">
      <text class="label">包含小写字母</text>
      <checkbox checked="{{includeLowercase}}" bindchange="onLowercaseChange" />
    </view>

    <view class="setting-item checkbox-item">
      <text class="label">包含数字</text>
      <checkbox checked="{{includeNumbers}}" bindchange="onNumbersChange" />
    </view>

    <view class="setting-item checkbox-item">
      <text class="label">包含特殊字符</text>
      <checkbox checked="{{includeSymbols}}" bindchange="onSymbolsChange" />
    </view>
  </view>

  <view class="button-group">
    <button class="btn-generate" bindtap="generate">重新生成</button>
    <button class="btn-copy" bindtap="copyPassword" disabled="{{!password}}">复制密码</button>
  </view>

  <view class="tips">
    <text class="tips-text">* 建议使用长度12位以上的强密码，并包含多种字符类型</text>
  </view>
</view>