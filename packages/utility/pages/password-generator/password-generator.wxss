/* packages/utility/pages/password-generator/password-generator.wxss */
.password-container {
  padding: 30rpx;
}

.password-display {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}

.password-text {
  display: block;
  font-size: 36rpx;
  font-family: monospace;
  color: #fff;
  text-align: center;
  word-break: break-all;
  margin-bottom: 20rpx;
  min-height: 50rpx;
}

.password-strength {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #f0f0f0;
}

.strength-label {
  margin-right: 10rpx;
}

.strength-value {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.strength-value.strong {
  background: #27ae60;
}

.strength-value.medium {
  background: #f39c12;
}

.strength-value.weak {
  background: #e74c3c;
}

.settings-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item.checkbox-item {
  justify-content: space-between;
}

.setting-item .label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.setting-item .slider {
  flex: 1;
  margin: 0 20rpx;
}

.button-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.btn-generate,
.btn-copy {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-generate {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: #fff;
}

.btn-copy {
  background: linear-gradient(135deg, #27ae60 0%, #219a52 100%);
  color: #fff;
}

.btn-copy[disabled] {
  background: #ccc;
  color: #fff;
}

.tips {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fff9e6;
  border-radius: 8rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #f59a23;
}