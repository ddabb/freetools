<!--packages/utility/pages/oddEven/oddEven.wxml-->
<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 标题 -->
    <view class="header">
      <text class="title">判断奇偶数</text>
    </view>

    <!-- 数字输入 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">请输入一个整数</text>
        <text class="required-mark">*</text>
      </view>
      <view class="input-with-unit">
        <input type="number" value="{{inputValue}}" bindinput="onInputChange" class="input-field" placeholder="例如：123"/>
        <text class="unit-text">数</text>
      </view>
    </view>

    <!-- 判断按钮 -->
    <view class="form-item btn-item">
      <button class="calculate-btn full-width-btn" bindtap="checkOddEven">
        <text class="btn-text">判断</text>
      </button>
    </view>

    <!-- 结果显示 -->
    <view class="form-item" wx:if="{{result !== ''}}">
      <view class="form-label">
        <text class="label-text">判断结果</text>
      </view>
      <view class="result-box">
        <text class="output-text">{{result}}</text>
      </view>
    </view>
  </view>
</view>