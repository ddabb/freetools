<view class="container">
  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 年龄输入 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">年龄</text>
        <text class="required-mark">*</text>
      </view>
      <view class="input-with-unit" hover-class="input-with-unit-hover">
        <input type="number" value="{{age}}" bindinput="setAge" class="input-field" placeholder="请输入年龄" min="1" max="120" placeholder-class="input-placeholder"/>
        <text class="unit-text">岁</text>
      </view>
    </view>

    <!-- 性别选择 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">性别</text>
        <text class="required-mark">*</text>
      </view>
      <picker bindchange="setGender" value="{{genderIndex}}" range="{{genders}}" class="gender-picker form-picker">
        <view class="picker-display {{genderIndex === -1 ? 'placeholder' : ''}}" hover-class="picker-display-hover">
          {{genders[genderIndex] || '请选择性别'}}
        </view>
      </picker>
    </view>

    <!-- 身高输入 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">身高</text>
        <text class="required-mark">*</text>
      </view>
      <view class="input-with-unit" hover-class="input-with-unit-hover">
        <input type="number" value="{{height}}" bindinput="setHeight" class="input-field" placeholder="请输入身高" placeholder-class="input-placeholder"/>
        <text class="unit-text">cm</text>
      </view>
    </view>

    <!-- 体重输入 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">体重</text>
        <text class="required-mark">*</text>
      </view>
      <view class="input-with-unit" hover-class="input-with-unit-hover">
        <input type="number" value="{{weight}}" bindinput="setWeight" class="input-field" placeholder="请输入体重" placeholder-class="input-placeholder"/>
        <text class="unit-text">kg</text>
      </view>
    </view>

    <!-- 计算按钮 -->
    <view class="form-item btn-item">
      <button class="calculate-btn full-width-btn" hover-class="full-width-btn-hover" bindtap="calculate">
        <text class="btn-text">计算健康指数</text>
      </button>
    </view>
  </view>

  <!-- 结果展示 -->
  <view class="result-section" wx:if="{{showResult}}">
    <view class="result-box">
      <view class="result-item">
        <text class="result-label">BMI指数</text>
        <text class="result-value bmi">{{bmi}}</text>
        <text class="bmi-status">{{bmiStatus}}</text>
      </view>
      <view class="result-divider"></view>
      <view class="result-row">
        <view class="result-item">
          <text class="result-label">理想体重</text>
          <text class="result-value ideal-weight">{{idealWeight}} kg</text>
        </view>
        <view class="result-item" wx:if="{{ageGroup !== 'elderly'}}">
          <text class="result-label">建议均值</text>
          <text class="result-value ideal-weight">{{idealWeightAvg}} kg</text>
        </view>
        <view class="result-item">
          <text class="result-label">健康建议</text>
          <text class="result-value suggestion">{{suggestion}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 分享海报生成 -->
  <view class="share-section">
    <canvas canvas-id="cvs1" type="2d" style="width: {{canvaswidth}}px; height: {{canvasheight}}px; position: fixed; left: -9999rpx; top: -9999rpx;" />
    <button class="btn-share" hover-class="btn-share-hover" bindtap="MakePosters">生成分享海报</button>
  </view>
</view>