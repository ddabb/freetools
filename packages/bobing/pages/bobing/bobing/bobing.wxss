.container, header, h1, .subtitle, .game-area, .dice-section, .info-section, .section-title, .dice-container, .dice-wrapper, .dice, .dice-face, .dice-dot, .dice-shadow, .button-container, .roll-btn, .result-display, .result-title, .result-desc, .dice-values, .awards-list, .award-item, .award-name, .award-condition, .history, .history-title, .history-list, .history-item, .dice-emoji, .color-info, .color-dot, .red-dot, .blue-dot, footer, .counter, .strong {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Arial', 'Microsoft YaHei', sans-serif;
}

.container {
  max-width: 900px;
  width: 100%;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  padding: 30px;
  margin-top: 20px;
}

header {
  text-align: center;
  margin-bottom: 30px;
  padding-bottom: 20px;
  border-bottom: 2px dashed #e74c3c;
}

h1 {
  color: #e74c3c;
  font-size: 2.8rem;
  margin-bottom: 10px;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
}

.subtitle {
  color: #666;
  font-size: 1.2rem;
  max-width: 800px;
  margin: 0 auto;
  line-height: 1.6;
}

.game-area {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 30px;
  margin-bottom: 30px;
}

.dice-section {
  flex: 1;
  min-width: 300px;
  background: #f8f9fa;
  border-radius: 15px;
  padding: 25px;
  box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.05);
}

.info-section {
  flex: 1;
  min-width: 300px;
  background: #f8f9fa;
  border-radius: 15px;
  padding: 25px;
  box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 1.5rem;
  color: #2c3e50;
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid #ddd;
  text-align: center;
}

.dice-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin: 30px 0;
  perspective: 1000px;
}

.dice-wrapper {
  width: 100px;
  height: 100px;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.1s;
}

.dice {
  width: 100%;
  height: 100%;
  position: absolute;
  transform-style: preserve-3d;
  background: linear-gradient(145deg, #ffffff, #e6e6e6);
  border-radius: 15px;
  box-shadow: 
    0 5px 15px rgba(0, 0, 0, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.8),
    inset 0 -1px 0 rgba(0, 0, 0, 0.1);
  border: 2px solid #ddd;
}

.dice.rolling {
  animation: diceRoll 1s ease-in-out infinite;
}

.dice-face {
  position: absolute;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 15px;
  background: linear-gradient(145deg, #f0f0f0, #ffffff);
  backface-visibility: hidden;
}

.dice-dot {
  border-radius: 50%;
  box-shadow: 
    inset 2px 2px 4px rgba(255, 255, 255, 0.3),
    inset -2px -2px 4px rgba(0, 0, 0, 0.2),
    0 2px 4px rgba(0, 0, 0, 0.3);
  position: absolute;
}

/* 1点样式 */
.dot-1 {
  width: 20px;
  height: 20px;
  background: radial-gradient(circle at 30% 30%, #e74c3c, #c0392b);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* 2点样式 */
.dot-2 {
  width: 16px;
  height: 16px;
  background: radial-gradient(circle at 30% 30%, #3498db, #2980b9);
}

.dice-face-back .dot-2:nth-child(1) {
  top: 25%;
  left: 25%;
}

.dice-face-back .dot-2:nth-child(2) {
  bottom: 25%;
  right: 25%;
}

/* 3点样式 */
.dot-3 {
  width: 16px;
  height: 16px;
  background: radial-gradient(circle at 30% 30%, #3498db, #2980b9);
}

.dice-face-right .dot-3:nth-child(1) {
  top: 25%;
  left: 25%;
}

.dice-face-right .dot-3:nth-child(2) {
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.dice-face-right .dot-3:nth-child(3) {
  bottom: 25%;
  right: 25%;
}

/* 4点样式 */
.dot-4 {
  width: 16px;
  height: 16px;
  background: radial-gradient(circle at 30% 30%, #e74c3c, #c0392b);
}

.dice-face-left .dot-4:nth-child(1) {
  top: 25%;
  left: 25%;
}

.dice-face-left .dot-4:nth-child(2) {
  top: 25%;
  right: 25%;
}

.dice-face-left .dot-4:nth-child(3) {
  bottom: 25%;
  left: 25%;
}

.dice-face-left .dot-4:nth-child(4) {
  bottom: 25%;
  right: 25%;
}

/* 5点样式 */
.dot-5 {
  width: 12px;
  height: 12px;
  background: radial-gradient(circle at 30% 30%, #3498db, #2980b9);
}

.dice-face-top .dot-5:nth-child(1) {
  top: 20%;
  left: 20%;
}

.dice-face-top .dot-5:nth-child(2) {
  top: 20%;
  right: 20%;
}

.dice-face-top .dot-5:nth-child(3) {
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.dice-face-top .dot-5:nth-child(4) {
  bottom: 20%;
  left: 20%;
}

.dice-face-top .dot-5:nth-child(5) {
  bottom: 20%;
  right: 20%;
}

/* 6点样式 */
.dot-6 {
  width: 16px;
  height: 16px;
  background: radial-gradient(circle at 30% 30%, #3498db, #2980b9);
}

.dice-face-bottom .dot-6:nth-child(1) {
  top: 20%;
  left: 25%;
}

.dice-face-bottom .dot-6:nth-child(2) {
  top: 20%;
  right: 25%;
}

.dice-face-bottom .dot-6:nth-child(3) {
  top: 50%;
  left: 25%;
  transform: translateY(-50%);
}

.dice-face-bottom .dot-6:nth-child(4) {
  top: 50%;
  right: 25%;
  transform: translateY(-50%);
}

.dice-face-bottom .dot-6:nth-child(5) {
  bottom: 20%;
  left: 25%;
}

.dice-face-bottom .dot-6:nth-child(6) {
  bottom: 20%;
  right: 25%;
}

.dice-face-front  { transform: translateZ(50px); }
.dice-face-back   { transform: rotateY(180deg) translateZ(50px); }
.dice-face-right  { transform: rotateY(90deg) translateZ(50px); }
.dice-face-left   { transform: rotateY(-90deg) translateZ(50px); }
.dice-face-top    { transform: rotateX(90deg) translateZ(50px); }
.dice-face-bottom { transform: rotateX(-90deg) translateZ(50px); }

@keyframes diceRoll {
  0% { 
    transform: rotateX(0deg) rotateY(0deg) rotateZ(0deg) translateZ(0);
  }
  20% { 
    transform: rotateX(180deg) rotateY(90deg) rotateZ(45deg) translateZ(-20px);
  }
  40% { 
    transform: rotateX(360deg) rotateY(180deg) rotateZ(90deg) translateZ(0);
  }
  60% { 
    transform: rotateX(540deg) rotateY(270deg) rotateZ(135deg) translateZ(-20px);
  }
  80% { 
    transform: rotateX(720deg) rotateY(360deg) rotateZ(180deg) translateZ(0);
  }
  100% { 
    transform: rotateX(900deg) rotateY(450deg) rotateZ(225deg) translateZ(-20px);
  }
}

.dice-shadow {
  position: absolute;
  bottom: -10px;
  left: 10%;
  width: 80%;
  height: 10px;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 50%;
  filter: blur(5px);
  transition: all 0.3s ease;
}

.dice-value {
  position: absolute;
  bottom: -30px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 1.2rem;
  font-weight: bold;
  color: #2c3e50;
  text-align: center;
  width: 100%;
}

.dice.rolling + .dice-shadow {
  animation: shadowBounce 0.5s ease-in-out infinite alternate;
}

@keyframes shadowBounce {
  0% { transform: scale(0.8); opacity: 0.1; }
  100% { transform: scale(1.2); opacity: 0.3; }
}

.button-container {
  text-align: center;
  margin-top: 20px;
}

.roll-btn {
  background: linear-gradient(to right, #e74c3c, #c0392b);
  color: white;
  border: none;
  padding: 18px 45px;
  font-size: 1.4rem;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 5px 15px rgba(231, 76, 60, 0.4);
  font-weight: bold;
  letter-spacing: 1px;
}

.roll-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(231, 76, 60, 0.6);
}

.roll-btn:active {
  transform: translateY(1px);
}

.roll-btn:disabled {
  background: #95a5a6;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

/* 结果和历史记录按钮样式 */
.button-container {
  display: flex;
  justify-content: center;
  gap: 15px;
  margin-top: 20px;
}

.result-btn, .history-btn {
  background: linear-gradient(to right, #27ae60, #229954);
  color: white;
  border: none;
  padding: 12px 25px;
  font-size: 1rem;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 3px 10px rgba(39, 174, 96, 0.4);
  font-weight: bold;
  letter-spacing: 1px;
}

.history-btn {
  background: linear-gradient(to right, #9b59b6, #8e44ad);
  box-shadow: 0 3px 10px rgba(155, 89, 182, 0.4);
}

.result-btn:hover, .history-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
}

.result-btn:active, .history-btn:active {
  transform: translateY(1px);
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 15px;
  width: 90%;
  max-width: 500px;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  border-bottom: 1px solid #eee;
  background: #f8f9fa;
  border-radius: 15px 15px 0 0;
}

.modal-header h3 {
  margin: 0;
  color: #2c3e50;
  font-size: 1.5rem;
}

.modal-close {
  font-size: 2rem;
  cursor: pointer;
  color: #7f8c8d;
  transition: color 0.2s ease;
  padding: 8px 12px;
  min-width: 44px;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.modal-close:hover {
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.1);
}

.modal-body {
  padding: 20px;
}

.modal-intro {
  color: #666;
  font-size: 1rem;
  line-height: 1.6;
  margin-bottom: 20px;
  padding-bottom: 15px;
  border-bottom: 1px solid #eee;
}

/* 结果弹窗样式 */
.result-section {
  text-align: center;
  padding: 20px 0;
}

.result-section .result-title {
  font-size: 1.8rem;
  color: #e74c3c;
  font-weight: bold;
  margin-bottom: 15px;
}

.result-section .dice-values {
  font-size: 1.3rem;
  color: #34495e;
  margin-bottom: 10px;
}

.result-section .dice-emojis {
  font-size: 2rem;
  margin-bottom: 15px;
  color: #2c3e50;
}

.result-section .score-info, .result-section .roll-count {
  font-size: 1.1rem;
  color: #7f8c8d;
  margin-bottom: 5px;
}

/* 历史记录弹窗样式 */
.history-section {
  max-height: 60vh;
  overflow-y: auto;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
  padding-bottom: 10px;
  border-bottom: 1px solid #eee;
}

.history-header view {
  color: #666;
  font-size: 0.9rem;
}

.clear-history-btn {
  background: #e74c3c;
  color: white;
  border: none;
  padding: 6px 12px;
  font-size: 0.8rem;
  border-radius: 15px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.clear-history-btn:hover {
  background: #c0392b;
  transform: translateY(-1px);
}

.history-list {
  max-height: 50vh;
  overflow-y: auto;
}

.history-item {
  padding: 12px 15px;
  background: #f8f9fa;
  margin-bottom: 10px;
  border-radius: 8px;
  border-left: 4px solid #9b59b6;
}

.history-time {
  font-size: 0.8rem;
  color: #7f8c8d;
  margin-bottom: 3px;
}

.history-award {
  font-size: 0.9rem;
  color: #2c3e50;
  margin-bottom: 3px;
}

.history-dice {
  font-size: 0.8rem;
  color: #666;
}

.dice-emoji {
  font-size: 0.9rem;
  margin-left: 5px;
}

.no-history {
  text-align: center;
  padding: 40px 0;
  color: #7f8c8d;
  font-size: 1rem;
}

.strong {
  font-weight: bold;
}

.awards-list {
  list-style: none;
  margin-top: 20px;
}

.award-item {
  padding: 12px 20px;
  margin-bottom: 12px;
  background: white;
  border-radius: 10px;
  border-left: 5px solid #3498db;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.2s ease;
}

.award-item:hover {
  transform: translateX(5px);
  box-shadow: 0 5px 10px rgba(0, 0, 0, 0.05);
}

.award-name {
  font-weight: bold;
  color: #2c3e50;
}

.award-condition {
  color: #7f8c8d;
  font-size: 0.95rem;
}

.counter {
  display: flex;
  justify-content: center;
  gap: 30px;
  margin-top: 20px;
  font-size: 1.1rem;
}

.counter text {
  font-weight: bold;
  color: #e74c3c;
}

.strong {
  font-weight: bold;
}

