<view class="container">
  <view class="section-title">📈 图表生成器</view>
  
  <!-- 图表类型选择 -->
  <view class="chart-type-section">
    <view class="section-header">
      <text class="section-label">图表类型</text>
    </view>
    <picker bindchange="setChartType" value="{{chartTypeIndex}}" range="{{chartTypes}}" class="chart-type-picker">
      <view class="picker-display">
        {{chartTypes[chartTypeIndex]}}
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>
  
  <!-- 数据输入 -->
  <view class="data-input-section">
    <view class="section-header">
      <text class="section-label">数据输入</text>
    </view>
    <textarea value="{{chartData}}" bindinput="setChartData" class="data-textarea" placeholder="请输入图表数据，格式：\n\n柱状图/折线图：\n[10, 20, 30, 40, 50]\n\n饼图：\n[{name: 'A', value: 30}, {name: 'B', value: 20}, {name: 'C', value: 50}]\n\n雷达图：\n[{name: '指标1', value: 80}, {name: '指标2', value: 60}, {name: '指标3', value: 90}]" maxlength="1000" />
  </view>
  
  <!-- 图表配置 -->
  <view class="chart-config-section">
    <view class="section-header">
      <text class="section-label">图表配置</text>
    </view>
    <view class="config-items">
      <view class="config-item">
        <text class="config-label">图表标题</text>
        <input type="text" value="{{chartTitle}}" bindinput="setChartTitle" class="config-input" placeholder="请输入图表标题" />
      </view>
      <view class="config-item">
        <text class="config-label">X轴标题</text>
        <input type="text" value="{{xAxisTitle}}" bindinput="setXAxisTitle" class="config-input" placeholder="请输入X轴标题" />
      </view>
      <view class="config-item">
        <text class="config-label">Y轴标题</text>
        <input type="text" value="{{yAxisTitle}}" bindinput="setYAxisTitle" class="config-input" placeholder="请输入Y轴标题" />
      </view>
    </view>
  </view>
  
  <!-- 图表预览 -->
  <view class="chart-preview-section">
    <view class="section-header">
      <text class="section-label">图表预览</text>
      <button class="refresh-btn" bindtap="refreshChart">刷新预览</button>
    </view>
    <view class="chart-container">
      <canvas canvas-id="chartCanvas" class="chart-canvas"></canvas>
      <view class="chart-placeholder" wx:if="{{!showChart}}">
        <text class="placeholder-text">请输入数据并点击刷新预览</text>
      </view>
    </view>
  </view>
  
  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="action-btn primary-btn" bindtap="createChart">
      <text class="btn-icon">🎯</text>
      <text class="btn-text">生成图表</text>
    </button>
    <button class="action-btn secondary-btn" bindtap="exportImage">
      <text class="btn-icon">💾</text>
      <text class="btn-text">导出图片</text>
    </button>
    <button class="action-btn secondary-btn" bindtap="loadTemplate">
      <text class="btn-icon">📋</text>
      <text class="btn-text">加载模板</text>
    </button>
  </view>
  
  <!-- 示例模板 -->
  <view class="templates-section">
    <view class="section-header">
      <text class="section-label">常用模板</text>
    </view>
    <view class="templates-grid">
      <view class="template-item" bindtap="useTemplate" data-template="bar">
        <text class="template-icon">📊</text>
        <text class="template-name">销售数据</text>
      </view>
      <view class="template-item" bindtap="useTemplate" data-template="pie">
        <text class="template-icon">🥧</text>
        <text class="template-name">市场份额</text>
      </view>
      <view class="template-item" bindtap="useTemplate" data-template="line">
        <text class="template-icon">📈</text>
        <text class="template-name">趋势分析</text>
      </view>
      <view class="template-item" bindtap="useTemplate" data-template="radar">
        <text class="template-icon">🎯</text>
        <text class="template-name">能力评估</text>
      </view>
    </view>
  </view>
</view>