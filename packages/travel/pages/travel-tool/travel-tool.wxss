/**travel-tool.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 20rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.input-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
}

.input {
  width: 100%;
  font-size: 32rpx;
  border: none;
  outline: none;
  color: #333;
  font-weight: 500;
}

.generate-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.generate-btn-hover {
  transform: scale(0.98);
}

.list-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.list-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:hover {
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
  padding-left: 10rpx;
}

.list-checkbox {
  font-size: 36rpx;
  margin-right: 20rpx;
  color: #667eea;
  font-weight: bold;
}

.list-item-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}
