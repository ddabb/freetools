<!--travel-tool.wxml-->
<view class="container">
  <!-- 旅行天数 -->
  <view class="section">
    <text class="section-title">旅行天数</text>
    <view class="input-box">
      <input type="number" value="{{days}}" bindinput="setDays" class="input" placeholder-class="input-placeholder"/>
    </view>
  </view>
  
  <!-- 目的地 -->
  <view class="section">
    <text class="section-title">目的地</text>
    <view class="input-box">
      <input type="text" placeholder="请输入目的地" value="{{destination}}" bindinput="setDestination" class="input" placeholder-class="input-placeholder"/>
    </view>
  </view>
  
  <!-- 生成按钮 -->
  <view class="section">
    <button class="generate-btn" hover-class="generate-btn-hover" bindtap="generate">生成行李清单</button>
  </view>
  
  <!-- 行李清单 -->
  <view class="section" wx:if="{{showList}}">
    <text class="section-title">行李清单</text>
    <view class="list-box">
      <view class="list-item" wx:for="{{packingList}}" wx:key="index">
        <text class="list-checkbox">□</text>
        <text class="list-item-name">{{item}}</text>
      </view>
    </view>
  </view>
</view>