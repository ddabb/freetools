/* packages/knowledge/pages/knowledgelist/knowledgelist.wxss */

/* ========== 基础样式 ========== */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

/* ========== 顶部搜索栏和排序容器 ========== */
.search-sort-container {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx 12rpx;
  background: rgba(255, 255, 255, 0.15);
  margin: 0 16rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  gap: 16rpx;
}

/* ========== 顶部搜索栏 ========== */
.search-bar {
  flex: 1;
  min-width: 0;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50rpx;
  padding: 0 40rpx;
  height: 88rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.icon-search {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 80rpx;
  line-height: 80rpx;
  min-width: 0;
  padding: 0 16rpx;
  text-align: center;
}

.icon-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
  flex-shrink: 0;
}

.search-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 10rpx 0 14rpx;
  text-align: center;
}

/* ========== 分类导航 ========== */
.category-nav {
  display: flex;
  white-space: nowrap;
  padding: 0 16rpx;
  margin-top: 8rpx;
  height: auto;
  overflow: visible;
}

.category-nav scroll-view {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  margin-right: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.category-item text {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
}

.category-item .count {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
}

.category-item.active {
  background: white;
  border-color: white;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.category-item.active text {
  color: #667eea;
}

.category-item.active .count {
  color: rgba(102, 126, 234, 0.6);
}

/* ========== 排序按钮 ========== */
.sort-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.sort-wrap:active {
  background: rgba(255, 255, 255, 0.35);
}

.sort-icon {
  font-size: 22rpx;
  color: white;
}

.sort-text {
  font-size: 22rpx;
  color: white;
  font-weight: 500;
}

/* 删除重复的样式定义 */

/* ========== 文章列表滚动区 ========== */
.article-scroll {
  flex: 1;
  margin-top: 8rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  gap: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.empty-btn {
  margin-top: 16rpx;
  padding: 16rpx 48rpx;
  background: white;
  color: #667eea;
  border: none;
  border-radius: 50rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.empty-btn::after { border: none; }

/* ========== 文章卡片列表 ========== */
.article-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 0 16rpx;
  gap: 0;
}

.article-card {
  width: 50%;
  padding: 12rpx;
  box-sizing: border-box;
  background: transparent;
  position: relative;
}

.article-card .card-inner {
  background: white;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.article-card .card-inner:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
}

.article-card .card-inner::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 20rpx 20rpx 0 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.card-category {
  display: inline-block;
  padding: 4rpx 14rpx;
  font-size: 18rpx;
  color: white;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160rpx;
}

.card-category.category-product-usage { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
.card-category.category-product-design { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
.card-category.category-product-thinking { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
.card-category.category-dev-practice { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
.card-category.category-dev-story { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }
.card-category.category-project-mgmt { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.card-category.category-uncategorized { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }

.card-order {
  font-size: 20rpx;
  color: #ccc;
  font-weight: 500;
  flex-shrink: 0;
}

.card-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 12rpx;
  flex-shrink: 0;
}

.card-desc {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 22rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  flex: 1;
}

.card-footer {
  flex-shrink: 0;
  margin-top: auto;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.card-tag {
  font-size: 20rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.08);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 10rpx;
  border-top: 1rpx solid #f0f0f0;
}

.card-words,
.card-time {
  font-size: 20rpx;
  color: #999;
}

.card-decoration {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  opacity: 0.08;
  pointer-events: none;
}

.card-decoration.deco-1 { background: #667eea; }
.card-decoration.deco-2 { background: #764ba2; }
.card-decoration.deco-3 { background: #f093fb; }

/* ========== 加载状态 ========== */
.loading-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ========== 列表结束 ========== */
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx 0 60rpx;
}

.end-line {
  width: 80rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 1rpx;
}

.end-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  white-space: nowrap;
}

/* ========== 分类树弹窗 ========== */
.category-container {
  position: relative;
}

.category-tree-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 80vh;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 1000;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 32rpx 32rpx 0 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: white;
}

.modal-close {
  font-size: 32rpx;
  color: white;
  padding: 8rpx;
}

.tree-scroll {
  max-height: calc(80vh - 100rpx);
  padding: 16rpx 0;
}

.tree-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s ease;
}

.tree-item:active {
  background-color: #f5f5f5;
}

.tree-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.tree-count {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.category-item .icon {
  margin-left: 8rpx;
  font-size: 24rpx;
}
