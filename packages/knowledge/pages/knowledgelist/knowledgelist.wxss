/* packages/knowledge/pages/knowledgelist/knowledgelist.wxss */

page {
  background: #f5f5f5;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.sort-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.sort-btn {
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  font-size: 26rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.filter-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 12rpx;
}

.filter-tag {
  padding: 8rpx 16rpx;
  background: #2980b9;
  color: white;
  border-radius: 16rpx;
  font-size: 24rpx;
}

/* 文章列表 */
.article-list {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
}

/* 文章卡片 */
.article-card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.article-card:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transform: translateY(-2rpx);
}

.article-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.article-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  line-height: 1.4;
}

.article-order {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
  white-space: nowrap;
}

.article-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-tag {
  padding: 6rpx 12rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  color: #2980b9;
  font-weight: 500;
}

.word-count {
  color: #999;
}

.meta-right {
  font-size: 22rpx;
  color: #bbb;
}

/* 标签 */
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 12rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #666;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}

.end-state {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #bbb;
}
