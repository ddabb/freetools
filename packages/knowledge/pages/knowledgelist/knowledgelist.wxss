/* packages/knowledge/pages/knowledgelist/knowledgelist.wxss */

/* 页面背景和基础样式 */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f8f9fa;
}

/* ========== 搜索栏 ========== */
.search-bar {
  padding: 24rpx 30rpx;
  background: white;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.15);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f6f8;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.search-input-wrap:focus-within {
  border-color: #667eea;
  background: white;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.icon-search {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 44rpx;
}

.search-input::placeholder {
  color: #999;
}

.icon-clear {
  font-size: 24rpx;
  color: #ccc;
  padding: 8rpx;
}

.icon-clear:active {
  color: #999;
}

/* ========== 分类导航 ========== */
.category-nav {
  display: flex;
  white-space: nowrap;
  padding: 20rpx 0;
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 64rpx;
  padding: 0 30rpx;
  margin: 0 10rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f6f8;
  border-radius: 32rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.category-item:first-child {
  margin-left: 20rpx;
}

.category-item:last-child {
  margin-right: 20rpx;
}

.category-item.active {
  color: white;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.4);
}

.category-item:active {
  transform: scale(0.95);
}

/* ========== 统计栏 ========== */
.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: white;
  margin-bottom: 4rpx;
}

.stats-text {
  font-size: 24rpx;
  color: #999;
}

.sort-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #f5f6f8;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.sort-wrap:active {
  background: #e8eaed;
}

.sort-icon {
  font-size: 20rpx;
  color: #667eea;
  font-weight: bold;
}

.sort-text {
  font-size: 24rpx;
  color: #666;
}

/* ========== 文章滚动区域 ========== */
.article-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ========== 文章列表 ========== */
.article-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  gap: 20rpx;
}

/* ========== 文章卡片 ========== */
.article-card {
  width: 48.5%;
  background: white;
  border-radius: 20rpx;
  padding: 28rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.article-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-category {
  padding: 6rpx 14rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
}

.card-category.项目管理 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.card-category.冷知识 {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.card-category.技术 {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.card-order {
  font-size: 22rpx;
  color: #ccc;
}

/* 卡片标题 */
.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 卡片描述 */
.card-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #f0f0f0;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.card-tag {
  font-size: 20rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.08);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 20rpx;
  color: #999;
}

.card-words {
  font-weight: 500;
}

.card-time {
  font-size: 18rpx;
}

/* 装饰元素 */
.card-decoration {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  opacity: 0.1;
}

.card-decoration.deco-1 {
  top: -20rpx;
  right: -20rpx;
  background: #667eea;
}

.card-decoration.deco-2 {
  bottom: -30rpx;
  left: -30rpx;
  background: #f5576c;
}

.card-decoration.deco-3 {
  top: 50%;
  right: -40rpx;
  width: 100rpx;
  height: 100rpx;
  background: #4facfe;
}

/* ========== 空状态 ========== */
.empty-state {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* ========== 加载更多 ========== */
.loading-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}

/* ========== 列表结束 ========== */
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx;
  gap: 16rpx;
}

.end-line {
  width: 60rpx;
  height: 1rpx;
  background: #e0e0e0;
}

.end-text {
  font-size: 24rpx;
  color: #bbb;
  white-space: nowrap;
}
