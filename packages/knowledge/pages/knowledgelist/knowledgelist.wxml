<!-- packages/knowledge/pages/knowledgelist/knowledgelist.wxml -->

<view class="container">
  <!-- 排序栏 -->
  <view class="sort-bar">
    <text class="sort-label">排序方式</text>
    <view class="sort-btn" bindtap="toggleSort">
      <text style="color: {{sortColor}}">
        {{sortOrder === 'asc' ? '↑ 升序' : '↓ 降序'}}
      </text>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-bar" wx:if="{{tag}}">
    <text class="filter-label">标签：</text>
    <text class="filter-tag">{{tag}}</text>
  </view>

  <!-- 分类标签 -->
  <view class="filter-bar" wx:if="{{category}}">
    <text class="filter-label">分类：</text>
    <text class="filter-tag">{{category}}</text>
  </view>

  <!-- 文章列表 -->
  <scroll-view 
    scroll-y 
    style="height: {{scrollHeight}}px;"
    lower-threshold="50"
    bindscrolltolower="lower"
  >
    <view class="article-list">
      <!-- 文章卡片 -->
      <view 
        class="article-card" 
        wx:for="{{list}}" 
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onArticleTap"
      >
        <view class="article-header">
          <text class="article-title">{{item.title}}</text>
          <text class="article-order">#{{item.order}}</text>
        </view>

        <text class="article-desc">{{item.description}}</text>

        <view class="article-meta">
          <view class="meta-left">
            <text class="category-tag" bindtap="onCategoryTap">{{item.category}}</text>
            <text class="word-count">{{item.wordCount}} 字</text>
          </view>
          <view class="meta-right">
            <text class="update-time">{{item.updateTime}}</text>
          </view>
        </view>

        <!-- 标签 -->
        <view class="tags" wx:if="{{item.tags && item.tags.length > 0}}">
          <text 
            class="tag" 
            wx:for="{{item.tags}}" 
            wx:key="*this"
            data-tag="{{item}}"
          >
            #{{item}}
          </text>
        </view>
      </view>

      <!-- 加载状态 -->
      <view class="loading-state" wx:if="{{loading}}">
        <text>加载中...</text>
      </view>

      <!-- 结束提示 -->
      <view class="end-state" wx:if="{{isOver && !loading}}">
        <text>--- 已加载全部内容 ---</text>
      </view>
    </view>
  </scroll-view>
</view>
