<!-- packages/knowledge/pages/knowledgelist/knowledgelist.wxml -->
<view class="container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="icon-search">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索标题、描述或标签..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <text class="icon-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
    </view>
    <view class="search-count" wx:if="{{searchKeyword && list.length > 0}}">
      找到 {{list.length}} 条结果
    </view>
  </view>

  <!-- 分类导航 -->
  <scroll-view class="category-nav" scroll-x enable-flex>
    <view 
      class="category-item {{currentCategory === '' ? 'active' : ''}}"
      bindtap="switchCategory"
      data-category=""
    >
      <text>全部</text>
      <text class="count" wx:if="{{categoryStats['']}}">{{categoryStats['']}}</text>
    </view>
    <view 
      class="category-item {{currentCategory === item.name ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="name"
      bindtap="switchCategory"
      data-category="{{item.name}}"
    >
      <text>{{item.name}}</text>
      <text class="count">{{item.count}}</text>
    </view>
  </scroll-view>

  <!-- 统计信息 -->
  <view class="stats-bar">
    <view class="stats-left">
      <text class="stats-text">共 {{totalCount}} 篇文章</text>
      <text class="stats-filter" wx:if="{{currentCategory || searchKeyword}}">
        {{currentCategory ? '分类: ' + currentCategory : ''}}
        {{searchKeyword ? '关键词: ' + searchKeyword : ''}}
      </text>
    </view>
    <view class="sort-wrap" bindtap="toggleSort">
      <text class="sort-icon">{{sortOrder === 'desc' ? '↓' : '↑'}}</text>
      <text class="sort-text">{{sortField === 'updateTime' ? '时间' : '序号'}}</text>
    </view>
  </view>

  <!-- 文章列表 -->
  <scroll-view 
    class="article-scroll"
    scroll-y 
    style="height: {{scrollHeight}}px;"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
    lower-threshold="100"
    bindscrolltolower="loadMore"
  >
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && list.length === 0}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">没有找到相关文章</text>
      <text class="empty-hint" wx:if="{{searchKeyword}}">
        换个关键词试试吧~
      </text>
      <text class="empty-hint" wx:else>
        该分类下暂无文章
      </text>
      <button class="empty-btn" wx:if="{{searchKeyword || currentCategory}}" bindtap="clearFilters">
        清除筛选
      </button>
    </view>

    <!-- 文章卡片列表 -->
    <view class="article-list">
      <view 
        class="article-card {{index % 2 === 0 ? 'card-left' : 'card-right'}}"
        wx:for="{{list}}"
        wx:key="id"
        bindtap="onArticleTap"
        data-id="{{item.id}}"
      >
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="card-category {{getCategoryClass(item.category)}}">{{item.category}}</view>
          <text class="card-order">#{{item.order}}</text>
        </view>

        <!-- 卡片标题 -->
        <text class="card-title">{{item.title}}</text>

        <!-- 卡片描述 -->
        <text class="card-desc">{{item.description}}</text>

        <!-- 卡片底部 -->
        <view class="card-footer">
          <view class="card-tags">
            <text class="card-tag" 
              wx:for="{{item.tags}}" 
              wx:for-item="tag" 
              wx:key="*this"
              data-tag="{{tag}}"
              catchtap="onTagTap"
            >#{{tag}}</text>
          </view>
          <view class="card-meta">
            <text class="card-words">{{item.wordCount}}字</text>
            <text class="card-time">{{item.formattedUpdateTime}}</text>
          </view>
        </view>

        <!-- 装饰元素 -->
        <view class="card-decoration {{index % 3 === 0 ? 'deco-1' : (index % 3 === 1 ? 'deco-2' : 'deco-3')}}"></view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-more" wx:if="{{loading && list.length > 0}}">
      <text>加载中...</text>
    </view>

    <!-- 结束提示 -->
    <view class="list-end" wx:if="{{isOver && list.length > 0}}">
      <view class="end-line"></view>
      <text class="end-text">— 已加载全部 —</text>
      <view class="end-line"></view>
    </view>
  </scroll-view>
</view>
