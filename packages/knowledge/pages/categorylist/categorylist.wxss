/* packages/knowledge/pages/categorylist/categorylist.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  margin-bottom: 30rpx;
  text-align: center;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.page-subtitle {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.category-list {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item:last-child {
  border-bottom: none;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.category-count {
  font-size: 22rpx;
  color: #999;
}

.category-arrow {
  margin-left: 20rpx;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
}

.loading-state, .error-state, .empty-state {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

.retry-btn {
  margin-top: 20rpx;
  padding: 12rpx 40rpx;
  font-size: 24rpx;
  color: #2980b9;
  border: 1rpx solid #2980b9;
  border-radius: 8rpx;
  background-color: #fff;
}

.retry-btn:hover {
  background-color: #f0f8ff;
}