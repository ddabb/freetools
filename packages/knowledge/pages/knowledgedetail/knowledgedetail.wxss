/* packages/knowledge/pages/knowledgedetail/knowledgedetail.wxss */

/* ========== 基础样式 ========== */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  overflow-x: hidden;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  padding: 0;
  margin: 0;
}

/* ========== 文章滚动区 ========== */
.article-scroll {
  flex: 1;
  min-height: 300rpx;
  padding-top: 20rpx;
  padding-bottom: 0;
  box-sizing: border-box;
  overflow-x: auto;
}

.article-wrapper {
  margin: 0 20rpx 20rpx;
  animation: slideUp 0.6s ease;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ========== 底部留白 ========== */
.bottom-spacer {
  height: 20rpx;
}

/* ========== 加载状态 ========== */
.loading-state {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  box-shadow: 0 0 30rpx rgba(255, 255, 255, 0.3);
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* ========== 错误状态 ========== */
.error-state {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.error-icon {
  font-size: 120rpx;
  animation: bounce 1s ease-in-out;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-20rpx); }
  60% { transform: translateY(-10rpx); }
}

.error-text {
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 0 60rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.retry-btn {
  margin-top: 20rpx;
  padding: 22rpx 64rpx;
  background: white;
  color: #667eea;
  border: none;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.retry-btn::after { border: none; }

/* ========== 英雄区域 (头部) ========== */
.article-hero {
  background: white;
  border-radius: 28rpx;
  padding: 40rpx;
  margin: 20rpx 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.2);
  position: relative;
  overflow: hidden;
  animation: slideUp 0.6s ease;
  flex-shrink: 0;
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.article-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #f093fb, #f5576c);
  border-radius: 28rpx 28rpx 0 0;
}

/* 分类标签 */
.hero-category {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.hero-category.category-product-usage { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
.hero-category.category-product-design { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
.hero-category.category-product-thinking { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
.hero-category.category-dev-practice { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
.hero-category.category-dev-story { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }
.hero-category.category-project-mgmt { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.hero-category.category-uncategorized { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }

.category-icon { font-size: 28rpx; color: #333; }
.category-name { color: #333; font-size: 24rpx; font-weight: 600; user-select: text; }

/* 标题和元信息容器 */
.hero-title-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 标题 */
.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.35;
  letter-spacing: 1rpx;
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
  user-select: text;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 14rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
  border: 1rpx solid #e9ecef;
}

.meta-icon { font-size: 22rpx; }
.meta-value { font-size: 22rpx; color: #666; font-weight: 500; }
.meta-divider {
  width: 1rpx;
  height: 20rpx;
  background: #e0e0e0;
}

/* ========== 描述卡片 ========== */
.article-desc-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

.desc-icon { font-size: 44rpx; flex-shrink: 0; }

.desc-text {
  color: white;
  font-size: 28rpx;
  line-height: 1.65;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  user-select: text;
}

/* ========== 文章正文 ========== */
.article-body {
  background: white;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.content-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
  gap: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.content-line {
  flex: 1;
  height: 3rpx;
  background: linear-gradient(to right, transparent, #667eea, transparent);
  border-radius: 2rpx;
}

.content-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
  white-space: nowrap;
  padding: 0 16rpx;
}

/* towxml 渲染内容 */
.content-body {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  user-select: text;
}

/* 回退：原始 Markdown 文本 */
.content-fallback .md-raw {
  display: block;
  white-space: pre-wrap;
  word-break: break-all;
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

/* towxml 默认节点样式增强 */
.content-body .h2w__h1 {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin: 40rpx 0 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 3rpx solid #667eea;
  display: block;
}

/* ========== markdown-it 表格样式 ========== */
.content-body table {
  width: 100%;
  border-collapse: collapse;
  margin: 28rpx 0;
  font-size: 26rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #e0e0e0;
  background: white;
}

.content-body thead {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.content-body th {
  padding: 20rpx 16rpx;
  text-align: left;
  font-weight: 600;
  color: white;
  border-right: 1rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
}

.content-body th:last-child {
  border-right: none;
}

.content-body td {
  padding: 18rpx 16rpx;
  border: 1rpx solid #f0f0f0;
  border-top: none;
  border-left: none;
  position: relative;
}

.content-body td:last-child {
  border-right: none;
}

.content-body tr:nth-child(even) {
  background: rgba(102, 126, 234, 0.03);
}

.content-body tr:hover {
  background: rgba(102, 126, 234, 0.08);
  transition: background 0.3s ease;
}

/* 表格边框美化 */
.content-body table::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 12rpx;
  pointer-events: none;
}

/* 表头阴影效果 */
.content-body thead::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.5), transparent);
}

/* ========== rich-text 组件样式 ========== */
.content-rich {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  user-select: text;
}

/* rich-text 中段落样式 */
.content-rich p {
  margin: 16rpx 0;
  text-align: justify;
}

/* rich-text 中标题样式 */
.content-rich h1 {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin: 40rpx 0 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 3rpx solid #667eea;
}

.content-rich h2 {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin: 32rpx 0 16rpx;
  padding-left: 14rpx;
  border-left: 5rpx solid #667eea;
}

.content-rich h3 {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin: 24rpx 0 12rpx;
}

/* rich-text 中列表样式 */
.content-rich ul,
.content-rich ol {
  margin: 16rpx 0;
  padding-left: 44rpx;
}

.content-rich li {
  margin: 10rpx 0;
}

.content-rich ul li {
  list-style-type: disc;
}

.content-rich ol li {
  list-style-type: decimal;
}

/* rich-text 中代码样式 */
.content-rich code {
  background: #f5f6f8;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
  color: #e74c3c;
}

.content-rich pre {
  background: #2d3436;
  color: #dfe6e9;
  padding: 24rpx;
  border-radius: 14rpx;
  overflow-x: auto;
  margin: 24rpx 0;
}

.content-rich pre code {
  background: none;
  color: inherit;
  padding: 0;
  font-size: 26rpx;
}

/* rich-text 中引用样式 */
.content-rich blockquote {
  margin: 24rpx 0;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #e3e8ff 100%);
  border-left: 6rpx solid #667eea;
  border-radius: 0 14rpx 14rpx 0;
  color: #555;
  font-style: italic;
}

/* ========== rich-text 中表格的样式 ========== */
.content-rich table {
  width: 100%;
  border-collapse: collapse;
  margin: 32rpx 0;
  font-size: 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.15);
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  background: white;
  transition: all 0.3s ease;
}

.content-rich table:hover {
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.25);
  transform: translateY(-2rpx);
}

.content-rich thead {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.content-rich th {
  padding: 24rpx 20rpx;
  text-align: left;
  font-weight: 700;
  color: white;
  border-right: 1rpx solid rgba(255, 255, 255, 0.4);
  position: relative;
  font-size: 26rpx;
  letter-spacing: 1rpx;
}

.content-rich th:last-child {
  border-right: none;
}

.content-rich th::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20rpx;
  right: 20rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.6);
}

.content-rich td {
  padding: 22rpx 20rpx;
  border: 1rpx solid #f0f0f0;
  border-top: none;
  border-left: none;
  position: relative;
  font-size: 26rpx;
  line-height: 1.5;
  color: #333;
}

.content-rich td:last-child {
  border-right: none;
}

.content-rich tr:nth-child(even) {
  background: rgba(102, 126, 234, 0.04);
}

.content-rich tr:hover {
  background: rgba(102, 126, 234, 0.08);
  transition: background 0.3s ease;
}

.content-body .h2w__h2 {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin: 32rpx 0 16rpx;
  padding-left: 14rpx;
  border-left: 5rpx solid #667eea;
  display: block;
}

.content-body .h2w__h3 {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin: 24rpx 0 12rpx;
  display: block;
}

.content-body .h2w__p {
  margin: 16rpx 0;
  text-align: justify;
  display: block;
}

.content-body .h2w__ul,
.content-body .h2w__ol {
  margin: 16rpx 0;
  padding-left: 44rpx;
  display: block;
}

.content-body .h2w__li {
  margin: 10rpx 0;
  display: list-item;
}

.content-body .h2w__ul .h2w__li { list-style-type: disc; }
.content-body .h2w__ol .h2w__li { list-style-type: decimal; }

.content-body .h2w__table {
  width: 100%;
  border-collapse: collapse;
  margin: 28rpx 0;
  font-size: 26rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  border-radius: 10rpx;
  overflow: hidden;
  display: table;
}

.content-body .h2w__thead,
.content-body .h2w__tbody,
.content-body .h2w__tr { display: table-row; }
.content-body .h2w__th,
.content-body .h2w__td {
  border: 1rpx solid #e0e0e0;
  padding: 16rpx;
  text-align: left;
  display: table-cell;
}

.content-body .h2w__th {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-weight: 600;
  color: white;
}

.content-body .h2w__blockquote {
  margin: 24rpx 0;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #e3e8ff 100%);
  border-left: 6rpx solid #667eea;
  border-radius: 0 14rpx 14rpx 0;
  color: #555;
  font-style: italic;
  display: block;
}

.content-body .h2w__code {
  background: #f5f6f8;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
  color: #e74c3c;
  display: inline;
}

.content-body .h2w__pre {
  background: #2d3436;
  color: #dfe6e9;
  padding: 24rpx;
  border-radius: 14rpx;
  overflow-x: auto;
  margin: 24rpx 0;
  display: block;
}

.content-body .h2w__pre .h2w__code {
  background: none;
  color: inherit;
  padding: 0;
  font-size: 26rpx;
  display: block;
}

.content-body .h2w__a {
  color: #667eea;
  text-decoration: underline;
  display: inline;
}

/* ========== 标签区域 ========== */
.tags-area {
  background: white;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.tags-header {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tags-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex-shrink: 0;
}

.tags-line {
  flex: 1;
  height: 3rpx;
  background: linear-gradient(to right, #667eea, #764ba2);
  border-radius: 2rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 12rpx 22rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 28rpx;
  transition: all 0.3s ease;
}

.tag-item:active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.tag-item:active .tag-hash,
.tag-item:active .tag-text {
  color: white;
}

.tag-hash {
  font-size: 24rpx;
  color: #667eea;
  margin-right: 4rpx;
  font-weight: 600;
}

.tag-text {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

/* ========== 相关推荐 ========== */
.related-section {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.related-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.related-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.related-count {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

.related-scroll {
  white-space: nowrap;
  padding: 4rpx 0;
  height: auto;
}

.related-card {
  display: inline-block;
  width: 300rpx;
  padding: 24rpx;
  margin-right: 20rpx;
  background: white;
  border-radius: 20rpx;
  vertical-align: top;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.12);
  border: 2rpx solid rgba(102, 126, 234, 0.15);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.related-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
  border-radius: 20rpx 20rpx 0 0;
}

.related-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
}

.related-category {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.related-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.related-card-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.5;
}

/* ========== 底部操作栏 ========== */
.action-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  background: white;
  padding: 20rpx 32rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  animation: slideUp 0.8s ease;
}

.action-btn {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.action-btn::after { border: none; }

.copy-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.share-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

/* ========== 调试区域样式 ========== */
.debug-area {
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 16rpx;
  margin: 30rpx 0;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.debug-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #dee2e6;
}

.debug-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #495057;
}

.debug-copy-btn {
  background: linear-gradient(135deg, #20c997 0%, #12b886 100%);
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.debug-copy-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.debug-content {
  background: white;
  border-radius: 8rpx;
  padding: 20rpx;
  max-height: 400rpx;
  overflow-y: auto;
  border: 1rpx solid #dee2e6;
}

.debug-text {
  font-size: 24rpx;
  font-family: 'Courier New', monospace;
  color: #495057;
  line-height: 1.4;
  word-break: break-all;
  white-space: pre-wrap;
}

/* 调试按钮样式 */
.debug-btn {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
}

/* ========== Rich-text 内容样式 ========== */
.content-rich {
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

/* 标题样式 */
.content-rich h1 {
  font-size: 40rpx;
  font-weight: bold;
  color: #2c3e50;
  margin: 40rpx 0 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #eaeaea;
}

.content-rich h2 {
  font-size: 36rpx;
  font-weight: bold;
  color: #34495e;
  margin: 35rpx 0 18rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #667eea;
}

.content-rich h3 {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a5568;
  margin: 30rpx 0 15rpx;
}

.content-rich h4 {
  font-size: 30rpx;
  font-weight: 600;
  color: #5a6c7d;
  margin: 25rpx 0 12rpx;
}

/* 段落和列表样式 */
.content-rich p {
  margin: 20rpx 0;
  text-align: justify;
}

.content-rich ul, .content-rich ol {
  margin: 20rpx 0;
  padding-left: 40rpx;
}

.content-rich li {
  margin: 8rpx 0;
  line-height: 1.5;
}

.content-rich blockquote {
  background: linear-gradient(to right, #f8f9fa, #e9ecef);
  border-left: 6rpx solid #667eea;
  margin: 25rpx 0;
  padding: 25rpx 30rpx;
  border-radius: 8rpx;
  font-style: italic;
  color: #555;
}

/* 代码块样式 */
.content-rich pre {
  background: #2d3748;
  color: #e2e8f0;
  padding: 25rpx;
  border-radius: 12rpx;
  margin: 25rpx 0;
  overflow-x: auto;
  overflow-y: hidden;
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
  line-height: 1.4;
  white-space: pre;
  max-width: 100%;
  -webkit-overflow-scrolling: touch;
}

/* 确保代码块内容可以横向滚动 */
.content-rich pre code {
  display: block;
  min-width: max-content;
  white-space: pre;
}

.content-rich code {
  background: #f7fafc;
  color: #2d3748;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
}

/* ========== 表格样式优化 ========== */
.content-rich table {
  width: 100%;
  border-collapse: collapse;
  margin: 30rpx 0;
  background: white;
  border: 1rpx solid #d1d5db;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 表头样式 */
.content-rich thead {
  background: #667eea;
}

.content-rich th {
  padding: 20rpx 16rpx;
  text-align: left;
  font-weight: 600;
  color: white;
  font-size: 28rpx;
  border-bottom: 2rpx solid #5a6cd8;
  border-right: 1rpx solid rgba(255, 255, 255, 0.3);
}

.content-rich th:last-child {
  border-right: none;
}

/* 单元格样式 */
.content-rich td {
  padding: 18rpx 16rpx;
  border-bottom: 1rpx solid #e5e7eb;
  border-right: 1rpx solid #f3f4f6;
  font-size: 28rpx;
  line-height: 1.5;
  color: #374151;
}

.content-rich td:last-child {
  border-right: none;
}

/* 最后一行单元格取消底部边框 */
.content-rich tr:last-child td {
  border-bottom: none;
}

/* 隔行变色效果 */
.content-rich tbody tr:nth-child(even) {
  background: #f9fafb;
}

.content-rich tbody tr:nth-child(odd) {
  background: white;
}

/* 响应式表格 */
@media (max-width: 750rpx) {
  .content-rich table {
    font-size: 26rpx;
  }
  
  .content-rich th,
  .content-rich td {
    padding: 18rpx 12rpx;
    font-size: 26rpx;
  }
}

/* 分隔线样式 */
.content-rich hr {
  border: none;
  height: 2rpx;
  background: linear-gradient(to right, transparent, #667eea, transparent);
  margin: 40rpx 0;
  border-radius: 1rpx;
}

/* 强调文本样式 */
.content-rich strong {
  color: #2c5282;
  font-weight: 600;
}

.content-rich em {
  color: #805ad5;
  font-style: italic;
}
