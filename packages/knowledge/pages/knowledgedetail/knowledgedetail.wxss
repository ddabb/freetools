/* packages/knowledge/pages/knowledgedetail/knowledgedetail.wxss */

/* ========== 基础样式 ========== */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  position: relative;
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  gap: 30rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
}

/* ========== 错误状态 ========== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  gap: 30rpx;
}

.error-icon {
  font-size: 120rpx;
}

.error-text {
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 0 60rpx;
}

.retry-btn {
  margin-top: 20rpx;
  padding: 20rpx 60rpx;
  background: white;
  color: #667eea;
  border: none;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.retry-btn::after {
  border: none;
}

/* ========== 文章主体 ========== */
.article-wrapper {
  margin: 20rpx;
  padding-bottom: 200rpx;
}

/* ========== 英雄区域 (头部) ========== */
.article-hero {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

/* 分类标签 */
.hero-category {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  margin-bottom: 24rpx;
}

.hero-category.项目管理 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.hero-category.冷知识 {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.hero-category.技术 {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.hero-category.未分类 {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.category-icon {
  font-size: 28rpx;
}

.category-name {
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

/* 标题 */
.hero-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
  margin-bottom: 30rpx;
  letter-spacing: 1rpx;
}

/* 元信息 */
.hero-meta {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 20rpx;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-value {
  font-size: 24rpx;
  color: #666;
}

.meta-divider {
  width: 1rpx;
  height: 24rpx;
  background: #e0e0e0;
}

/* ========== 描述卡片 ========== */
.article-desc-card {
  display: flex;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.desc-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.desc-content {
  flex: 1;
}

.desc-text {
  color: white;
  font-size: 28rpx;
  line-height: 1.6;
}

/* ========== 文章正文 ========== */
.article-body {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.1);
}

/* 内容标题装饰 */
.content-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  gap: 20rpx;
}

.content-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(to right, transparent, #667eea, transparent);
}

.content-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
  white-space: nowrap;
}

/* HTML 内容 */
.content-body {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

.content-body rich-text {
  display: block;
}

/* HTML 内容样式增强 */
.content-body rich-text h1 {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin: 40rpx 0 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 4rpx solid #667eea;
}

.content-body rich-text h2 {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin: 32rpx 0 16rpx;
}

.content-body rich-text h3 {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin: 28rpx 0 12rpx;
}

.content-body rich-text p {
  margin: 16rpx 0;
  text-align: justify;
}

.content-body rich-text ul,
.content-body rich-text ol {
  margin: 16rpx 0;
  padding-left: 40rpx;
}

.content-body rich-text li {
  margin: 8rpx 0;
}

.content-body rich-text table {
  width: 100%;
  border-collapse: collapse;
  margin: 24rpx 0;
  font-size: 26rpx;
}

.content-body rich-text th,
.content-body rich-text td {
  border: 1rpx solid #e0e0e0;
  padding: 16rpx;
  text-align: left;
}

.content-body rich-text th {
  background: #f5f6f8;
  font-weight: 600;
  color: #333;
}

.content-body rich-text blockquote {
  margin: 24rpx 0;
  padding: 20rpx 24rpx;
  background: #f8f9ff;
  border-left: 6rpx solid #667eea;
  border-radius: 0 12rpx 12rpx 0;
  color: #666;
}

.content-body rich-text code {
  background: #f5f6f8;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-family: monospace;
  font-size: 26rpx;
  color: #e74c3c;
}

.content-body rich-text pre {
  background: #2d3436;
  color: #dfe6e9;
  padding: 24rpx;
  border-radius: 12rpx;
  overflow-x: auto;
  margin: 24rpx 0;
}

.content-body rich-text pre code {
  background: none;
  color: inherit;
  padding: 0;
}

/* ========== 标签区域 ========== */
.tags-area {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.1);
}

.tags-header {
  margin-bottom: 24rpx;
}

.tags-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.tags-line {
  height: 4rpx;
  width: 80rpx;
  background: linear-gradient(to right, #667eea, #764ba2);
  margin-top: 12rpx;
  border-radius: 2rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 30rpx;
  transition: all 0.3s ease;
}

.tag-item:active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transform: scale(0.95);
}

.tag-item:active .tag-hash,
.tag-item:active .tag-text {
  color: white;
}

.tag-hash {
  font-size: 24rpx;
  color: #667eea;
  margin-right: 4rpx;
  font-weight: 600;
}

.tag-text {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

/* ========== 底部操作栏 ========== */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  margin-top: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  position: fixed;
  bottom: 40rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 100;
}

.action-left {
  display: flex;
  gap: 40rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.action-icon {
  font-size: 40rpx;
  transition: all 0.3s ease;
}

.action-icon.active {
  transform: scale(1.2);
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.action-right {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.copy-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.share-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.action-btn::after {
  border: none;
}

/* ========== 相关推荐 ========== */
.related-section {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.1);
}

.related-header {
  margin-bottom: 20rpx;
}

.related-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.related-scroll {
  white-space: nowrap;
}

.related-card {
  display: inline-block;
  width: 280rpx;
  padding: 24rpx;
  margin-right: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  vertical-align: top;
}

.related-card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.related-card-desc {
  display: block;
  font-size: 22rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ========== 返回按钮 ========== */
.back-btn {
  position: fixed;
  top: 80rpx;
  left: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  z-index: 1000;
  font-size: 40rpx;
  color: #333;
}

.back-btn:active {
  transform: scale(0.9);
}
