/* packages/knowledge/pages/knowledgedetail/knowledgedetail.wxss */

/* ========== 基础样式 ========== */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  overflow-x: hidden;
}

.container {
  min-height: 100vh;
  position: relative;
  padding-top: 20rpx;
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  gap: 30rpx;
  animation: fadeIn 0.5s ease;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  box-shadow: 0 0 30rpx rgba(255, 255, 255, 0.3);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.loading-text {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* ========== 错误状态 ========== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  gap: 30rpx;
  animation: fadeIn 0.5s ease;
}

.error-icon {
  font-size: 120rpx;
  animation: bounce 1s ease-in-out;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-20rpx); }
  60% { transform: translateY(-10rpx); }
}

.error-text {
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 0 60rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.retry-btn {
  margin-top: 20rpx;
  padding: 22rpx 64rpx;
  background: white;
  color: #667eea;
  border: none;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.retry-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.25);
}

.retry-btn:active {
  transform: translateY(0);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.retry-btn::after {
  border: none;
}

/* ========== 文章主体 ========== */
.article-wrapper {
  margin: 0 20rpx 20rpx;
  padding-bottom: 220rpx;
  animation: slideUp 0.6s ease;
}

@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(30rpx);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== 英雄区域 (头部) ========== */
.article-hero {
  background: white;
  border-radius: 28rpx;
  padding: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.2);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.article-hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #f093fb, #f5576c);
  border-radius: 28rpx 28rpx 0 0;
}

.article-hero:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.25);
}

/* 分类标签 */
.hero-category {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  animation: slideInLeft 0.5s ease;
}

@keyframes slideInLeft {
  from { 
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to { 
    opacity: 1;
    transform: translateX(0);
  }
}

.hero-category.category-product-usage {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.hero-category.category-product-design {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.hero-category.category-product-thinking {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.hero-category.category-dev-practice {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.hero-category.category-dev-story {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.hero-category.category-project-mgmt {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.hero-category.category-uncategorized {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.category-icon {
  font-size: 32rpx;
}

.category-name {
  color: white;
  font-size: 26rpx;
  font-weight: 600;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.2);
}

/* 标题 */
.hero-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
  margin-bottom: 36rpx;
  letter-spacing: 1rpx;
  animation: slideInUp 0.6s ease;
}

@keyframes slideInUp {
  from { 
    opacity: 0;
    transform: translateY(20rpx);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

/* 元信息 */
.hero-meta {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 24rpx;
  flex-wrap: wrap;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
  animation: fadeIn 0.8s ease;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 16rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
  border: 1rpx solid #e9ecef;
  transition: all 0.3s ease;
}

.meta-item:hover {
  background: #e9ecef;
  transform: translateY(-2rpx);
}

.meta-icon {
  font-size: 26rpx;
}

.meta-value {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.meta-divider {
  width: 1rpx;
  height: 24rpx;
  background: #e0e0e0;
  margin: 0 8rpx;
}

/* ========== 描述卡片 ========== */
.article-desc-card {
  display: flex;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.article-desc-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(45deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
  border-radius: 24rpx;
}

.article-desc-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.4);
}

.desc-icon {
  font-size: 52rpx;
  margin-right: 24rpx;
  z-index: 1;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.desc-content {
  flex: 1;
  z-index: 1;
}

.desc-text {
  color: white;
  font-size: 30rpx;
  line-height: 1.6;
  font-weight: 400;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* ========== 文章正文 ========== */
.article-body {
  background: white;
  border-radius: 28rpx;
  padding: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  transition: all 0.3s ease;
  position: relative;
}

.article-body:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.2);
}

/* 内容标题装饰 */
.content-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  gap: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.content-line {
  flex: 1;
  height: 3rpx;
  background: linear-gradient(to right, transparent, #667eea, transparent);
  border-radius: 2rpx;
}

.content-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
  white-space: nowrap;
  padding: 0 20rpx;
  background: white;
  position: relative;
  z-index: 1;
}

/* HTML 内容 */
.content-body {
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
  animation: fadeIn 0.8s ease;
}

.content-body rich-text {
  display: block;
}

/* HTML 内容样式增强 */
.content-body rich-text h1 {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin: 48rpx 0 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 4rpx solid #667eea;
  animation: slideInLeft 0.5s ease;
}

.content-body rich-text h2 {
  font-size: 38rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin: 36rpx 0 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
  animation: slideInLeft 0.5s ease;
}

.content-body rich-text h3 {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin: 32rpx 0 16rpx;
  animation: slideInLeft 0.5s ease;
}

.content-body rich-text p {
  margin: 20rpx 0;
  text-align: justify;
  animation: fadeIn 0.6s ease;
}

.content-body rich-text ul,
.content-body rich-text ol {
  margin: 20rpx 0;
  padding-left: 48rpx;
  animation: fadeIn 0.6s ease;
}

.content-body rich-text li {
  margin: 12rpx 0;
  position: relative;
}

.content-body rich-text ul li {
  list-style-type: disc;
}

.content-body rich-text ol li {
  list-style-type: decimal;
}

.content-body rich-text table {
  width: 100%;
  border-collapse: collapse;
  margin: 32rpx 0;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  border-radius: 12rpx;
  overflow: hidden;
  animation: fadeIn 0.6s ease;
}

.content-body rich-text th,
.content-body rich-text td {
  border: 1rpx solid #e0e0e0;
  padding: 20rpx;
  text-align: left;
}

.content-body rich-text th {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-weight: 600;
  color: white;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.2);
}

.content-body rich-text tr:nth-child(even) {
  background: #f8f9fa;
}

.content-body rich-text blockquote {
  margin: 32rpx 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #e3e8ff 100%);
  border-left: 8rpx solid #667eea;
  border-radius: 0 16rpx 16rpx 0;
  color: #666;
  font-style: italic;
  animation: slideInLeft 0.5s ease;
}

.content-body rich-text code {
  background: #f5f6f8;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-family: 'Courier New', monospace;
  font-size: 28rpx;
  color: #e74c3c;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.content-body rich-text pre {
  background: #2d3436;
  color: #dfe6e9;
  padding: 32rpx;
  border-radius: 16rpx;
  overflow-x: auto;
  margin: 32rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  animation: fadeIn 0.6s ease;
}

.content-body rich-text pre code {
  background: none;
  color: inherit;
  padding: 0;
  box-shadow: none;
}

/* ========== 标签区域 ========== */
.tags-area {
  background: white;
  border-radius: 28rpx;
  padding: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  transition: all 0.3s ease;
}

.tags-area:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.2);
}

.tags-header {
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tags-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.tags-line {
  flex: 2;
  height: 4rpx;
  background: linear-gradient(to right, #667eea, #764ba2);
  border-radius: 2rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  animation: fadeIn 0.6s ease;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 32rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tag-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  border-color: rgba(102, 126, 234, 0.4);
}

.tag-item:active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.tag-item:active .tag-hash,
.tag-item:active .tag-text {
  color: white;
}

.tag-hash {
  font-size: 26rpx;
  color: #667eea;
  margin-right: 6rpx;
  font-weight: 600;
}

.tag-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

/* ========== 相关推荐 ========== */
.related-section {
  background: white;
  border-radius: 28rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  transition: all 0.3s ease;
}

.related-section:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.2);
}

.related-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.related-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.related-count {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.related-scroll {
  white-space: nowrap;
  padding: 8rpx 0;
  animation: fadeIn 0.6s ease;
}

.related-card {
  display: inline-block;
  width: 340rpx;
  padding: 32rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 20rpx;
  vertical-align: top;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.related-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 20rpx 20rpx 0 0;
}

.related-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
}

.related-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.related-category {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  color: white;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.related-category.category-product-usage {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.related-category.category-product-design {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.related-category.category-product-thinking {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.related-category.category-dev-practice {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.related-category.category-dev-story {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.related-category.category-project-mgmt {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.related-category.category-uncategorized {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.related-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.related-card-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.5;
}

/* ========== 底部操作栏 ========== */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  border-radius: 50rpx;
  padding: 24rpx 36rpx;
  margin-top: 36rpx;
  box-shadow: 0 -6rpx 24rpx rgba(0, 0, 0, 0.15);
  position: fixed;
  bottom: 48rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 100;
  transition: all 0.3s ease;
  animation: slideUp 0.5s ease;
}

.action-bar:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.action-left {
  display: flex;
  gap: 48rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.action-item:hover {
  background: #f8f9fa;
  transform: translateY(-2rpx);
}

.action-icon {
  font-size: 44rpx;
  transition: all 0.3s ease;
}

.action-icon.active {
  transform: scale(1.2);
  filter: drop-shadow(0 2rpx 8rpx rgba(255, 0, 0, 0.3));
}

.action-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.action-right {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 18rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  gap: 10rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.action-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.action-btn:active {
  transform: translateY(0);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.copy-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.share-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.action-btn::after {
  border: none;
}

/* ========== 返回按钮 ========== */
.back-btn {
  position: fixed;
  top: 96rpx;
  left: 36rpx;
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.2);
  z-index: 1000;
  font-size: 44rpx;
  color: #333;
  transition: all 0.3s ease;
  animation: slideInLeft 0.5s ease;
}

.back-btn:hover {
  transform: scale(1.1);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
  background: white;
}

.back-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

/* ========== 响应式设计 ========== */
@media (max-width: 750rpx) {
  .article-wrapper {
    margin: 0 16rpx 16rpx;
    padding-bottom: 200rpx;
  }
  
  .article-hero {
    padding: 36rpx;
    margin-bottom: 20rpx;
  }
  
  .hero-title {
    font-size: 40rpx;
    margin-bottom: 28rpx;
  }
  
  .article-body {
    padding: 36rpx;
    margin-bottom: 20rpx;
  }
  
  .tags-area {
    padding: 36rpx;
    margin-bottom: 20rpx;
  }
  
  .related-section {
    padding: 32rpx;
    margin-bottom: 20rpx;
  }
  
  .related-card {
    width: 300rpx;
    padding: 28rpx;
    margin-right: 16rpx;
  }
  
  .action-bar {
    padding: 20rpx 30rpx;
    bottom: 40rpx;
    left: 20rpx;
    right: 20rpx;
  }
  
  .action-left {
    gap: 32rpx;
  }
  
  .action-btn {
    padding: 16rpx 28rpx;
    font-size: 26rpx;
  }
  
  .back-btn {
    top: 80rpx;
    left: 30rpx;
    width: 80rpx;
    height: 80rpx;
    font-size: 40rpx;
  }
}

@media (max-width: 480rpx) {
  .hero-meta {
    flex-direction: column;
    align-items: flex-start;
    gap: 12rpx;
  }
  
  .meta-divider {
    display: none;
  }
  
  .related-card {
    width: 280rpx;
    padding: 24rpx;
  }
  
  .action-bar {
    flex-direction: column;
    gap: 16rpx;
    padding: 24rpx;
    border-radius: 24rpx;
  }
  
  .action-left {
    width: 100%;
    justify-content: space-around;
  }
  
  .action-right {
    width: 100%;
    justify-content: space-around;
  }
}
