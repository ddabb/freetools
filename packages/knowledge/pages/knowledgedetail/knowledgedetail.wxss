/* packages/knowledge/pages/knowledgedetail/knowledgedetail.wxss */

/* ========== 基础样式 ========== */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  overflow-x: hidden;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  padding: 0;
  margin: 0;
}

/* ========== 文章滚动区 ========== */
.article-scroll {
  flex: 1;
  min-height: 300rpx;
  padding-top: 20rpx;
  padding-bottom: 0;
  box-sizing: border-box;
}

.article-wrapper {
  margin: 0 20rpx 20rpx;
  animation: slideUp 0.6s ease;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ========== 底部留白 ========== */
.bottom-spacer {
  height: 20rpx;
}

/* ========== 加载状态 ========== */
.loading-state {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  box-shadow: 0 0 30rpx rgba(255, 255, 255, 0.3);
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* ========== 错误状态 ========== */
.error-state {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.error-icon {
  font-size: 120rpx;
  animation: bounce 1s ease-in-out;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-20rpx); }
  60% { transform: translateY(-10rpx); }
}

.error-text {
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 0 60rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.retry-btn {
  margin-top: 20rpx;
  padding: 22rpx 64rpx;
  background: white;
  color: #667eea;
  border: none;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.retry-btn::after { border: none; }

/* ========== 英雄区域 (头部) ========== */
.article-hero {
  background: white;
  border-radius: 28rpx;
  padding: 40rpx;
  margin: 20rpx 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.2);
  position: relative;
  overflow: hidden;
  animation: slideUp 0.6s ease;
  flex-shrink: 0;
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.article-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #f093fb, #f5576c);
  border-radius: 28rpx 28rpx 0 0;
}

/* 分类标签 */
.hero-category {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.hero-category.category-product-usage { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
.hero-category.category-product-design { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
.hero-category.category-product-thinking { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
.hero-category.category-dev-practice { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
.hero-category.category-dev-story { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }
.hero-category.category-project-mgmt { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.hero-category.category-uncategorized { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }

.category-icon { font-size: 28rpx; color: #333; }
.category-name { color: #333; font-size: 24rpx; font-weight: 600; }

/* 标题 */
.hero-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.35;
  margin-bottom: 28rpx;
  letter-spacing: 1rpx;
}

/* 元信息 */
.hero-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 14rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
  border: 1rpx solid #e9ecef;
}

.meta-icon { font-size: 22rpx; }
.meta-value { font-size: 22rpx; color: #666; font-weight: 500; }
.meta-divider {
  width: 1rpx;
  height: 20rpx;
  background: #e0e0e0;
}

/* ========== 描述卡片 ========== */
.article-desc-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

.desc-icon { font-size: 44rpx; flex-shrink: 0; }

.desc-text {
  color: white;
  font-size: 28rpx;
  line-height: 1.65;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* ========== 文章正文 ========== */
.article-body {
  background: white;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.content-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
  gap: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.content-line {
  flex: 1;
  height: 3rpx;
  background: linear-gradient(to right, transparent, #667eea, transparent);
  border-radius: 2rpx;
}

.content-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
  white-space: nowrap;
  padding: 0 16rpx;
}

/* towxml 渲染内容 */
.content-body {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

/* 回退：原始 Markdown 文本 */
.content-fallback .md-raw {
  display: block;
  white-space: pre-wrap;
  word-break: break-all;
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

/* towxml 默认节点样式增强 */
.content-body .h2w__h1 {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin: 40rpx 0 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 3rpx solid #667eea;
  display: block;
}

.content-body .h2w__h2 {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin: 32rpx 0 16rpx;
  padding-left: 14rpx;
  border-left: 5rpx solid #667eea;
  display: block;
}

.content-body .h2w__h3 {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin: 24rpx 0 12rpx;
  display: block;
}

.content-body .h2w__p {
  margin: 16rpx 0;
  text-align: justify;
  display: block;
}

.content-body .h2w__ul,
.content-body .h2w__ol {
  margin: 16rpx 0;
  padding-left: 44rpx;
  display: block;
}

.content-body .h2w__li {
  margin: 10rpx 0;
  display: list-item;
}

.content-body .h2w__ul .h2w__li { list-style-type: disc; }
.content-body .h2w__ol .h2w__li { list-style-type: decimal; }

.content-body .h2w__table {
  width: 100%;
  border-collapse: collapse;
  margin: 28rpx 0;
  font-size: 26rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  border-radius: 10rpx;
  overflow: hidden;
  display: table;
}

.content-body .h2w__thead,
.content-body .h2w__tbody,
.content-body .h2w__tr { display: table-row; }
.content-body .h2w__th,
.content-body .h2w__td {
  border: 1rpx solid #e0e0e0;
  padding: 16rpx;
  text-align: left;
  display: table-cell;
}

.content-body .h2w__th {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-weight: 600;
  color: white;
}

.content-body .h2w__blockquote {
  margin: 24rpx 0;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #e3e8ff 100%);
  border-left: 6rpx solid #667eea;
  border-radius: 0 14rpx 14rpx 0;
  color: #555;
  font-style: italic;
  display: block;
}

.content-body .h2w__code {
  background: #f5f6f8;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
  color: #e74c3c;
  display: inline;
}

.content-body .h2w__pre {
  background: #2d3436;
  color: #dfe6e9;
  padding: 24rpx;
  border-radius: 14rpx;
  overflow-x: auto;
  margin: 24rpx 0;
  display: block;
}

.content-body .h2w__pre .h2w__code {
  background: none;
  color: inherit;
  padding: 0;
  font-size: 26rpx;
  display: block;
}

.content-body .h2w__a {
  color: #667eea;
  text-decoration: underline;
  display: inline;
}

/* ========== 标签区域 ========== */
.tags-area {
  background: white;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.tags-header {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tags-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex-shrink: 0;
}

.tags-line {
  flex: 1;
  height: 3rpx;
  background: linear-gradient(to right, #667eea, #764ba2);
  border-radius: 2rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 12rpx 22rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 28rpx;
  transition: all 0.3s ease;
}

.tag-item:active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.tag-item:active .tag-hash,
.tag-item:active .tag-text {
  color: white;
}

.tag-hash {
  font-size: 24rpx;
  color: #667eea;
  margin-right: 4rpx;
  font-weight: 600;
}

.tag-text {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

/* ========== 相关推荐 ========== */
.related-section {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.related-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.related-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.related-count {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

.related-scroll {
  white-space: nowrap;
  padding: 4rpx 0;
  height: auto;
}

.related-card {
  display: inline-block;
  width: 320rpx;
  padding: 24rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 18rpx;
  vertical-align: top;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.related-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 18rpx 18rpx 0 0;
}

.related-category {
  display: inline-block;
  padding: 4rpx 14rpx;
  font-size: 18rpx;
  color: #333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.related-card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.related-card-desc {
  display: block;
  font-size: 22rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.5;
}

/* ========== 底部操作栏 ========== */
.action-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  background: white;
  padding: 20rpx 32rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  animation: slideUp 0.8s ease;
}

.action-btn {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.action-btn::after { border: none; }

.copy-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.share-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}
