/* packages/knowledge/pages/knowledgedetail/knowledgedetail.wxss */

page {
  background: #f5f5f5;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 28rpx;
  color: #999;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 28rpx;
  color: #e74c3c;
}

.retry-btn {
  margin-top: 30rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #2980b9;
  border: 1rpx solid #2980b9;
  border-radius: 8rpx;
  background-color: #fff;
}

.retry-btn:hover {
  background-color: #f0f8ff;
}

/* 文章详情 */
.article-detail {
  padding: 30rpx;
  background: white;
  margin: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 文章头部 */
.article-header {
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}

.article-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 16rpx;
  display: block;
}

.article-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
  flex-wrap: wrap;
}

.category {
  padding: 6rpx 12rpx;
  background: #2980b9;
  color: white;
  border-radius: 12rpx;
  font-weight: 500;
}

.word-count,
.update-time {
  color: #999;
}

/* 文章描述 */
.article-description {
  padding: 16rpx;
  background: #f9f9f9;
  border-left: 4rpx solid #2980b9;
  border-radius: 4rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 文章内容 */
.article-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  margin-bottom: 24rpx;
}

.article-content rich-text {
  display: block;
}

/* 标签部分 */
.tags-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.tags-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #2980b9;
  font-weight: 500;
}

.tag:active {
  background: #e8e8e8;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 12rpx;
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.btn-share {
  flex: 1;
  background: #2980b9 !important;
  color: white !important;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 16rpx !important;
}

.btn-share::after {
  border: none;
}
