/**packages/math/pages/24point/24point.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #fff5eb 0%, #ffe8d6 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 20rpx 15rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 头部说明区域 */
.header-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.game-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #ff6b35;
  margin-bottom: 15rpx;
}

.game-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.game-rules {
  display: block;
  font-size: 22rpx;
  color: #ff6b35;
  font-weight: 600;
  background: rgba(255, 107, 53, 0.1);
  padding: 12rpx 15rpx;
  border-radius: 10rpx;
  border-left: 4rpx solid #ff6b35;
  margin: 0 10rpx;
}

/* 控制区域 */
.control-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.numbers-display {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.number-card {
  width: 70rpx;
  height: 70rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s ease;
}

.number-card.first {
  background: linear-gradient(135deg, #ff9a56, #ff7f4d);
}

.number-card.second {
  background: linear-gradient(135deg, #4ecdc4, #3db8a8);
}

.number-card.third {
  background: linear-gradient(135deg, #45b7d1, #3ca5c0);
}

.number-card.fourth {
  background: linear-gradient(135deg, #a29bfe, #74b9ff);
}

.number-text {
  font-size: 30rpx;
  font-weight: 800;
  color: white;
}

.control-buttons {
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 20rpx;
  flex-wrap: nowrap;
}

.control-btn {
  flex: 1;
  background: white;
  border: 2rpx solid #ff9a56;
  border-radius: 12rpx;
  padding: 12rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  transition: all 0.3s ease;
  min-height: 80rpx;
  max-width: 120rpx;
}

.control-btn:active {
  background: #ff9a56;
  transform: scale(0.95);
}

.control-btn:active .btn-icon,
.control-btn:active .btn-text {
  color: white;
}

.new-game-btn {
  border-color: #ff6b35;
}

.hint-btn {
  border-color: #4ecdc4;
}

.solution-btn {
  border-color: #45b7d1;
}

.btn-icon {
  font-size: 36rpx;
  color: #ff9a56;
}

.btn-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

/* 输入区域 */
.input-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.expression-input-container {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.expression-input-container:focus-within {
  border-color: #ff9a56;
  background: white;
  box-shadow: 0 0 0 8rpx rgba(255, 154, 86, 0.1);
}

.expression-input {
  flex: 1;
  font-size: 28rpx;
  border: none;
  outline: none;
  color: #333;
  font-weight: 500;
  background: transparent;
  padding: 24rpx 0;
  font-family: 'Monaco', 'Menlo', monospace;
  min-height: 60rpx;
}

.clear-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #ff4757;
  color: white;
  border: none;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 15rpx;
  min-width: 50rpx;
}

.action-buttons {
  text-align: center;
  margin-top: 20rpx;
}

.check-btn {
  background: linear-gradient(135deg, #ff7f4d, #ffa66e);
  color: white;
  border: none;
  border-radius: 15rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(255, 107, 53, 0.2);
  transition: all 0.2s ease;
}

.check-btn:not(:disabled):active {
  transform: translateY(1rpx);
  box-shadow: 0 2rpx 5rpx rgba(255, 107, 53, 0.3);
}

.check-btn:disabled {
  background: #ddd;
  box-shadow: none;
}

/* 结果显示区域 */
.result-section {
  margin-bottom: 20rpx;
}

.result-box {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 25rpx 20rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
}

.result-box.correct {
  border: 1rpx solid #2ed573;
  background: rgba(46, 213, 115, 0.1);
}

.result-box.incorrect {
  border: 1rpx solid #ff4757;
  background: rgba(255, 71, 87, 0.1);
}

.result-icon {
  font-size: 72rpx;
}

.result-message {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
}

.result-expression {
  text-align: center;
}

.expression-display {
  font-size: 32rpx;
  color: #666;
  font-family: 'Monaco', 'Menlo', monospace;
  background: rgba(255, 255, 255, 0.5);
  padding: 20rpx 30rpx;
  border-radius: 15rpx;
}

/* 提示和答案区域 */
.hint-section,
.solution-section {
  margin-bottom: 15rpx;
}

.hint-box,
.solution-box {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 25rpx 20rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.hint-header,
.solution-header {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.hint-content {
  margin-bottom: 40rpx;
}

.hint-text {
  font-size: 32rpx;
  color: #555;
  line-height: 1.6;
  background: rgba(255, 193, 7, 0.1);
  padding: 30rpx;
  border-radius: 18rpx;
  border-left: 5rpx solid #ffc107;
}

.close-hint-btn,
.close-solution-btn {
  background: #6c757d;
  color: white;
  border: none;
  border-radius: 18rpx;
  padding: 25rpx 50rpx;
  font-size: 32rpx;
  margin: 0 auto;
  display: block;
}

.solution-list {
  margin-bottom: 40rpx;
}

.solution-item {
  background: rgba(69, 183, 209, 0.1);
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-left: 5rpx solid #45b7d1;
}

.solution-expression {
  display: block;
  font-size: 32rpx;
  color: #45b7d1;
  font-weight: 700;
  font-family: 'Monaco', 'Menlo', monospace;
  margin-bottom: 10rpx;
}

.solution-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
}

/* 统计区域 */
.stats-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  gap: 10rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-number {
  font-size: 32rpx;
  font-weight: 800;
  color: #ff6b35;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
  text-align: center;
}

/* 历史记录区域 */
.history-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 15rpx;
}

.history-header {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 15rpx 20rpx;
}

.history-numbers {
  display: flex;
  gap: 8rpx;
}

.history-number {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: #ff9a56;
  color: white;
  font-size: 18rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-result {
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.history-result.solved {
  background: #2ed573;
  color: white;
}

.history-result.unsolved {
  background: #ff4757;
  color: white;
}

/* 动画效果 */
@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
  70% {
    transform: scale(0.9);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 自定义数字区域 */
.custom-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 25rpx 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.custom-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.custom-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #ff6b35;
  margin-bottom: 10rpx;
}

.custom-desc {
  display: block;
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

.custom-inputs {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.custom-input {
  width: 120rpx;
  height: 80rpx;
  border: 2rpx solid #ff9a56;
  border-radius: 15rpx;
  font-size: 32rpx;
  text-align: center;
  color: #333;
  font-weight: 700;
  background: white;
  outline: none;
}

.custom-input:focus {
  border-color: #ff6b35;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 53, 0.1);
}

.random-generate-btn {
  background: linear-gradient(135deg, #45b7d1, #96e6a1);
  color: white;
  border: none;
  border-radius: 15rpx;
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 25rpx rgba(69, 183, 209, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: all 0.3s ease;
  min-width: 140rpx;
  height: 90rpx;
}

.random-generate-btn:active {
  transform: translateY(-2rpx) scale(1.05);
  box-shadow: 0 12rpx 30rpx rgba(69, 183, 209, 0.4);
}

.random-generate-btn .btn-icon {
  font-size: 32rpx;
  color: white;
}

.random-generate-btn .btn-text {
  font-size: 22rpx;
  color: white;
  font-weight: 600;
}

.custom-actions {
  display: flex;
  justify-content: space-between;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.custom-btn {
  flex: 1;
  background: white;
  border: 2rpx solid #ff9a56;
  border-radius: 12rpx;
  padding: 15rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  transition: all 0.3s ease;
  min-height: 80rpx;
}

.custom-btn:active {
  background: #ff9a56;
  transform: scale(0.95);
}

.custom-btn:active .btn-icon,
.custom-btn:active .btn-text {
  color: white;
}

.custom-btn:disabled {
  opacity: 0.5;
  background: #f8f9fa;
}

.check-solvability-btn {
  border-color: #45b7d1;
}

.use-custom-btn {
  border-color: #2ed573;
}

.solvability-result {
  animation: slideInUp 0.5s ease-out;
}

.solvability-box {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 15rpx;
  padding: 20rpx 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.solvability-box.solvable {
  border: 1rpx solid #2ed573;
  background: rgba(46, 213, 115, 0.1);
}

.solvability-box.unsolvable {
  border: 1rpx solid #ff4757;
  background: rgba(255, 71, 87, 0.1);
}

.solvability-icon {
  font-size: 60rpx;
}

.solvability-message {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
}

.solvability-solutions {
  width: 100%;
  margin-top: 10rpx;
}

.solution-count {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-bottom: 15rpx;
}

.solution-item {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  padding: 15rpx;
  margin-bottom: 10rpx;
}

.solution-expression {
  font-size: 26rpx;
  color: #333;
  font-family: 'Monaco', 'Menlo', monospace;
  text-align: center;
}

/* 模式切换区域 */
.mode-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 12rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.mode-tabs {
  display: flex;
  justify-content: space-around;
  gap: 10rpx;
}

.mode-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx 8rpx;
  border-radius: 12rpx;
  background: #f8f9fa;
  transition: all 0.2s ease;
}

.mode-tab.active {
  background: linear-gradient(135deg, #ff7f4d, #ffa66e);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.2);
}

.mode-tab:active {
  opacity: 0.9;
}

.mode-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.mode-tab.active .mode-icon,
.mode-tab.active .mode-text {
  color: white;
}

.mode-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #333;
}

/* 预设模式控制 */
.preset-controls {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 自定义模式控制 */
.custom-controls {
  display: flex;
