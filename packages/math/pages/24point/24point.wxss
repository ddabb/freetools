  border: none;
  border-radius: 15rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(255, 107, 53, 0.2);
  transition: all 0.2s ease;
  display: block;
  width: 100%;
  box-sizing: border-box;
}

.mode-specific-btn .btn-icon,
.mode-specific-btn .btn-text {
  color: white;
}

.mode-specific-btn:active {
  transform: translateY(1rpx);
  box-shadow: 0 2rpx 5rpx rgba(255, 107, 53, 0.3);
}

/* 全局控制按钮 */
.global-control-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.global-control-buttons {
  display: flex;
  justify-content: space-between;
  gap: 15rpx;
}

.global-control-btn {
  flex: 1;
  background: white;
  border: 2rpx solid #ff9a56;
  border-radius: 12rpx;
  padding: 15rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  transition: all 0.2s ease;
  min-height: 70rpx;
}

.global-control-btn:active {
  background: rgba(255, 154, 86, 0.1);
}

.global-control-btn:active .btn-icon,
.global-control-btn:active .btn-text {
  color: #ff6b35;
}

.global-control-btn:disabled {
  opacity: 0.5;
  background: #f8f9fa;
}

.global-control-btn.hint-btn {
  border-color: #4ecdc4;
}

.global-control-btn.solution-btn {
  border-color: #45b7d1;
}

/* 调整数字显示区域的间距 */
.control-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.numbers-display {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 0;
}

/* 隐藏控制区域（保留空间） */
.hidden-control {
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
}