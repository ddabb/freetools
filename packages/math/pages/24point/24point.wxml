<view class="container">
  <!-- 头部说明 -->
  <view class="header-section">
    <view class="game-title">🎮 24点速算挑战</view>
    <view class="game-desc">使用给定的4个数字，通过加减乘除运算得到24</view>
    <view class="game-rules">规则：每个数字必须使用且只能使用一次</view>
  </view>

  <!-- 模式切换选项卡 -->
  <view class="mode-section">
    <view class="mode-tabs">
      <view class="mode-tab {{gameMode === 'custom' ? 'active' : ''}}" hover-class="mode-tab-hover" bindtap="switchGameMode" data-mode="custom">
        <text class="mode-icon">🔢</text>
        <text class="mode-text">自定义模式</text>
      </view>
      <view class="mode-tab {{gameMode === 'preset' ? 'active' : ''}}" hover-class="mode-tab-hover" bindtap="switchGameMode" data-mode="preset">
        <text class="mode-icon">🎲</text>
        <text class="mode-text">预设模式</text>
      </view>
      <view class="mode-tab sound-tab {{soundEnabled ? 'active' : ''}}" hover-class="mode-tab-hover" bindtap="toggleSound">
        <text class="mode-icon">{{soundEnabled ? '🔊' : '🔇'}}</text>
        <text class="mode-text">音效</text>
      </view>
    </view>
  </view>

  <!-- 数字显示区域（始终保留空间，仅在预设模式显示内容） -->
  <view class="control-section {{gameMode !== 'preset' ? 'hidden-control' : ''}}">
    <view class="numbers-display">
      <view class="number-card {{index === 0 ? 'first' : ''}} {{index === 1 ? 'second' : ''}} {{index === 2 ? 'third' : ''}} {{index === 3 ? 'fourth' : ''}}" 
            wx:for="{{numbers}}" wx:key="index" wx:for-index="index">
        <text class="number-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 模式特定控制区域 -->
  <view class="mode-control-section">
    <!-- 预设模式控制 -->
    <view wx:if="{{gameMode === 'preset'}}">
      <button class="new-game-btn mode-specific-btn" hover-class="mode-specific-btn-hover" bindtap="generateNewGame">
        <text class="btn-icon">🎲</text>
        <text class="btn-text">新游戏</text>
      </button>
    </view>

    <!-- 自定义模式控制 -->
    <view wx:elif="{{gameMode === 'custom'}}">
      <view class="custom-input-section">
        <view class="custom-inputs">
          <input type="number" placeholder="数字1" value="{{customNumbers[0]}}" bindinput="onCustomInput1" class="custom-input"  placeholder-class="input-placeholder"/>
          <input type="number" placeholder="数字2" value="{{customNumbers[1]}}" bindinput="onCustomInput2" class="custom-input"  placeholder-class="input-placeholder"/>
          <input type="number" placeholder="数字3" value="{{customNumbers[2]}}" bindinput="onCustomInput3" class="custom-input"  placeholder-class="input-placeholder"/>
          <input type="number" placeholder="数字4" value="{{customNumbers[3]}}" bindinput="onCustomInput4" class="custom-input"  placeholder-class="input-placeholder"/>
          <button class="random-generate-btn" hover-class="random-generate-btn-hover" bindtap="generateRandomCustomNumbers">
            <text class="btn-icon">🎲</text>
            <text class="btn-text">随机生成</text>
          </button>
        </view>
        
        <view class="custom-actions">
          <button class="custom-btn check-solvability-btn" hover-class="custom-btn-hover" bindtap="checkSolvability" disabled="{{!customNumbersValid}}">
            <text class="btn-icon">🔍</text>
            <text class="btn-text">检查是否有解</text>
          </button>
          <button class="custom-btn use-custom-btn" hover-class="custom-btn-hover" bindtap="useCustomNumbers" disabled="{{!customNumbersValid}}">
            <text class="btn-icon">🎮</text>
            <text class="btn-text">使用这些数字游戏</text>
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 可解性结果（仅自定义模式显示） -->
  <view class="solvability-section" wx:if="{{gameMode === 'custom' && showSolvabilityResult}}">
    <view class="solvability-box {{isSolvable ? 'solvable' : 'unsolvable'}}">
      <view class="solvability-icon">{{isSolvable ? '✅' : '❌'}}</view>
      <view class="solvability-message">{{solvabilityMessage}}</view>
      <view class="solvability-solutions" wx:if="{{isSolvable && customSolutions.length > 0}}">
        <view class="solution-count">找到 {{customSolutions.length}} 种解法:</view>
        <view class="solution-item" wx:for="{{customSolutions}}" wx:key="index">
          <text class="solution-expression">{{item.expression}} = 24</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 全局控制按钮（仅预设模式显示） -->
  <view class="global-control-section" wx:if="{{gameMode === 'preset'}}">
    <view class="global-control-buttons">
      <button class="global-control-btn hint-btn" hover-class="control-btn-hover" bindtap="showHint" disabled="{{showingHint}}">
        <text class="btn-icon">💡</text>
        <text class="btn-text">提示</text>
      </button>
      <button class="global-control-btn solution-btn" hover-class="control-btn-hover" bindtap="showSolution" disabled="{{solutionFound}}">
        <text class="btn-icon">🔍</text>
        <text class="btn-text">答案</text>
      </button>
    </view>
  </view>

  <!-- 用户输入区域 -->
  <view class="input-section">
    <view class="expression-input-container">
      <input type="text" value="{{expression}}" bindinput="setExpression" class="expression-input" placeholder="输入算式，如：(1+2+3)×4 或 (1+2+3)*4"  placeholder-class="input-placeholder"/>
      <button class="clear-btn" bindtap="clearExpression" wx:if="{{expression}}">×</button>
    </view>
    
    <view class="action-buttons">
      <button class="check-btn" bindtap="checkAnswer" disabled="{{!expression}}" hover-class="check-btn-active">
        <text class="btn-text">检验答案</text>
      </button>
    </view>
  </view>

  <!-- 结果显示区域 -->
  <view class="result-section" wx:if="{{showResult}}">
    <view class="result-box {{isCorrect ? 'correct' : 'incorrect'}}">
      <view class="result-icon">{{isCorrect ? '🎉' : '😅'}}</view>
      <view class="result-message">{{resultMessage}}</view>
      <view class="result-expression" wx:if="{{isCorrect}}">
        <text class="expression-display">{{expression}} = 24</text>
      </view>
    </view>
  </view>

  <!-- 提示区域 -->
  <view class="hint-section" wx:if="{{showingHint}}">
    <view class="hint-box">
      <view class="hint-header">💡 解题提示</view>
      <view class="hint-content">
        <text class="hint-text">{{currentHint}}</text>
      </view>
      <button class="close-hint-btn" bindtap="closeHint">关闭提示</button>
    </view>
  </view>

  <!-- 答案区域 -->
  <view class="solution-section" wx:if="{{showingSolution}}">
    <view class="solution-box">
      <view class="solution-header">🔍 参考答案</view>
      <view class="solution-list">
        <view class="solution-item" wx:for="{{solutions}}" wx:key="index">
          <text class="solution-expression">{{item.expression}} = 24</text>
          <text class="solution-desc">{{item.description}}</text>
        </view>
      </view>
      <button class="close-solution-btn" bindtap="closeSolution">关闭答案</button>
    </view>
  </view>

  <!-- 统计信息（仅预设模式显示） -->
  <view class="stats-section" wx:if="{{gameMode === 'preset'}}">
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-number">{{gamesPlayed}}</text>
        <text class="stat-label">已玩局数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{correctAnswers}}</text>
        <text class="stat-label">答对题数</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{accuracy}}%</text>
        <text class="stat-label">正确率</text>
      </view>
    </view>
  </view>

  <!-- 历史记录（仅预设模式显示，且有记录时） -->
  <view class="history-section" wx:if="{{gameMode === 'preset' && gameHistory.length > 0}}">
    <view class="history-header">📝 最近游戏</view>
    <view class="history-list">
      <view class="history-item" wx:for="{{gameHistory}}" wx:key="index">
        <view class="history-numbers">
          <text class="history-number" wx:for="{{item.numbers}}" wx:key="numIndex" wx:for-item="num">{{num}}</text>
        </view>
        <view class="history-result {{item.solved ? 'solved' : 'unsolved'}}">
          {{item.solved ? '✓ 已解' : '✗ 未解'}}
        </view>
      </view>
    </view>
  </view>
</view>