/**packages/math/pages/divisor-finder/divisor-finder.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* 输入区域 */
.input-section {
  margin-bottom: 24rpx;
}

.input-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.input-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.input-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.input-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.input-wrapper {
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: #667eea;
  background: white;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.1);
}

.number-input {
  width: 100%;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  padding: 28rpx 0;
  border: none;
  outline: none;
  background: transparent;
}

.number-input::placeholder {
  color: #aaa;
  font-weight: 400;
}

.input-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
}

/* 错误提示 */
.error-card {
  background: rgba(255, 59, 48, 0.1);
  border: 2rpx solid rgba(255, 59, 48, 0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  animation: shake 0.3s ease;
}

.error-icon {
  font-size: 32rpx;
}

.error-text {
  font-size: 26rpx;
  color: #ff3b30;
  font-weight: 600;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  75% { transform: translateX(8rpx); }
}

/* 结果区域 */
.result-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  animation: fadeIn 0.4s ease-out;
}

.result-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.result-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 约数数量徽章 */
.count-badge {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 16rpx;
}

.count-num {
  font-size: 48rpx;
  font-weight: 800;
  color: white;
}

.count-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 约数网格 */
.divisors-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.divisor-chip {
  padding: 14rpx 20rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 12rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  min-width: 60rpx;
  text-align: center;
}

.divisor-chip.prime {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-color: transparent;
}

.chip-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
}

.divisor-chip.prime .chip-text {
  color: white;
}

/* 特殊提示 */
.special-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-radius: 16rpx;
  margin-top: 24rpx;
}

.special-hint.prime-only {
  background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
}

.hint-icon {
  font-size: 28rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #92400e;
  font-weight: 600;
}

.special-hint.prime-only .hint-text {
  color: #5b21b6;
}

/* 示例卡片 */
.examples-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.examples-header {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.examples-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.example-btn {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.example-btn:active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  transform: scale(0.96);
}

.example-btn:active .example-text {
  color: white;
}

.example-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
}

/* 引导区域 */
.guide-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.guide-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.guide-header {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.guide-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.guide-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.guide-example {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 600;
  font-family: 'Monaco', monospace;
  padding: 16rpx 20rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 10rpx;
  border-left: 4rpx solid #667eea;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式 */
@media (max-width: 375px) {
  .examples-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .divisors-grid {
    padding: 16rpx;
  }

  .divisor-chip {
    padding: 12rpx 16rpx;
    min-width: 50rpx;
  }

  .chip-text {
    font-size: 24rpx;
  }
}
