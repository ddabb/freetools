<view class="container">
  <!-- 全局控制区域 -->
  <view class="control-section" style="width: 724rpx; display: block; box-sizing: border-box" style="width: 724rpx; display: block; box-sizing: border-box">
    <!-- 模式选择 -->
    <view class="mode-tabs">
      <view 
        class="mode-tab {{mode === 'daily' ? 'active' : ''}}" 
        bindtap="switchMode" 
        data-mode="daily"
      >
        <text class="tab-icon">📅</text>
        <text class="tab-name">每日数独</text>
      </view>

      <view 
        class="mode-tab {{mode === 'paste' ? 'active' : ''}}" 
        bindtap="switchMode" 
        data-mode="paste"
      >
        <text class="tab-icon">📋</text>
        <text class="tab-name">粘贴题目</text>
      </view>
    </view>
  </view>

  <!-- 粘贴模式 -->
  <view class="import-section" wx:if="{{mode === 'paste'}}">
    <view class="section-header">
      <text class="section-title">📋 快速导入</text>
    </view>
    <view class="import-content">
      <view class="paste-hint">支持3种格式：81位字符串、纯数字、9行格式</view>
      <textarea 
        class="paste-input" 
        placeholder="请粘贴数独题目..."
        bindinput="onPasteInput"
        value="{{pastedText}}"
        maxlength="100"
      ></textarea>
      <view class="paste-actions">
        <button class="btn-sm" bindtap="importPasted">📥 导入</button>
        <button class="btn-sm btn-outline" bindtap="clearPasted">清空</button>
      </view>
    </view>
  </view>

  <!-- 数独棋盘 -->
  <view class="board-section">
    <view class="board">
      <view class="row" wx:for="{{board}}" wx:for-index="rowIndex" wx:for-item="row" wx:key="row">
        <view 
          class="cell {{(colIndex + 1) % 3 === 0 && colIndex !== 8 ? 'right-border' : ''}} {{(rowIndex + 1) % 3 === 0 && rowIndex !== 8 ? 'bottom-border' : ''}} {{cell.fixed ? 'fixed' : ''}} {{selectedCell.row === rowIndex && selectedCell.col === colIndex ? 'selected' : ''}}"
          wx:for="{{row}}" 
          wx:for-item="cell" 
          wx:for-index="colIndex"
          wx:key="cell"
          bindtap="onCellTap"
          data-row="{{rowIndex}}"
          data-col="{{colIndex}}"
        >
          <!-- 有数字的格子 -->
          <view class="cell-value" wx:if="{{cell.value}}">
            <text class="value-text {{cell.fixed ? 'fixed-text' : 'user-text'}}">{{cell.value}}</text>
          </view>
          
          <!-- 候选数模式开启 - 3x3网格显示 -->
          <view class="candidates-grid" wx:elif="{{showCandidates && cell.value === '' && cell.candidates}}">
            <view 
              class="candidate-item"
              wx:for="{{[1,2,3,4,5,6,7,8,9]}}"
              wx:for-item="num"
              wx:key="num"
              bindtap="onCandidateTap"
              data-row="{{rowIndex}}"
              data-col="{{colIndex}}"
              data-num="{{num}}"
            >
              <text class="{{cell.candidates.includes(num) ? 'has' : 'empty'}}">{{cell.candidates.includes(num) ? num : ''}}</text>
            </view>
          </view>
          
          <!-- 空格子 -->
          <view class="cell-empty" wx:else>
            <text class="empty-placeholder"></text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 结果区域 -->
  <view class="result-section" wx:if="{{solutionMessage}}">
    <view class="result-box {{hasSolution ? 'success' : 'error'}}">
      <text class="result-icon">{{hasSolution ? '✅' : '❌'}}</text>
      <text class="result-text">{{solutionMessage}}</text>
    </view>
  </view>

  <!-- 数字输入和候选数控制区 -->
  <view class="control-section" style="width: 724rpx; display: block; box-sizing: border-box" style="width: 724rpx; display: block; box-sizing: border-box">
    <view class="number-input-section">
      <view class="panel-title">
        <text>输入数字</text>
        <text class="selected-info" wx:if="{{selectedCell.row >= 0}}">选中: 第{{selectedCell.row + 1}}行 第{{selectedCell.col + 1}}列</text>
        <text class="selected-info" wx:else>请先点击格子</text>
      </view>
      <view class="number-grid">
        <!-- 第一行：1-6 -->
        <view 
          class="number-item {{selectedCell.row === -1 ? 'disabled' : ''}}" 
          wx:for="{{[1,2,3,4,5,6]}}" 
          wx:key="*this"
          bindtap="onNumberInput"
          data-num="{{item}}"
        >
          {{item}}
        </view>
        <!-- 第二行：7-9, 候选, 清除, 重置 -->
        <view 
          class="number-item {{selectedCell.row === -1 ? 'disabled' : ''}}" 
          wx:for="{{[7,8,9]}}" 
          wx:key="*this"
          bindtap="onNumberInput"
          data-num="{{item}}"
        >
          {{item}}
        </view>
        <!-- 候选数开关 -->
        <view 
          class="number-item candidate-btn {{showCandidates ? 'active' : ''}}"
          bindtap="toggleCandidates"
        >
          {{showCandidates ? '💡' : '🔴'}}
        </view>
        <!-- 清除按钮 -->
        <view class="number-item clear-item {{selectedCell.row === -1 ? 'disabled' : ''}}" bindtap="onClearCell">
          清除
        </view>
        <!-- 重置按钮 -->
        <view class="number-item reset-item" bindtap="clearBoard">
          重置
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="buttons-section">
    <button class="btn btn-sm clear-btn" bindtap="clearBoard" disabled="{{solving}}">
      <text class="btn-icon">🗑️</text>
      <text class="btn-text">清空</text>
    </button>
    <button class="btn btn-lg solve-btn" bindtap="solveSudoku" disabled="{{solving}}">
      <text class="btn-icon">{{solving ? '⏳' : '🔍'}}</text>
      <text class="btn-text">{{solving ? '求解中...' : '求解'}}</text>
    </button>
    <button class="btn btn-sm copy-btn" bindtap="copyBoard" disabled="{{solving}}">
      <text class="btn-icon">📋</text>
      <text class="btn-text">复制</text>
    </button>
  </view>
</view>
