<view class="container">
  <view class="header-section">
    <view class="title">🧩 数独求解器</view>
    <view class="desc">输入数独题目，点击求解按钮自动获得答案</view>
  </view>

  <!-- 快速导入区域 -->
  <view class="import-section">
    <view class="section-header">
      <text class="section-title">📋 快速导入</text>
      <view class="switch-wrapper">
        <text class="switch-label">候选数</text>
        <switch class="candidate-switch" checked="{{showCandidates}}" bindchange="toggleCandidates" size="mini"/>
      </view>
    </view>
    <view class="import-tabs">
      <view class="tab-item {{importMode === 'paste' ? 'active' : ''}}" bindtap="switchImportMode" data-mode="paste">
        粘贴题目
      </view>
      <view class="tab-item {{importMode === 'preset' ? 'active' : ''}}" bindtap="switchImportMode" data-mode="preset">
        预设题目
      </view>
    </view>
    
    <!-- 粘贴模式 -->
    <view class="import-content" wx:if="{{importMode === 'paste'}}">
      <view class="paste-hint">支持3种格式：81位字符串、纯数字、9行格式</view>
      <textarea 
        class="paste-input" 
        placeholder="请粘贴数独题目..."
        bindinput="onPasteInput"
        value="{{pastedText}}"
        maxlength="100"
      ></textarea>
      <view class="paste-actions">
        <button class="btn-sm" bindtap="importPasted">📥 导入</button>
        <button class="btn-sm btn-outline" bindtap="clearPasted">清空</button>
      </view>
    </view>
    
    <!-- 预设模式 -->
    <view class="import-content" wx:if="{{importMode === 'preset'}}">
      <view class="preset-grid">
        <view 
          class="preset-item {{selectedPreset === index ? 'active' : ''}}" 
          wx:for="{{presetList}}"
          wx:key="index"
          bindtap="selectPreset" 
          data-index="{{index}}"
        >
          <text class="preset-name">{{item.name}}</text>
          <text class="preset-level">{{item.level}}</text>
        </view>
      </view>
      <view class="preset-actions">
        <button class="btn-sm" bindtap="importPreset">📥 使用此题</button>
      </view>
    </view>
  </view>

  <!-- 数独棋盘 -->
  <view class="board-section">
    <view class="board">
      <view class="row" wx:for="{{board}}" wx:for-index="rowIndex" wx:for-item="row" wx:key="row">
        <view 
          class="cell {{(colIndex + 1) % 3 === 0 && colIndex !== 8 ? 'right-border' : ''}} {{(rowIndex + 1) % 3 === 0 && rowIndex !== 8 ? 'bottom-border' : ''}} {{cell.fixed ? 'fixed' : ''}} {{selectedCell.row === rowIndex && selectedCell.col === colIndex ? 'selected' : ''}}"
          wx:for="{{row}}" 
          wx:for-item="cell" 
          wx:for-index="colIndex"
          wx:key="cell"
          bindtap="onCellTap"
          data-row="{{rowIndex}}"
          data-col="{{colIndex}}"
        >
          <!-- 有数字的格子 -->
          <view class="cell-value" wx:if="{{cell.value}}">
            <text class="value-text {{cell.fixed ? 'fixed-text' : 'user-text'}}">{{cell.value}}</text>
          </view>
          
          <!-- 空格子 - 候选数模式开启 -->
          <view class="candidates-grid" wx:elif="{{showCandidates && cell.candidates && cell.candidates.length > 0}}">
            <view 
              class="candidate-item"
              wx:for="{{[1,2,3,4,5,6,7,8,9]}}"
              wx:for-item="num"
              wx:for-index="numIndex"
              wx:key="num"
              bindtap="onCandidateTap"
              data-row="{{rowIndex}}"
              data-col="{{colIndex}}"
              data-num="{{num}}"
            >
              <text class="{{cell.candidates.includes(num) ? 'has' : 'empty'}}">{{cell.candidates.includes(num) ? num : ''}}</text>
            </view>
          </view>
          
          <!-- 空格子 - 候选数模式关闭或无候选 -->
          <view class="cell-empty" wx:else>
            <text class="empty-placeholder">+</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 数字输入面板 -->
  <view class="input-panel" wx:if="{{showInputPanel}}">
    <view class="panel-mask" bindtap="closeInputPanel"></view>
    <view class="panel-content">
      <view class="panel-title">输入数字</view>
      <view class="number-grid">
        <view 
          class="number-item" 
          wx:for="{{[1,2,3,4,5,6,7,8,9]}}" 
          wx:key="*this"
          bindtap="onNumberInput"
          data-num="{{item}}"
        >
          {{item}}
        </view>
        <view class="number-item clear-item" bindtap="onClearCell">
          清除
        </view>
      </view>
      <view class="panel-actions">
        <button class="panel-btn" bindtap="closeInputPanel">取消</button>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="buttons-section">
    <button class="btn clear-btn" bindtap="clearBoard" disabled="{{solving}}">
      <text class="btn-icon">🗑️</text>
      <text class="btn-text">清空</text>
    </button>
    <button class="btn solve-btn" bindtap="solveSudoku" disabled="{{solving}}">
      <text class="btn-icon">{{solving ? '⏳' : '🔍'}}</text>
      <text class="btn-text">{{solving ? '求解中...' : '求解'}}</text>
    </button>
    <button class="btn copy-btn" bindtap="copyBoard" disabled="{{solving}}">
      <text class="btn-icon">📋</text>
      <text class="btn-text">复制</text>
    </button>
  </view>

  <!-- 结果区域 -->
  <view class="result-section" wx:if="{{solutionMessage}}">
    <view class="result-box {{hasSolution ? 'success' : 'error'}}">
      <text class="result-icon">{{hasSolution ? '✅' : '❌'}}</text>
      <text class="result-text">{{solutionMessage}}</text>
    </view>
  </view>

  <!-- 使用提示 -->
  <view class="tips-section">
    <view class="tips-title">💡 使用提示</view>
    <view class="tips-list">
      <view class="tip-item">• 点击空格子弹出数字输入面板</view>
      <view class="tip-item">• 打开"候选数"开关可显示可能的数字</view>
      <view class="tip-item">• 深色格子是题目给出的固定数字</view>
      <view class="tip-item">• 点击候选数字可直接填入</view>
    </view>
  </view>
</view>
