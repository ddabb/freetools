page {
  min-height: 100vh;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.container {
  padding: 20rpx 15rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部栏 */
.header {
  background: rgba(255,255,255,0.98);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.difficulty-tabs {
  display: flex;
  gap: 8rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 8rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #f0f0f0;
  color: #666;
  transition: all 0.2s;
}

.tab.active {
  background: linear-gradient(135deg, #43a047, #66bb6a);
  color: white;
}

.info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.timer {
  color: #43a047;
}

.progress {
  color: #666;
  font-size: 26rpx;
}

/* 游戏区 */
.game-area {
  background: rgba(255,255,255,0.98);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  justify-content: center;
  overflow-x: auto;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  border: 2rpx solid #2e7d32;
}

.cell-wrap {
  box-sizing: border-box;
  border: 1rpx solid rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cell-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4rpx;
  transition: background 0.15s;
}

.cell-inner.hole {
  background: #e0e0e0;
}

.cell-inner.visited {
  background: #c8e6c9;
  border: 3rpx solid #43a047;
}

.cell-text {
  font-size: 28rpx;
  font-weight: 700;
}

.hole-text {
  color: #999;
  font-size: 36rpx;
}

.path-num {
  color: #2e7d32;
}

/* 完成遮罩 */
.complete-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.complete-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx 50rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
}

.complete-icon {
  font-size: 72rpx;
}

.complete-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #2e7d32;
}

.complete-time {
  font-size: 28rpx;
  color: #666;
}

.next-btn {
  background: linear-gradient(135deg, #43a047, #66bb6a);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

/* 底部按钮 */
.footer {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.btn {
  flex: 1;
  border: none;
  border-radius: 12rpx;
  padding: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}

.btn.reset {
  background: white;
  color: #666;
  border: 2rpx solid #ddd;
}

.btn.next {
  background: linear-gradient(135deg, #43a047, #66bb6a);
  color: white;
}

/* 规则 */
.rules {
  background: rgba(255,255,255,0.98);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.rules-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.rules-text {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}
