page {
  min-height: 100vh;
  background: linear-gradient(180deg, #e0f2fe 0%, #f0f9ff 50%, #e0e7ff 100%);
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ==================== 顶部信息栏 ==================== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.08);
  backdrop-filter: blur(10px);
  flex-wrap: wrap;
  gap: 16rpx;
}

.difficulty-tabs {
  display: flex;
  gap: 12rpx;
}

.tab {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #64748b;
  background: #f1f5f9;
  transition: all 0.25s ease;
  border: 2rpx solid transparent;
}

.tab-icon {
  font-size: 24rpx;
}

.tab-text {
  font-weight: 500;
}

.tab.active.easy {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  border-color: #16a34a;
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.3);
}

.tab.active.medium {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: white;
  border-color: #d97706;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
}

.tab.active.hard {
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: white;
  border-color: #dc2626;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
}

.info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.timer-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
  border-radius: 16rpx;
}

.timer-icon {
  font-size: 28rpx;
}

.timer {
  font-size: 30rpx;
  font-weight: 700;
  color: #334155;
  font-variant-numeric: tabular-nums;
}

.progress-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #dcfce7, #bbf7d0);
  border-radius: 16rpx;
}

.progress-icon {
  font-size: 24rpx;
}

.progress {
  font-size: 30rpx;
  font-weight: 700;
  color: #166534;
  font-variant-numeric: tabular-nums;
}

/* ==================== 游戏区域 ==================== */
.game-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0;
  flex: 1;
  min-height: 0;
}

.grid-shadow {
  filter: drop-shadow(0 8rpx 32rpx rgba(34, 197, 94, 0.15));
}

.grid {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.cell-wrap {
  box-sizing: border-box;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
}

.cell-wrap:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.cell-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4rpx;
  transition: all 0.2s ease;
}

.cell-inner.hole {
  background: linear-gradient(135deg, #94a3b8, #64748b);
}

.cell-inner.visited {
  background: linear-gradient(135deg, #4ade80, #22c55e);
  box-shadow: inset 0 2rpx 8rpx rgba(255, 255, 255, 0.3);
}

.cell-text {
  font-size: 28rpx;
  font-weight: 700;
}

.hole-text {
  color: #475569;
  font-size: 36rpx;
  font-weight: bold;
}

.path-num {
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 答案路径样式（蓝色，与用户路径绿色区分） */
.cell-inner.answer-visited {
  background: linear-gradient(135deg, #60a5fa, #3b82f6);
  box-shadow: inset 0 2rpx 8rpx rgba(255, 255, 255, 0.3);
  animation: answerPulse 1.5s ease-in-out infinite;
}

.answer-num {
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  opacity: 0.9;
}

@keyframes answerPulse {
  0%, 100% { opacity: 0.85; }
  50% { opacity: 1; }
}

/* ==================== 完成提示 ==================== */
.complete-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(8px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.complete-card {
  background: white;
  padding: 48rpx 56rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.25);
  animation: scaleIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  max-width: 340px;
  width: 90%;
}

@keyframes scaleIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.complete-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
  animation: bounce 0.6s ease infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.complete-text {
  font-size: 44rpx;
  font-weight: 800;
  color: #166534;
  margin-top: 8rpx;
}

.complete-time {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 16rpx;
}

.next-btn {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 24rpx 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.4);
}

/* ==================== 底部按钮 ==================== */
.footer {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 24rpx 20rpx;
}

.btn {
  flex: 1;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.btn:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.btn.reset {
  background: #f1f5f9;
  color: #64748b;
}

.btn.next {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
}

/* 查看答案按钮 */
.btn.answer-btn {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: white;
  flex: 1;
}

.btn.answer-btn.hide {
  background: linear-gradient(135deg, #6b7280, #4b5563);
  color: white;
  flex: 1;
}

/* ==================== 规则说明 ==================== */
.rules {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.rules-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.rules-text {
  display: block;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.8;
}
