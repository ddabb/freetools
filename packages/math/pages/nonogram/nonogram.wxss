page { background: #eef0ec; min-height: 100vh; }
.container { display: flex; flex-direction: column; align-items: center; padding: 12px 0 24px; min-height: 100vh; }

/* 难度栏 */
.diff-bar { display: flex; gap: 10px; padding: 6px 0; }
.pill { font-size: 13px; padding: 6px 16px; border-radius: 20px; background: #e0e0e0; color: #666; }
.pill.on { background: #43a047; color: #fff; }

/* 顶栏 */
.top-info { display: flex; align-items: center; width: 100%; padding: 4px 16px 6px; gap: 10px; }
.mode-toggle { display: flex; gap: 6px; flex: 1; justify-content: center; }
.mode-btn { font-size: 12px; padding: 5px 14px; border-radius: 16px; background: #e0e0e0; color: #666; }
.mode-btn.on { background: #333; color: #fff; }
.info-right { display: flex; gap: 10px; align-items: center; flex-shrink: 0; }
.timer { font-size: 12px; color: #999; }
.progress { font-size: 13px; color: #43a047; font-weight: 600; }

/* 加载 */
.loading { padding: 60px 0; font-size: 14px; color: #999; }

/* 棋盘 */
.board-wrap { display: flex; justify-content: center; margin-top: 6px; overflow: visible; }
.board { display: flex; flex-direction: column; flex-shrink: 0; overflow: visible; }

/* 列提示 */
.col-hints-row { display: flex; flex-shrink: 0; }
.corner { flex-shrink: 0; overflow: hidden; }
.col-hint { display: flex; flex-direction: column; justify-content: flex-end; align-items: center; padding-bottom: 3px; overflow: hidden; }
.hn { font-size: 11px; font-weight: 600; color: #555; line-height: 14px; text-align: center; }

/* 行 */
.row-group { display: flex; flex-wrap: nowrap; flex-shrink: 0; }
.row-hint { display: flex; flex-direction: row; justify-content: flex-end; align-items: center; gap: 1px; padding-right: 5px; flex-shrink: 0; overflow: hidden; }

/* 格子 */
.cell {
  border: 1px solid #ccc;
  border-radius: 2px;
  background: #fff;
  flex-shrink: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: background 0.06s;
}
.cell-filled { background: #2d2d2d !important; border-color: #2d2d2d !important; }
.cell-marked { background: #fffde7 !important; border-color: #f0e68c !important; }
.cell-row-last { border-bottom-width: 2px !important; border-bottom-color: #555 !important; }
.cell-col-last { border-right-width: 2px !important; border-right-color: #555 !important; }

/* X标记 */
.mark-x { font-size: 65%; color: #e53935; font-weight: 700; line-height: 1; }

/* 操作栏 */
.action-bar { display: flex; gap: 10px; margin-top: 10px; align-items: center; justify-content: center; flex-wrap: wrap; }
.btn { font-size: 13px; padding: 8px 18px; border-radius: 20px; background: #fff; color: #555; border: 1px solid #ccc; }
.btn.next { background: #43a047; color: #fff; border-color: #43a047; }
.btn.answer-btn { background: #ff9800; color: #fff; border-color: #ff9800; }
.btn.answer-btn.hide { background: #9e9e9e; border-color: #9e9e9e; }
.sound-btn { font-size: 16px; padding: 6px 12px; }

/* 跳关导航 */
.nav-row { display: flex; align-items: center; gap: 8px; margin-top: 10px; padding: 0 16px; }
.puzzle-info { font-size: 13px; color: #666; white-space: nowrap; }
.jump-input { width: 60px; height: 30px; font-size: 13px; text-align: center; border: 1px solid #ccc; border-radius: 6px; background: #fff; }
.btn-jump { font-size: 12px; padding: 5px 14px; border-radius: 14px; background: #43a047; color: #fff; }

/* 通关弹窗 */
.mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 99; }
.card { background: #fff; border-radius: 16px; padding: 32px 40px; text-align: center; }
.card-icon { font-size: 52px; margin-bottom: 8px; }
.card-title { font-size: 20px; font-weight: 700; color: #333; margin-bottom: 6px; }
.card-time { font-size: 14px; color: #999; margin-bottom: 16px; }
.card-btn { display: inline-block; font-size: 14px; padding: 10px 32px; border-radius: 20px; background: #43a047; color: #fff; font-weight: 600; }
