page { background: #f2f5f2; min-height: 100vh; }
.container { display: flex; flex-direction: column; align-items: center; padding: 12px 0 30px; min-height: 100vh; }

/* 窈뜻젎 */
.top-bar { display: flex; align-items: center; justify-content: center; width: 100%; padding: 6px 0; }
.diff-bar { gap: 10px; }
.info-bar { justify-content: space-between; padding: 4px 24px; }
.mode-bar { gap: 12px; }

.pill { font-size: 13px; padding: 6px 16px; border-radius: 20px; background: #e0e0e0; color: #666; }
.pill.on { background: #43a047; color: #fff; }
.pill-sm { font-size: 12px; padding: 5px 18px; border-radius: 16px; background: #e0e0e0; color: #666; }
.pill-sm.on { background: #333; color: #fff; }

.level-text { font-size: 16px; font-weight: 700; color: #333; }
.sub-text { font-size: 12px; color: #999; }
.sub-text.accent { color: #43a047; font-weight: 600; }

/* 汝뗧썥 */
.board-wrap { display: flex; justify-content: center; align-items: flex-start; margin-top: 8px; }
.board { display: flex; flex-direction: column; }

.col-hints-row { display: flex; }
.corner { flex-shrink: 0; }
.col-hint { display: flex; flex-direction: column; justify-content: flex-end; align-items: center; padding-bottom: 3px; }

.hn { font-size: 11px; font-weight: 600; color: #555; line-height: 14px; text-align: center; }

.grow { display: flex; }
.row-hint { display: flex; flex-direction: row; justify-content: flex-end; align-items: center; gap: 2px; padding-right: 6px; flex-shrink: 0; }
.row-hint .hn { line-height: 14px; }

.cell { background: #fff; border-radius: 3px; flex-shrink: 0; transition: background 0.05s; }
.cell.f { background: #333; }
.cell.m { background: #fff8e1; }

/* 佯뺞젎 */
.bottom-bar { margin-top: 16px; }
.btn { font-size: 13px; padding: 10px 30px; border-radius: 20px; background: #fff; color: #555; border: 1px solid #ccc; }

/* 凉밭첊 */
.mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 99; }
.card { background: #fff; border-radius: 16px; padding: 32px 40px; text-align: center; }
.card-icon { font-size: 48px; margin-bottom: 8px; }
.card-title { font-size: 20px; font-weight: 700; color: #333; margin-bottom: 6px; }
.card-time { font-size: 14px; color: #999; margin-bottom: 16px; }
.card-btn { display: inline-block; font-size: 14px; padding: 10px 32px; border-radius: 20px; background: #43a047; color: #fff; font-weight: 600; }
