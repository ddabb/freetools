<view class="container">
  <view class="header-section">
    <view class="title">🎲 数独生成器</view>
    <view class="desc">随机生成不同难度的数独题目</view>
  </view>

  <!-- 难度选择 -->
  <view class="difficulty-section">
    <view class="difficulty-tabs">
      <view 
        class="difficulty-tab {{difficulty === 'easy' ? 'active' : ''}}" 
        bindtap="setDifficulty" 
        data-difficulty="easy"
      >
        <text class="tab-name">入门</text>
        <text class="tab-hint">⭐ 简单</text>
      </view>
      <view 
        class="difficulty-tab {{difficulty === 'medium' ? 'active' : ''}}" 
        bindtap="setDifficulty" 
        data-difficulty="medium"
      >
        <text class="tab-name">初级</text>
        <text class="tab-hint">⭐⭐ 中等</text>
      </view>
      <view 
        class="difficulty-tab {{difficulty === 'hard' ? 'active' : ''}}" 
        bindtap="setDifficulty" 
        data-difficulty="hard"
      >
        <text class="tab-name">高级</text>
        <text class="tab-hint">⭐⭐⭐ 困难</text>
      </view>
    </view>
  </view>

  <!-- 候选解开关 -->
  <view class="option-section">
    <view class="option-item">
      <switch checked="{{showCandidates}}" bindchange="toggleCandidates" color="#4ecdc4"/>
      <text class="option-label">显示候选解</text>
    </view>
    <view class="candidate-hint" wx:if="{{showCandidates && !showingAnswer && hasCandidates}}">
      💡 点击候选数字可直接填入
    </view>
  </view>

  <!-- 数独棋盘 -->
  <view class="board-section">
    <view class="board {{showCandidates ? 'show-candidates' : ''}}">
      <view class="row" wx:for="{{board}}" wx:for-index="rowIndex" wx:for-item="row" wx:key="row">
        <view 
          class="cell {{(colIndex + 1) % 3 === 0 && colIndex !== 8 ? 'right-border' : ''}} {{(rowIndex + 1) % 3 === 0 && rowIndex !== 8 ? 'bottom-border' : ''}} {{cell.fixed ? 'fixed' : ''}}"
          wx:for="{{row}}" 
          wx:for-item="cell" 
          wx:for-index="colIndex"
          wx:key="cell"
        >
          <!-- 已有数字 -->
          <view class="cell-value" wx:if="{{cell.value && !cell.showCandidates}}">
            <text class="value-text {{cell.isAnswer ? 'answer' : ''}} {{cell.isError ? 'error' : ''}}">{{cell.value}}</text>
          </view>
          
          <!-- 候选解显示 -->
          <view 
            class="candidates-grid" 
            wx:if="{{showCandidates && !cell.value && cell.candidates}}"
            bindtap="onCellTap"
            data-row="{{rowIndex}}"
            data-col="{{colIndex}}"
          >
            <view 
              class="candidate-item"
              wx:for="{{cell.candidates}}"
              wx:for-item="candidateNum"
              wx:for-index="index"
              wx:key="index"
            >
              <text class="{{candidateNum !== 0 ? 'has' : 'empty'}}" style="font-size: 16rpx;">{{candidateNum !== 0 ? candidateNum : ''}}</text>
            </view>
          </view>
          
          <!-- 空格子 -->
          <view class="cell-empty" wx:if="{{!cell.value && !cell.showCandidates}}">
            <text class="empty-text">-</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="buttons-section">
    <button class="btn regenerate-btn" bindtap="generateSudoku" disabled="{{generating}}">
      <text class="btn-icon">🎲</text>
      <text class="btn-text">{{generating ? '生成中...' : '重新生成'}}</text>
    </button>
    <button class="btn answer-btn" bindtap="toggleAnswer" disabled="{{generating}}">
      <text class="btn-icon">{{showingAnswer ? '🙈' : '👁️'}}</text>
      <text class="btn-text">{{showingAnswer ? '隐藏答案' : '显示答案'}}</text>
    </button>
  </view>

  <!-- 数字输入面板 -->
  <view class="input-panel" wx:if="{{showInputPanel}}">
    <view class="panel-mask" bindtap="closeInputPanel"></view>
    <view class="panel-content">
      <view class="panel-title">输入数字</view>
      <view class="number-grid">
        <view 
          class="number-item" 
          wx:for="{{[1,2,3,4,5,6,7,8,9]}}" 
          wx:key="*this"
          bindtap="onNumberInput"
          data-num="{{item}}"
        >
          {{item}}
        </view>
        <view class="number-item clear-item" bindtap="onClearCell">
          清除
        </view>
      </view>
      <view class="panel-actions">
        <button class="panel-btn" bindtap="closeInputPanel">取消</button>
      </view>
    </view>
  </view>

  <!-- 提示 -->
  <view class="tips-section">
    <view class="tips-title">💡 使用提示</view>
    <view class="tips-list">
      <view class="tip-item">• 选择难度后自动生成数独题目</view>
      <view class="tip-item">• 点击"显示答案"查看完整解答</view>
      <view class="tip-item">• 开启候选解可查看可能的数字</view>
      <view class="tip-item">• 点击空格子弹出数字输入面板</view>
    </view>
  </view>
</view>
