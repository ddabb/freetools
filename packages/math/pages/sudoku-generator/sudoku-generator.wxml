<view class="container">
  <!-- 难度选择 -->
  <view class="difficulty-section">
    <view class="difficulty-tabs">
      <view 
        class="difficulty-tab {{difficulty === 'easy' ? 'active' : ''}}" 
        bindtap="setDifficulty" 
        data-difficulty="easy"
      >
        <text class="tab-name">入门</text>
        <text class="tab-hint">⭐ 简单</text>
      </view>
      <view 
        class="difficulty-tab {{difficulty === 'medium' ? 'active' : ''}}" 
        bindtap="setDifficulty" 
        data-difficulty="medium"
      >
        <text class="tab-name">初级</text>
        <text class="tab-hint">⭐⭐ 中等</text>
      </view>
      <view 
        class="difficulty-tab {{difficulty === 'hard' ? 'active' : ''}}" 
        bindtap="setDifficulty" 
        data-difficulty="hard"
      >
        <text class="tab-name">高级</text>
        <text class="tab-hint">⭐⭐⭐ 困难</text>
      </view>
    </view>
  </view>

  <!-- 数独棋盘 -->
  <view class="board-section">
    <view class="board {{showCandidates ? 'show-candidates' : ''}}">
      <view class="row" wx:for="{{board}}" wx:for-index="rowIndex" wx:for-item="row" wx:key="row">
        <view 
          class="cell {{(colIndex + 1) % 3 === 0 && colIndex !== 8 ? 'right-border' : ''}} {{(rowIndex + 1) % 3 === 0 && rowIndex !== 8 ? 'bottom-border' : ''}} {{cell.fixed ? 'fixed' : ''}} {{cell.selected ? 'selected' : ''}}"
          wx:for="{{row}}" 
          wx:for-item="cell" 
          wx:for-index="colIndex"
          wx:key="cell"
        >
          <!-- 已有数字 -->
          <view 
            class="cell-value" 
            wx:if="{{cell.value && !cell.showCandidates}}"
            bindtap="onCellTap"
            data-row="{{rowIndex}}"
            data-col="{{colIndex}}"
          >
            <text class="value-text {{cell.isAnswer ? 'answer' : ''}} {{cell.isError ? 'error' : ''}}">{{cell.value}}</text>
          </view>
          
          <!-- 候选解显示 -->
          <view 
            class="candidates-grid" 
            wx:if="{{showCandidates && cell.showCandidates && cell.candidates}}"
            bindtap="onCellTap"
            data-row="{{rowIndex}}"
            data-col="{{colIndex}}"
          >
            <view 
              class="candidate-item"
              wx:for="{{cell.candidates}}"
              wx:for-item="candidateNum"
              wx:for-index="index"
              wx:key="index"
            >
              <text class="{{candidateNum !== 0 ? 'has' : 'empty'}}" style="font-size: 16rpx;">{{candidateNum !== 0 ? candidateNum : ''}}</text>
            </view>
          </view>
          
          <!-- 空格子 -->
          <view 
            class="cell-empty" 
            wx:if="{{!cell.value && !cell.showCandidates}}"
            bindtap="onCellTap"
            data-row="{{rowIndex}}"
            data-col="{{colIndex}}"
          >
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 数字输入和候选数控制区 -->
  <view class="control-section">
    <!-- 数字输入面板 -->
    <view class="number-input-section">

      <view class="number-grid">
        <!-- 第一行：1-6 -->
        <view 
          class="number-item {{selectedCell.row === -1 ? 'disabled' : ''}}" hover-class="number-item-hover" 
          wx:for="{{[1,2,3,4,5,6]}}" 
          wx:key="*this"
          bindtap="onNumberInput"
          data-num="{{item}}"
        >
          {{item}}
        </view>
        <!-- 第二行：7-9, 候选, 清除, 重置 -->
        <view 
          class="number-item {{selectedCell.row === -1 ? 'disabled' : ''}}" hover-class="number-item-hover" 
          wx:for="{{[7,8,9]}}" 
          wx:key="*this"
          bindtap="onNumberInput"
          data-num="{{item}}"
        >
          {{item}}
        </view>
        <!-- 候选解按钮 -->
        <view 
          class="number-item candidate-btn {{showCandidates ? 'active' : ''}}" hover-class="number-item-hover"
          bindtap="toggleCandidates"
        >
          {{showCandidates ? '💡' : '🔴'}}
        </view>
        <view class="number-item clear-item {{selectedCell.row === -1 ? 'disabled' : ''}}" hover-class="number-item-hover" bindtap="onClearCell">
          清除
        </view>
        <!-- 重置按钮 -->
        <view class="number-item reset-item" hover-class="number-item-hover" bindtap="resetBoard">
          重置
        </view>
      </view>

    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="buttons-section">
    <button class="btn regenerate-btn" bindtap="generateSudoku" disabled="{{generating}}">
      <text class="btn-icon">🎲</text>
      <text class="btn-text">{{generating ? '生成中...' : '重新生成'}}</text>
    </button>
    <button class="btn answer-btn" bindtap="toggleAnswer" disabled="{{generating}}">
      <text class="btn-icon">{{showingAnswer ? '🙈' : '👁️'}}</text>
      <text class="btn-text">{{showingAnswer ? '隐藏答案' : '显示答案'}}</text>
    </button>
  </view>
  <!-- 搴曢儴骞垮憡 -->
  <ad unit-id="adunit-07e9c9da9e4b8254" ad-intervals="30" binderror="onAdError" bindclose="onAdClose"></ad>
</view>
