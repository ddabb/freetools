page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

.container {
  padding: 20rpx 15rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 12rpx;
}

.desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.difficulty-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.difficulty-tabs {
  display: flex;
  gap: 10rpx;
}

.difficulty-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #f8f9fa;
  color: #666;
  transition: all 0.3s ease;
}

.difficulty-tab.active {
  background: linear-gradient(135deg, #1abc9c, #16a085);
  color: white;
}

/* 每日数独信息 */
.daily-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(26, 188, 156, 0.08);
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.daily-date {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c3e50;
}

.daily-difficulty {
  font-size: 24rpx;
  color: #e67e22;
  font-weight: 600;
}

.daily-hint {
  font-size: 22rpx;
  color: #999;
}

.board-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
  display: flex;
  justify-content: center;
}

.board {
  width: 630rpx;
  border: 4rpx solid #333;
  border-radius: 8rpx;
  overflow: hidden;
}

.row {
  display: flex;
}

.cell {
  width: 70rpx;
  height: 70rpx;
  border: 1rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  background: #fff;
  transition: all 0.2s;
}

.cell.right-border {
  border-right: 3rpx solid #333;
}

.cell.bottom-border {
  border-bottom: 3rpx solid #333;
}

.cell.fixed {
  background: #f0f0f0;
}

/* 单元格内容 */
.cell-content {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cell-value {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.value-text {
  font-size: 36rpx;
  font-weight: 700;
}

.cell.fixed .value-text {
  color: #2c3e50;
  font-weight: 800;
}

.buttons-section {
  display: flex;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.btn {
  flex: 1;
  border: none;
  border-radius: 15rpx;
  padding: 25rpx 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 26rpx;
}

.regenerate-btn {
  background: linear-gradient(135deg, #1abc9c, #16a085);
  color: white;
}

.answer-btn {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: white;
}

.tips-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.tips-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 15rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 候选解开关 */
.option-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.option-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.option-label {
  font-size: 26rpx;
  color: #333;
}

.candidate-hint {
  font-size: 22rpx;
  color: #4ecdc4;
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 候选解网格 */
.candidates-grid {
  width: 100%;
  height: 100%;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  padding: 4rpx;
  box-sizing: border-box;
  background: rgba(78, 205, 196, 0.08);
}

.candidate-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
}

.candidate-item text {
  line-height: 1;
}

.candidate-item .has {
  color: #4ecdc4;
}

.value-text.answer {
  color: #1abc9c;
}

.value-text.error {
  color: #e74c3c;
  font-weight: 800;
}

.cell-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(78, 205, 196, 0.05);
}

.empty-text {
  font-size: 24rpx;
  color: #ccc;
}

/* 候选模式下的空格子 */
.show-candidates .cell-empty {
  background: rgba(78, 205, 196, 0.1);
}

/* 难度tab样式 */
.tab-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.tab-hint {
  display: block;
  font-size: 22rpx;
  opacity: 0.8;
}

/* 输入面板样式 */
.input-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.panel-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.panel-content {
  position: relative;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  width: 80%;
  max-width: 600rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.number-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.number-item {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f9fa;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  transition: all 0.2s;
}

.number-item:active {
  background: #e9ecef;
}

.clear-item {
  background: #e74c3c;
  color: white;
}

.clear-item:active {
  background: #c0392b;
}

.panel-actions {
  display: flex;
  justify-content: center;
}

.panel-btn {
  background: #95a5a6;
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.panel-btn:active {
  background: #7f8c8d;
}

/* 选中格子样式 */
.cell.selected {
  background: rgba(78, 205, 196, 0.2) !important;
  border: 2rpx solid #4ecdc4 !important;
}
