page {
  min-height: 100vh;
  background: linear-gradient(135deg, #e8f8f5 0%, #d1f2eb 100%);
}

.container {
  padding: 20rpx 15rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1abc9c;
  margin-bottom: 10rpx;
}

.desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.difficulty-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.difficulty-tabs {
  display: flex;
  gap: 10rpx;
}

.difficulty-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #f8f9fa;
  color: #666;
  transition: all 0.3s ease;
}

.difficulty-tab.active {
  background: linear-gradient(135deg, #1abc9c, #16a085);
  color: white;
}

.board-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
  display: flex;
  justify-content: center;
}

.board {
  width: 630rpx;
  border: 4rpx solid #333;
}

.row {
  display: flex;
}

.cell {
  width: 70rpx;
  height: 70rpx;
  border: 1rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cell.right-border {
  border-right: 3rpx solid #333;
}

.cell.bottom-border {
  border-bottom: 3rpx solid #333;
}

.cell.fixed {
  background: #f0f0f0;
}

.cell-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.cell.fixed .cell-value {
  color: #2c3e50;
  font-weight: 800;
}

.buttons-section {
  display: flex;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.btn {
  flex: 1;
  border: none;
  border-radius: 15rpx;
  padding: 25rpx 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 26rpx;
}

.regenerate-btn {
  background: linear-gradient(135deg, #1abc9c, #16a085);
  color: white;
}

.answer-btn {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: white;
}

.tips-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  padding: 20rpx 15rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.06);
}

.tips-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 15rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}
