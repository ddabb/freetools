/* oddEven.wxss */
.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  padding: 20rpx;
  box-sizing: border-box;
}

.header-bg {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-wrapper {
  margin-bottom: 16rpx;
}

.main-icon {
  font-size: 72rpx;
}

.main-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input-card,
.result-card,
.concept-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.1);
  animation: fadeInUp 0.4s ease-out;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.input-section {
  margin-bottom: 0;
}

.input-wrapper {
  margin-bottom: 0;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input-container {
  position: relative;
}

.modern-input {
  width: 100%;
  padding: 28rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: 500;
  box-sizing: border-box;
  background: #f9f9f9;
  transition: all 0.3s ease;
  min-height: 96rpx;
  line-height: 1.4;
}

.modern-input:focus {
  border-color: #f5576c;
  background: white;
  box-shadow: 0 0 0 3rpx rgba(245, 87, 108, 0.15);
}

/* 结果卡片 */
.result-card {
  border-left: 8rpx solid #f5576c;
}

.even-card {
  border-left-color: #4CAF50;
}

.odd-card {
  border-left-color: #f5576c;
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.result-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.result-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.result-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: white;
}

.even-badge {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
}

.odd-badge {
  background: linear-gradient(135deg, #f5576c, #ff8787);
}

/* 结果数字展示 */
.result-number {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff5f7, #ffeef1);
  border-radius: 16rpx;
}

.odd-card .result-number {
  background: linear-gradient(135deg, #fff5f7, #ffeef1);
}

.even-card .result-number {
  background: linear-gradient(135deg, #f0fff4, #e6fff0);
}

.number-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #f5576c;
  margin-right: 12rpx;
}

.even-card .number-value {
  color: #4CAF50;
}

.number-suffix {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.info-item {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.info-icon {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.info-content {
  flex: 1;
  width: 100%;
}

.info-label {
  display: block;
  font-size: 20rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.info-value.highlight {
  color: #f5576c;
}

.even-card .info-value.highlight {
  color: #4CAF50;
}

/* 说明框 */
.explanation-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fff9e6;
  border-radius: 12rpx;
}

.explanation-icon {
  font-size: 28rpx;
}

.explanation-text {
  font-size: 24rpx;
  color: #8b6914;
  flex: 1;
  line-height: 1.5;
}

/* 结果操作按钮 */
.result-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.action-btn {
  flex: 1;
  background: #f5f5f5;
  color: #333;
  border: none;
  border-radius: 10rpx;
  padding: 18rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.btn-icon {
  font-size: 26rpx;
}

/* 概念说明 */
.concept-card {
  margin-top: 0;
}

.concept-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.concept-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.concept-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.concept-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.concept-item {
  display: flex;
  flex-direction: column;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  border-left: 4rpx solid #f5576c;
}

.concept-highlight {
  font-size: 24rpx;
  font-weight: bold;
  color: #f5576c;
  margin-bottom: 6rpx;
}

.concept-desc {
  font-size: 22rpx;
  color: #666;
  line-height: 1.5;
}

/* 动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式 */
@media (max-width: 375px) {
  .info-grid {
    grid-template-columns: 1fr;
  }

  .result-actions {
    flex-direction: column;
  }

  .result-number {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8rpx;
  }

  .number-value {
    font-size: 48rpx;
  }
}
