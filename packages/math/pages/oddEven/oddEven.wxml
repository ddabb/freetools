<!--packages/math/pages/oddEven/oddEven.wxml-->
<view class="page-container">
  <!-- 顶部装饰 -->
  <view class="header-bg">
    <view class="header-content">
      <view class="icon-wrapper">
        <text class="main-icon">🔢</text>
      </view>
      <text class="main-title">奇偶判断</text>
      <text class="subtitle">输入数字，实时判断</text>
    </view>
  </view>

  <view class="content-wrapper">
    <!-- 输入卡片 -->
    <view class="input-card card-shadow fade-in-up">
      <view class="card-header">
        <view class="card-icon">✏️</view>
        <text class="card-title">输入数字</text>
      </view>

      <view class="card-body">
        <view class="input-section">
          <view class="input-wrapper">
            <text class="input-label">请输入一个整数</text>
            <view class="input-container">
              <input
                type="number"
                value="{{inputValue}}"
                bindinput="onInputChange"
                class="modern-input"
                placeholder="例如：123"
                maxlength="20"
                confirm-type="done"
               placeholder-class="input-placeholder"/>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 结果卡片 -->
    <view wx:if="{{showResult}}" class="result-card card-shadow fade-in-up {{result.isEven ? 'even-card' : 'odd-card'}}">
      <view class="result-header">
        <view class="result-icon">{{result.isEven ? '⚡' : '🌟'}}</view>
        <text class="result-title">判断结果</text>
        <view class="result-badge {{result.isEven ? 'even-badge' : 'odd-badge'}}">{{result.isEven ? '偶数' : '奇数'}}</view>
      </view>

      <view class="result-body">
        <view class="result-number">
          <text class="number-value">{{result.number}}</text>
          <text class="number-suffix">{{result.isEven ? ' 是偶数' : ' 是奇数'}}</text>
        </view>

        <view class="info-grid">
          <view class="info-item">
            <view class="info-icon">📊</view>
            <view class="info-content">
              <text class="info-label">除以2余数</text>
              <text class="info-value highlight">{{result.remainder}}</text>
            </view>
          </view>

          <view class="info-item">
            <view class="info-icon">⬅️</view>
            <view class="info-content">
              <text class="info-label">前一个</text>
              <text class="info-value">{{result.previousNumber}}</text>
            </view>
          </view>

          <view class="info-item">
            <view class="info-icon">➡️</view>
            <view class="info-content">
              <text class="info-label">后一个</text>
              <text class="info-value">{{result.nextNumber}}</text>
            </view>
          </view>
        </view>

        <view class="explanation-box">
          <text class="explanation-icon">💡</text>
          <text class="explanation-text">{{result.explanation}}</text>
        </view>
      </view>

      <view class="result-actions">
        <button class="action-btn copy-btn" bindtap="copyResult" hover-class="btn-action-hover">
          <text class="btn-icon">📋</text>
          <text>复制</text>
        </button>
        <button class="action-btn retry-btn" bindtap="clearInput" hover-class="btn-action-hover">
          <text class="btn-icon">🔄</text>
          <text>清空</text>
        </button>
      </view>
    </view>

    <!-- 概念说明 -->
    <view class="concept-card card-shadow fade-in-up" style="animation-delay: 0.4s">
      <view class="concept-header">
        <view class="concept-icon">ℹ️</view>
        <text class="concept-title">概念说明</text>
      </view>
      <view class="concept-content">
        <view class="concept-item">
          <text class="concept-highlight">偶数</text>
          <text class="concept-desc">能被2整除的整数，如 0、2、4、6、8...</text>
        </view>
        <view class="concept-item">
          <text class="concept-highlight">奇数</text>
          <text class="concept-desc">不能被2整除的整数，如 1、3、5、7、9...</text>
        </view>
        <view class="concept-item">
          <text class="concept-highlight">判断方法</text>
          <text class="concept-desc">除以2余数为0则是偶数，余数为1则是奇数</text>
        </view>
      </view>
    </view>
  </view>
</view>
