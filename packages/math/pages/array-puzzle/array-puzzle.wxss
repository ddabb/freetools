/* 数组迷宫 - 数织(Nonogram)游戏 */
page {
  background: linear-gradient(160deg, #e8f5e9 0%, #f1f8e9 50%, #fff8e1 100%);
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 40rpx;
  min-height: 100vh;
}

/* 难度选择 */
.difficulty-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.diff-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  background: #e0e0e0;
  color: #666;
  transition: all 0.2s;
}

.diff-btn.active {
  background: #4caf50;
  color: #fff;
}

/* 关卡信息 */
.level-info {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 16rpx;
}

.level-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.timer-text {
  font-size: 26rpx;
  color: #666;
}

/* 棋盘区域 */
.board-scroll {
  max-height: 65vh;
  width: 100%;
}

.board-wrapper {
  display: inline-flex;
  flex-direction: column;
  margin: 0 auto;
  background: #f5f5f5;
  border: 2rpx solid #bbb;
  border-radius: 8rpx;
  padding: 8rpx;
}

/* 列提示行 */
.col-hints-row {
  display: flex;
  flex-direction: row;
}

.corner {
  width: 80rpx;
  min-width: 80rpx;
}

.col-hint {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  width: 64rpx;
  min-width: 64rpx;
  height: 120rpx;
  padding: 4rpx 0;
}

.hint-num {
  font-size: 22rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.3;
}

.row-hint .hint-num {
  display: inline;
}

/* 行 */
.game-row {
  display: flex;
  flex-direction: row;
}

.row-hint {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  align-items: center;
  width: 80rpx;
  min-width: 80rpx;
  padding-right: 8rpx;
  gap: 6rpx;
  flex-wrap: nowrap;
}

.row-hint .hint-num {
  font-size: 22rpx;
}

/* 格子 */
.cell {
  width: 64rpx;
  min-width: 64rpx;
  height: 64rpx;
  min-height: 64rpx;
  background: #fff;
  border: 1rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  transition: background 0.15s;
}

.cell.filled {
  background: #333;
  color: #fff;
}

.cell.marked {
  background: #fff3e0;
  color: #e53935;
  font-size: 24rpx;
}

.cell.blocked {
  background: #9e9e9e;
}

.cell:active {
  opacity: 0.7;
}

/* 操作提示 */
.tips {
  display: flex;
  gap: 20rpx;
  margin: 20rpx 0 10rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.tip-item {
  font-size: 22rpx;
  color: #888;
  background: rgba(255,255,255,0.7);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 按钮栏 */
.btn-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.btn {
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  color: #fff;
  font-weight: 500;
}

.btn-undo {
  background: #ff9800;
}

.btn-reset {
  background: #f44336;
}

.btn-next {
  background: #4caf50;
}

/* 完成弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 80rpx;
  text-align: center;
}

.modal-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.modal-info {
  font-size: 28rpx;
  color: #666;
}
