<view class="container">
  <!-- 难度选择 -->
  <view class="top-bar diff-bar">
    <view class="pill {{difficulty==='easy'?'on':''}}" bindtap="setDifficulty" data-diff="easy">简单 5×5</view>
    <view class="pill {{difficulty==='medium'?'on':''}}" bindtap="setDifficulty" data-diff="medium">中等 8×8</view>
    <view class="pill {{difficulty==='hard'?'on':''}}" bindtap="setDifficulty" data-diff="hard">困难 10×10</view>
  </view>

  <!-- 关卡 + 计时 -->
  <view class="top-bar info-bar">
    <text class="level-text">第 {{currentLevel}} 关</text>
    <text class="sub-text">⏱ {{timerText}}</text>
    <text class="sub-text accent">{{filledCount}}/{{totalFill}}</text>
  </view>

  <!-- 模式切换 -->
  <view class="top-bar mode-bar">
    <view class="pill-sm {{mode==='fill'?'on':''}}" bindtap="setMode" data-mode="fill">● 填充</view>
    <view class="pill-sm {{mode==='mark'?'on':''}}" bindtap="setMode" data-mode="mark">✕ 标记</view>
  </view>

  <!-- 棋盘 -->
  <view class="board-wrap">
    <view class="board" style="width:{{boardPx}}px;">
      <!-- 列提示 -->
      <view class="col-hints-row">
        <view class="corner" style="width:{{hintPx}}px;"></view>
        <view class="col-hint" wx:for="{{colHints}}" wx:key="idx" style="width:{{cellPx}}px;">
          <text class="hn" wx:for="{{item}}" wx:for-item="n" wx:key="*this">{{n}}</text>
        </view>
      </view>
      <!-- 行 -->
      <view class="grow" wx:for="{{grid}}" wx:key="ri" wx:for-index="ri">
        <view class="row-hint" style="width:{{hintPx}}px;height:{{cellPx}}px;">
          <text class="hn" wx:for="{{rowHints[ri]}}" wx:for-item="n" wx:key="*this">{{n}}</text>
        </view>
        <view class="cell {{item.s===1?'f':(item.s===2?'m':'')}}"
              wx:for="{{grid[ri]}}" wx:key="ci" wx:for-index="ci"
              style="width:{{cellPx}}px;height:{{cellPx}}px;"
              catchtouchstart="onTouchStart"
              catchtouchmove="onTouchMove"
              catchtouchend="onTouchEnd"
              data-row="{{ri}}" data-col="{{ci}}">
        </view>
      </view>
    </view>
  </view>

  <!-- 操作 -->
  <view class="bottom-bar">
    <view class="btn" bindtap="undo">↩ 重来</view>
  </view>

  <!-- 通关弹窗 -->
  <view class="mask" wx:if="{{showWin}}" bindtap="closeWin">
    <view class="card" catchtap="">
      <view class="card-icon">🎉</view>
      <view class="card-title">通关！</view>
      <view class="card-time">用时 {{timerText}}</view>
      <view class="card-btn" bindtap="nextLevel">下一关 ▶</view>
    </view>
  </view>
</view>
