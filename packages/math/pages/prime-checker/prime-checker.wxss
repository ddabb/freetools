/* prime-checker.wxss */
.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  box-sizing: border-box;
}

.header-bg {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-wrapper {
  margin-bottom: 16rpx;
}

.main-icon {
  font-size: 72rpx;
}

.main-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input-card,
.result-card,
.concept-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.1);
  animation: fadeInUp 0.4s ease-out;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.input-section {
  margin-bottom: 0;
}

.input-wrapper {
  margin-bottom: 0;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input-container {
  position: relative;
}

.modern-input {
  width: 100%;
  padding: 28rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: 500;
  box-sizing: border-box;
  background: #f9f9f9;
  transition: all 0.3s ease;
  min-height: 96rpx;
  line-height: 1.4;
}

.modern-input:focus {
  border-color: #667eea;
  background: white;
  box-shadow: 0 0 0 3rpx rgba(102, 126, 234, 0.15);
}

/* 结果卡片 */
.result-card {
  border-left: 8rpx solid #667eea;
}

.prime-card {
  border-left-color: #4CAF50;
}

.composite-card {
  border-left-color: #FF6B6B;
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.result-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.result-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.result-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: white;
}

.prime-badge {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
}

.composite-badge {
  background: linear-gradient(135deg, #FF6B6B, #ff8787);
}

/* 结果数字展示 */
.result-number {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f8f9ff, #f0f2ff);
  border-radius: 16rpx;
}

.number-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #667eea;
  margin-right: 12rpx;
}

.number-suffix {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

/* 原因说明 */
.reason-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fff9e6;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.reason-icon {
  font-size: 28rpx;
}

.reason-text {
  font-size: 24rpx;
  color: #8b6914;
  flex: 1;
}

/* 性质标签 */
.properties-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 14rpx;
}

.properties-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.property-tag {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 10rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* 相邻质数 */
.neighbor-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.neighbor-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.neighbor-item {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
}

.neighbor-label {
  display: block;
  font-size: 20rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.neighbor-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
}

/* 计算耗时 */
.time-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eee;
}

.time-icon {
  font-size: 24rpx;
}

.time-text {
  font-size: 22rpx;
  color: #999;
}

/* 结果操作按钮 */
.result-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.action-btn {
  flex: 1;
  background: #f5f5f5;
  color: #333;
  border: none;
  border-radius: 10rpx;
  padding: 18rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.btn-icon {
  font-size: 26rpx;
}

/* 概念说明 */
.concept-card {
  margin-top: 0;
}

.concept-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.concept-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.concept-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.concept-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.concept-item {
  display: flex;
  flex-direction: column;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  border-left: 4rpx solid #667eea;
}

.concept-highlight {
  font-size: 24rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 6rpx;
}

.concept-desc {
  font-size: 22rpx;
  color: #666;
  line-height: 1.5;
}

/* 动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式 */
@media (max-width: 375px) {
  .neighbor-grid {
    grid-template-columns: 1fr;
  }

  .result-actions {
    flex-direction: column;
  }

  .result-number {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8rpx;
  }

  .number-value {
    font-size: 48rpx;
  }
}
