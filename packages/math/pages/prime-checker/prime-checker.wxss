/* prime-checker.wxss */
.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  box-sizing: border-box;
}

.header-bg {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-wrapper {
  margin-bottom: 20rpx;
}

.main-icon {
  font-size: 80rpx;
}

.main-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.input-card,
.result-card,
.concept-card,
.loading-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.1);
  animation: fadeInUp 0.6s ease-out;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.input-section {
  margin-bottom: 30rpx;
}

.input-wrapper {
  margin-bottom: 20rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 15rpx;
}

.input-container {
  position: relative;
}

.modern-input {
  width: 100%;
  padding: 30rpx 60rpx 30rpx 30rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: 500;
  box-sizing: border-box;
  background: #f9f9f9;
  transition: all 0.3s ease;
  min-height: 100rpx;
  line-height: 1.5;
}

.modern-input:focus {
  border-color: #667eea;
  background: white;
  box-shadow: 0 0 0 3rpx rgba(102, 126, 234, 0.1);
}

.input-status {
  position: absolute;
  right: 25rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

.status-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ddd;
  transition: all 0.3s ease;
}

.input-status.valid .status-dot {
  background: #4CAF50;
  box-shadow: 0 0 10rpx rgba(76, 175, 80, 0.5);
}

.action-section {
  display: flex;
  gap: 15rpx;
  margin-top: 20rpx;
}

.primary-btn {
  flex: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.primary-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 5rpx 15rpx rgba(102, 126, 234, 0.4);
}

.primary-btn.ready {
  opacity: 1;
}

.primary-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.secondary-btn {
  background: #f0f0f0;
  color: #333;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  transition: all 0.3s ease;
}

.secondary-btn:hover {
  background: #e0e0e0;
  transform: translateY(-2rpx);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 24rpx;
  font-weight: bold;
}

.btn-shine {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    to right,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.3) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  transform: rotate(30deg);
  animation: shine 2s infinite;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #666;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.result-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.result-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.result-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.prime-badge {
  background: #4CAF50;
  color: white;
}

.composite-badge {
  background: #FF6B6B;
  color: white;
}

.prime-card {
  border-left: 8rpx solid #4CAF50;
}

.composite-card {
  border-left: 8rpx solid #FF6B6B;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.info-item {
  background: #f9f9f9;
  padding: 20rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.info-icon {
  font-size: 32rpx;
  color: #667eea;
}

.info-content {
  flex: 1;
  min-width: 0;
}

.info-label {
  display: block;
  font-size: 20rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.info-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  word-break: break-all;
}

.info-value.highlight {
  color: #667eea;
}

.properties-section {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.properties-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 15rpx;
}

.property-tag {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.neighbor-section {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.neighbor-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 15rpx;
}

.neighbor-item {
  background: #f9f9f9;
  padding: 20rpx;
  border-radius: 10rpx;
  text-align: center;
}

.neighbor-label {
  display: block;
  font-size: 20rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.neighbor-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
}

.explanation-section {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.section-title {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.explanation-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.result-actions {
  display: flex;
  gap: 15rpx;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.action-btn {
  flex: 1;
  background: #f0f0f0;
  color: #333;
  border: none;
  border-radius: 10rpx;
  padding: 15rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: all 0.3s ease;
}

.action-btn:hover {
  background: #e0e0e0;
  transform: translateY(-2rpx);
}

.concept-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.concept-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.concept-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.concept-content {
  padding: 15rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
}

.concept-text {
  display: block;
  font-size: 22rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.concept-text:last-child {
  margin-bottom: 0;
}

.concept-highlight {
  font-weight: bold;
  color: #667eea;
}

/* 动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes shine {
  0% { transform: translateX(-100%) rotate(30deg); }
  100% { transform: translateX(100%) rotate(30deg); }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .info-grid {
    grid-template-columns: 1fr;
  }
  
  .neighbor-grid {
    grid-template-columns: 1fr;
  }
  
  .action-section {
    flex-direction: column;
  }
  
  .result-actions {
    flex-direction: column;
  }
}
