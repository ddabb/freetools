/* 全局样式重置 */

/* 容器样式 */
.container {
  padding: 0;
  background-color: #f8f9fa;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  padding-bottom: 140rpx;
}

/* 卡片容器布局 */
.card-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 20rpx 20rpx 0 20rpx;
}

/* 底部模式选择 */
.fixed-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #ffffff;
  padding: 16rpx;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  border-top: 1rpx solid #e9ecef;
}

.fixed-footer .mode-selector {
  margin: 0;
}

/* 模式选择 */
.mode-selector {
  display: flex;
  background-color: #f8f9fa;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 3rpx 12rpx rgba(0, 0, 0, 0.06);
}

.mode-item {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-size: 17rpx;
  font-weight: 600;
  color: #6c757d;
  transition: all 0.3s ease;
  position: relative;
  border-radius: 16rpx;
  margin: 4rpx;
}

.mode-item.active {
  background-color: #4361ee;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(67, 97, 238, 0.4);
  transform: translateY(-2rpx);
}

.mode-item:not(.active):hover {
  background-color: #e9ecef;
  transform: translateY(-2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  position: relative;
  border: 1rpx solid #f1f3f4;
  margin-bottom: 16rpx;
  will-change: transform, height;
}

/* 卡片悬停效果 */
.card:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-2rpx);
}

/* 卡片展开状态 */
.card.expanded {
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-4rpx);
  z-index: 10;
}

/* 卡片编辑状态 */
.card.editing {
  background-color: #f8f9ff;
  border-color: #4361ee;
  box-shadow: 0 4rpx 20rpx rgba(67, 97, 238, 0.15);
}

/* 卡片收起状态 */
.card.collapsed {
  max-height: 60rpx;
  overflow: hidden;
}

/* 主要卡片样式 */
.primary-card {
  border-left: 4rpx solid #4361ee;
  box-shadow: 0 4rpx 16rpx rgba(67, 97, 238, 0.1);
}

.primary-card:hover {
  box-shadow: 0 8rpx 24rpx rgba(67, 97, 238, 0.15);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f1f3f4;
  background-color: #f8f9fa;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
}

.card-header:hover {
  background-color: #f0f4ff;
}

.card-header.editing {
  background-color: #e9ecef;
  border-bottom-color: #4361ee;
}

.card-title {
  font-size: 16rpx;
  font-weight: 600;
  color: #212529;
  flex: 1;
}

/* 卡片操作按钮 */
.card-actions {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.card-toggle {
  width: 24rpx;
  height: 24rpx;
  border: none;
  background-color: transparent;
  cursor: pointer;
  transition: transform 0.3s ease;
  color: #6c757d;
  font-size: 12rpx;
}

.card-toggle.expanded {
  transform: rotate(180deg);
}

/* 卡片内容 */
.card-content {
  padding: 20rpx;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  overflow: hidden;
}

/* 卡片内容收起状态 */
.card-content.collapsed {
  padding: 0;
  max-height: 0;
  opacity: 0;
}

/* 卡片内容展开状态 */
.card-content.expanded {
  padding: 20rpx;
  max-height: 1000rpx;
  opacity: 1;
}

/* 设置项 */
.generate-settings,
.investment-settings {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.settings-label {
  font-size: 15rpx;
  color: #495057;
  font-weight: 500;
  flex-shrink: 0;
}

/* 选项网格 */
.option-grid {
  display: flex;
  flex-wrap: wrap;
  flex: 1;
  gap: 8rpx;
}

.option-item {
  flex: none;
  min-width: 70rpx;
  padding: 10rpx 8rpx;
  text-align: center;
  border: 1rpx solid #dee2e6;
  border-radius: 10rpx;
  font-size: 14rpx;
  font-weight: 500;
  color: #495057;
  background-color: #ffffff;
  transition: all 0.3s ease;
  cursor: pointer;
}

.option-item:hover {
  border-color: #4361ee;
  background-color: #f0f4ff;
  transform: translateY(-1rpx);
}

.option-item.active {
  background-color: #4361ee;
  color: #ffffff;
  border-color: #4361ee;
  box-shadow: 0 2rpx 8rpx rgba(67, 97, 238, 0.3);
}

/* 按钮样式 */
.generate-btn {
  width: 100%;
  background-color: #4361ee;
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 600;
  padding: 18rpx;
  border-radius: 12rpx;
  margin: 20rpx 0;
  transition: all 0.3s ease;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(67, 97, 238, 0.2);
}

.generate-btn:hover {
  background-color: #3a0ca3;
  box-shadow: 0 6rpx 16rpx rgba(67, 97, 238, 0.3);
  transform: translateY(-2rpx);
}

.investment-btn {
  width: 100%;
  background-color: #7209b7;
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 600;
  padding: 18rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(114, 9, 183, 0.2);
}

.investment-btn:hover:not(:disabled) {
  background-color: #5a189a;
  box-shadow: 0 6rpx 16rpx rgba(114, 9, 183, 0.3);
  transform: translateY(-2rpx);
}

.investment-btn:disabled {
  background-color: #adb5bd;
  cursor: not-allowed;
  box-shadow: none;
}

.add-btn {
  width: 100%;
  background-color: #4cc9f0;
  color: #ffffff;
  font-size: 15rpx;
  font-weight: 600;
  padding: 16rpx;
  border-radius: 10rpx;
  margin-top: 16rpx;
  transition: all 0.3s ease;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(76, 201, 240, 0.2);
}

.add-btn:hover {
  background-color: #4361ee;
  box-shadow: 0 6rpx 16rpx rgba(76, 201, 240, 0.3);
  transform: translateY(-2rpx);
}

.clear-btn {
  background-color: #f72585;
  color: #ffffff;
  font-size: 13rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(247, 37, 133, 0.2);
}

.clear-btn:hover {
  background-color: #b5179e;
  box-shadow: 0 4rpx 12rpx rgba(247, 37, 133, 0.3);
  transform: translateY(-1rpx);
}

/* 导出区域 */
.export-section {
  display: flex;
  margin-top: 16rpx;
  gap: 10rpx;
}

.export-btn,
.share-btn,
.share-investment-btn {
  flex: 1;
  font-size: 15rpx;
  font-weight: 600;
  padding: 16rpx;
  border-radius: 10rpx;
  transition: all 0.3s ease;
  border: none;
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.1);
}

.export-btn {
  background-color: #4361ee;
  color: #ffffff;
}

.export-btn:hover {
  background-color: #3a0ca3;
  box-shadow: 0 4rpx 12rpx rgba(67, 97, 238, 0.3);
  transform: translateY(-1rpx);
}

.share-btn,
.share-investment-btn {
  background-color: #7209b7;
  color: #ffffff;
}

.share-btn:hover,
.share-investment-btn:hover {
  background-color: #5a189a;
  box-shadow: 0 4rpx 12rpx rgba(114, 9, 183, 0.3);
  transform: translateY(-1rpx);
}

/* 号码容器 */
.numbers-container {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx solid #e9ecef;
}

.balls-section {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 15rpx;
  color: #495057;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 600;
}

/* 球的容器 */
.balls {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
}

.balls.inline-balls {
  flex-wrap: nowrap;
  overflow-x: auto;
  padding-bottom: 8rpx;
  white-space: nowrap;
  gap: 8rpx;
}

/* 球的样式 */
.ball {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15rpx;
  font-weight: 600;
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  position: relative;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
}

/* 棕球样式 */
.ball.brown {
  background-color: #8b4513;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.2);
}

/* 绿球样式 */
.ball.green {
  background-color: #27ae60;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(39, 174, 96, 0.2);
}

/* 小球样式 */
.ball.small {
  width: 36rpx;
  height: 36rpx;
  font-size: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

/* 球的悬停效果 */
.ball:hover {
  transform: scale(1.1);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.2);
  z-index: 10;
}

.ball.small:hover {
  transform: scale(1.1);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.15);
}

/* 次数管理 */
.notes-list {
  max-height: 300rpx;
  overflow-y: auto;
}

.note-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border: 1rpx solid #e9ecef;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  transition: all 0.3s ease;
  background-color: #f8f9fa;
}

.note-item:hover {
  border-color: #4361ee;
  box-shadow: 0 2rpx 8rpx rgba(67, 97, 238, 0.1);
  background-color: #f0f4ff;
  transform: translateY(-1rpx);
}

.note-checkbox {
  margin-right: 16rpx;
}

.checkbox {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #dee2e6;
  border-radius: 50%;
  transition: all 0.3s ease;
  position: relative;
  cursor: pointer;
}

.checkbox:hover {
  border-color: #4361ee;
}

.checkbox.checked {
  background-color: #4361ee;
  border-color: #4361ee;
}

.checkbox.checked::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 14rpx;
  font-weight: bold;
  animation: check 0.3s ease;
}

@keyframes check {
  0% { transform: translate(-50%, -50%) scale(0); }
  100% { transform: translate(-50%, -50%) scale(1); }
}

.note-content {
  flex: 1;
  overflow: hidden;
}

.note-balls {
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  overflow-x: auto;
  white-space: nowrap;
  gap: 6rpx;
}

.empty-note {
  text-align: center;
  color: #6c757d;
  padding: 40rpx 0;
  font-size: 15rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx dashed #dee2e6;
}

/* 模拟结果 */
.draw-result {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx solid #e9ecef;
}

/* 匹配结果 */
.match-list {
  margin-top: 16rpx;
}

.match-item {
  padding: 16rpx;
  border: 1rpx solid #e9ecef;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  transition: all 0.3s ease;
  background-color: #f8f9fa;
}

.match-item:hover {
  border-color: #4361ee;
  box-shadow: 0 2rpx 8rpx rgba(67, 97, 238, 0.1);
  background-color: #f0f4ff;
  transform: translateY(-1rpx);
}

.match-balls-container {
  margin-bottom: 12rpx;
}

.match-balls {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6rpx;
}

.match-info {
  margin-top: 12rpx;
}

.match-info text {
  display: block;
  font-size: 15rpx;
  color: #495057;
  margin-bottom: 6rpx;
}

.match-level {
  font-weight: 600;
  color: #f72585;
}

.match-revenue {
  font-weight: 600;
  color: #4cc9f0;
  margin-top: 6rpx;
  display: block;
}

/* 结果统计 */
.result-summary {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx solid #e9ecef;
  flex-wrap: wrap;
  gap: 12rpx;
}

.summary-item {
  flex: 1;
  min-width: 140rpx;
  text-align: center;
  padding: 8rpx;
  background-color: #ffffff;
  border-radius: 8rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.summary-label {
  display: block;
  font-size: 14rpx;
  color: #6c757d;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.summary-value {
  display: block;
  font-size: 16rpx;
  font-weight: 600;
  color: #4361ee;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 结果统计样式 */
.award-statistics {
  margin-top: 20rpx;
}

.details-title {
  font-size: 15rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 16rpx;
  display: block;
}

.award-list {
  border: 1rpx solid #e9ecef;
  border-radius: 12rpx;
  background-color: #f8f9fa;
  padding: 16rpx;
}

.award-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e9ecef;
  transition: all 0.3s ease;
}

.award-item:hover {
  background-color: #f0f4ff;
  padding-left: 12rpx;
  border-radius: 8rpx;
}

.award-item:last-child {
  border-bottom: none;
}

.award-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.award-name {
  font-size: 15rpx;
  font-weight: 600;
  color: #212529;
}

.award-count {
  font-size: 15rpx;
  font-weight: 600;
  color: #4361ee;
}

.award-revenue {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.revenue-label {
  font-size: 13rpx;
  color: #6c757d;
}

.revenue-value {
  font-size: 13rpx;
  font-weight: 600;
  color: #4cc9f0;
}

.no-award {
  text-align: center;
  padding: 24rpx 0;
}

.no-award-text {
  font-size: 15rpx;
  color: #6c757d;
  font-style: italic;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 6rpx;
  height: 6rpx;
}

::-webkit-scrollbar-track {
  background: #f1f3f4;
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb {
  background: #adb5bd;
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #6c757d;
}

/* 动画效果 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.card {
  animation: fadeIn 0.4s ease-out;
}

.ball {
  animation: fadeIn 0.3s ease-out;
}

.option-item {
  animation: fadeIn 0.3s ease-out;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 12rpx;
    gap: 12rpx;
  }
  
  .fixed-footer {
    padding: 10rpx 12rpx;
  }
  
  .card {
    margin-bottom: 12rpx;
  }
  
  .card-content {
    padding: 16rpx;
  }
  
  .ball {
    width: 50rpx;
    height: 50rpx;
    font-size: 14rpx;
  }
  
  .ball.small {
    width: 32rpx;
    height: 32rpx;
    font-size: 11rpx;
  }
  
  .mode-item {
    font-size: 15rpx;
    padding: 16rpx;
  }
  
  .result-summary {
    flex-direction: column;
    align-items: stretch;
  }
  
  .summary-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-width: auto;
  }
  
  .export-section {
    flex-direction: column;
  }
  
  .export-section button {
    margin-bottom: 10rpx;
  }
  
  .export-section button:last-child {
    margin-bottom: 0;
  }
  
  .generate-settings,
  .investment-settings {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .settings-label {
    width: 100%;
  }
  
  .option-grid {
    width: 100%;
  }
}

/* 命中状态美化 */
.hit-status {
  font-size: 12rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  background-color: rgba(67, 97, 238, 0.1);
  color: #4361ee;
}

/* 卡片布局动画 */
@keyframes slideDown {
  0% { 
    max-height: 0;
    opacity: 0;
    transform: translateY(-10rpx);
  }
  100% { 
    max-height: 1000rpx;
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  0% { 
    max-height: 1000rpx;
    opacity: 1;
    transform: translateY(0);
  }
  100% { 
    max-height: 0;
    opacity: 0;
    transform: translateY(-10rpx);
  }
}

/* 卡片内容展开动画 */
.card-content.expanding {
  animation: slideDown 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

.card-content.collapsing {
  animation: slideUp 0.3s cubic-bezier(0.55, 0.085, 0.68, 0.53) forwards;
}

/* 卡片间距优化 */
.card + .card {
  margin-top: 8rpx;
}

/* 卡片悬浮层叠效果 */
.card:hover {
  z-index: 5;
}

.card.expanded {
  z-index: 10;
}

/* 卡片内容区域优化 */
.card-content > view {
  margin-bottom: 16rpx;
}

.card-content > view:last-child {
  margin-bottom: 0;
}

/* 卡片操作按钮优化 */
.card-actions button {
  margin: 0;
  padding: 8rpx 16rpx;
  font-size: 13rpx;
}

/* 清空按钮样式优化 */
.clear-btn {
  background-color: #f72585;
  color: #ffffff;
  font-size: 13rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(247, 37, 133, 0.2);
  margin: 0;
}

.clear-btn:hover {
  background-color: #b5179e;
  box-shadow: 0 4rpx 12rpx rgba(247, 37, 133, 0.3);
  transform: translateY(-1rpx);
}

/* 底部固定区域优化 */
.fixed-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #ffffff;
  padding: 12rpx 16rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  border-top: 1rpx solid #e9ecef;
}
