<view class="container">
  <view class="card-container">
    <!-- 号码生成区 -->
    <view class="card primary-card {{expandedCards.generate ? 'expanded' : ''}}" data-card="generate">
      <view class="card-header {{generatedNotes.length > 0 ? 'editing' : ''}}" bindtap="toggleCard" data-card="generate">
        <text class="card-title">号码生成</text>
        <view class="card-actions">
          <text class="card-toggle {{expandedCards.generate ? 'expanded' : ''}}">▼</text>
        </view>
      </view>
      <view class="card-content {{expandedCards.generate ? 'expanded' : 'collapsed'}}">
        <view class="generate-settings">
          <text class="settings-label">生成数量：</text>
          <view class="option-grid">
            <view wx:for="{{generateOptions}}" wx:key="index" class="option-item {{selectedGenerateCount === item ? 'active' : ''}}" bindtap="setGenerateCountDirectly" data-count="{{item}}">{{item}}</view>
          </view>
        </view>
        <button class="generate-btn" bindtap="generateNumbers">一键生成</button>
        
        <!-- 生成的号码 -->
        <view class="numbers-container" wx:if="{{brownBalls.length > 0}}">
          <view class="balls-section">
            <text class="section-title">号码：</text>
            <view class="balls inline-balls">
              <view class="ball brown" wx:for="{{brownBalls}}" wx:key="index">{{item}}</view>
              <view class="ball green" wx:for="{{greenBalls}}" wx:key="index">{{item}}</view>
            </view>
          </view>
          <button class="add-btn" bindtap="addToNotes">添加到次数</button>
          <view class="export-section">
            <button class="export-btn" bindtap="exportResult">导出Excel</button>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 次数管理区 -->
    <view class="card {{expandedCards.notes ? 'expanded' : ''}}" data-card="notes">
      <view class="card-header {{generatedNotes.length > 0 ? 'editing' : ''}}" bindtap="toggleCard" data-card="notes">
        <text class="card-title">次数管理</text>
        <view class="card-actions">
          <button class="clear-btn" bindtap="clearNotes">清空</button>
          <text class="card-toggle {{expandedCards.notes ? 'expanded' : ''}}">▼</text>
        </view>
      </view>
      <view class="card-content {{expandedCards.notes ? 'expanded' : 'collapsed'}}">
        <view class="notes-list">
          <view class="note-item" wx:for="{{generatedNotes}}" wx:key="item.id">
            <view class="note-checkbox" bindtap="toggleNote" data-id="{{item.id}}">
              <view class="checkbox {{item.selected ? 'checked' : ''}}"></view>
            </view>
            <view class="note-content">
              <view class="note-balls">
                <view class="ball brown small" wx:for="{{item.brownBalls}}" wx:key="index">{{item}}</view>
                <view class="ball green small" wx:for="{{item.greenBalls}}" wx:key="index">{{item}}</view>
              </view>
            </view>
          </view>
          <view class="empty-note" wx:if="{{generatedNotes.length === 0}}">
            暂无生成的次数
          </view>
        </view>
        <view class="export-section" wx:if="{{generatedNotes.length > 0}}">
          <button class="export-btn" bindtap="copyNotesToClipboard">导出Excel</button>
        </view>
      </view>
    </view>
    
    <!-- 批量模拟区 -->
    <view class="card {{expandedCards.batch ? 'expanded' : ''}}" data-card="batch">
      <view class="card-header {{showInvestmentResult ? 'editing' : ''}}" bindtap="toggleCard" data-card="batch">
        <text class="card-title">批量模拟</text>
        <view class="card-actions">
          <text class="card-toggle {{expandedCards.batch ? 'expanded' : ''}}">▼</text>
        </view>
      </view>
      <view class="card-content {{expandedCards.batch ? 'expanded' : 'collapsed'}}">
        <view class="investment-settings">
          <text class="settings-label">模拟次数：</text>
          <view class="option-grid">
            <view wx:for="{{periodOptions}}" wx:key="index" class="option-item {{selectedPeriod === item ? 'active' : ''}}" bindtap="setInvestmentPeriodsDirectly" data-periods="{{item}}">{{item}}</view>
          </view>
        </view>
        <button 
          class="investment-btn" 
          bindtap="startInvestment"
          disabled="{{isInvesting}}"
        >
          {{isInvesting ? '模拟中...' : '批量模拟'}}
        </button>
      </view>
    </view>
    
    <!-- 模拟结果 -->
    <view class="card {{expandedCards.result ? 'expanded' : ''}}" wx:if="{{showDrawResult}}" data-card="result">
      <view class="card-header {{showDrawResult ? 'editing' : ''}}" bindtap="toggleCard" data-card="result">
        <text class="card-title">模拟结果</text>
        <view class="card-actions">
          <text class="card-toggle {{expandedCards.result ? 'expanded' : ''}}">▼</text>
        </view>
      </view>
      <view class="card-content {{expandedCards.result ? 'expanded' : 'collapsed'}}">
        <view class="draw-result">
          <view class="balls-section">
            <text class="section-title">开奖结果：</text>
            <view class="balls">
              <view class="ball brown" wx:for="{{drawResult.brownBalls}}" wx:key="index">{{item}}</view>
              <view class="ball green" wx:for="{{drawResult.greenBalls}}" wx:key="index">{{item}}</view>
            </view>
          </view>
          
          <!-- 模拟结果信息 -->
          <view class="result-summary" wx:if="{{showMatchResult}}">
            <view class="summary-item">
              <text class="summary-label">总次数：</text>
              <text class="summary-value">{{singleResult.totalCost / 2}}次</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">总成本：</text>
              <text class="summary-value">¥{{singleResult.totalCost}}</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">总收入：</text>
              <text class="summary-value">¥{{singleResult.totalRevenue}}</text>
            </view>
            <view class="summary-item">
              <text class="summary-label">净利润：</text>
              <text class="summary-value" style="color: {{singleResult.netProfit >= 0 ? '#27ae60' : '#e74c3c'}}">¥{{singleResult.netProfit}}
              </text>
            </view>
          </view>
          
          <button class="share-btn" bindtap="shareResult">导出Excel</button>
        </view>
      </view>
    </view>
    
    <!-- 匹配结果区 -->
    <view class="card {{expandedCards.match ? 'expanded' : ''}}" wx:if="{{showMatchResult}}" data-card="match">
      <view class="card-header {{showMatchResult ? 'editing' : ''}}" bindtap="toggleCard" data-card="match">
        <text class="card-title">匹配结果</text>
        <view class="card-actions">
          <text class="card-toggle {{expandedCards.match ? 'expanded' : ''}}">▼</text>
        </view>
      </view>
      <view class="card-content {{expandedCards.match ? 'expanded' : 'collapsed'}}">
        <!-- 模拟结果统计 -->
        <view class="result-summary">
          <view class="summary-item">
            <text class="summary-label">总支出：</text>
            <text class="summary-value">¥{{singleResult.totalCost.toLocaleString()}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">总收益：</text>
            <text class="summary-value">¥{{singleResult.totalRevenue.toLocaleString()}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">净结果：</text>
            <text class="summary-value" style="color: {{singleResult.netProfit >= 0 ? '#27ae60' : '#e74c3c'}}">¥{{singleResult.netProfit.toLocaleString()}}
            </text>
          </view>
        </view>
        
        <!-- 每次匹配结果 -->
        <view class="match-list">
          <view class="match-item" wx:for="{{matchResults}}" wx:key="item.id">
            <view class="match-balls-container">
              <view class="match-balls">
                <view class="ball brown small" wx:for="{{item.brownBalls}}" wx:key="index">{{item}}</view>
                <view class="ball green small" wx:for="{{item.greenBalls}}" wx:key="index">{{item}}</view>
              </view>
            </view>
            <view class="match-info">
              <text>棕球：{{item.matchedBrown}}个，绿球：{{item.matchedGreen}}个</text>
              <text class="match-level">{{item.matchLevel}}</text>
              <text class="match-revenue" wx:if="{{item.revenue > 0}}">收益：¥{{item.revenue}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 批量结果区 -->
    <view class="card {{expandedCards.investment ? 'expanded' : ''}}" wx:if="{{showInvestmentResult}}" data-card="investment">
      <view class="card-header {{showInvestmentResult ? 'editing' : ''}}" bindtap="toggleCard" data-card="investment">
        <text class="card-title">批量模拟结果</text>
        <view class="card-actions">
          <text class="card-toggle {{expandedCards.investment ? 'expanded' : ''}}">▼</text>
        </view>
      </view>
      <view class="card-content {{expandedCards.investment ? 'expanded' : 'collapsed'}}">
        <view class="result-summary">
          <view class="summary-item">
            <text class="summary-label">总次数：</text>
            <text class="summary-value">{{investmentResult.totalPeriods}}次</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">命中次数：</text>
            <text class="summary-value">{{investmentResult.hitPeriods}}次</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">命中率：</text>
            <text class="summary-value">{{investmentResult.hitRate}}%</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">总支出：</text>
            <text class="summary-value">¥{{investmentResult.totalCost}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">总收益：</text>
            <text class="summary-value">¥{{investmentResult.totalRevenue}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">净结果：</text>
            <text class="summary-value" style="color: {{investmentResult.netProfit >= 0 ? '#27ae60' : '#e74c3c'}}">¥{{investmentResult.netProfit}}
            </text>
          </view>
        </view>
        
        <!-- 奖项统计 -->
        <view class="award-statistics">
          <text class="details-title">结果统计</text>
          <view class="award-list">
            <view class="award-item" wx:for="{{investmentResult.awardStats}}" wx:key="name">
              <view class="award-header">
                <text class="award-name">{{item.name}}</text>
                <text class="award-count">{{item.count}}个</text>
              </view>
              <view class="award-revenue">
                <text class="revenue-label">累计金额：</text>
                <text class="revenue-value">¥{{item.revenue}}</text>
              </view>
            </view>
            <view class="no-award" wx:if="{{investmentResult.awardStats.length === 0}}">
              <text class="no-award-text">本次模拟未命中任何结果</text>
            </view>
          </view>
        </view>
        

      </view>
    </view>
  </view>
  
  <!-- 底部模式选择 -->
  <view class="fixed-footer">
    <view class="mode-selector">
      <view 
        class="mode-item {{mode === 'double' ? 'active' : ''}}"
        data-mode="double"
        bindtap="switchMode"
      >
        模式1
      </view>
      <view 
        class="mode-item {{mode === 'lottery' ? 'active' : ''}}"
        data-mode="lottery"
        bindtap="switchMode"
      >
        模式2
      </view>
    </view>
  </view>
</view>