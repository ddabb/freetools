/* 黑白棋 (Othello / Reversi) */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  min-height: 100vh;
}

/* 顶部信息栏 */
.header {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.score-board {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 10rpx;
}

.score-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.1);
}

.piece-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.black-icon {
  background: #1a1a1a;
  border: 2rpx solid #333;
}

.white-icon {
  background: #fff;
  border: 2rpx solid #ccc;
}

.score {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.score-divider {
  font-size: 28rpx;
  color: #888;
}

.status {
  font-size: 28rpx;
  color: #aaa;
  margin-top: 10rpx;
}

/* 难度选择 */
.difficulty-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.diff-item {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #888;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  transition: all 0.3s;
}

.diff-item.active {
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 棋盘 */
.board-container {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
}

.board {
  position: relative;
  background: #2d5a27;
  background-image: 
    linear-gradient(rgba(0, 0, 0, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 0, 0, 0.1) 1px, transparent 1px);
  background-size: 12.5% 12.5%;
}

.cell {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid rgba(0, 0, 0, 0.2);
}

/* 棋子 */
.piece {
  width: 80%;
  height: 80%;
  border-radius: 50%;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
}

.black-piece {
  background: radial-gradient(circle at 30% 30%, #4a4a4a, #1a1a1a);
}

.white-piece {
  background: radial-gradient(circle at 30% 30%, #fff, #d0d0d0);
}

.last-move {
  box-shadow: 0 0 0 4rpx #ffd700, 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
}

.flipped {
  animation: flip 0.3s ease;
}

@keyframes flip {
  0% { transform: scale(1); }
  50% { transform: scale(0.8); }
  100% { transform: scale(1); }
}

/* 合法落子提示 */
.valid-hint {
  width: 30%;
  height: 30%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.2); }
}

/* 回合指示 */
.turn-indicator {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #aaa;
}

.turn-piece {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
}

.black-turn {
  background: #1a1a1a;
  border: 2rpx solid #333;
}

.white-turn {
  background: #fff;
  border: 2rpx solid #ccc;
}

.thinking {
  color: #ffd700;
  animation: blink 1s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 操作按钮 */
.controls {
  margin-top: 40rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}

.btn-restart {
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  border: none;
}

.btn-restart::after {
  border: none;
}

/* 结果弹窗 */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 100;
}

.result-modal.show {
  opacity: 1;
  visibility: visible;
}

.result-content {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 60rpx;
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.5);
}

.result-title {
  font-size: 48rpx;
  color: #fff;
  margin-bottom: 30rpx;
}

.result-score {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 30rpx;
  font-size: 32rpx;
  color: #aaa;
  margin-bottom: 40rpx;
}

.result-score .vs {
  color: #666;
}

.btn-play-again {
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  border: none;
}

.btn-play-again::after {
  border: none;
}