/* 躲避青蛙 - 绿野沼泽主题 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f8f0 0%, #d0f0e4 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 0;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
  max-width: 400px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16px;
  margin-bottom: 12px;
}

.status-item {
  display: flex;
  align-items: center;
  gap: 4px;
  background: #fff;
  border-radius: 20px;
  padding: 6px 14px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.status-icon {
  font-size: 18px;
}

.status-num {
  font-size: 16px;
  font-weight: 700;
  color: #1a5c38;
  font-variant-numeric: tabular-nums;
}

.status-center {
  flex: 1;
  display: flex;
  justify-content: center;
}

.diff-btn {
  background: #27ae60;
  color: #fff;
  border-radius: 20px;
  padding: 6px 16px;
  font-size: 13px;
  box-shadow: 0 2px 8px rgba(39,174,96,0.3);
}

.tool-bar {
  width: 100%;
  max-width: 400px;
  display: flex;
  gap: 10px;
  padding: 0 16px;
  margin-bottom: 12px;
}

.flag-btn, .help-btn {
  flex: 1;
  background: #fff;
  border: 2px solid #b8e6d4;
  border-radius: 10px;
  padding: 8px 0;
  text-align: center;
  font-size: 14px;
  color: #1a5c38;
  box-shadow: 0 2px 6px rgba(0,0,0,0.06);
}

.flag-btn.active {
  background: #f39c12;
  border-color: #e67e22;
  color: #fff;
}

.board-wrapper {
  display: flex;
  justify-content: center;
  padding: 8px;
  background: #b8e6d4;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(39,174,96,0.2);
}

.board {
  display: flex;
  flex-direction: column;
  border-radius: 8px;
  overflow: hidden;
}

.board-row {
  display: flex;
}

.cell {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #a8d8c8;
  box-sizing: border-box;
  background: #c8e8d8;
  position: relative;
}

.cell:active {
  opacity: 0.85;
}

.cell.revealed {
  background: #e8f8f0;
  border-color: #d0e8d8;
}

.cell.flagged {
  background: #fef9e7;
}

.cell.frog-reveal {
  background: #fde8e8 !important;
}

.cell-text {
  font-size: 18px;
  line-height: 1;
}

.frog-text {
  font-size: 22px;
}

.water-text {
  font-size: 18px;
  color: #85c1e9;
}

.num-text {
  font-size: 14px;
  font-weight: 700;
  color: #2c5f2e;
}

.hidden-cell {
  display: block;
  width: 100%;
  height: 100%;
}

.flag-text {
  font-size: 16px;
}

.best-time {
  margin-top: 12px;
  font-size: 13px;
  color: #888;
}

/* 结果/帮助弹窗 */
.result-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.result-modal {
  background: #fff;
  border-radius: 20px;
  padding: 32px 28px;
  width: 280px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.15);
}

.result-icon {
  font-size: 56px;
  line-height: 1;
}

.result-title {
  font-size: 22px;
  font-weight: 700;
  color: #1a5c38;
}

.result-sub {
  font-size: 14px;
  color: #888;
}

.result-actions {
  margin-top: 8px;
  width: 100%;
}

.result-btn {
  width: 100%;
  padding: 12px 0;
  border-radius: 25px;
  text-align: center;
  font-size: 15px;
  font-weight: 600;
}

.result-btn.primary {
  background: #27ae60;
  color: #fff;
}

.help-content {
  display: flex;
  flex-direction: column;
  gap: 6px;
  text-align: left;
  width: 100%;
}

.help-line {
  font-size: 14px;
  color: #444;
  line-height: 1.6;
}
