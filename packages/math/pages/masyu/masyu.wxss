/*珍珠游戏样式*/
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f3e5f5 0%, #e1bee7 100%);
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ==================== 顶部信息栏 ==================== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(103, 58, 183, 0.1);
  flex-wrap: wrap;
  gap: 16rpx;
}

.difficulty-tabs {
  display: flex;
  gap: 12rpx;
}

.tab {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #64748b;
  background: #f1f5f9;
  transition: all 0.25s ease;
  border: 2rpx solid transparent;
}

.tab.active.easy {
  background: linear-gradient(135deg, #4caf50, #388e3c);
  color: white;
  border-color: #388e3c;
  box-shadow: 0 4rpx 12rpx rgba(56, 142, 60, 0.3);
}

.tab.active.medium {
  background: linear-gradient(135deg, #ff7043, #f4511e);
  color: white;
  border-color: #f4511e;
  box-shadow: 0 4rpx 12rpx rgba(244, 81, 30, 0.3);
}

.tab.active.hard {
  background: linear-gradient(135deg, #7e57c2, #5e35b1);
  color: white;
  border-color: #5e35b1;
  box-shadow: 0 4rpx 12rpx rgba(94, 53, 177, 0.3);
}

.info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.timer-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #e8eaf6, #c5cae9);
  border-radius: 16rpx;
}

.timer-icon {
  font-size: 28rpx;
}

.timer {
  font-size: 30rpx;
  font-weight: 700;
  color: #283593;
  font-variant-numeric: tabular-nums;
}

/* ==================== 游戏区域 ==================== */
.game-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0;
  flex: 1;
  min-height: 0;
  position: relative;
}

.grid-shadow {
  filter: drop-shadow(0 8rpx 32rpx rgba(103, 58, 183, 0.15));
}

.grid-container {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  min-width: 200px;
  min-height: 200px;
}

/* 珍珠（点）*/
.pearls {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 15;
}

.pearl-wrap {
  position: absolute;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  z-index: 16;
}

.pearl {
  border-radius: 50%;
  position: relative;
  z-index: 6;
}

.pearl.white-pearl {
  width: 32px;
  height: 32px;
  background: linear-gradient(135deg, #fff9c4, #ffd54f);
  box-shadow: 0 2rpx 8rpx rgba(255, 193, 7, 0.4);
}

.pearl.black-pearl {
  width: 32px;
  height: 32px;
  background: linear-gradient(135deg, #37474f, #263238);
  box-shadow: 0 2rpx 8rpx rgba(38, 50, 56, 0.4);
}

/* 格点 */
.dots {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 10;
}

.dot {
  position: absolute;
  width: 8px;
  height: 8px;
  background: linear-gradient(135deg, #7c4dff, #5e35b1);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 2rpx 4rpx rgba(124, 77, 255, 0.3);
}

/* 横边 */
.edges-h {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 5;
}

.edge-h {
  position: absolute;
  transform: translateY(-50%);
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  border-radius: 4px;
  transition: all 0.15s ease;
  padding: 0;
  box-sizing: border-box;
}

.edge-h::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  height: 5px;
  top: 50%;
  transform: translateY(-50%);
  background: transparent;
  border-radius: 3px;
  transition: all 0.15s ease;
}

.edge-h:active::before {
  background: rgba(124, 77, 255, 0.25);
}

.edge-h.line::before {
  background: linear-gradient(90deg, #7c4dff, #9c7cff, #7c4dff);
  box-shadow: 0 0 8rpx rgba(124, 77, 255, 0.6);
}

/* 竖边 */
.edges-v {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 5;
}

.edge-v {
  position: absolute;
  transform: translateX(-50%);
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  border-radius: 4px;
  transition: all 0.15s ease;
  padding: 0;
  box-sizing: border-box;
}

.edge-v::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 5px;
  left: 50%;
  transform: translateX(-50%);
  background: transparent;
  border-radius: 3px;
  transition: all 0.15s ease;
}

.edge-v:active::before {
  background: rgba(124, 77, 255, 0.25);
}

.edge-v.line::before {
  background: linear-gradient(180deg, #7c4dff, #9c7cff, #7c4dff);
  box-shadow: 0 0 8rpx rgba(124, 77, 255, 0.6);
}

/* ==================== 完成提示 ==================== */
.complete-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(8px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.complete-card {
  background: white;
  padding: 48rpx 56rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.25);
  animation: scaleIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  max-width: 340px;
  width: 90%;
}

@keyframes scaleIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.complete-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
  animation: bounce 0.6s ease infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.complete-text {
  font-size: 44rpx;
  font-weight: 800;
  color: #7e57c2;
  margin-top: 8rpx;
}

.complete-time {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 16rpx;
}

.next-btn {
  background: linear-gradient(135deg, #7c4dff, #5e35b1);
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 24rpx 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(94, 53, 177, 0.4);
}

/* ==================== 底部按钮 ==================== */
.footer {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 24rpx 20rpx;
}

.btn {
  flex: 1;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.btn:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.btn.reset {
  background: #f1f5f9;
  color: #64748b;
}

.btn.next {
  background: linear-gradient(135deg, #7c4dff, #5e35b1);
  color: white;
}

.btn.answer-btn {
  background: linear-gradient(135deg, #ff7043, #f4511e);
  color: white;
}

.btn.answer-btn.hide {
  background: linear-gradient(135deg, #78909c, #546e7a);
  color: white;
}

.btn.rules-btn {
  background: linear-gradient(135deg, #42a5f5, #1e88e5);
  color: white;
}

/* ==================== 规则弹窗 ==================== */
.rules-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.55);
  backdrop-filter: blur(8px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
  animation: fadeIn 0.3s ease;
}

.rules-card {
  background: white;
  padding: 44rpx 40rpx 36rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.22);
  animation: scaleIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  max-width: 360px;
  width: 88%;
  max-height: 82vh;
  overflow-y: auto;
}

.rules-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.rules-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

.rules-close {
  font-size: 32rpx;
  color: #94a3b8;
  padding: 8rpx;
  line-height: 1;
}

.rules-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.rule-icon {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  margin-top: 2rpx;
}

.rule-icon.rule-white {
  background: #fff9c4;
  color: #ffd54f;
  font-size: 22rpx;
}

.rule-icon.rule-black {
  background: #1e293b;
  color: #eceff1;
  font-size: 22rpx;
}

.rule-icon.rule-no-cross {
  background: #fce4ec;
  color: #c62828;
  font-size: 18rpx;
}

.rule-icon.rule-tap {
  background: #e8eaf6;
  font-size: 24rpx;
}

.rule-desc {
  font-size: 27rpx;
  color: #334155;
  line-height: 1.6;
}

.rule-divider {
  height: 2rpx;
  background: #e2e8f0;
  margin: 4rpx 0;
}

.rules-footer {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
}

.rules-ok-btn {
  padding: 22rpx 64rpx;
  background: linear-gradient(135deg, #42a5f5, #1e88e5);
  color: white;
  border-radius: 20rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(30, 136, 229, 0.35);
  transition: all 0.2s ease;
}

/* ==================== 题号与跳关 ==================== */
.nav-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 20rpx 24rpx;
}

.puzzle-info {
  font-size: 28rpx;
  color: #475569;
  font-weight: 500;
}

.jump-input {
  width: 100rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  background: #fff;
}

.btn-jump {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #7c4dff, #5e35b1);
  color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}