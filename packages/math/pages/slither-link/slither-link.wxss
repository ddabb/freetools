/* 数回游戏样式 - 现代化UI */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #e0f2fe 0%, #f0f9ff 50%, #e0e7ff 100%);
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* ==================== 顶部信息栏 ==================== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.08);
  backdrop-filter: blur(10px);
}

.difficulty-tabs {
  display: flex;
  gap: 12rpx;
}

.tab {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #64748b;
  background: #f1f5f9;
  transition: all 0.25s ease;
  border: 2rpx solid transparent;
}

.tab-icon {
  font-size: 24rpx;
}

.tab-text {
  font-weight: 500;
}

.tab.active.easy {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  border-color: #16a34a;
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.3);
}

.tab.active.medium {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: white;
  border-color: #d97706;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
}

.tab.active.hard {
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: white;
  border-color: #dc2626;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
}

.info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.timer-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
  border-radius: 16rpx;
}

.timer-icon {
  font-size: 28rpx;
}

.timer {
  font-size: 30rpx;
  font-weight: 700;
  color: #334155;
  font-variant-numeric: tabular-nums;
}

/* ==================== 游戏区域 ==================== */
.game-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.grid-shadow {
  filter: drop-shadow(0 8rpx 32rpx rgba(59, 130, 246, 0.15));
}

.grid-container {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

/* 格子 */
.cells {
  position: absolute;
  top: 0;
  left: 0;
}

.cell {
  position: absolute;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(59, 130, 246, 0.03);
  box-sizing: border-box;
}

.hint {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e40af;
  text-shadow: 0 2rpx 4rpx rgba(30, 64, 175, 0.1);
}

/* 格点 */
.dots {
  position: absolute;
  top: 0;
  left: 0;
}

.dot {
  position: absolute;
  width: 10px;
  height: 10px;
  background: linear-gradient(135deg, #64748b, #475569);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 边 - 水平 */
.edges-h {
  position: absolute;
  top: 0;
  left: 0;
}

.edge-h {
  position: absolute;
  transform: translateY(-50%);
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  border-radius: 6px;
  transition: all 0.15s ease;
}

.edge-h::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  height: 6px;
  top: 50%;
  transform: translateY(-50%);
  background: transparent;
  border-radius: 3px;
  transition: all 0.15s ease;
}

.edge-h:active::before {
  background: rgba(59, 130, 246, 0.2);
}

.edge-h.line::before {
  background: linear-gradient(90deg, #1e40af, #3b82f6, #1e40af);
  box-shadow: 0 0 8rpx rgba(59, 130, 246, 0.5);
}

.edge-h.cross::before {
  background: #e2e8f0;
}

.edge-h.cross:active::before {
  background: #cbd5e1;
}

/* 边 - 垂直 */
.edges-v {
  position: absolute;
  top: 0;
  left: 0;
}

.edge-v {
  position: absolute;
  width: 36px;
  transform: translateX(-50%);
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  border-radius: 6px;
  transition: all 0.15s ease;
}

.edge-v::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 6px;
  left: 50%;
  transform: translateX(-50%);
  background: transparent;
  border-radius: 3px;
  transition: all 0.15s ease;
}

.edge-v:active::before {
  background: rgba(59, 130, 246, 0.2);
}

.edge-v.line::before {
  background: linear-gradient(180deg, #1e40af, #3b82f6, #1e40af);
  box-shadow: 0 0 8rpx rgba(59, 130, 246, 0.5);
}

.edge-v.cross::before {
  background: #e2e8f0;
}

.edge-v.cross:active::before {
  background: #cbd5e1;
}

.cross-mark {
  font-size: 18px;
  color: #94a3b8;
  font-weight: bold;
  line-height: 1;
}

/* ==================== 完成提示 ==================== */
.complete-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(8px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 彩带效果 */
.confetti {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200px;
  overflow: hidden;
  pointer-events: none;
}

.confetti-dot {
  position: absolute;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  animation: confettiFall 2s ease-in-out infinite;
}

.dot1 {
  left: 20%;
  background: #f59e0b;
  animation-delay: 0s;
}

.dot2 {
  left: 40%;
  background: #22c55e;
  animation-delay: 0.2s;
}

.dot3 {
  left: 60%;
  background: #3b82f6;
  animation-delay: 0.4s;
}

.dot4 {
  left: 75%;
  background: #ef4444;
  animation-delay: 0.6s;
}

.dot5 {
  left: 90%;
  background: #a855f7;
  animation-delay: 0.8s;
}

@keyframes confettiFall {
  0% {
    transform: translateY(-20px) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(220px) rotate(720deg);
    opacity: 0;
  }
}

.complete-card {
  background: white;
  padding: 48rpx 56rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.25);
  animation: scaleIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  max-width: 340px;
  width: 90%;
}

@keyframes scaleIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.complete-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
  animation: bounce 0.6s ease infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.complete-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1e293b;
  margin-top: 8rpx;
}

.complete-subtitle {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 16rpx;
}

.complete-stats {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #f8fafc, #f1f5f9);
  border-radius: 20rpx;
  margin: 8rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #3b82f6;
}

.stat-label {
  font-size: 22rpx;
  color: #94a3b8;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: #e2e8f0;
}

.complete-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  width: 100%;
}

.complete-btn {
  flex: 1;
  padding: 24rpx 32rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.complete-btn.secondary {
  background: #f1f5f9;
  color: #64748b;
}

.complete-btn.secondary:active {
  background: #e2e8f0;
}

.complete-btn.primary {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
}

.complete-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.3);
}

.btn-arrow {
  font-size: 24rpx;
  font-weight: bold;
}

/* ==================== 底部按钮 ==================== */
.footer {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 24rpx 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 36rpx;
  border-radius: 20rpx;
  background: white;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn.verify-btn {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.3);
}

.action-btn.primary {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

.action-btn.active {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.3);
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 24rpx;
  font-weight: 500;
}

/* ==================== 规则说明 ==================== */
.rules {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.rules-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rules-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #334155;
}

.rules-toggle {
  font-size: 24rpx;
  color: #3b82f6;
  font-weight: 500;
}

.rules-content {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.rule-num {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: white;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 50%;
  flex-shrink: 0;
}

.rule-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
}
