<!--数回游戏页面-->
<view class="container">
  <!-- 顶部信息栏 -->
  <view class="header">
    <view class="difficulty-tabs">
      <view class="tab {{difficulty === 'easy' ? 'active easy' : ''}}" data-difficulty="easy" bindtap="onDifficultyChange">
        <text class="tab-icon">🌱</text>
        <text class="tab-text">简单</text>
      </view>
      <view class="tab {{difficulty === 'medium' ? 'active medium' : ''}}" data-difficulty="medium" bindtap="onDifficultyChange">
        <text class="tab-icon">🌿</text>
        <text class="tab-text">中等</text>
      </view>
      <view class="tab {{difficulty === 'hard' ? 'active hard' : ''}}" data-difficulty="hard" bindtap="onDifficultyChange">
        <text class="tab-icon">🌳</text>
        <text class="tab-text">困难</text>
      </view>
    </view>
    <view class="info">
      <view class="timer-box">
        <text class="timer-icon">⏱</text>
        <text class="timer">{{timeStr}}</text>
      </view>
    </view>
  </view>

  <!-- 游戏区域 -->
  <view class="game-area">
    <view class="grid-shadow">
      <view class="grid-container" style="width: {{cols * 50 + 30}}px; height: {{rows * 50 + 30}}px;">
        <!-- 格子和数字提示 -->
        <view class="cells">
          <block wx:for="{{hints}}" wx:for-index="row" wx:for-item="hintRow">
            <block wx:for="{{hintRow}}" wx:for-index="col" wx:for-item="hint">
              <view class="cell" style="left: {{col * 50 + 15}}px; top: {{row * 50 + 15}}px;">
                <text wx:if="{{hint >= 0}}" class="hint">{{hint}}</text>
              </view>
            </block>
          </block>
        </view>

        <!-- 格点 -->
        <view class="dots">
          <block wx:for="{{rows + 1}}" wx:for-index="r" wx:key="r">
            <block wx:for="{{cols + 1}}" wx:for-index="c" wx:key="c">
              <view class="dot" style="left: {{c * 50 + 15}}px; top: {{r * 50 + 15}}px;"></view>
            </block>
          </block>
        </view>

        <!-- 水平边 -->
        <view class="edges-h">
          <block wx:for="{{edges.h}}" wx:for-index="row" wx:for-item="hRow" wx:key="row">
            <block wx:for="{{hRow}}" wx:for-index="col" wx:for-item="edge" wx:key="col">
              <view class="edge-h {{edge === 1 ? 'line' : ''}} {{edge === 2 ? 'cross' : ''}}"
                    style="left: {{col * 50 + 15}}px; top: {{row * 50 + 15}}px; width: 50px;"
                    data-type="h" data-row="{{row}}" data-col="{{col}}"
                    bindtap="onEdgeTap">
                <text wx:if="{{edge === 2}}" class="cross-mark">×</text>
              </view>
            </block>
          </block>
        </view>

        <!-- 垂直边 -->
        <view class="edges-v">
          <block wx:for="{{edges.v}}" wx:for-index="row" wx:for-item="vRow" wx:key="row">
            <block wx:for="{{vRow}}" wx:for-index="col" wx:for-item="edge" wx:key="col">
              <view class="edge-v {{edge === 1 ? 'line' : ''}} {{edge === 2 ? 'cross' : ''}}"
                    style="left: {{col * 50 + 15}}px; top: {{row * 50 + 15}}px; height: 50px;"
                    data-type="v" data-row="{{row}}" data-col="{{col}}"
                    bindtap="onEdgeTap">
                <text wx:if="{{edge === 2}}" class="cross-mark">×</text>
              </view>
            </block>
          </block>
        </view>
      </view>
    </view>
  </view>

  <!-- 完成提示 -->
  <view class="complete-overlay" wx:if="{{isComplete}}">
    <view class="confetti">
      <view class="confetti-dot dot1"></view>
      <view class="confetti-dot dot2"></view>
      <view class="confetti-dot dot3"></view>
      <view class="confetti-dot dot4"></view>
      <view class="confetti-dot dot5"></view>
    </view>
    <view class="complete-card">
      <view class="complete-icon">🎉</view>
      <view class="complete-title">恭喜通关！</view>
      <view class="complete-subtitle">第 {{puzzleId + 1}} 关 · {{difficultyText}}</view>
      <view class="complete-stats">
        <view class="stat-item">
          <text class="stat-value">{{timeStr}}</text>
          <text class="stat-label">用时</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{rows}}×{{cols}}</text>
          <text class="stat-label">难度</text>
        </view>
      </view>
      <view class="complete-actions">
        <view class="complete-btn secondary" bindtap="onReset">
          <text>重置</text>
        </view>
        <view class="complete-btn primary" bindtap="nextPuzzle">
          <text>下一关</text>
          <text class="btn-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer">
    <view class="action-btn" bindtap="onReset">
      <text class="action-icon">↩</text>
      <text class="action-text">重置</text>
    </view>
    <view class="action-btn {{showAnswer ? 'active' : ''}}" bindtap="onShowAnswer">
      <text class="action-icon">{{showAnswer ? '🙈' : '👁'}}</text>
      <text class="action-text">{{showAnswer ? '隐藏' : '答案'}}</text>
    </view>
    <view class="action-btn verify-btn" bindtap="onVerify">
      <text class="action-icon">✓</text>
      <text class="action-text">验证</text>
    </view>
    <view class="action-btn primary" bindtap="nextPuzzle">
      <text class="action-icon">▶</text>
      <text class="action-text">下一题</text>
    </view>
  </view>

  <!-- 规则说明 -->
  <view class="rules" bindtap="toggleRules">
    <view class="rules-header">
      <text class="rules-title">📖 游戏规则</text>
      <text class="rules-toggle">{{showRules ? '收起 ▲' : '展开 ▼'}}</text>
    </view>
    <view class="rules-content" wx:if="{{showRules}}">
      <view class="rule-item">
        <text class="rule-num">1</text>
        <text class="rule-text">点击两个格点之间的空位画出线段</text>
      </view>
      <view class="rule-item">
        <text class="rule-num">2</text>
        <text class="rule-text">格子中的数字 = 该格四周围了多少条线</text>
      </view>
      <view class="rule-item">
        <text class="rule-num">3</text>
        <text class="rule-text">所有线段必须连成一条闭合的环（不能分叉、不能断开、不能交叉）</text>
      </view>
      <view class="rule-item">
        <text class="rule-num">4</text>
        <text class="rule-text">再点一次线段变×（标记此处无线），再点取消</text>
      </view>
    </view>
  </view>
</view>
