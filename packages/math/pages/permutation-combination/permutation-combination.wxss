/**packages/math/pages/permutation-combination/permutation-combination.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* 输入区域 */
.input-section {
  margin-bottom: 24rpx;
}

.input-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.input-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.input-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.input-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 输入行 */
.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.input-row:last-of-type {
  margin-bottom: 0;
}

.input-label {
  width: 160rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.input-wrapper {
  flex: 1;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: #f5576c;
  background: white;
  box-shadow: 0 0 0 6rpx rgba(245, 87, 108, 0.1);
}

.number-input {
  width: 100%;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  padding: 24rpx 0;
  border: none;
  outline: none;
  background: transparent;
}

.number-input::placeholder {
  color: #aaa;
  font-weight: 400;
}

.input-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 16rpx;
  text-align: center;
}

/* 错误提示 */
.error-card {
  background: rgba(255, 59, 48, 0.1);
  border: 2rpx solid rgba(255, 59, 48, 0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  animation: shake 0.3s ease;
}

.error-icon {
  font-size: 32rpx;
}

.error-text {
  font-size: 26rpx;
  color: #ff3b30;
  font-weight: 600;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  75% { transform: translateX(8rpx); }
}

/* 结果区域 */
.result-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  animation: fadeIn 0.4s ease-out;
}

.result-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.result-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 公式卡片 */
.formula-card {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.formula {
  font-size: 26rpx;
  color: #666;
  font-family: 'Monaco', 'Menlo', monospace;
}

/* 结果数字 */
.result-display {
  display: flex;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #f093fb, #f5576c);
  border-radius: 16rpx;
}

.result-num {
  font-size: 56rpx;
  font-weight: 800;
  color: white;
  letter-spacing: 4rpx;
}

/* 信息卡片 */
.info-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.info-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #f5576c;
}

.info-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.info-relation {
  margin-top: 8rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-radius: 12rpx;
}

.relation-text {
  font-size: 24rpx;
  color: #92400e;
  font-weight: 600;
}

/* 示例卡片 */
.examples-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.examples-header {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.examples-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.example-btn {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.example-btn-hover {
  background: linear-gradient(135deg, #f093fb, #f5576c);
  transform: scale(0.96);
}

.example-n {
  font-size: 32rpx;
  font-weight: 700;
  color: #f5576c;
}

.example-sep {
  font-size: 24rpx;
  color: #999;
}

.example-r {
  font-size: 32rpx;
  font-weight: 700;
  color: #f5576c;
}

.example-btn-hover .example-n,
.example-btn-hover .example-r {
  color: white;
}

.example-btn-hover .example-sep {
  color: rgba(255, 255, 255, 0.7);
}

/* 引导区域 */
.guide-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.guide-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.guide-header {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.guide-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.guide-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.guide-example {
  font-size: 26rpx;
  color: #f5576c;
  font-weight: 600;
  font-family: 'Monaco', monospace;
  padding: 12rpx 16rpx;
  background: rgba(245, 87, 108, 0.1);
  border-radius: 10rpx;
  border-left: 4rpx solid #f5576c;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式 */
@media (max-width: 375px) {
  .examples-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .input-row {
    flex-direction: column;
    align-items: flex-start;
    gap: 8rpx;
  }

  .input-label {
    width: auto;
  }

  .result-num {
    font-size: 44rpx;
  }
}
