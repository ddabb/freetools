/* 桥游戏样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 12rpx;
  box-sizing: border-box;
}

/* 顶部信息栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.difficulty-tabs {
  display: flex;
  gap: 20rpx;
}

.tab {
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: bold;
}

.info {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.timer {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 游戏区域 */
.game-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 10rpx 0;
}

.grid-wrapper {
  position: relative;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
  margin: 0 auto;
  overflow: hidden;
}

/* 网格背景 */
.grid-bg {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  z-index: 0;
}

.grid-row {
  display: flex;
  flex-direction: row;
}

.grid-cell {
  box-sizing: border-box;
  border-right: 1rpx solid #e0e0e0;
  border-bottom: 1rpx solid #e0e0e0;
  background: #fafafa;
}

.grid-cell.has-island {
  background: #f0f0f0;
}

.grid-cell:first-child {
  border-left: 1rpx solid #e0e0e0;
}

.grid-row:first-child .grid-cell {
  border-top: 1rpx solid #e0e0e0;
}

/* 桥 — 渲染在岛屿下层，加粗加醒目 */
.bridge {
  position: absolute;
  z-index: 1;
}

.bridge-h {
  height: 8px;
  background: #5b3a9e;
  border-radius: 4px;
  box-shadow: 0 2rpx 6rpx rgba(91, 58, 158, 0.5);
}

.bridge-h-2 {
  height: 14px;
  background: transparent;
  border-top: 4px solid #5b3a9e;
  border-bottom: 4px solid #5b3a9e;
  box-shadow: 0 2rpx 8rpx rgba(91, 58, 158, 0.4);
}

.bridge-v {
  width: 8px;
  background: #5b3a9e;
  border-radius: 4px;
  box-shadow: 0 2rpx 6rpx rgba(91, 58, 158, 0.5);
}

.bridge-v-2 {
  width: 14px;
  background: transparent;
  border-left: 4px solid #5b3a9e;
  border-right: 4px solid #5b3a9e;
  box-shadow: 0 2rpx 8rpx rgba(91, 58, 158, 0.4);
}

/* 岛屿 — 缩小为cellSize的70%，避免相邻岛重叠 */
.island {
  position: absolute;
  z-index: 2;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  background: white;
  border: 3px solid #5b3a9e;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
  transition: all 0.15s ease;
  /* 核心修复：岛屿尺寸缩小到cellSize的68%，留出间隙 */
  width: calc(var(--island-size, 46px) * 0.68) !important;
  height: calc(var(--island-size, 46px) * 0.68) !important;
  /* 居中偏移：向右下移动 (cellSize - islandSize)/2 */
  margin-left: calc(var(--island-size, 46px) * 0.16);
  margin-top: calc(var(--island-size, 46px) * 0.16);
}

.island.selected {
  border-color: #f5576c;
  box-shadow: 0 0 24rpx rgba(245, 87, 108, 0.6), 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
  transform: scale(1.08);
}

.island.satisfied {
  background: #e8f5e9;
  border-color: #43a047;
  box-shadow: 0 4rpx 16rpx rgba(67, 160, 71, 0.35);
}

.island-num {
  font-weight: bold;
  color: #333;
  font-size: 30rpx;
}

.island.satisfied .island-num {
  color: #2e7d32;
  font-weight: 900;
}

/* 完成提示 */
.complete-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.complete-card {
  background: white;
  padding: 60rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.complete-icon { font-size: 100rpx; }
.complete-text { font-size: 40rpx; font-weight: bold; color: #333; }
.complete-time { font-size: 32rpx; color: #666; }

.next-btn {
  margin-top: 20rpx;
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 20rpx;
  font-size: 32rpx;
  border: none;
}

/* 底部按钮 */
.footer {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 10rpx;
  flex-wrap: wrap;
  background: rgba(255,255,255,0.95);
  border-radius: 20rpx;
  margin-top: 16rpx;
}

.btn {
  padding: 18rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  flex: 1;
  min-width: 0;
}

.btn.reset { background: white; color: #666; }
.btn.next { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
.btn.verify { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; }
.btn.answer { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white; }

/* 跳转输入框 */
.jump-label {
  font-size: 26rpx;
  color: #666;
}

.jump-input-inline {
  width: 120rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  background: white;
  margin: 0 10rpx;
}

.btn-jump {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  background: linear-gradient(135deg, #11998e, #38ef7d);
  color: white;
  border-radius: 12rpx;
}

/* 规则说明 */
.rules {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rules-title { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 6rpx; }
.rules-text { font-size: 24rpx; color: #666; line-height: 1.5; }
