.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.difficulty-tabs {
  display: flex;
  gap: 10rpx;
}

.tab {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  transition: all 0.3s;
}

.tab.active {
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.tab-icon {
  font-size: 28rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #fff;
}

.tab.active .tab-text {
  color: #667eea;
}

.info {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.puzzle-idx {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.timer-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.timer-icon {
  font-size: 24rpx;
}

.timer {
  font-size: 24rpx;
  color: #fff;
}

.game-area {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.grid-shadow {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.grid-with-hints {
  display: flex;
  flex-direction: column;
}

.hints-row {
  display: flex;
}

.hint-corner {
  width: 40rpx;
}

.col-hint {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20rpx;
  color: #999;
}

.col-hint.has-value {
  color: #667eea;
  font-weight: bold;
}

.grid-row-with-hint {
  display: flex;
}

.row-hint {
  width: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20rpx;
  color: #999;
}

.row-hint.has-value {
  color: #667eea;
  font-weight: bold;
}

.row {
  display: flex;
}

.cell {
  border: 1rpx solid #ddd;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s;
  background: #fafafa;
}

.cell:active {
  transform: scale(0.95);
}

.cell.ship {
  background: linear-gradient(145deg, #4a90d9, #357abd);
}

.cell.water {
  background: linear-gradient(145deg, #a8d8ea, #87ceeb);
}

.ship-icon {
  font-size: 28rpx;
}

.water-icon {
  font-size: 24rpx;
}

.complete-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.complete-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 60rpx 80rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.complete-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.complete-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.complete-time {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
}

.next-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: inline-block;
}

.rules-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.rules-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 0;
  width: 90%;
  max-height: 80vh;
  overflow: hidden;
}

.rules-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
}

.rules-close {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
  font-size: 32rpx;
}

.rules-body {
  padding: 30rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.rule-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 12rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

.rule-icon.rule-num {
  background: #e3f2fd;
  color: #1976d2;
}

.rule-icon.rule-ship {
  background: #e3f2fd;
}

.rule-icon.rule-overlap {
  background: #ffebee;
  color: #c62828;
}

.rule-icon.rule-diag {
  background: #e8f5e9;
  color: #388e3c;
}

.rule-icon.rule-tap {
  background: #fff3e0;
  color: #f57c00;
}

.rule-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.hl-num {
  color: #1976d2;
  font-weight: bold;
}

.hl-ship {
  color: #1565c0;
  font-weight: bold;
}

.hl-overlap {
  color: #c62828;
  font-weight: bold;
}

.hl-diag {
  color: #388e3c;
  font-weight: bold;
}

.rule-divider {
  height: 1rpx;
  background: #eee;
  margin: 20rpx 0;
}

.rules-footer {
  padding: 20rpx 30rpx 30rpx;
}

.rules-ok-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 24rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.footer {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.btn {
  background: rgba(255, 255, 255, 0.9);
  padding: 10rpx 16rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  white-space: nowrap;
  flex-shrink: 0;
}

.btn.next {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.nav-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.puzzle-info {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.jump-input {
  width: 70rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 10rpx;
  text-align: center;
  font-size: 22rpx;
}

.btn-jump {
  background: rgba(255, 255, 255, 0.9);
  padding: 10rpx 16rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  color: #667eea;
  font-weight: bold;
  white-space: nowrap;
}