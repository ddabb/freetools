/**packages/math/pages/prime-factorization/prime-factorization.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* 输入区域 */
.input-section {
  margin-bottom: 24rpx;
}

.input-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.input-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.input-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.input-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.input-wrapper {
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: #11998e;
  background: white;
  box-shadow: 0 0 0 6rpx rgba(17, 153, 142, 0.1);
}

.number-input {
  width: 100%;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  padding: 28rpx 0;
  border: none;
  outline: none;
  background: transparent;
}

.number-input::placeholder {
  color: #aaa;
  font-weight: 400;
}

.input-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
}

/* 结果卡片 */
.result-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  animation: fadeIn 0.4s ease-out;
}

.result-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.result-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 因子展示 */
.factor-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.original-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #11998e;
}

.equals {
  font-size: 36rpx;
  font-weight: 600;
  color: #666;
}

.factor-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
}

.factor-chip {
  padding: 12rpx 20rpx;
  background: rgba(17, 153, 142, 0.1);
  border-radius: 12rpx;
  border: 2rpx solid rgba(17, 153, 142, 0.3);
}

.factor-chip.prime {
  background: linear-gradient(135deg, #11998e, #38ef7d);
}

.factor-chip.prime .chip-text {
  color: white;
  font-weight: 700;
}

.chip-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #11998e;
}

.multiply {
  font-size: 28rpx;
  color: #666;
  margin: 0 6rpx;
}

/* 质数提示 */
.prime-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.hint-icon {
  font-size: 28rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #92400e;
  font-weight: 600;
}

/* 分解步骤 */
.steps-section {
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.steps-header {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.steps-scroll {
  max-height: 300rpx;
}

.step-item {
  padding: 12rpx 0;
  padding-left: 20rpx;
  border-left: 3rpx solid #38ef7d;
  margin-bottom: 8rpx;
}

.step-text {
  font-size: 24rpx;
  color: #555;
  line-height: 1.5;
}

/* 示例卡片 */
.examples-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.examples-header {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.examples-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.example-btn {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.example-btn-hover {
  background: linear-gradient(135deg, #11998e, #38ef7d);
  transform: scale(0.96);
}

.example-btn-hover .example-text {
  color: white;
}

.example-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #11998e;
}

/* 引导区域 */
.guide-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.guide-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
}

.guide-header {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.guide-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.guide-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.guide-example {
  font-size: 28rpx;
  color: #11998e;
  font-weight: 600;
  font-family: 'Monaco', monospace;
  padding: 16rpx 20rpx;
  background: rgba(17, 153, 142, 0.1);
  border-radius: 10rpx;
  border-left: 4rpx solid #11998e;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式 */
@media (max-width: 375px) {
  .examples-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .factor-display {
    padding: 24rpx;
  }

  .original-num {
    font-size: 40rpx;
  }

  .chip-text {
    font-size: 28rpx;
  }
}
