/**packages/math/pages/prime-factorization/prime-factorization.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
}

/* 表单区域样式 */
.form-container {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-right: 10rpx;
}

.required-mark {
  color: #ff4757;
  font-size: 28rpx;
}

/* 输入框样式 */
.input-with-unit {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-with-unit:focus-within {
  border-color: #11998e;
  background: white;
  box-shadow: 0 0 0 6rpx rgba(17, 153, 142, 0.1);
}

.input-field {
  flex: 1;
  font-size: 34rpx;
  border: none;
  outline: none;
  color: #333;
  font-weight: 500;
  background: transparent;
  padding: 28rpx 0;
}

.input-field::placeholder {
  color: #999;
}

.input-hint {
  font-size: 24rpx;
  color: #888;
  margin-top: 10rpx;
  margin-left: 10rpx;
}

/* 按钮样式 */
.btn-item {
  margin-top: 50rpx;
  margin-bottom: 0;
}

.calculate-btn {
  width: 100%;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 32rpx;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 15rpx 40rpx rgba(17, 153, 142, 0.4);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.calculate-btn:not(.disabled):active {
  transform: translateY(-2rpx) scale(1.02);
  box-shadow: 0 20rpx 50rpx rgba(17, 153, 142, 0.5);
}

.calculate-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

.full-width-btn {
  width: 100%;
}

.btn-text {
  color: inherit;
  font-size: inherit;
  font-weight: inherit;
}

/* 结果展示样式 */
.result-section {
  margin-bottom: 40rpx;
  animation: fadeInScale 0.6s ease-out;
}

.result-box {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
}

.result-item {
  text-align: center;
  margin-bottom: 30rpx;
}

.result-item.highlight {
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
  border-radius: 20rpx;
  padding: 50rpx 30rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid rgba(56, 239, 125, 0.2);
}

.result-label {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 40rpx;
}

/* 因子树样式 */
.factor-tree {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.original-number {
  font-size: 48rpx;
  font-weight: 800;
  color: #11998e;
  background: rgba(17, 153, 142, 0.1);
  padding: 20rpx 30rpx;
  border-radius: 15rpx;
  border: 2rpx solid rgba(17, 153, 142, 0.3);
}

.equals-sign {
  font-size: 40rpx;
  font-weight: 800;
  color: #666;
}

.factors-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  max-width: 100%;
  padding: 10rpx;
}

.factor-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 5rpx;
  flex-shrink: 0;
  gap: 15rpx;
}

.factor-item.first {
  /* 第一个元素不需要特殊样式 */
}

.factor-item.prime .prime-number {
  background: linear-gradient(135deg, #11998e, #38ef7d);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 800;
}

.prime-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #11998e;
  padding: 12rpx 18rpx;
  background: rgba(17, 153, 142, 0.1);
  border-radius: 12rpx;
  border: 2rpx solid rgba(17, 153, 142, 0.3);
  display: inline-block;
  min-width: 60rpx;
  text-align: center;
  box-sizing: border-box;
  line-height: 1.2;
}

.factor-item text {
  display: inline-block;
  font-size: 36rpx;
  font-weight: 700;
  color: #11998e;
  padding: 12rpx 18rpx;
  background: rgba(17, 153, 142, 0.1);
  border-radius: 12rpx;
  border: 2rpx solid rgba(17, 153, 142, 0.3);
  min-width: 60rpx;
  text-align: center;
  box-sizing: border-box;
  line-height: 1.2;
}

.multiply-sign {
  font-size: 32rpx;
  font-weight: 600;
  color: #666;
  margin: 0 15rpx;
  padding: 0 5rpx;
}

.result-divider {
  width: 100%;
  height: 2rpx;
  background: linear-gradient(to right, transparent, #ddd, transparent);
  margin: 30rpx 0;
}

/* 计算步骤 */
.calculation-steps {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.steps-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.step-text {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 10rpx;
  padding-left: 20rpx;
  position: relative;
}

.step-text:before {
  content: "→";
  position: absolute;
  left: 0;
  color: #11998e;
  font-weight: bold;
}

/* 滚动区域样式 */
.steps-scroll {
  max-height: 400rpx;
  padding-right: 10rpx;
  margin-top: 10rpx;
}

.steps-scroll::-webkit-scrollbar {
  width: 6rpx;
}

.steps-scroll::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 3rpx;
}

.steps-scroll::-webkit-scrollbar-thumb {
  background: #11998e;
  border-radius: 3rpx;
}

.steps-scroll::-webkit-scrollbar-thumb:hover {
  background: #38ef7d;
}

/* 质数提示 */
.prime-notice {
  text-align: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-radius: 15rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.3);
}

.notice-text {
  font-size: 28rpx;
  color: #92400e;
  font-weight: 600;
}

/* 信息科普区域 */
.info-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
  animation: fadeInUp 0.6s ease-out;
}

.info-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.info-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

.info-example {
  font-size: 26rpx;
  color: #11998e;
  font-weight: 600;
  font-family: 'Monaco', 'Menlo', monospace;
  background: rgba(17, 153, 142, 0.1);
  padding: 15rpx 20rpx;
  border-radius: 10rpx;
  border-left: 4rpx solid #11998e;
}

/* 示例区域 */
.examples-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
  animation: fadeInUp 0.6s ease-out;
}

.examples-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.examples-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.example-item {
  background: linear-gradient(135deg, #f8f9fa, #e9ecef);
  border-radius: 15rpx;
  padding: 24rpx;
  text-align: center;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.example-item:active {
  background: linear-gradient(135deg, #11998e, #38ef7d);
  transform: scale(0.95);
}

.example-item:active .example-text {
  color: white;
}

.example-text {
  font-size: 28rpx;
  color: #11998e;
  font-weight: 600;
}

/* 动画效果 */
@keyframes fadeInScale {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}