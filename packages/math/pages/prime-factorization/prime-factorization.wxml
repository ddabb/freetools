<view class="container">
  <!-- 输入区域 -->
  <view class="input-section">
    <view class="input-card">
      <view class="input-header">
        <text class="input-icon">🔢</text>
        <text class="input-title">质因数分解</text>
      </view>
      <view class="input-wrapper">
        <input
          type="number"
          value="{{number}}"
          bindinput="onInputChange"
          class="number-input"
          placeholder="输入数字"
          maxlength="12"
          confirm-type="done"
         placeholder-class="input-placeholder"/>
      </view>
      <view class="input-hint">支持 2 ~ 999,999,999,999</view>
    </view>
  </view>

  <!-- 结果展示 -->
  <view class="result-section" wx:if="{{showResult && number >= 2}}">
    <!-- 分解结果 -->
    <view class="result-card">
      <view class="result-header">
        <text class="result-icon">✨</text>
        <text class="result-title">分解结果</text>
      </view>

      <view class="factor-display">
        <view class="original-num">{{number}}</view>
        <text class="equals">=</text>
        <view class="factor-list">
          <block wx:for="{{factors}}" wx:key="index">
            <view class="factor-chip {{item.isPrime ? 'prime' : ''}}">
              <text class="chip-text">{{item.value}}</text>
            </view>
            <text class="multiply" wx:if="{{index < factors.length - 1}}">×</text>
          </block>
        </view>
      </view>

      <!-- 质数提示 -->
      <view class="prime-hint" wx:if="{{isPrime}}">
        <text class="hint-icon">🎉</text>
        <text class="hint-text">{{number}} 本身就是质数，无需分解</text>
      </view>

      <!-- 分解步骤 -->
      <view class="steps-section" wx:if="{{steps.length > 1}}">
        <view class="steps-header">分解过程</view>
        <scroll-view class="steps-scroll" scroll-y>
          <view class="step-item" wx:for="{{steps}}" wx:key="index">
            <text class="step-text">{{item}}</text>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 快捷示例 -->
    <view class="examples-card">
      <view class="examples-header">快速示例</view>
      <view class="examples-grid">
        <view class="example-btn" hover-class="example-btn-hover" wx:for="{{examples}}" wx:key="index" bindtap="useExample" data-number="{{item.number}}">
          <text class="example-text">{{item.number}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 无结果时的示例引导 -->
  <view class="guide-section" wx:if="{{!showResult || number < 2}}">
    <view class="guide-card">
      <view class="guide-header">💡 什么是质因数分解？</view>
      <view class="guide-content">
        <text class="guide-text">把一个合数分解成若干个质数相乘的形式</text>
        <view class="guide-example">例如：12 = 2 × 2 × 3</view>
      </view>
    </view>

    <view class="examples-card">
      <view class="examples-header">快速示例</view>
      <view class="examples-grid">
        <view class="example-btn" hover-class="example-btn-hover" wx:for="{{examples}}" wx:key="index" bindtap="useExample" data-number="{{item.number}}">
          <text class="example-text">{{item.number}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
