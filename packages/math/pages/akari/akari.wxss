/* 灯塔游戏样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  padding: 12rpx;
  box-sizing: border-box;
}

/* 顶部信息栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.difficulty-tabs {
  display: flex;
  gap: 20rpx;
}

.tab {
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  font-weight: bold;
}

.info {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.timer {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.light-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #f5576c;
  background: #fff;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

/* 游戏区域 */
.game-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 10rpx 0;
  flex: 0 0 auto;
}

/* 棋盘自适应屏幕 */
.grid {
  max-width: calc(100vw - 40rpx);
  overflow: auto;
}

.grid {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
}

.row {
  display: flex;
}

.cell {
  box-sizing: border-box;
  border: 1px solid #e0e0e0;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.cell.white {
  background: #fff;
  cursor: pointer;
}

.cell.white:active {
  background: #f0f0f0;
}

.cell.white.lit {
  background: #fff3cd;
}

.cell.white.answer-light {
  background: #e3f2fd !important;
}

.cell.white.answer-light .light-icon {
  color: #1976d2;
}

.cell.white.light {
  background: #ffe066;
}

.cell.black {
  background: #333;
  border-color: #333;
}

.black-num {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
}

.light-icon {
  font-size: 48rpx;
  transition: transform 0.2s;
}

/* 完成提示 */
.complete-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.complete-card {
  background: white;
  padding: 60rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.complete-icon {
  font-size: 100rpx;
}

.complete-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.complete-time {
  font-size: 32rpx;
  color: #666;
}

.next-btn {
  margin-top: 20rpx;
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  border-radius: 20rpx;
  font-size: 32rpx;
  border: none;
}

/* 底部按钮 */
.footer {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 10rpx;
  flex-wrap: wrap;
  background: rgba(255,255,255,0.95);
  border-radius: 20rpx;
  margin-top: 16rpx;
}

.btn {
  padding: 18rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  flex: 1;
  min-width: 0;
}

.btn.reset {
  background: white;
  color: #666;
}

.btn.next {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.btn.active {
  background: #ff6b6b;
  color: white;
}

.btn.verify {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
}

.btn.answer {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn.jump {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: white;
}

/* 跳转输入框 */
.jump-label {
  font-size: 26rpx;
  color: #666;
}

.jump-input-inline {
  width: 120rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  background: white;
  margin: 0 10rpx;
}

.btn-jump {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  background: linear-gradient(135deg, #11998e, #38ef7d);
  color: white;
  border-radius: 12rpx;
}

.btn.jump {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: white;
}

/* 规则说明 */
.rules {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rules-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.rules-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}
