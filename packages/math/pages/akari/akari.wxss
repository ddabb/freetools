/* 灯塔游戏样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  padding: 20rpx;
  box-sizing: border-box;
}

/* 顶部信息栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.difficulty-tabs {
  display: flex;
  gap: 20rpx;
}

.tab {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  font-weight: bold;
}

.info {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.timer {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 游戏区域 */
.game-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.grid {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
}

.row {
  display: flex;
}

.cell {
  box-sizing: border-box;
  border: 1px solid #e0e0e0;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s;
}

.cell.white {
  background: #fff;
  cursor: pointer;
}

.cell.white:active {
  background: #f0f0f0;
}

.cell.white.lit {
  background: #fff9e6;
}

.cell.white.light {
  background: #ffe066;
}

.cell.black {
  background: #333;
  border-color: #333;
}

.black-num {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
}

.light-icon {
  font-size: 48rpx;
}

/* 完成提示 */
.complete-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.complete-card {
  background: white;
  padding: 60rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.complete-icon {
  font-size: 100rpx;
}

.complete-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.complete-time {
  font-size: 32rpx;
  color: #666;
}

.next-btn {
  margin-top: 20rpx;
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  border-radius: 20rpx;
  font-size: 32rpx;
  border: none;
}

/* 底部按钮 */
.footer {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  padding: 20rpx;
}

.btn {
  padding: 20rpx 60rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.btn.reset {
  background: white;
  color: #666;
}

.btn.next {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

/* 规则说明 */
.rules {
  margin-top: 30rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.rules-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
