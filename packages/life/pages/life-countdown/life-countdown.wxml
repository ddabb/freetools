<!--packages/life/pages/life-countdown/life-countdown.wxml-->
<view class="container">
  <!-- 头部介绍 -->
  <view class="header">
    <text class="header-title">人生A4纸</text>
    <text class="header-subtitle">900个格子，见证生命的成长~</text>
  </view>

  <!-- 基本信息 -->
  <view class="combined-section">
    <view class="input-row">
      <view class="input-box date-input">
        <text class="section-title-small">出生日期</text>
        <picker mode="date" value="{{birthDate}}" start="1900-01-01" end="{{currentYear}}-12-31" bindchange="setBirthDate" class="picker">
          <view class="picker-view {{birthDate ? 'has-value' : ''}}">
            {{birthDate || '点击选择'}}
          </view>
        </picker>
      </view>
      
      <view class="input-box age-input">
        <text class="section-title-small">预期寿命（岁）</text>
        <input type="number" value="{{expectedLifeYears}}" bindinput="setExpectedLifeYears" class="input" placeholder="75"/>
      </view>
    </view>
  </view>

  <!-- 计算按钮 -->
  <view class="section">
    <button class="calculate-btn {{!birthDate ? 'disabled' : ''}}" bindtap="calculate" disabled="{{!birthDate}}">
      绘制A4纸
    </button>
  </view>

  <!-- 结果展示 -->
  <view class="section result-section" wx:if="{{showResult}}">
    <!-- 统计信息 -->
    <view class="stats-container">
      <view class="stat-item">
        <text class="stat-number">{{daysLived || 0}}</text>
        <text class="stat-label">已活天数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{lifeLeft || 0}}</text>
        <text class="stat-label">剩余天数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number highlight">{{progress || 0}}%</text>
        <text class="stat-label">人生进度</text>
      </view>
    </view>

    <!-- 900个格子可视化 -->
    <view class="grid-section">
      <view class="grid-title">
        <text>人生A4纸（共{{totalGrids}}格，{{gridRows}}×{{gridCols}}）</text>
        <text class="grid-percentage">已填充 {{gridPercentage || 0}}%（{{livedGrids || 0}}/{{totalGrids}}）</text>
      </view>
      <view class="grid-container">
        <scroll-view class="grid-scroll" scroll-x="false" scroll-y="true" enhanced="true" bounces="true" scroll-top="0">
          <view class="grid-wrapper">
            <view class="grid-row" wx:for="{{rowsArray}}" wx:key="row-{{index}}" wx:for-index="rowIndex">
              <view class="grid-cell {{rowIndex * gridCols + colIndex < livedGrids - 1 ? 'lived' : ''}} {{rowIndex * gridCols + colIndex == livedGrids - 1 && livedGrids > 0 && progress < 100 ? 'current' : ''}}" 
                    wx:for="{{colsArray}}" 
                    wx:key="cell-{{rowIndex}}-{{colIndex}}" 
                    wx:for-item="colIndex"
                    data-index="{{rowIndex * gridCols + colIndex}}"
                    bindtap="onGridTap">
              </view>
            </view>
          </view>
        </scroll-view>
      </view>
      <view class="grid-legend">
        <view class="legend-item">
          <view class="legend-color lived"></view>
          <text>已度过的时光</text>
        </view>
        <view class="legend-item">
          <view class="legend-color current"></view>
          <text>正在经历</text>
        </view>
        <view class="legend-item">
          <view class="legend-color future"></view>
          <text>未来可期</text>
        </view>
      </view>
      <view class="grid-info">
        <text>💡 每格 ≈ {{daysPerGridText}}，拖动可查看全部格子</text>
      </view>
    </view>

    <!-- 人生思考引导 -->
    <view class="reflection-section">
      <view class="reflection-header">
        <view class="banner-arrow left" bindtap="prevQuestion">
          <text>‹</text>
        </view>
        <text class="reflection-title">🤔 人生思考</text>
        <view class="banner-indicator">
          <view wx:for="{{questions}}" wx:key="index" class="indicator-dot {{currentIndex === index ? 'active' : ''}}"></view>
        </view>
        <view class="banner-arrow right" bindtap="nextQuestion">
          <text>›</text>
        </view>
      </view>
      <view class="question-card" style="animation: fadeInScale 0.8s ease-out;">
        <text class="question-text">{{questions[currentIndex].text}}</text>
      </view>
      <view class="reflection-hint">
        <text>静下心来，认真思考这个问题。生命有限，别让时光在无意识中溜走。</text>
      </view>
    </view>

    <!-- 重置按钮 -->
    <view class="reset-section">
      <button class="reset-btn" bindtap="reset">重新计算</button>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip" wx:if="{{!showResult}}">
    <text>💡 每个格子约等于2.67小时，900格代表约75年的人生</text>
  </view>

  <!-- 分享按钮 -->
  <view class="share-section" wx:if="{{showResult}}">
    <button class="share-btn" bindtap="MakePosters">
      分享人生A4纸
    </button>
  </view>

  <!-- 隐藏的Canvas用于生成分享图片 -->
  <canvas id="cvs1" canvas-id="cvs1" type="2d" style="width: {{canvaswidth}}px; height: {{canvasheight}}px; position: absolute; left: -9999px; top: -9999px;"></canvas>
</view>