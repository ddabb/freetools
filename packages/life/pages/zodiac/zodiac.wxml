<!-- 查询区域 -->
<view class="query-section">
  <view class="input-group">
    <view class="input-label">年份：</view>
    <input type="number" class="year-input" id="yearInput" value="{{year}}" bindinput="onYearInput" bindblur="onQuery" placeholder="请输入年份"  placeholder-class="input-placeholder"/>
  </view>
</view>

<!-- 结果区域 -->
<view class="result-section">
  <view class="zodiac-circle">
    <view class="zodiac-icon">
      <text class="icon">{{zodiacIcon}}</text>
    </view>
    <view class="zodiac-name">{{zodiacName}}</view>
  </view>
  <view class="birth-year">{{birthYearInfo}}</view>
  <view class="link-row">
    <view class="link-btn" hover-class="link-btn-hover" bindtap="goToCalendar">
      <text>万年历</text>
    </view>
    <view class="link-btn" hover-class="link-btn-hover" bindtap="goToConstellation">
      <text>星座</text>
    </view>
  </view>
  
  <!-- 生肖列表（支持左右滑动） -->
  <view class="zodiac-scroll">
    <view class="list-title">
      <text>十二生肖</text>
      <text class="swipe-hint">左右滑动切换</text>
    </view>
    <scroll-view scroll-x="true" class="zodiac-scroll-view">
      <view class="zodiac-scroll-content">
        <view wx:for="{{zodiacScrollItems}}" wx:key="index" class="zodiac-scroll-item {{item.name == zodiacName ? 'active' : ''}}" data-index="{{index}}" bindtap="onZodiacScrollItemClick">
          <view class="zodiac-item-icon" hover-class="zodiac-item-hover">
            <text class="icon">{{item.icon}}</text>
          </view>
          <view class="zodiac-item-details" hover-class="zodiac-item-hover">
            <view class="zodiac-item-name" hover-class="zodiac-item-hover">{{item.name}}</view>
            <view class="zodiac-item-year" hover-class="zodiac-item-hover">{{item.year}}年</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

<!-- 生肖列表 -->
<view class="zodiac-list">
  <view class="list-title">其他生肖年龄</view>
  
  <view wx:for="{{zodiacItems}}" wx:key="index" class="zodiac-item {{item.year == year ? 'active' : ''}}" hover-class="zodiac-item-hover" data-year="{{item.year}}" bindtap="onZodiacItemClick">
    <view class="zodiac-item-icon" hover-class="zodiac-item-hover">
      <text class="icon">{{item.icon}}</text>
    </view>
    <view class="zodiac-item-details" hover-class="zodiac-item-hover">
      <view class="zodiac-item-name" hover-class="zodiac-item-hover">{{item.name}}</view>
      <view class="zodiac-item-year" hover-class="zodiac-item-hover">出生于{{item.year}}</view>
    </view>
    <view class="zodiac-item-age" hover-class="zodiac-item-hover">{{item.age}}岁</view>
  </view>
  <!-- 搴曢儴骞垮憡 -->
  <ad unit-id="adunit-07e9c9da9e4b8254" ad-intervals="30" binderror="onAdError" bindclose="onAdClose"></ad>
</view>

