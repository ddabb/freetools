/* packages/life/pages/poison-soup/poison-soup.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 头部 */
.header {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #ffd700;
  text-shadow: 0 2rpx 20rpx rgba(255, 215, 0, 0.4);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 10rpx;
}

/* 鸡汤卡片 */
.soup-card {
  background: linear-gradient(145deg, #2a2a4a, #1a1a3a);
  border-radius: 40rpx;
  padding: 50rpx 35rpx;
  margin: 0 5rpx 35rpx;
  box-shadow:
    0 20rpx 60rpx rgba(0, 0, 0, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 215, 0, 0.2);
  position: relative;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.soup-card:active {
  transform: scale(0.98);
}

.soup-card.shake {
  animation: shake 0.4s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: translateX(0) rotate(0); }
  15% { transform: translateX(-8rpx) rotate(-2deg); }
  30% { transform: translateX(8rpx) rotate(2deg); }
  45% { transform: translateX(-6rpx) rotate(-1.5deg); }
  60% { transform: translateX(6rpx) rotate(1.5deg); }
  75% { transform: translateX(-3rpx) rotate(-1deg); }
  90% { transform: translateX(3rpx) rotate(1deg); }
}

.soup-icon-wrapper {
  text-align: center;
  margin-bottom: 30rpx;
}

.soup-icon {
  font-size: 100rpx;
  display: inline-block;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.soup-text {
  display: block;
  font-size: 36rpx;
  color: #fff;
  line-height: 1.9;
  text-align: center;
  min-height: 150rpx;
  letter-spacing: 1rpx;
}

.soup-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.soup-hint text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.daily-badge {
  background: linear-gradient(135deg, #ffd700, #ff8c00);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.daily-badge text {
  font-size: 22rpx;
  color: #1a1a2e;
  font-weight: bold;
}

/* 统计区域 */
.stats-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 25rpx;
  padding: 30rpx 20rpx;
  margin: 0 5rpx 35rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #ffd700;
  text-shadow: 0 2rpx 10rpx rgba(255, 215, 0, 0.3);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.15);
}

/* 操作按钮 */
.action-section {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin: 0 5rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 25rpx 15rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  min-height: 130rpx;
}

.action-btn:active {
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0.96);
}

.action-btn.primary {
  background: linear-gradient(145deg, #ffd700, #ff8c00);
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(255, 140, 0, 0.3);
}

.action-btn.primary .action-icon,
.action-btn.primary .action-text {
  color: #1a1a2e;
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 24rpx;
  color: #fff;
}

/* 分享弹窗 */
.share-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.share-content {
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  width: 100%;
  padding: 40rpx 30rpx 60rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.share-title {
  text-align: center;
  font-size: 34rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 40rpx;
}

.share-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  background: #f8f8f8;
}

.share-item:active {
  background: #eee;
}

.share-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.share-text {
  font-size: 30rpx;
  color: #333;
}

.share-cancel {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 30rpx;
  margin-top: 20rpx;
}
