<view class="container">
  <!-- 加载状态 -->
  <view class="status-section" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="status-section error" wx:if="{{error}}" bindtap="onRetry">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
  </view>

  <!-- 内容区域 -->
  <view class="content-section" wx:if="{{!loading}}">
    <!-- 最新版本 -->
    <view class="latest-section">
      <view class="latest-card">
        <view class="card-header">
          <view class="latest-info">
            <view class="latest-label">当前版本</view>
            <view class="version-row">
              <text class="version-tag">{{currentVersion}}</text>
            </view>
          </view>
          <view class="export-section">
            <button class="export-btn" hover-class="export-btn-hover" bindtap="onExportExcel" loading="{{exporting}}">
              <text class="export-icon">📊</text>
              <text class="export-text">{{exporting ? '导出中...' : '导出Excel'}}</text>
            </button>
          </view>
        </view>
      </view>
    </view>

    <!-- 版本历史 -->
    <view class="history-section" wx:if="{{!error && changelog}}">
      <view class="section-header">
        <text class="section-title">更新历史</text>
      </view>
      <view class="timeline">
        <view class="timeline-item" wx:for="{{changelog.changelog}}" wx:key="version">
          <view class="timeline-dot {{item.type}}"></view>
          <view class="timeline-content">
            <view class="timeline-header">
              <text class="timeline-version">v{{item.version}}</text>
              <text class="timeline-date">{{item.date}}</text>
              <text class="timeline-type {{item.type}}">{{item.type === 'feature' ? '✨ 新功能' : item.type === 'fix' ? '🐛 修复' : '📦 其他'}}</text>
            </view>
            <text class="timeline-title">{{item.title}}</text>
            <view class="timeline-changes">
              <text class="change-item" wx:for="{{item.changes}}" wx:for-item="change" wx:key="*this">• {{change}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
