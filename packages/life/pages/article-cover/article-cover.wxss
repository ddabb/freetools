.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 预览区域 */
.preview-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.preview-wrapper {
  width: 100%;
  height: 240rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  color: #999;
  font-size: 28rpx;
}

.preview-hint {
  display: block;
  text-align: center;
  color: #666;
  font-size: 24rpx;
  margin-top: 16rpx;
}

/* 输入区域 */
.input-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}

.textarea.small {
  min-height: 80rpx;
}

.textarea:focus {
  border-color: #1890ff;
}

.textarea-placeholder {
  color: #6b7280;
}

.input-placeholder {
  color: #6b7280;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}

.input:focus {
  border-color: #1890ff;
}

.count {
  display: block;
  text-align: right;
  color: #666;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 样式选择 */
.style-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.style-scroll {
  width: 100%;
  white-space: nowrap;
}

.style-list {
  display: inline-flex;
  gap: 20rpx;
}

.style-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.style-preview {
  width: 120rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: border-color 0.3s;
}

.style-item.active .style-preview {
  border-color: #1890ff;
}

.style-name {
  font-size: 22rpx;
  font-weight: bold;
}

.style-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 操作按钮 */
.action-section {
  padding: 20rpx 0;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1890ff, #0066cc);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary-hover {
  opacity: 0.9;
}
