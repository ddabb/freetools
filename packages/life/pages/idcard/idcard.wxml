<!--packages/utility/pages/idcard/idcard.wxml-->
<view class="page-container">
  <!-- 顶部装饰 -->
  <view class="header-bg">
    <view class="header-content">
      <view class="icon-wrapper">
        <text class="main-icon">🆔</text>
      </view>
      <text class="main-title">身份证验证</text>
      <text class="subtitle">快速验证身份证格式与信息</text>
    </view>
  </view>

  <view class="content-wrapper">
    <!-- 输入卡片 -->
    <view class="input-card card-shadow fade-in-up">
      <view class="card-header">
        <view class="card-icon">✏️</view>
        <text class="card-title">输入身份证号码</text>
      </view>
      
      <view class="card-body">
        <view class="input-section">
          <view class="input-wrapper">
            <text class="input-label">身份证号码</text>
            <view class="input-container">
              <input
                type="idcard"
                value="{{idcard}}"
                bindinput="onIdcardInput"
                class="modern-input"
                placeholder="请输入18位身份证号码"
                maxlength="18"
                focus="{{inputFocus}}"
              />
              <view class="input-status {{idcard.length > 0 ? (idcard.length === 18 ? 'valid' : 'typing') : ''}}">
                <text class="status-dot"></text>
              </view>
            </view>
          </view>
          
          <!-- 隐私声明 -->
          <view class="privacy-section">
            <text class="privacy-title">🔒 隐私声明</text>
            <text class="privacy-text">本工具仅在本地验证身份证格式，</text>
            <text class="privacy-text">不采集、不存储任何用户数据，</text>
            <text class="privacy-text">无后台存储功能，请放心使用。</text>
          </view>
        </view>

        <!-- 操作按钮组 -->
        <view class="action-section">
          <button 
            class="primary-btn {{idcard.length >= 18 ? 'ready' : ''}}" 
            bindtap="validate"
            disabled="{{!idcard || idcard.length < 18}}"
            hover-class="btn-primary-hover"
          >
            <text class="btn-icon">🔍</text>
            <text class="btn-text">立即验证</text>
            <view class="btn-shine" wx:if="{{idcard.length >= 18}}"></view>
          </button>
          
          <button 
            class="secondary-btn" 
            bindtap="clearInput"
            wx:if="{{idcard}}"
            hover-class="btn-secondary-hover"
          >
            <text class="btn-icon">🗑️</text>
            <text class="btn-text">清空</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-card card-shadow" wx:if="{{loading}}">
      <view class="loading-content">
        <view class="loading-spinner"></view>
        <text class="loading-text">正在验证中...</text>
      </view>
    </view>

    <!-- 结果卡片 -->
    <view wx:if="{{showResult}}" class="result-card card-shadow fade-in-up {{result.valid ? 'success-card' : 'error-card'}}" style="animation-delay: 0.2s">
      <!-- 成功结果 -->
      <view wx:if="{{result.valid}}" class="success-result">
        <view class="result-header">
          <view class="success-icon">✅</view>
          <text class="result-title">验证通过</text>
          <view class="success-badge">有效身份证</view>
        </view>
        
        <view class="result-body">
          <view class="info-grid">
            <view class="info-item">
              <view class="info-icon">👤</view>
              <view class="info-content">
                <text class="info-label">性别</text>
                <text class="info-value highlight">{{result.gender}}</text>
              </view>
            </view>
            
            <view class="info-item">
              <view class="info-icon">🎂</view>
              <view class="info-content">
                <text class="info-label">年龄</text>
                <text class="info-value highlight">{{result.age}}岁</text>
              </view>
            </view>
            
            <view class="info-item">
              <view class="info-icon">📅</view>
              <view class="info-content">
                <text class="info-label">出生日期</text>
                <text class="info-value">{{result.birthday}}</text>
              </view>
            </view>
            
            <view class="info-item">
              <view class="info-icon">📍</view>
              <view class="info-content">
                <text class="info-label">签发地点</text>
                <text class="info-value">{{result.sign}}</text>
              </view>
            </view>
          </view>
        </view>
        
        <view class="result-actions">
          <button class="action-btn copy-btn" bindtap="copyResult" hover-class="btn-action-hover">
            <text class="btn-icon">📋</text>
            <text>复制信息</text>
          </button>
        </view>
      </view>

      <!-- 错误结果 -->
      <view wx:else class="error-result">
        <view class="result-header">
          <view class="error-icon">❌</view>
          <text class="result-title">验证失败</text>
          <view class="error-badge">格式错误</view>
        </view>
        
        <view class="error-content">
          <text class="error-message">{{result.message}}</text>
          <view class="error-help">
            <text class="help-icon">💡</text>
            <text class="help-text">请检查身份证号码格式是否正确</text>
          </view>
        </view>
        
        <view class="result-actions">
          <button class="action-btn retry-btn" bindtap="retryValidation" hover-class="btn-action-hover">
            <text class="btn-icon">🔄</text>
            <text>重新验证</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 使用提示 -->
    <view class="tips-card card-shadow fade-in-up" style="animation-delay: 0.4s">
      <view class="tips-header">
        <view class="tips-icon">ℹ️</view>
        <text class="tips-title">温馨提示</text>
      </view>
      <view class="tips-content">
        <text class="tips-text">
          本工具仅用于验证身份证号码格式是否正确，不涉及个人信息查询。
          请确保输入的信息仅用于合法用途。
        </text>
      </view>
    </view>
  </view>
</view>