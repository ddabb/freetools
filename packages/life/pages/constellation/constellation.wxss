/* 全局样式 */
page {
  color: #333;
  line-height: 1.5;
  min-height: 100vh;
  background-color: #f8f9fc;
}

/* 查询区域 */
.query-section {
  padding: 25px 20px 20px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-bottom: 1px solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 10px rgba(102, 126, 234, 0.3);
}

.input-group {
  display: flex;
  margin-bottom: 8px;
}

.date-picker-display {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: white;
  border-radius: 8px;
  padding: 16px 20px;
}

.date-text {
  font-size: 22px;
  font-weight: 600;
  color: #333;
}

.date-arrow {
  font-size: 14px;
  color: #999;
}

.query-btn {
  background: linear-gradient(135deg, #ffd700, #ffb800);
  color: #333;
  border: none;
  border-radius: 0 8px 8px 0;
  padding: 0 25px;
  font-size: 18px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s;
}

.query-btn:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #ffb800, #ffa500);
}

.input-hint {
  color: rgba(255, 255, 255, 0.9);
  font-size: 14px;
  margin-top: 8px;
  padding-left: 5px;
}

/* 结果区域 */
.result-section {
  padding: 30px 20px;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  animation: fadeIn 0.5s ease-out;
}

.constellation-circle {
  width: 160px;
  height: 160px;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.1));
  border-radius: 50%;
  margin: 0 auto 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  border: 3px solid rgba(255, 255, 255, 0.3);
}

.constellation-icon {
  font-size: 60px;
  margin-bottom: 5px;
}

.constellation-name {
  font-size: 26px;
  font-weight: 700;
  color: white;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
}

.constellation-date {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 5px;
}

.link-row {
  display: flex;
  justify-content: center;
  gap: 15px;
  margin-top: 20px;
}

.link-btn {
  padding: 8px 20px;
  background: rgba(255, 255, 255, 0.2);
  color: white;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 500;
  border: 1px solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s;
}

.link-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

/* 星座详情 */
.detail-section {
  padding: 20px 15px;
  background-color: white;
}

.detail-title {
  font-size: 20px;
  font-weight: 700;
  color: #333;
  margin-bottom: 20px;
  padding-left: 10px;
  border-left: 4px solid #667eea;
}

.detail-card {
  background: linear-gradient(145deg, #f8f9fc, #fff);
  border-radius: 12px;
  padding: 18px;
  margin-bottom: 15px;
  box-shadow: 0 3px 12px rgba(0, 0, 0, 0.08);
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.detail-icon {
  font-size: 22px;
  margin-right: 10px;
}

.detail-label {
  font-size: 17px;
  font-weight: 600;
  color: #667eea;
}

.detail-content {
  font-size: 15px;
  color: #555;
  line-height: 1.8;
}

/* 星座列表 */
.constellation-list {
  padding: 0 15px 25px;
  background-color: white;
}

.list-title {
  font-size: 18px;
  color: #666;
  margin-bottom: 15px;
  padding-left: 5px;
}

.constellation-item {
  display: flex;
  align-items: center;
  padding: 15px;
  border-radius: 12px;
  margin-bottom: 10px;
  background-color: #f8f9fc;
  transition: all 0.3s;
  animation: fadeIn 0.5s ease-out;
}

.constellation-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
}

.constellation-item.active .constellation-item-name,
.constellation-item.active .constellation-item-date {
  color: white;
}

.constellation-item-icon {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 15px;
  font-size: 24px;
  color: white;
}

.constellation-item.active .constellation-item-icon {
  background: rgba(255, 255, 255, 0.3);
}

.constellation-item-details {
  flex: 1;
}

.constellation-item-name {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 3px;
}

.constellation-item-date {
  font-size: 14px;
  color: #777;
}

/* 页脚 */
.footer {
  text-align: center;
  padding: 20px;
  color: #888;
  font-size: 14px;
  background-color: #f8f9fc;
}

/* 响应式调整 */
@media (max-width: 480px) {
  .constellation-circle {
    width: 140px;
    height: 140px;
  }

  .constellation-icon {
    font-size: 50px;
  }

  .constellation-name {
    font-size: 22px;
  }

  .detail-card {
    padding: 15px;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.constellation-item:nth-child(1) { animation-delay: 0.05s; }
.constellation-item:nth-child(2) { animation-delay: 0.1s; }
.constellation-item:nth-child(3) { animation-delay: 0.15s; }
.constellation-item:nth-child(4) { animation-delay: 0.2s; }
.constellation-item:nth-child(5) { animation-delay: 0.25s; }
.constellation-item:nth-child(6) { animation-delay: 0.3s; }
.constellation-item:nth-child(7) { animation-delay: 0.35s; }
.constellation-item:nth-child(8) { animation-delay: 0.4s; }
.constellation-item:nth-child(9) { animation-delay: 0.45s; }
.constellation-item:nth-child(10) { animation-delay: 0.5s; }
.constellation-item:nth-child(11) { animation-delay: 0.55s; }
.constellation-item:nth-child(12) { animation-delay: 0.6s; }

/* 图标样式 */
.icon {
  font-size: 30px;
}
