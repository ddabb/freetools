<!-- 查询区域 -->
<view class="query-section">
  <view class="input-group">
    <view class="input-hint">选择日期(公历):</view>
    <picker mode="multiSelector" range="{{pickerRange}}" value="{{pickerValue}}" bindchange="onDateChange" bindcolumnchange="onPickerColumnChange">
      <view class="date-picker-display" hover-class="date-picker-display-hover">
        <text class="date-text">{{month}}月{{day}}日</text>
        <text class="date-arrow">▼</text>
      </view>
    </picker>
  </view>
</view>

<!-- 结果区域 -->
<view class="result-section">
  <view class="constellation-circle" hover-class="constellation-circle-hover">
    <view class="constellation-icon">
      <text class="icon">{{constellationIcon}}</text>
    </view>
    <view class="constellation-name">{{constellationName}}</view>
    <view class="constellation-date">{{constellationDate}}</view>
  </view>
  <view class="link-row">
    <view class="link-btn" hover-class="link-btn-hover" bindtap="goToCalendar">
      <text>万年历</text>
    </view>
    <view class="link-btn" hover-class="link-btn-hover" bindtap="goToZodiac">
      <text>生肖</text>
    </view>
  </view>
  
  <!-- 星座列表（支持左右滑动） -->
  <view class="constellation-scroll">
    <view class="list-title">
      <text>十二星座</text>
      <text class="swipe-hint">左右滑动切换</text>
    </view>
    <scroll-view scroll-x="true" class="constellation-scroll-view">
      <view class="constellation-scroll-content">
        <view wx:for="{{constellationItems}}" wx:key="index" class="constellation-scroll-item {{item.name == constellationName ? 'active' : ''}}" data-index="{{index}}" bindtap="onConstellationItemClick">
          <view class="constellation-item-icon">
            <text class="icon">{{item.icon}}</text>
          </view>
          <view class="constellation-item-details">
            <view class="constellation-item-name">{{item.name}}</view>
            <view class="constellation-item-date">{{item.date}}</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

<!-- 星座特性介绍 -->
<view class="detail-section" wx:if="{{constellationData}}">
  <view class="detail-title">{{constellationName}} 特性分析</view>
  
  <view class="detail-card" hover-class="detail-card-hover">
    <view class="detail-header">
      <text class="detail-icon">🎯</text>
      <text class="detail-label">性格特点</text>
    </view>
    <view class="detail-content">{{constellationData.personality}}</view>
  </view>

  <view class="detail-card" hover-class="detail-card-hover">
    <view class="detail-header">
      <text class="detail-icon">💕</text>
      <text class="detail-label">爱情运势</text>
    </view>
    <view class="detail-content">{{constellationData.love}}</view>
  </view>

  <view class="detail-card" hover-class="detail-card-hover">
    <view class="detail-header">
      <text class="detail-icon">💼</text>
      <text class="detail-label">事业运势</text>
    </view>
    <view class="detail-content">{{constellationData.career}}</view>
  </view>

  <view class="detail-card" hover-class="detail-card-hover">
    <view class="detail-header">
      <text class="detail-icon">🍀</text>
      <text class="detail-label">幸运数字</text>
    </view>
    <view class="detail-content">幸运数字：{{constellationData.luckyNumber}} | 幸运色：{{constellationData.luckyColor}} | 幸运日：{{constellationData.luckyDay}}</view>
  </view>
</view>



