/* idiom-chain.wxss - 成语龙链页面样式 */

.container {
  padding: 20rpx;
  min-height: 100vh;
  background: #f5f5f5;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-copy {
  flex: 1;
  min-width: 0;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #2c3e50;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a8a8a;
  line-height: 1.6;
}

.clear-btn {
  flex-shrink: 0;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #fff0ef;
  color: #e74c3c;
  font-size: 24rpx;
  font-weight: 600;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 80rpx 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  font-size: 72rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
}

.empty-desc {
  font-size: 24rpx;
  color: #8a8a8a;
  line-height: 1.8;
  text-align: center;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.list-tip {
  margin: 0 8rpx 6rpx;
  font-size: 22rpx;
  color: #9a9a9a;
}

.record-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 2rpx solid #f5f5f5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.record-card:active {
  opacity: 0.92;
  transform: scale(0.99);
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.record-word {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  font-weight: 700;
  color: #2c3e50;
}

.record-count-badge {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e8f4fd;
  color: #2980b9;
  font-size: 22rpx;
  font-weight: 600;
}

.record-preview {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #faf7f2;
  color: #8c6d1f;
  font-size: 24rpx;
  line-height: 1.8;
  word-break: break-all;
}

.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.record-time {
  font-size: 24rpx;
  color: #9a9a9a;
}

.record-action {
  font-size: 24rpx;
  font-weight: 600;
  color: #e74c3c;
}
