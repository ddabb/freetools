/* idiom-battle.wxss - 成语对战页面样式 */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

/* =====================
   加载中
   ===================== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e3f2fd;
  border-top-color: #2196f3;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* =====================
   欢迎界面（空闲状态）
   ===================== */
.welcome-section {
  display: flex;
  flex-direction: column;
  padding: 40rpx 30rpx;
  flex: 1;
}

.welcome-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.battle-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1565c0;
  margin-bottom: 8rpx;
}

.welcome-subtitle {
  font-size: 26rpx;
  color: #888;
}

/* 规则卡片 */
.rule-card {
  background: linear-gradient(135deg, #fff8f0 0%, #fff5e6 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.rule-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.rule-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.rule-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #e65100;
}

.rule-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
}

.rule-dot {
  width: 12rpx;
  height: 12rpx;
  background: #ff9800;
  border-radius: 50%;
  margin-right: 16rpx;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.rule-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 先手选择 */
.first-choose-section {
  margin-bottom: 32rpx;
}

.choose-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.first-choose {
  display: flex;
  gap: 24rpx;
}

.first-btn {
  flex: 1;
  background: #fff;
  border: 3rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 32rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.first-btn.active {
  border-color: #2196f3;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  box-shadow: 0 6rpx 20rpx rgba(33, 150, 243, 0.2);
}

.btn-icon {
  font-size: 52rpx;
  margin-bottom: 12rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.btn-desc {
  font-size: 22rpx;
  color: #999;
}

.first-btn.active .btn-text {
  color: #1565c0;
}

/* 开始按钮 */
.start-section {
  margin-top: auto;
  padding-bottom: 40rpx;
}

.start-btn {
  background: #e0e0e0;
  border-radius: 50rpx;
  text-align: center;
  padding: 32rpx 0;
  transition: all 0.3s;
}

.start-btn.ready {
  background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
  box-shadow: 0 8rpx 24rpx rgba(33, 150, 243, 0.35);
}

.start-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #999;
}

.start-btn.ready .start-text {
  color: #fff;
}

.start-btn.ready-hover {
  transform: scale(0.98);
  opacity: 0.95;
}

/* =====================
   对战中
   ===================== */
.battle-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(180deg, #e3f2fd 0%, #f5f5f5 100%);
  border-bottom: 1rpx solid #e0e0e0;
}

.header-left {
  flex-shrink: 0;
}

.round-badge {
  background: #fff;
  border-radius: 24rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.header-center {
  flex: 1;
  display: flex;
  justify-content: center;
  padding: 0 20rpx;
}

.turn-indicator {
  border-radius: 28rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.turn-indicator.user-turn {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  color: #2e7d32;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.2);
}

.turn-indicator.ai-turn {
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
  color: #7b1fa2;
  box-shadow: 0 4rpx 12rpx rgba(156, 39, 176, 0.2);
}

.header-right {
  flex-shrink: 0;
}

.timer {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.timer-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.timer-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #2196f3;
  font-variant-numeric: tabular-nums;
}

.timer.timer-danger {
  background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
  animation: pulse 1s infinite;
}

.timer.timer-danger .timer-num {
  color: #d32f2f;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* 对战提示 */
.battle-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin: 16rpx 24rpx;
}

.hint-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.hint-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #f57c00;
}

/* 接龙历史 */
.chain-container {
  flex: 1;
  padding: 0 24rpx;
}

.chain-list {
  display: flex;
  flex-direction: column;
  padding: 12rpx 0;
}

.chain-item {
  display: flex;
  margin-bottom: 20rpx;
}

.chain-item.user-chain {
  justify-content: flex-end;
}

.chain-item.ai-chain {
  justify-content: flex-start;
}

.chain-bubble {
  max-width: 75%;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.user-chain .chain-bubble {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border-bottom-right-radius: 8rpx;
}

.ai-chain .chain-bubble {
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-bottom-left-radius: 8rpx;
}

.bubble-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.side-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

.user-chain .side-label {
  background: #2196f3;
}

.ai-chain .side-label {
  background: #9e9e9e;
}

.chain-index {
  font-size: 20rpx;
  color: #999;
}

.bubble-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.idiom-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.tail-char {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
  padding: 6rpx 14rpx;
}

.tail-label {
  font-size: 20rpx;
  color: #666;
  margin-right: 8rpx;
}

.char-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #d32f2f;
}

/* 输入区域 */
.input-section {
  padding: 16rpx 24rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #e0e0e0;
}

.input-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.idiom-input {
  flex: 1;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 44rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid #e0e0e0;
}

.send-btn {
  flex-shrink: 0;
  height: 88rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.3);
}

.send-btn-hover {
  transform: scale(0.96);
  opacity: 0.9;
}

.send-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

/* AI思考中 */
.ai-thinking {
  padding: 24rpx;
  background: #fff;
  border-top: 1rpx solid #e0e0e0;
}

.thinking-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.thinking-animation {
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.thinking-dot {
  width: 16rpx;
  height: 16rpx;
  background: #ccc;
  border-radius: 50%;
  animation: dotBounce 1.2s infinite ease-in-out;
}

.thinking-dot:nth-child(1) { animation-delay: 0s; }
.thinking-dot:nth-child(2) { animation-delay: 0.2s; }
.thinking-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.thinking-text {
  font-size: 26rpx;
  color: #999;
}

/* 底部操作 */
.battle-footer {
  padding: 16rpx 24rpx 32rpx;
  background: #fff;
  display: flex;
  justify-content: center;
}

.surrender-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 32rpx;
  border-radius: 28rpx;
  background: #f5f5f5;
}

.surrender-btn-hover {
  background: #e0e0e0;
}

.surrender-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.surrender-text {
  font-size: 26rpx;
  color: #999;
}

/* =====================
   对战结束
   ===================== */
.result-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 40rpx 30rpx;
}

.result-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.result-emoji {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 12rpx;
}

.result-subtitle {
  font-size: 26rpx;
  color: #888;
  text-align: center;
}

/* 统计 */
.stats-section {
  margin-bottom: 32rpx;
}

.stats-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  text-align: center;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.stat-value.win {
  color: #4caf50;
}

.stat-value.lose {
  color: #f44336;
}

.stat-value.streak {
  color: #ff9800;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 本局接龙 */
.chain-result-section {
  margin-bottom: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.chain-header {
  margin-bottom: 16rpx;
}

.chain-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
}

.chain-result {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  max-height: 160rpx;
  box-sizing: border-box;
}

.chain-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  word-break: break-all;
  display: block;
}

/* 再来一局 */
.action-section {
  display: flex;
  justify-content: center;
}

.restart-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 60rpx;
  background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(33, 150, 243, 0.35);
}

.restart-btn-hover {
  transform: scale(0.98);
  opacity: 0.95;
}

.restart-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.restart-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}
