/**packages/life/pages/calendar/calendar.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 0rpx;
  margin: 0rpx;
}

.section {
  margin-bottom: 20rpx;
  margin-left: 0rpx;
  margin-right: 0rpx;
}

.card {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  padding: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 日期选择器 */
.date-picker {
  width: 100%;
}

.date-display {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
}

.date-text {
  font-size: 42rpx;
  font-weight: 800;
  color: #667eea;
}

.date-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 信息卡片 */
.info-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: calc(100% - 60rpx);
  padding: 0 20rpx;
  margin-bottom: 40rpx;
}

.info-card-row {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  padding: 0 10rpx 10rpx;
  margin: 0 -10rpx;
}

.info-card {
  flex: 0 0 auto;
  min-width: 100rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 16rpx;
  padding: 20rpx 15rpx;
  text-align: center;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  position: relative;
  overflow: visible;
  min-height: 130rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  z-index: 10;
  white-space: nowrap;
}

.info-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.info-label {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
  font-weight: 600;
}

.info-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  display: block;
  word-break: break-all;
}

.info-link {
  font-size: 20rpx;
  color: #667eea;
  margin-top: 6rpx;
  font-weight: 500;
}

/* 日历部分 */
.calendar-section {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 0rpx;
  padding: 0rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 30rpx;
  width: calc(100% - 20rpx);
  margin-left: 50rpx;
  margin-right: 50rpx;
  position: relative;
  z-index: 1;
}

/* 星期标题 */
.calendar-header {
  display: flex;
  margin-bottom: 0rpx;
  border-bottom: 2rpx solid #f0f0f0;
  padding: 12rpx 0;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
}

/* 日历网格 */
.calendar-grid {
  display: flex;
  flex-direction: column;
  gap: 0rpx;
  padding: 0rpx;
  margin: 0rpx;
}

.calendar-week {
  display: flex;
  gap: 0rpx;
  height: 140rpx;
  margin: 0rpx;
  padding: 0rpx;
}

.calendar-day {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 0rpx;
  padding: 8rpx;
  position: relative;
  transition: all 0.3s ease;
  cursor: pointer;
  height: 140rpx;
  min-width: calc(100% / 7);
  box-sizing: border-box;
  border: 1rpx solid transparent;
}

.calendar-day:active {
  transform: scale(0.95);
  background: rgba(0, 0, 0, 0.05);
}

.calendar-day.today:active {
  background: linear-gradient(135deg, #e083ea 0%, #e5475c 100%);
}

.calendar-day.holiday:active {
  background: rgba(52, 152, 219, 0.2);
}

/* 日期数字 */
.day-number {
  font-size: 42rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1;
}

/* 农历日期 */
.lunar-day {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
  line-height: 1;
}

/* 节假日名称 */
.calendar-day .holiday-name {
  font-size: 16rpx;
  color: #f5576c;
  font-weight: 600;
  text-align: center;
  line-height: 1;
  word-break: break-all;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 其他月份的日期 */
.calendar-day.other-month {
  opacity: 0.5;
}

.calendar-day.other-month .day-number {
  color: #ccc;
}

.calendar-day.other-month .lunar-day {
  color: #ccc;
}

/* 今天 */
.calendar-day.today {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  box-shadow: 0 4rpx 12rpx rgba(240, 147, 251, 0.4);
}

.calendar-day.today .day-number {
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.calendar-day.today .lunar-day {
  color: rgba(255, 255, 255, 0.8);
}

/* 选中日期 */
.calendar-day.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.calendar-day.selected .day-number {
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.calendar-day.selected .lunar-day {
  color: rgba(255, 255, 255, 0.8);
}

/* 节假日 */
.calendar-day.holiday {
  background: rgba(52, 152, 219, 0.1);
  border: 2rpx solid #3498db;
}

.calendar-day.holiday .day-number {
  color: #3498db;
  font-weight: 700;
}

.calendar-day.today.holiday {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: 2rpx solid #667eea;
}

.calendar-day.today.holiday .day-number {
  color: white;
}

.calendar-day.today.holiday .holiday-name {
  color: rgba(255, 255, 255, 0.9);
}

/* 功能按钮 */
.buttons-section {
  display: flex;
  gap: 12rpx;
  position: relative;
  z-index: 0;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  border: none;
  color: white;
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  box-shadow: 0 8rpx 20rpx rgba(168, 237, 234, 0.4);
}

.action-btn.primary {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  box-shadow: 0 8rpx 20rpx rgba(240, 147, 251, 0.4);
}

.action-btn:active {
  transform: scale(0.98);
}

.btn-share {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(231, 76, 60, 0.4);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-share:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(231, 76, 60, 0.4);
}

/* 功能按钮容器 */
.buttons-container {
  margin-top: 30rpx;
  margin-bottom: 30rpx;
  padding: 0 20rpx;
  position: relative;
  z-index: 0;
}

/* 年月导航 */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 15px;
  padding: 20rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-bottom: 2rpx solid #f0f0f0;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 1rpx solid #ddd;
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  color: #333;
}

.nav-btn:active {
  transform: scale(0.95);
  background: linear-gradient(145deg, #f0f0f0 0%, #e0e0e0 100%);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}
