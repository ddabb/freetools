/**packages/life/pages/calendar/calendar.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #fecfef 100%);
}

.container {
  padding: 0rpx;
  margin: 0rpx;
}

.section {
  margin-bottom: 20rpx;
  margin-left: 0rpx;
  margin-right: 0rpx;
}

.card {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  padding: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 日期选择器 */
.date-picker {
  width: 100%;
}

.date-display {
  background: linear-gradient(145deg, #ffffff 0%, #fff0f5 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 25rpx rgba(255, 154, 158, 0.2);
  margin: 20rpx;
}

.date-text {
  font-size: 42rpx;
  font-weight: 800;
  color: #f472b6;
  text-shadow: 0 2rpx 4rpx rgba(255, 154, 158, 0.3);
}

.date-arrow {
  font-size: 24rpx;
  color: #f472b6;
  transition: transform 0.3s ease;
}

.date-display-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 30rpx rgba(255, 154, 158, 0.3);
}

.date-display-hover .date-arrow {
  transform: rotate(180deg);
}

/* 信息卡片 */
.info-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: calc(100% - 60rpx);
  padding: 0 20rpx;
  margin-bottom: 40rpx;
}

.info-card-row {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  padding: 0 10rpx 10rpx;
  margin: 0 -10rpx;
}

.info-card {
  flex: 0 0 auto;
  min-width: 100rpx;
  background: linear-gradient(145deg, #ffffff 0%, #fff0f5 100%);
  border-radius: 16rpx;
  padding: 20rpx 15rpx;
  text-align: center;
  box-shadow: 0 8rpx 25rpx rgba(255, 154, 158, 0.2);
  position: relative;
  overflow: visible;
  min-height: 130rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  z-index: 10;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.info-card-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 30rpx rgba(255, 154, 158, 0.3);
}

.info-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #f472b6, #fb7185);
}

.info-label {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
  font-weight: 600;
}

.info-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #f472b6;
  display: block;
  word-break: break-all;
  text-shadow: 0 1rpx 2rpx rgba(255, 154, 158, 0.3);
}

.info-link {
  font-size: 20rpx;
  color: #f472b6;
  margin-top: 6rpx;
  font-weight: 500;
  text-decoration: underline;
  text-decoration-color: rgba(244, 114, 182, 0.5);
}

/* 日历部分 */
.calendar-section {
  background: linear-gradient(145deg, #ffffff 0%, #fff0f5 100%);
  border-radius: 16rpx;
  padding: 0rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 154, 158, 0.2);
  margin-bottom: 30rpx;
  width: calc(100% - 40rpx);
  margin-left: 20rpx;
  margin-right: 20rpx;
  position: relative;
  z-index: 1;
}

/* 星期标题 */
.calendar-header {
  display: flex;
  margin-bottom: 0rpx;
  border-bottom: 2rpx solid #fecdd3;
  padding: 12rpx 0;
  background: linear-gradient(135deg, #fecfef 0%, #ffd9e2 100%);
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #f472b6;
  text-shadow: 0 1rpx 2rpx rgba(255, 154, 158, 0.3);
}

/* 日历网格 */
.calendar-grid {
  display: flex;
  flex-direction: column;
  gap: 0rpx;
  padding: 0rpx;
  margin: 0rpx;
}

.calendar-week {
  display: flex;
  gap: 0rpx;
  height: 140rpx;
  margin: 0rpx;
  padding: 0rpx;
}

.calendar-day {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  padding: 12rpx 4rpx;
  position: relative;
  transition: all 0.3s ease;
  cursor: pointer;
  height: 140rpx;
  box-sizing: border-box;
  border: 1rpx solid transparent;
  background: rgba(255, 255, 255, 0.7);
}

.calendar-day-hover {
  transform: scale(0.95);
  background: rgba(255, 154, 158, 0.1);
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 158, 0.2);
}

.calendar-day.today-hover {
  background: linear-gradient(135deg, #f472b6 0%, #fb7185 100%);
}

.calendar-day.holiday-hover {
  background: rgba(255, 154, 158, 0.2);
}

/* 日期数字 */
.day-number {
  font-size: 42rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* 农历日期 */
.lunar-day {
  font-size: 24rpx;
  color: #f472b6;
  margin-bottom: 6rpx;
  line-height: 1;
}

/* 节假日名称 */
.calendar-day .holiday-name {
  font-size: 16rpx;
  color: #f472b6;
  font-weight: 600;
  text-align: center;
  line-height: 1;
  word-break: break-all;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 其他月份的日期 */
.calendar-day.other-month {
  opacity: 0.5;
}

.calendar-day.other-month .day-number {
  color: #ccc;
}

.calendar-day.other-month .lunar-day {
  color: #ccc;
}

/* 今天 */
.calendar-day.today {
  background: linear-gradient(135deg, #f472b6 0%, #fb7185 100%);
  box-shadow: 0 4rpx 12rpx rgba(244, 114, 182, 0.4);
}

.calendar-day.today .day-number {
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.calendar-day.today .lunar-day {
  color: rgba(255, 255, 255, 0.8);
}

.calendar-day.today .holiday-name {
  color: rgba(255, 255, 255, 0.9);
}

/* 选中日期 */
.calendar-day.selected {
  background: linear-gradient(135deg, #fecfef 0%, #ffd9e2 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 158, 0.3);
}

.calendar-day.selected .day-number {
  color: #f472b6;
  text-shadow: 0 2rpx 4rpx rgba(255, 154, 158, 0.3);
}

.calendar-day.selected .lunar-day {
  color: #f472b6;
}

/* 节假日 */
.calendar-day.holiday {
  background: rgba(255, 154, 158, 0.1);
}

.calendar-day.holiday .day-number {
  color: #f472b6;
  font-weight: 700;
}

.calendar-day.today.holiday {
  background: linear-gradient(135deg, #f472b6 0%, #fb7185 100%);
}

.calendar-day.today.holiday .day-number {
  color: white;
}

.calendar-day.today.holiday .holiday-name {
  color: rgba(255, 255, 255, 0.9);
}

/* 功能按钮 */
.buttons-section {
  display: flex;
  gap: 12rpx;
  position: relative;
  z-index: 0;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  border: none;
  color: #333;
  background: linear-gradient(135deg, #fecfef 0%, #ffd9e2 100%);
  box-shadow: 0 8rpx 20rpx rgba(255, 154, 158, 0.3);
  transition: all 0.3s ease;
}

.action-btn.primary {
  background: linear-gradient(135deg, #f472b6 0%, #fb7185 100%);
  box-shadow: 0 8rpx 20rpx rgba(244, 114, 182, 0.4);
  color: white;
}

.action-btn-hover {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 158, 0.4);
}

.btn-share {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #f472b6 0%, #fb7185 100%);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(244, 114, 182, 0.4);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-share-hover {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(244, 114, 182, 0.4);
}

/* 功能按钮容器 */
.buttons-container {
  margin-top: 30rpx;
  margin-bottom: 30rpx;
  padding: 0 20rpx;
  position: relative;
  z-index: 0;
}

/* 年月导航 */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 15px;
  padding: 20rpx;
  background: linear-gradient(135deg, #fecfef 0%, #ffd9e2 100%);
  border-bottom: 2rpx solid #fecdd3;
  border-radius: 16rpx 16rpx 0 0;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 1rpx solid #fecdd3;
  background: linear-gradient(145deg, #ffffff 0%, #fff0f5 100%);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 158, 0.2);
  color: #f472b6;
  transition: all 0.3s ease;
}

.nav-btn-hover {
  transform: scale(0.95);
  background: linear-gradient(145deg, #fecfef 0%, #ffd9e2 100%);
  box-shadow: 0 2rpx 6rpx rgba(255, 154, 158, 0.3);
}
