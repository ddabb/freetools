<!--battery-health.wxml-->
<view class="container">
  <!-- 标题区 -->
  <view class="header">
    <text class="title">设备电量信息</text>
    <text class="subtitle">实时获取系统电池状态</text>
  </view>

  <!-- 表单区 -->
  <view class="form-container">
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">操作</text>
      </view>
      <button class="full-width-btn btn-primary" bindtap="getBatteryInfo">刷新电量信息</button>
    </view>

    <!-- 结果区 -->
    <view class="form-item" wx:if="{{showResult}}">
      <view class="form-label">
        <text class="label-text">电量信息</text>
      </view>
      <view class="result-box">
        <text class="output-text">{{result}}</text>
      </view>
      <view class="form-item" wx:if="{{level !== null}}">
        <view class="form-label"><text class="label-text">电量百分比</text></view>
        <view class="result-box"><text class="output-text">{{level}}%</text></view>
      </view>
      <view class="form-item" wx:if="{{isCharging !== null}}">
        <view class="form-label"><text class="label-text">充电状态</text></view>
        <view class="result-box"><text class="output-text">{{isCharging ? '充电中' : '未在充电'}}</text></view>
      </view>
      <view class="form-item" wx:if="{{isLowPowerModeEnabled !== null}}">
        <view class="form-label"><text class="label-text">省电模式</text></view>
        <view class="result-box"><text class="output-text">{{isLowPowerModeEnabled ? '已开启' : '未开启'}}</text></view>
      </view>
    </view>

    <!-- 分享海报生成 -->
    <view class="share-section">
      <canvas canvas-id="cvs1" type="2d" style="width: {{canvaswidth}}px; height: {{canvasheight}}px; position: fixed; left: -9999rpx; top: -9999rpx;" />
      <button class="btn-share" hover-class="btn-share-hover" bindtap="MakePosters" >生成分享海报</button>
    </view>
  </view>
  <!-- 搴曢儴骞垮憡 -->
  <ad unit-id="adunit-07e9c9da9e4b8254" ad-intervals="30" binderror="onAdError" bindclose="onAdClose"></ad>
</view>