/**battery-health.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 32rpx 24rpx;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form-container {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 16rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  margin-bottom: 12rpx;
}

.label-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #333;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #667eea;
  background: white;
}

.full-width-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  outline: none;
  margin-top: 8rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 8rpx 25rpx rgba(102, 126, 234, 0.3);
}

.btn-primary:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 35rpx rgba(102, 126, 234, 0.4);
}

.result-box {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  border-left: 4rpx solid #667eea;
}

.output-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  word-break: break-all;
}

.share-section {
  margin-top: 30rpx;
  text-align: center;
}

.btn-share {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: #fff;
  margin-top: 20rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(231, 76, 60, 0.4);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-share-hover {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(231, 76, 60, 0.4);
  opacity: 0.85;
}
