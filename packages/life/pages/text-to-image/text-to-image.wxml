<view class="container">
  <!-- 内容区域 -->
  <view class="content-area">
    <!-- 输入区域 -->
    <view class="input-section">
      <view class="form-group">
        <text class="label">文字内容（50字以内）</text>
        <textarea 
          class="textarea" 
          placeholder="请输入要生成图片的文字内容（建议20字以内效果更佳）" 
          bindinput="onTextInput" 
          bindblur="onInputBlur"
          maxlength="50" 
          value="{{text}}"
        ></textarea>
        <text class="count">{{textLength}}/50</text>
      </view>
      <view class="form-group">
        <text class="label">出处（可不填，15字以内）</text>
        <input 
          class="input" 
          placeholder="请输入出处信息" 
          bindinput="onFromInput" 
          bindblur="onInputBlur"
          value="{{from}}" 
          maxlength="15"
        ></input>
        <text class="count">{{from ? from.length : 0}}/15</text>
      </view>
      <!-- 二维码选择 -->
      <view class="form-group">
        <text class="label">选择二维码（可选）</text>
        <view class="qr-selection">
          <view class="qr-options">
            <view class="qr-option {{selectedQrCode === 'default' ? 'active' : ''}}" bindtap="selectQrCode" data-type="default">
              <image class="qr-thumbnail" src="/images/text2image.jpg" mode="aspectFit"></image>
              <text class="qr-label">默认二维码</text>
            </view>
            <view class="qr-option {{selectedQrCode === 'custom' ? 'active' : ''}}" bindtap="selectQrCode" data-type="custom">
              <view class="custom-qr-placeholder">
                <text class="qr-icon">📷</text>
                <text class="qr-label">选择二维码</text>
              </view>
            </view>
            <view class="make-qr-btn" bindtap="goToQRCodePage">
              <text class="make-qr-icon">✨</text>
              <text class="make-qr-text">制作二维码</text>
            </view>
          </view>
          <!-- 自定义二维码上传区域 -->
          <view class="custom-qr-section" wx:if="{{selectedQrCode === 'custom'}}">
            <button class="image-upload-btn {{customQrCodeImage ? 'has-image' : ''}}" bindtap="uploadQRCodeImage">
              <text class="upload-icon">📷</text>
              {{customQrCodeImage ? '更换' : '上传'}}二维码图片
            </button>
            <button class="btn-secondary" bindtap="removeQRCodeImage" wx:if="{{customQrCodeImage}}">
              移除
            </button>
            <!-- 自定义二维码预览 -->
            <view class="qr-preview" wx:if="{{customQrCodeImage}}">
              <text class="section-title">二维码预览</text>
              <image class="qrcode-preview" src="{{customQrCodeImage}}" mode="aspectFit"></image>
            </view>
          </view>
        </view>
      </view>





      <!-- 生成图片按钮 -->
      <view class="action-buttons">
        <button class="btn-primary" bindtap="generateImage">💾 保存到相册</button>
      </view>
    </view>
  </view>
  
  <!-- 隐藏的画布元素，用于生成高清图片 -->
  <canvas id="cvsTextToImage" type="2d" style="width: 375px; height: 667px; position: absolute; left: -9999px; top: -9999px;"></canvas>
</view>
