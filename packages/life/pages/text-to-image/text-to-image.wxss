.container {
  padding: 0;
  background-color: #f0f2f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 预览开关 */
.preview-toggle {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.toggle-label {
  margin-left: 16rpx;
  font-size: 26rpx;
  color: #666;
}

/* 预览区域 */
.preview-section {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.preview-tip {
  font-size: 22rpx;
  color: #999;
}

.preview-container {
  display: flex;
  justify-content: center;
}

.preview-wrapper {
  position: relative;
  width: 280rpx;
  height: 498rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.preview-canvas {
  width: 100%;
  height: 100%;
  background: #fff;
}

.preview-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-loading {
  font-size: 24rpx;
  color: #666;
}

.content-area {
  flex: 1;
  padding: 24rpx;
}

.input-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 56rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.textarea {
  width: 100%;
  height: 400rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
  color: #374151;
  background-color: #f9fafb;
  resize: none;
  box-sizing: border-box;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #374151;
  background-color: #f9fafb;
  box-sizing: border-box;
}

.count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 12rpx;
}

.qr-selection {
  margin-top: 16rpx;
}

.qr-options {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.qr-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  background-color: #f9fafb;
}

.qr-option.active {
  border-color: #3b82f6;
  background-color: #eff6ff;
}

.qr-thumbnail {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.custom-qr-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.qr-label {
  font-size: 24rpx;
  color: #6b7280;
  text-align: center;
  font-weight: 500;
}

.make-qr-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  border: 2rpx solid #3b82f6;
  border-radius: 12rpx;
  background-color: #3b82f6;
  min-width: 140rpx;
}

.make-qr-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.make-qr-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.custom-qr-section {
  margin-top: 24rpx;
}

.qr-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.btn-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #374151;
  background-color: #f3f4f6;
  border-radius: 12rpx;
  border: none;
  font-weight: 500;
}

.btn-secondary[disabled] {
  color: #9ca3af;
  background-color: #f9fafb;
}

.qr-preview {
  background-color: #f9fafb;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx dashed #e5e7eb;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
  align-self: flex-start;
}

.qrcode-canvas {
  background-color: #fff;
  border-radius: 8rpx;
}

.image-upload-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #374151;
  background-color: #f9fafb;
  border-radius: 12rpx;
  border: 2rpx dashed #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-weight: 500;
}

.image-upload-btn.has-image {
  border-color: #3b82f6;
  background-color: #eff6ff;
  color: #3b82f6;
}

.upload-icon {
  font-size: 36rpx;
}

.qrcode-preview {
  width: 240rpx;
  height: 240rpx;
  background-color: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #e5e7eb;
}

.action-buttons {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f3f4f6;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  color: #fff;
  background-color: #3b82f6;
  border-radius: 16rpx;
  border: none;
  font-weight: 600;
  margin: 0;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
}
