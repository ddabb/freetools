.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.content-area {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 120rpx; /* 为底部固定按钮预留空间 */
}

.input-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fafafa;
  resize: none;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fafafa;
}

.count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.qr-selection {
  margin-top: 12rpx;
}

.qr-options {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.qr-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  background-color: #fafafa;
  transition: all 0.3s ease;
}

.qr-option.active {
  border-color: #007aff;
  background-color: #e8f0fe;
}

.qr-thumbnail {
  width: 60rpx;
  height: 60rpx;
  border-radius: 4rpx;
  margin-bottom: 8rpx;
}

.custom-qr-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.qr-label {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.custom-qr-section {
  margin-top: 16rpx;
}

.qr-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.btn-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  border: none;
}

.btn-secondary[disabled] {
  color: #ccc;
  background-color: #fafafa;
}

.qr-preview {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  align-self: flex-start;
}

.qrcode-canvas {
  background-color: #fafafa;
  border-radius: 8rpx;
}

.image-upload-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  border: 2rpx dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.image-upload-btn.has-image {
  border-color: #007aff;
  background-color: #e8f0fe;
}

.upload-icon {
  font-size: 36rpx;
}

.qrcode-preview {
  width: 200px;
  height: 200px;
  background-color: #fafafa;
  border-radius: 8rpx;
  border: 1rpx solid #e8e8e8;
}

.preview-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.image-canvas {
  width: 100%;
  height: 600rpx;
  background-color: #fafafa;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.preview-actions {
  display: flex;
  justify-content: center;
}

/* 固定底部按钮区域 */
.fixed-action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #e8e8e8;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.fixed-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  color: #fff;
  background-color: #007aff;
  border-radius: 12rpx;
  border: none;
  font-weight: 500;
  margin: 0;
}

/* 移除固定按钮的禁用状态样式，按钮始终可点击 */

/* 响应式设计 */
@media (max-width: 375px) {
  .textarea {
    height: 180rpx;
  }
  
  .image-canvas {
    height: 500rpx;
  }
}
