<!-- 成语接龙 -->
<view class="container">

  <!-- ====== 加载遮罩 ====== -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载成语数据中…</text>
      <text class="loading-sub">首次加载约需 2 秒</text>
    </view>
  </view>

  <!-- ====== 错误提示 ====== -->
  <view wx:if="{{loadError && !loading}}" class="error-overlay">
    <view class="error-box">
      <text class="error-icon">⚠️</text>
      <text class="error-msg">{{loadError}}</text>
      <button class="retry-btn" bindtap="_loadData">重新加载</button>
    </view>
  </view>

  <!-- ====== 主内容 ====== -->
  <block wx:if="{{!loading && !loadError}}">

    <!-- 头部 Banner -->
    <view class="page-header">
      <view class="header-left">
        <text class="header-icon">🀄</text>
        <view>
          <text class="header-title">成语接龙</text>
          <text class="header-sub">汉字接龙 · 益智游戏</text>
        </view>
      </view>
      <view class="header-stats">
        <view class="mini-stat">
          <text class="mini-stat-num win">{{userStats.wins}}</text>
          <text class="mini-stat-label">胜</text>
        </view>
        <view class="mini-stat">
          <text class="mini-stat-num lose">{{userStats.losses}}</text>
          <text class="mini-stat-label">负</text>
        </view>
        <view class="mini-stat">
          <text class="mini-stat-num streak">{{userStats.streak}}</text>
          <text class="mini-stat-label">连胜</text>
        </view>
      </view>
    </view>

    <!-- Tab 栏 -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab===0?'active':''}}" data-idx="0" bindtap="onTabChange">
        <text class="tab-icon">🔍</text>
        <text class="tab-text">查接龙</text>
      </view>
      <view class="tab-item {{activeTab===1?'active':''}}" data-idx="1" bindtap="onTabChange">
        <text class="tab-icon">⚔️</text>
        <text class="tab-text">对战</text>
      </view>
      <view class="tab-item {{activeTab===2?'active':''}}" data-idx="2" bindtap="onTabChange">
        <text class="tab-icon">🔗</text>
        <text class="tab-text">接龙链</text>
      </view>
    </view>

    <!-- ====== 查询 Tab ====== -->
    <view class="tab-content" wx:if="{{activeTab===0}}">
      <!-- 搜索框 -->
      <view class="search-bar">
        <input class="search-input" placeholder="输入任意成语，查看接龙结果" value="{{queryInput}}" bindinput="onQueryInput" bindconfirm="onQueryConfirm" confirm-type="search" />
        <view class="search-btn" bindtap="onQuerySearch">查询</view>
      </view>

      <!-- 历史记录 -->
      <view class="history-bar" wx:if="{{queryHistory.length>0}}">
        <text class="history-label">最近：</text>
        <view class="history-chips">
          <view class="chip" wx:for="{{queryHistory}}" wx:key="index" data-word="{{item}}" bindtap="onHistoryTap">{{item}}</view>
        </view>
      </view>

      <!-- 提示语 -->
      <view class="empty-tip" wx:if="{{queryResults.length===0}}">
        <text class="empty-icon">🀄</text>
        <text class="empty-text">{{queryTip}}</text>
      </view>

      <!-- 结果列表 -->
      <view wx:if="{{queryResults.length>0}}">
        <view class="result-header">
          <text class="result-count">{{queryTip}}</text>
          <view class="copy-btn" bindtap="onCopyResult">📋 复制</view>
        </view>
        <view class="result-item" wx:for="{{queryResults}}" wx:key="index" data-word="{{item.next}}" bindtap="onQueryItemTap">
          <view class="result-main">
            <text class="result-next">{{item.next}}</text>
          </view>
          <view class="result-tail">
            <text class="result-char">{{item.lastChar}}</text>
            <text class="result-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ====== 对战 Tab ====== -->
    <view class="tab-content" wx:if="{{activeTab===1}}">

      <!-- 空闲状态：选先手 -->
      <block wx:if="{{battleState==='idle'}}">
        <view class="battle-welcome">
          <text class="battle-welcome-icon">⚔️</text>
          <text class="battle-welcome-title">挑战 AI 对战</text>
          <text class="battle-welcome-sub">选择先手后手，开始成语接龙</text>
        </view>

        <view class="rule-card">
          <text class="rule-title">📖 规则</text>
          <text class="rule-line">• 汉字接龙：下一个成语首字与上一个末字相同</text>
          <text class="rule-line">• 每局 60 秒，超时判负</text>
          <text class="rule-line">• 无法接龙的一方判负</text>
        </view>

        <view class="first-choose">
          <view class="first-btn {{battleFirst==='user'?'active':''}}" data-first="user" bindtap="onChooseFirst">
            <text class="first-icon">🙋</text>
            <text class="first-text">我先出</text>
          </view>
          <view class="first-btn {{battleFirst==='ai'?'active':''}}" data-first="ai" bindtap="onChooseFirst">
            <text class="first-icon">🤖</text>
            <text class="first-text">AI 先出</text>
          </view>
        </view>

        <view class="start-btn" bindtap="onStartBattle">开始对战</view>
      </block>

      <!-- 对战中 -->
      <block wx:if="{{battleState==='playing'}}">
        <!-- 顶栏：回合 / 计时 / 提示 -->
        <view class="battle-top">
          <view class="battle-round-badge">第 {{battleRound}} 回合</view>
          <view class="battle-turn-badge {{battleTurn==='user'?'turn-user':'turn-ai'}}">
            <text>{{battleTurn==='user'?'🙋 你的回合':'🤖 AI 思考中'}}</text>
          </view>
          <view class="battle-timer {{battleTimer<=10?'timer-danger':''}}">
            <text class="timer-num">{{battleTimer}}</text>
            <text class="timer-label">s</text>
          </view>
        </view>

        <!-- 提示 -->
        <view class="battle-hint">{{battleHint}}</view>

        <!-- 接龙历史 -->
        <scroll-view class="battle-chain-scroll" scroll-y scroll-into-view="chain-bottom">
          <view class="battle-chain">
            <view class="chain-row {{item.side==='user'?'chain-row-user':'chain-row-ai'}}"
                  wx:for="{{battleChain}}" wx:key="index"
                  id="{{index===battleChain.length-1?'chain-bottom':''}}">
              <view class="chain-bubble {{item.side==='user'?'bubble-user':(item.side==='system'?'bubble-system':'bubble-ai')}}">
                <text class="chain-side-label">{{item.side==='user'?'我':(item.side==='system'?'起':'AI')}}</text>
                <text class="chain-word">{{item.word}}</text>
                <text class="chain-tail-char">{{item.lastChar}}</text>
              </view>
            </view>
          </view>
        </scroll-view>

        <!-- 输入区 -->
        <view class="battle-input-area" wx:if="{{battleTurn==='user'}}">
          <input class="battle-input" placeholder="输入成语并发送" value="{{battleInput}}" bindinput="onBattleInput" bindconfirm="onBattleConfirm" confirm-type="send" focus="{{battleTurn==='user'}}" />
          <view class="battle-send-btn" bindtap="onBattleConfirm">发送</view>
        </view>
        <view class="battle-ai-thinking" wx:else>
          <view class="thinking-dots">
            <view class="dot dot1"></view>
            <view class="dot dot2"></view>
            <view class="dot dot3"></view>
          </view>
          <text class="thinking-text">AI 正在思考…</text>
        </view>

        <!-- 认输按钮 -->
        <view class="surrender-btn" bindtap="onSurrender">🏳️ 认输</view>
      </block>

      <!-- 对战结束 -->
      <block wx:if="{{battleState==='ended'}}">
        <view class="result-card">
          <text class="result-emoji">{{battleResult==='win'?'🏆':'😅'}}</text>
          <text class="result-title">{{battleResult==='win'?'你赢了！':(battleResult==='timeout'?'超时判负':'你输了')}}</text>
          <view class="result-stats-row">
            <view class="result-stat-item">
              <text class="result-stat-num win">{{userStats.wins}}</text>
              <text class="result-stat-label">总胜</text>
            </view>
            <view class="result-stat-item">
              <text class="result-stat-num lose">{{userStats.losses}}</text>
              <text class="result-stat-label">总负</text>
            </view>
            <view class="result-stat-item">
              <text class="result-stat-num streak">{{userStats.bestStreak}}</text>
              <text class="result-stat-label">最佳连胜</text>
            </view>
          </view>
          <text class="result-chain-label">本局接龙（{{battleChain.length}} 个）：</text>
          <view class="result-chain-scroll">
            <text class="result-chain-text">{{battleChainText}}</text>
          </view>
          <view class="result-btns">
            <view class="restart-btn" bindtap="onRestartBattle">再来一局</view>
          </view>
        </view>
      </block>
    </view>

    <!-- ====== 接龙链 Tab ====== -->
    <view class="tab-content" wx:if="{{activeTab===2}}">
      <!-- 输入区 -->
      <view class="chain-input-card">
        <text class="chain-input-label">起始成语</text>
        <view class="chain-input-row">
          <input class="chain-input" placeholder="例如：一马当先" value="{{chainInput}}" bindinput="onChainInput" bindconfirm="onChainConfirm" />
          <view class="chain-gen-btn" bindtap="onGenerateChain">生成</view>
        </view>
        <view class="chain-len-row">
          <text class="chain-len-label">最多接</text>
          <input class="chain-len-input" type="number" value="{{chainMaxLen}}" bindinput="onChainLenInput" />
          <text class="chain-len-label">个成语</text>
        </view>
      </view>

      <!-- 提示 -->
      <view class="empty-tip" wx:if="{{chainResult.length===0 && !chainRunning}}">
        <text class="empty-icon">🔗</text>
        <text class="empty-text">{{chainTip}}</text>
      </view>
      <view class="empty-tip" wx:if="{{chainRunning}}">
        <text class="empty-icon">⏳</text>
        <text class="empty-text">正在搜索接龙链…</text>
      </view>

      <!-- 结果 -->
      <view class="chain-result-card" wx:if="{{chainResult.length>0}}">
        <view class="chain-result-header">
          <text class="chain-result-title">共 {{chainCount}} 个成语</text>
          <view class="chain-copy-btn" bindtap="onCopyChain">📋 复制</view>
        </view>
        <view class="chain-flow">
          <view class="chain-flow-item {{index===0?'flow-first':''}}" wx:for="{{chainResult}}" wx:key="index">
            <view class="flow-badge">{{index+1}}</view>
            <text class="flow-word">{{item}}</text>
            <text class="flow-arrow" wx:if="{{index < chainResult.length-1}}">→</text>
          </view>
        </view>
        <view class="chain-actions">
          <view class="chain-retry-btn" bindtap="onGenerateChain">🔄 重新生成</view>
          <view class="chain-clear-btn" bindtap="onChainClear">✕ 清空</view>
        </view>
      </view>
    </view>

  </block>

  <!-- ====== 详情弹窗 ====== -->
  <view class="detail-modal {{showDetail?'show':''}}" catchtap="onDetailClose">
    <view class="detail-box" catchtap="">
      <view class="detail-close" bindtap="onDetailClose">✕</view>
      <view wx:if="{{detailItem}}">
        <view class="detail-word">{{detailItem.word}}</view>
        <view class="detail-pinyin">{{detailItem.pinyin}}</view>
        <view class="detail-section" wx:if="{{detailItem.explanation}}">
          <text class="detail-section-title">释义</text>
          <text class="detail-section-content">{{detailItem.explanation}}</text>
        </view>
        <view class="detail-section" wx:if="{{detailItem.derivation}}">
          <text class="detail-section-title">出处</text>
          <text class="detail-section-content">{{detailItem.derivation}}</text>
        </view>
      </view>
    </view>
  </view>

</view>
