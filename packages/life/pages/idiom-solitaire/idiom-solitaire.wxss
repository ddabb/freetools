/* 成语接龙 - 样式 */

/* ===== 基础布局 ===== */
.container {
  margin: 0;
  padding: 0;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  background: #f0f2f5;
  min-height: 100vh;
  color: #333;
}

/* ===== 加载遮罩 ===== */
.loading-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.loading-spinner {
  width: 48px; height: 48px;
  border: 4px solid #e8e8e8;
  border-top-color: #3498db;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 16px; color: #333; font-weight: 600; }
.loading-sub { font-size: 13px; color: #999; }

/* ===== 错误提示 ===== */
.error-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.error-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 32px;
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  max-width: 80%;
}
.error-icon { font-size: 40px; }
.error-msg { font-size: 15px; color: #666; text-align: center; }
.retry-btn {
  background: #3498db;
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 10px 24px;
  font-size: 15px;
}

/* ===== Tab 栏 ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1px solid #e8e8e8;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 10px 0;
  color: #999;
  transition: all 0.2s;
  border-bottom: 2px solid transparent;
}
.tab-item.active {
  color: #3498db;
  border-bottom-color: #3498db;
}
.tab-icon { font-size: 20px; }
.tab-text { font-size: 13px; font-weight: 600; }

/* ===== Tab 内容区 ===== */
.tab-content {
  padding: 16px 12px;
}

/* ===== 查询 Tab ===== */
.search-bar {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}
.search-input {
  flex: 1;
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 15px;
  outline: none;
}
.search-input:focus { border-color: #3498db; }
.search-btn {
  background: #3498db;
  color: #fff;
  border-radius: 10px;
  padding: 10px 16px;
  font-size: 14px;
  font-weight: 600;
  display: flex;
  align-items: center;
  white-space: nowrap;
}

/* 历史记录 */
.history-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}
.history-label { font-size: 13px; color: #999; }
.history-chips { display: flex; gap: 6px; flex-wrap: wrap; }
.chip {
  background: #e8f4fd;
  color: #3498db;
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 13px;
}

/* 提示语 */
.tip-text {
  font-size: 13px;
  color: #999;
  text-align: center;
  padding: 20px 0;
}

/* 结果列表 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
  padding: 0 2px;
}
.result-count { font-size: 13px; color: #666; }
.copy-btn {
  background: #f0f0f0;
  color: #666;
  border-radius: 6px;
  padding: 4px 10px;
  font-size: 12px;
}
.result-item {
  background: #fff;
  border-radius: 10px;
  padding: 12px 14px;
  margin-bottom: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  transition: transform 0.15s;
}
.result-item:active { transform: scale(0.98); }
.result-main { display: flex; align-items: center; gap: 8px; }
.result-next { font-size: 16px; color: #2c3e50; font-weight: 600; }
.result-arrow { color: #3498db; font-size: 16px; }
.result-char { color: #e74c3c; font-size: 14px; }
.result-abbr { font-size: 12px; color: #bbb; }

/* ===== 对战 Tab ===== */

/* 战绩条 */
.stats-bar {
  display: flex;
  background: #fff;
  border-radius: 12px;
  padding: 12px 8px;
  margin-bottom: 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  gap: 4px;
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}
.stat-num { font-size: 22px; font-weight: 700; }
.stat-num.win { color: #27ae60; }
.stat-num.lose { color: #e74c3c; }
.stat-num.streak { color: #f39c12; }
.stat-num.best { color: #9b59b6; }
.stat-label { font-size: 11px; color: #999; }

/* 欢迎区 */
.battle-welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 24px 0;
}
.battle-welcome-icon { font-size: 48px; }
.battle-welcome-title { font-size: 20px; font-weight: 700; color: #2c3e50; }
.battle-welcome-sub { font-size: 14px; color: #999; }

/* 先手选择 */
.first-choose {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-bottom: 16px;
}
.first-btn {
  flex: 1;
  background: #fff;
  border: 2px solid #e8e8e8;
  border-radius: 12px;
  padding: 16px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  transition: all 0.2s;
  max-width: 140px;
}
.first-btn.active {
  border-color: #3498db;
  background: #e8f4fd;
}
.first-icon { font-size: 28px; }
.first-text { font-size: 14px; font-weight: 600; color: #2c3e50; }

/* 开始按钮 */
.start-btn {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #fff;
  border-radius: 25px;
  text-align: center;
  padding: 14px 0;
  font-size: 16px;
  font-weight: 700;
  margin: 0 20px;
  box-shadow: 0 4px 12px rgba(52,152,219,0.4);
}
.ready-hint { text-align: center; color: #666; font-size: 14px; margin-bottom: 12px; }

/* 对战中顶栏 */
.battle-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 10px;
  padding: 10px 16px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.battle-round { font-size: 14px; color: #666; font-weight: 600; }
.battle-timer {
  background: #e8f4fd;
  border-radius: 20px;
  padding: 4px 14px;
  display: flex;
  align-items: center;
  gap: 2px;
}
.timer-num { font-size: 20px; font-weight: 700; color: #3498db; }
.timer-label { font-size: 12px; color: #3498db; }
.timer-danger { background: #fdecea; }
.timer-danger .timer-num,
.timer-danger .timer-label { color: #e74c3c; }

/* 接龙历史 */
.battle-chain {
  max-height: 280px;
  background: #fff;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.chain-item {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}
.chain-side {
  font-size: 11px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 10px;
  flex-shrink: 0;
}
.ai-side { background: #f0f0f0; color: #999; }
.user-side { background: #e8f4fd; color: #3498db; }
.chain-word { font-size: 16px; font-weight: 600; color: #2c3e50; }
.chain-arrow-row { display: flex; align-items: center; margin-left: 36px; }
.chain-arrow { font-size: 12px; color: #bbb; }

/* 提示 */
.battle-hint {
  background: #fffbeb;
  border: 1px solid #fde68a;
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 14px;
  color: #92400e;
  text-align: center;
  margin-bottom: 12px;
}

/* 输入区 */
.battle-input-area {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}
.battle-input {
  flex: 1;
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 15px;
}
.battle-send-btn {
  background: #3498db;
  color: #fff;
  border-radius: 10px;
  padding: 10px 18px;
  font-size: 14px;
  font-weight: 600;
  display: flex;
  align-items: center;
}
.battle-ai-thinking {
  text-align: center;
  padding: 12px;
  font-size: 14px;
  color: #999;
  margin-bottom: 10px;
}

/* 认输按钮 */
.surrender-btn {
  text-align: center;
  color: #999;
  font-size: 13px;
  padding: 6px;
}

/* 结束画面 */
.result-overlay {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding: 24px 16px;
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}
.result-emoji { font-size: 56px; }
.result-title { font-size: 24px; font-weight: 700; color: #2c3e50; }
.result-sub { font-size: 13px; color: #999; }
.result-chain-label { font-size: 13px; color: #666; margin-top: 8px; }
.result-chain {
  background: #f8f9fa;
  border-radius: 10px;
  padding: 12px 16px;
  font-size: 13px;
  color: #555;
  line-height: 1.8;
  text-align: center;
  max-width: 100%;
  word-break: break-all;
}
.restart-btn {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #fff;
  border-radius: 25px;
  padding: 12px 32px;
  font-size: 15px;
  font-weight: 600;
  margin-top: 8px;
  box-shadow: 0 4px 12px rgba(52,152,219,0.4);
}

/* ===== 接龙链 Tab ===== */
.chain-input-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 12px;
}
.chain-input {
  flex: 1;
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 15px;
  min-width: 0;
}
.chain-len-label { font-size: 13px; color: #666; white-space: nowrap; }
.chain-len-input {
  width: 44px;
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 6px 8px;
  font-size: 14px;
  text-align: center;
}
.chain-gen-btn {
  background: #27ae60;
  color: #fff;
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 14px;
  font-weight: 600;
  white-space: nowrap;
}

/* 接龙链结果 */
.chain-result-count { font-size: 13px; color: #666; margin-bottom: 10px; padding: 0 2px; }
.chain-result-item {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #fff;
  border-radius: 10px;
  padding: 12px 14px;
  margin-bottom: 8px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.chain-result-item.first-item { border-left: 3px solid #3498db; }
.chain-result-index {
  font-size: 12px;
  color: #bbb;
  width: 20px;
  flex-shrink: 0;
  text-align: center;
}
.chain-result-word { font-size: 16px; font-weight: 600; color: #2c3e50; flex: 1; }
.chain-result-arrow { color: #27ae60; font-size: 14px; }
.chain-actions { display: flex; gap: 10px; margin-top: 16px; }
.chain-save-btn {
  flex: 1;
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #fff;
  border-radius: 10px;
  padding: 12px 0;
  text-align: center;
  font-size: 14px;
  font-weight: 600;
}
.chain-retry-btn {
  flex: 1;
  background: #fff;
  border: 1px solid #e0e0e0;
  color: #666;
  border-radius: 10px;
  padding: 12px 0;
  text-align: center;
  font-size: 14px;
  font-weight: 600;
}

/* ===== 详情弹窗 ===== */
.detail-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  transition: background 0.2s;
}
.detail-modal.show {
  background: rgba(0,0,0,0.5);
  pointer-events: auto;
}
.detail-box {
  background: #fff;
  border-radius: 16px;
  padding: 24px 20px;
  width: 88%;
  max-width: 340px;
  position: relative;
  transform: scale(0.9);
  transition: transform 0.2s;
  max-height: 70vh;
  overflow-y: auto;
}
.detail-modal.show .detail-box { transform: scale(1); }
.detail-close {
  position: absolute;
  top: 12px; right: 14px;
  font-size: 20px;
  color: #ccc;
}
.detail-word { font-size: 24px; font-weight: 700; color: #2c3e50; text-align: center; margin-bottom: 4px; }
.detail-pinyin { font-size: 13px; color: #999; text-align: center; margin-bottom: 16px; }
.detail-section { margin-bottom: 12px; }
.detail-section-title { font-size: 12px; color: #3498db; font-weight: 600; margin-bottom: 4px; }
.detail-section-content { font-size: 14px; color: #555; line-height: 1.7; }
