/* 成语接龙 - 样式 */

.container {
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  background: #f5f6fa;
  min-height: 100vh;
  color: #333;
}

/* ===== 加载 / 错误 ===== */
.loading-overlay, .error-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.loading-content, .error-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.loading-spinner {
  width: 80rpx; height: 80rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #e74c3c;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 30rpx; color: #333; font-weight: 600; margin-top: 8rpx; }
.loading-sub { font-size: 24rpx; color: #999; }
.error-box {
  padding: 60rpx 48rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 32rpx rgba(0,0,0,0.1);
  max-width: 80%;
}
.error-icon { font-size: 72rpx; }
.error-msg { font-size: 28rpx; color: #666; text-align: center; margin-top: 8rpx; }
.retry-btn {
  background: #e74c3c;
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 18rpx 48rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
}

/* ===== 页面头部 ===== */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #c0392b, #e74c3c);
  padding: 36rpx 32rpx 28rpx;
  color: #fff;
}
.header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.header-icon { font-size: 56rpx; }
.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
}
.header-sub {
  display: block;
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}
.header-stats {
  display: flex;
  gap: 20rpx;
}
.mini-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  min-width: 72rpx;
}
.mini-stat-num { font-size: 34rpx; font-weight: 800; line-height: 1; }
.mini-stat-num.win { color: #a8ff78; }
.mini-stat-num.lose { color: #ffb3b3; }
.mini-stat-num.streak { color: #ffd700; }
.mini-stat-label { font-size: 20rpx; opacity: 0.9; margin-top: 2rpx; }

/* ===== Tab 栏 ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 20rpx 0;
  color: #bbb;
  transition: all 0.2s;
  border-bottom: 4rpx solid transparent;
}
.tab-item.active {
  color: #e74c3c;
  border-bottom-color: #e74c3c;
}
.tab-icon { font-size: 36rpx; }
.tab-text { font-size: 24rpx; font-weight: 600; }

/* ===== 内容区 ===== */
.tab-content {
  padding: 24rpx 24rpx 40rpx;
}

/* ===== 空状态 ===== */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 60rpx 20rpx;
}
.empty-icon { font-size: 72rpx; }
.empty-text { font-size: 26rpx; color: #bbb; text-align: center; }

/* ===== 查询 Tab ===== */
.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.search-input {
  flex: 1;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
}
.search-btn {
  background: #e74c3c;
  color: #fff;
  border-radius: 20rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  white-space: nowrap;
}

.history-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}
.history-label { font-size: 24rpx; color: #bbb; white-space: nowrap; }
.history-chips { display: flex; gap: 10rpx; flex-wrap: wrap; }
.chip {
  background: #fdecea;
  color: #e74c3c;
  border-radius: 30rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.result-count { font-size: 24rpx; color: #999; }
.copy-btn {
  background: #f5f5f5;
  color: #666;
  border-radius: 20rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
}
.result-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  transition: transform 0.15s;
}
.result-item:active { transform: scale(0.98); }
.result-next { font-size: 32rpx; color: #2c3e50; font-weight: 600; }
.result-tail {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.result-char {
  font-size: 28rpx;
  color: #e74c3c;
  font-weight: 700;
  background: #fdecea;
  border-radius: 12rpx;
  padding: 6rpx 16rpx;
}
.result-arrow { font-size: 32rpx; color: #ccc; }

/* ===== 对战 Tab ===== */
.battle-welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 40rpx 0 24rpx;
}
.battle-welcome-icon { font-size: 80rpx; }
.battle-welcome-title { font-size: 36rpx; font-weight: 700; color: #2c3e50; }
.battle-welcome-sub { font-size: 26rpx; color: #999; }

.rule-card {
  background: #fff8f0;
  border: 2rpx solid #fde68a;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.rule-title { font-size: 26rpx; font-weight: 700; color: #b7791f; margin-bottom: 4rpx; }
.rule-line { font-size: 24rpx; color: #78716c; line-height: 1.6; }

.first-choose {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.first-btn {
  flex: 1;
  background: #fff;
  border: 3rpx solid #eee;
  border-radius: 20rpx;
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transition: all 0.2s;
}
.first-btn.active {
  border-color: #e74c3c;
  background: #fdecea;
}
.first-icon { font-size: 48rpx; }
.first-text { font-size: 28rpx; font-weight: 600; color: #2c3e50; }

.start-btn {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  border-radius: 50rpx;
  text-align: center;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(231,76,60,0.35);
}
.start-btn:active { opacity: 0.9; transform: scale(0.98); }

/* 对战中顶栏 */
.battle-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}
.battle-round-badge {
  background: #f5f5f5;
  color: #666;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.battle-turn-badge {
  flex: 1;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}
.turn-user { background: #e8f4fd; color: #2980b9; }
.turn-ai { background: #f0f0f0; color: #888; }

.battle-timer {
  background: #e8f4fd;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  min-width: 80rpx;
  justify-content: center;
}
.timer-num { font-size: 36rpx; font-weight: 800; color: #3498db; }
.timer-label { font-size: 22rpx; color: #3498db; }
.timer-danger { background: #fdecea; }
.timer-danger .timer-num,
.timer-danger .timer-label { color: #e74c3c; animation: blink 0.6s infinite; }
@keyframes blink { 50% { opacity: 0.5; } }

/* 提示 */
.battle-hint {
  background: #fffbeb;
  border: 2rpx solid #fde68a;
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
  color: #92400e;
  font-weight: 600;
  text-align: center;
  margin-bottom: 16rpx;
}

/* 接龙链（聊天气泡式） */
.battle-chain-scroll {
  max-height: 380rpx;
  margin-bottom: 16rpx;
}
.battle-chain { padding: 12rpx 0; }

.chain-row {
  display: flex;
  margin-bottom: 16rpx;
}
.chain-row-user { justify-content: flex-end; }
.chain-row-ai { justify-content: flex-start; }

.chain-bubble {
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  max-width: 75%;
}
.bubble-user {
  background: #e8f4fd;
  border-bottom-right-radius: 8rpx;
}
.bubble-ai {
  background: #fff;
  border: 2rpx solid #eee;
  border-bottom-left-radius: 8rpx;
}
.bubble-system {
  background: #f5f5f5;
  border: 2rpx dashed #ddd;
}
.chain-side-label {
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  background: rgba(0,0,0,0.2);
  border-radius: 20rpx;
  padding: 4rpx 12rpx;
  white-space: nowrap;
}
.bubble-user .chain-side-label { background: #3498db; }
.bubble-ai .chain-side-label { background: #888; }
.bubble-system .chain-side-label { background: #aaa; }

.chain-word { font-size: 30rpx; font-weight: 700; color: #2c3e50; }
.chain-tail-char {
  font-size: 22rpx;
  color: #e74c3c;
  background: #fdecea;
  border-radius: 10rpx;
  padding: 4rpx 10rpx;
  white-space: nowrap;
}

/* 输入区 */
.battle-input-area {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.battle-input {
  flex: 1;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}
.battle-send-btn {
  background: #e74c3c;
  color: #fff;
  border-radius: 20rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
}

/* AI 思考中 */
.battle-ai-thinking {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}
.thinking-dots { display: flex; gap: 10rpx; align-items: center; }
.dot {
  width: 16rpx; height: 16rpx;
  background: #ccc;
  border-radius: 50%;
  animation: dotBounce 1.2s infinite ease-in-out;
}
.dot1 { animation-delay: 0s; }
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }
@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}
.thinking-text { font-size: 26rpx; color: #999; }

/* 认输按钮 */
.surrender-btn {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 12rpx;
}

/* 结束画面 */
.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}
.result-emoji { font-size: 96rpx; }
.result-title { font-size: 44rpx; font-weight: 800; color: #2c3e50; }
.result-stats-row {
  display: flex;
  gap: 32rpx;
  margin: 8rpx 0;
}
.result-stat-item { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.result-stat-num { font-size: 40rpx; font-weight: 800; }
.result-stat-num.win { color: #27ae60; }
.result-stat-num.lose { color: #e74c3c; }
.result-stat-num.streak { color: #f39c12; }
.result-stat-label { font-size: 22rpx; color: #999; }
.result-chain-label { font-size: 24rpx; color: #666; align-self: flex-start; }
.result-chain-scroll {
  width: 100%;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  max-height: 160rpx;
  overflow-y: auto;
}
.result-chain-text { font-size: 26rpx; color: #555; line-height: 1.8; }
.result-btns { width: 100%; }
.restart-btn {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(231,76,60,0.35);
}

/* ===== 接龙链 Tab ===== */
.chain-input-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.chain-input-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}
.chain-input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.chain-input {
  flex: 1;
  background: #f8f8f8;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  min-width: 0;
}
.chain-gen-btn {
  background: #27ae60;
  color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
  display: flex;
  align-items: center;
}
.chain-len-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.chain-len-label { font-size: 26rpx; color: #999; }
.chain-len-input {
  width: 80rpx;
  background: #f8f8f8;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  text-align: center;
}

.chain-result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.chain-result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.chain-result-title { font-size: 28rpx; font-weight: 700; color: #27ae60; }
.chain-copy-btn {
  background: #f0faf0;
  color: #27ae60;
  border-radius: 20rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
}

.chain-flow {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.chain-flow-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.flow-badge {
  width: 36rpx; height: 36rpx;
  background: #eee;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #999;
  flex-shrink: 0;
}
.chain-flow-item.flow-first .flow-badge { background: #e74c3c; color: #fff; }
.flow-word { font-size: 28rpx; font-weight: 600; color: #2c3e50; }
.flow-arrow { font-size: 24rpx; color: #27ae60; font-weight: 700; }

.chain-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}
.chain-retry-btn {
  flex: 2;
  background: #f0faf0;
  color: #27ae60;
  border: 2rpx solid #27ae60;
  border-radius: 16rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
}
.chain-clear-btn {
  flex: 1;
  background: #f5f5f5;
  color: #999;
  border-radius: 16rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 26rpx;
}

/* ===== 详情弹窗 ===== */
.detail-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  transition: background 0.25s;
}
.detail-modal.show {
  background: rgba(0,0,0,0.55);
  pointer-events: auto;
}
.detail-box {
  background: #fff;
  border-radius: 28rpx;
  padding: 48rpx 36rpx 36rpx;
  width: 86%;
  max-width: 640rpx;
  position: relative;
  transform: scale(0.88);
  transition: transform 0.25s;
  max-height: 72vh;
  overflow-y: auto;
}
.detail-modal.show .detail-box { transform: scale(1); }
.detail-close {
  position: absolute;
  top: 20rpx; right: 28rpx;
  font-size: 36rpx;
  color: #ccc;
  font-weight: bold;
}
.detail-word { font-size: 48rpx; font-weight: 800; color: #2c3e50; text-align: center; margin-bottom: 8rpx; }
.detail-pinyin { font-size: 26rpx; color: #e74c3c; text-align: center; margin-bottom: 28rpx; }
.detail-section { margin-bottom: 20rpx; }
.detail-section-title {
  font-size: 22rpx;
  color: #e74c3c;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
  display: block;
}
.detail-section-content { font-size: 28rpx; color: #555; line-height: 1.8; }
