/* idiom-query.wxss - 成语查询页面样式 */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
  overflow: hidden;
}


/* =====================
   加载中
   ===================== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* =====================
   固定头部区域
   ===================== */
.sticky-header {
  position: fixed;
  top: 20rpx; /* 稍微下移一点 */
  left: 0;
  right: 0;
  background: #f5f5f5;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}


.sticky-content {
  width: 100%;
  max-width: 100%;
}

.content-stage {
  position: relative;
  flex: 1;
  min-height: 0;
  overflow: hidden;
  margin-top: 340rpx; /* 调整间距，保持与头部区域的距离 */
}

/* =====================
   可滚动内容区域 - 从底部滑出效果
   ===================== */
.scrollable-content {
  position: fixed;
  left: 10rpx;
  right: 10rpx;
  bottom: -100vh;
  top: auto;
  height: calc(100vh - 300rpx);
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -20rpx 60rpx rgba(79, 95, 194, 0.25);
  transform: translateY(0);
  opacity: 0;
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
  will-change: transform, opacity;
  z-index: 5;
}


/* 当有内容时滚动区域从底部滑出 */
.scrollable-content.has-content {
  bottom: 0;
  opacity: 1;
  transform: translateY(0);
}


/* =====================
   搜索框区域
   ===================== */
.search-bar {
  padding: 0 0 16rpx;
  background: linear-gradient(180deg, #e3f2fd 0%, #f5f5f5 100%);
  border-bottom: 1rpx solid #e0e0e0;
}


.search-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1565c0;
  text-align: center;
  margin-bottom: 24rpx;
}

.search-row {
  display: flex;
  align-items: center;
  width: 100%;
}

.search-input-wrap {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
}

.search-input {
  width: 100%;
  height: 84rpx;
  padding: 0 84rpx 0 32rpx;
  background: #fff;
  border-radius: 42rpx;
  font-size: 32rpx;
  color: #333;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}


.search-placeholder {
  color: #999;
  font-size: 30rpx;
}


.search-input::placeholder {
  color: #999;
}

.search-clear {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  color: #999;
  font-size: 24rpx;
  background: #f5f5f5;
  border-radius: 50%;
}

.mode-toggle {
  width: 100rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.mode-toggle:active {
  opacity: 0.85;
  transform: scale(0.97);
}

/* 顺查模式 - 蓝色系 */
.mode-toggle-forward {
  background: linear-gradient(135deg, #2980b9 0%, #3498db 100%);
  box-shadow: 0 8rpx 20rpx rgba(41, 128, 185, 0.3);
}

/* 逆查模式 - 橙色系 */
.mode-toggle-reverse {
  background: linear-gradient(135deg, #e67e22 0%, #f39c12 100%);
  box-shadow: 0 8rpx 20rpx rgba(230, 126, 34, 0.3);
}

.mode-toggle-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.search-hint {
  margin-top: 8rpx;
  padding: 0 4rpx;
}

.search-hint-text {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.6;
}

.search-helper {
  margin-top: 8rpx;
  padding: 0 4rpx;
}

.search-helper-text {
  display: block;
  font-size: 22rpx;
  line-height: 1.7;
  color: #6b7280;
}

.search-input-wrap-with-btn {
  flex: 1;
  min-width: 0;
}


/* =====================
   历史记录区域
   ===================== */
.history-section {
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.history-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 0 18rpx;
}


.history-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.history-scroll {
  flex: 1;
  white-space: nowrap;
  max-width: 100%;
  overflow-x: auto;
}

.history-chips {
  display: flex;
  gap: 12rpx;
  min-width: min-content;
}

.chip {
  padding: 12rpx 24rpx;
  background: #f0f2ff;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #4f5fc2;
  white-space: nowrap;
  flex-shrink: 0;
}

/* =====================
   空状态提示
   ===================== */
.empty-tip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

/* =====================
   结果列表
   ===================== */
.result-list {
  flex: 1;
  min-height: 0;
  padding: 20rpx 0 0 0;
  height: 100%;
}


.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 10rpx; /* 左右添加10rpx间距 */
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-count {
  font-size: 26rpx;
  color: #666;
}

.copy-btn {
  padding: 8rpx 24rpx;
  background: #f0f2ff;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #4f5fc2;
}

.result-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 0 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.result-item:last-child {
  margin-bottom: 0;
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-main {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}


.result-word {
  font-size: 28rpx;
  color: #666;
}

.result-arrow-icon {
  margin: 0 16rpx;
  font-size: 28rpx;
  color: #555;
}

.result-next {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 查询词本身：蓝色高亮，底部点线提示可点击查释义 */
.result-query-word {
  color: #1565c0;
  border-bottom: 2rpx dotted #1565c0;
  padding-bottom: 2rpx;
}

/* 候选词（接龙结果）：深色，底部点线提示可点击查释义 */
.result-candidate-word {
  border-bottom: 2rpx dotted #aaa;
  padding-bottom: 2rpx;
}

.result-tail {
  display: flex;
  align-items: center;
}

.result-action {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(238, 90, 111, 0.3);
}


/* =====================
   详情弹窗
   ===================== */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s ease;
  pointer-events: none;
}

.detail-modal.show {
  background: rgba(0, 0, 0, 0.6);
  pointer-events: auto;
}

.detail-box {
  position: relative;
  width: 600rpx;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  overflow-y: auto;
  transform: scale(0.8);
  opacity: 0;
  transition: all 0.3s ease;
}

.detail-modal.show .detail-box {
  transform: scale(1);
  opacity: 1;
}

.detail-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: #666;
  background: #eee;
  border-radius: 50%;
}

.detail-word {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.detail-pinyin {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 32rpx;
}

.detail-section {
  margin-bottom: 24rpx;
}

.detail-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.detail-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1976d2;
}

.detail-copy-btn {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e0e0e0;
}

.detail-copy-btn-hover {
  background: #e0e0e0;
}

.detail-section-content {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}
