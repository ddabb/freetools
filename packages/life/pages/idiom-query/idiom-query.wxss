/* idiom-query.wxss - 成语查询页面样式 */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* =====================
   加载中
   ===================== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* =====================
   固定头部区域
   ===================== */
.sticky-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #f5f5f5;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.sticky-content {
  width: 100%;
  max-width: 100%;
}

/* =====================
   可滚动内容区域
   ===================== */
.scrollable-content {
  position: fixed;
  top: 200rpx; /* 增加顶部间距，避免被固定区域遮盖 */
  left: 10rpx; /* 左侧10rpx间距 */
  right: 10rpx; /* 右侧10rpx间距 */
  bottom: 0;
  z-index: 99;
  background: #f5f5f5;
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.1);
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  overflow: hidden;
}

/* 当有内容时滚动区域从底部弹出 */
.scrollable-content.has-content {
  transform: translateY(0);
}

/* =====================
   搜索框区域
   ===================== */
.search-bar {
  padding: 20rpx 0 30rpx;
  background: linear-gradient(180deg, #e3f2fd 0%, #f5f5f5 100%);
  border-bottom: 1rpx solid #e0e0e0;
}

.search-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1565c0;
  text-align: center;
  margin-bottom: 24rpx;
}

.search-row {
  display: flex;
  align-items: center;
  width: 100%;
}

.search-input-wrap {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
}

.search-input {
  width: 100%;
  height: 96rpx;
  padding: 0 80rpx 0 30rpx;
  background: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #333;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.search-placeholder {
  text-align: center;
  color: #999;
  font-size: 30rpx;
}

.search-input::placeholder {
  color: #999;
}

.search-clear {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  color: #999;
  font-size: 24rpx;
  background: #f5f5f5;
  border-radius: 50%;
}

.search-btn {
  margin-left: 20rpx;
  padding: 0 40rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.3);
  flex-shrink: 0;
}

.search-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* =====================
   历史记录区域
   ===================== */
.history-section {
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.history-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.history-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.history-scroll {
  flex: 1;
  white-space: nowrap;
}

.history-chips {
  display: flex;
  gap: 12rpx;
}

.chip {
  padding: 12rpx 24rpx;
  background: #f0f2ff;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #667eea;
  white-space: nowrap;
  flex-shrink: 0;
}

/* =====================
   空状态提示
   ===================== */
.empty-tip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

/* =====================
   结果列表
   ===================== */
.result-list {
  flex: 1;
  padding: 20rpx 0 0 0; /* 顶部添加20rpx间距 */
  height: 100%;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 10rpx; /* 左右添加10rpx间距 */
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-count {
  font-size: 26rpx;
  color: #666;
}

.copy-btn {
  padding: 8rpx 24rpx;
  background: #f0f2ff;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #667eea;
}

.result-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 0 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.result-item:last-child {
  margin-bottom: 0;
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-main {
  display: flex;
  align-items: center;
  flex: 1;
  margin-right: 20rpx;
}

.result-word {
  font-size: 28rpx;
  color: #999;
}

.result-arrow-icon {
  margin: 0 16rpx;
  font-size: 28rpx;
  color: #ccc;
}

.result-next {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.result-tail {
  display: flex;
  align-items: center;
}

.result-hint {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.result-char {
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(238, 90, 111, 0.3);
}

.result-char-active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* =====================
   详情弹窗
   ===================== */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s ease;
  pointer-events: none;
}

.detail-modal.show {
  background: rgba(0, 0, 0, 0.6);
  pointer-events: auto;
}

.detail-box {
  position: relative;
  width: 600rpx;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  overflow-y: auto;
  transform: scale(0.8);
  opacity: 0;
  transition: all 0.3s ease;
}

.detail-modal.show .detail-box {
  transform: scale(1);
  opacity: 1;
}

.detail-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: #999;
  background: #f5f5f5;
  border-radius: 50%;
}

.detail-word {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.detail-pinyin {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 32rpx;
}

.detail-section {
  margin-bottom: 24rpx;
}

.detail-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.detail-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1976d2;
}

.detail-copy-btn {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e0e0e0;
}

.detail-copy-btn:active {
  background: #e0e0e0;
}

.detail-section-content {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}
