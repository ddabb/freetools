<!-- idiom-query.wxml - 成语查询页面 -->
<view class="container">

  <!-- 加载中 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <text class="loading-text">加载数据中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:if="{{error}}" class="error-container">
    <error-state
      text="{{errorText}}"
      subText="{{errorSubText}}"
      showButton="{{true}}"
      buttonText="重试"
      bindbuttonClick="onErrorRetry"
    />
  </view>

  <!-- 固定顶部区域：搜索栏、历史记录 -->
  <view class="sticky-header">
    <view class="sticky-content">
      <!-- 搜索框区域 -->
      <view class="search-bar">
        <view class="search-row">
          <view class="search-input-wrap search-input-wrap-with-btn">
            <input
              class="search-input"
              placeholder="{{queryPlaceholder}}"
              placeholder-class="search-placeholder"
              value="{{queryInput}}"
              bindinput="onQueryInput"
              bindconfirm="onQueryConfirm"
              confirm-type="search"
            />
            <view class="search-clear" wx:if="{{queryInput}}" bindtap="onClearQuery">✕</view>
          </view>
          <view class="mode-toggle mode-toggle-{{queryMode}}" bindtap="onQueryModeToggle">
            <text class="mode-toggle-text">{{queryMode === 'forward' ? '顺查' : '逆查'}}</text>
          </view>
        </view>
        <view class="search-helper">
          <text class="search-helper-text">顺查看后续可接成语，逆查看前面可接成语；点词条看释义，点右侧按钮继续查询</text>
        </view>
      </view>

      <!-- 历史记录 -->
      <view class="history-section" wx:if="{{queryHistory.length > 0}}">
        <view class="history-bar">
          <text class="history-label">最近：</text>
          <scroll-view class="history-scroll" scroll-x enhanced show-scrollbar="false">
            <view class="history-chips">
              <view
                class="chip"
                wx:for="{{queryHistory}}"
                wx:key="index"
                data-word="{{item}}"
                bindtap="onHistoryTap"
              >{{item}}</view>
            </view>
          </scroll-view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部滑出结果区域 -->
  <view class="content-stage">
    <view class="scrollable-content {{hasContent ? 'has-content' : ''}}">
      <view class="result-header" wx:if="{{queryResults.length > 0}}">
        <text class="result-count">{{queryTip}}</text>
        <view class="copy-btn" bindtap="onCopyResult">📋 复制</view>
      </view>

      <!-- 提示语（无结果时） -->
      <view class="empty-tip" wx:if="{{queryResults.length === 0}}">
        <text class="empty-icon">🀄</text>
        <text class="empty-text">{{queryTip}}</text>
      </view>

      <!-- 模糊匹配列表（多结果时展示） -->
      <view class="fuzzy-section" wx:if="{{fuzzyResults.length > 0}}">
        <view class="fuzzy-header">
          <text class="fuzzy-title">找到 {{fuzzyResults.length}} 条匹配，请点选成语</text>
        </view>
        <view class="fuzzy-list">
          <view
            class="fuzzy-item"
            wx:for="{{fuzzyResults}}"
            wx:key="index"
            data-word="{{item.word}}"
            bindtap="onFuzzyTap"
          >
            <text class="fuzzy-word">{{item.word}}</text>
            <text class="fuzzy-arrow">→</text>
          </view>
        </view>
      </view>

      <!-- 接龙结果列表 -->
      <scroll-view
        class="result-list"
        wx:if="{{queryResults.length > 0}}"
        scroll-y
        enhanced
        show-scrollbar="false"
      >

      <view
        class="result-item"
        wx:for="{{queryResults}}"
        wx:key="index"
      >
        <view class="result-row">
          <view class="result-main">
            <text
              class="{{item.leftClass}}"
              data-word="{{item.leftWord}}"
              catchtap="onWordTap"
            >{{item.leftWord}}</text>
            <text class="result-arrow-icon">→</text>
            <text
              class="{{item.rightClass}}"
              data-word="{{item.rightWord}}"
              catchtap="onWordTap"
            >{{item.rightWord}}</text>
          </view>
          <view class="result-tail">
            <text
              class="result-action {{item.canContinue === false ? 'result-action-disabled' : ''}}"
              data-word="{{item.continueWord}}"
              catchtap="{{item.canContinue !== false ? 'onContinueChain' : ''}}"
            >{{item.actionText}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 详情弹窗 - 使用通用组件 -->
  <tool-detail-modal
    show="{{showDetail}}"
    type="idiom"
    data="{{detailItem}}"
    showCopy="{{true}}"
    bindclose="onDetailClose"
    bindcopy="onDetailCopy"
  />

</view>
  <!-- 搴曢儴骞垮憡 -->
  <ad unit-id="adunit-07e9c9da9e4b8254" ad-intervals="30" binderror="onAdError" bindclose="onAdClose"></ad>
</view>
