<!--packages/life/pages/time-tool/time-tool.wxml-->
<view class="container">
  <!-- 标签页切换 -->
  <view class="tabs">
    <view
      class="tab {{activeTab === index ? 'active' : ''}}" hover-class="tab-hover"
      wx:for="{{tabs}}"
      wx:key="index"
      bindtap="onTabChange"
      data-index="{{index}}"
    >
      <view class="tab-content-wrapper" hover-class="tab-hover">
        <text class="tab-emoji">{{index === 0 ? '⏱️' : index === 1 ? '⏰' : '🌍'}}</text>
        <text class="tab-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 秒表 -->
  <view class="tab-content" hover-class="tab-hover" wx:if="{{activeTab === 0}}">
    <view class="stopwatch-content">
      <view class="display-container">
        <view class="stopwatch-display">{{stopwatch.display}}</view>
      </view>
      
      <view class="button-container">
        <view class="button-group">
          <button
            class="btn {{stopwatch.isRunning ? 'stop' : 'start'}}" hover-class="btn-hover"
            bindtap="toggleStopwatch"
          >
            {{stopwatch.isRunning ? '暂停' : '开始'}}
          </button>
          <button class="btn lap" hover-class="btn-hover" bindtap="lapStopwatch">计次</button>
          <button class="btn reset" hover-class="btn-hover" bindtap="resetStopwatch">重置</button>
        </view>
      </view>

      <view class="laps-section" wx:if="{{stopwatch.laps.length > 0}}">
        <text class="section-title">计次记录</text>
        <scroll-view class="laps-container" scroll-y>
          <view class="lap-item" wx:for="{{stopwatch.laps}}" wx:key="number">
            <text class="lap-number">Lap {{item.number}}</text>
            <text class="lap-time">{{item.time}}</text>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <!-- 计时器 -->
  <view class="tab-content" hover-class="tab-hover" wx:if="{{activeTab === 1}}">
    <view class="timer-content">
      <view class="display-container">
        <view class="timer-display">{{timer.display}}</view>
      </view>

      <view class="time-inputs-section" wx:if="{{!timer.isRunning}}">
        <text class="section-title">设置时间</text>
        <view class="time-inputs">
          <view class="time-input-group">
            <text class="time-label">小时</text>
            <input
              type="number"
              value="{{timer.hours}}"
              bindinput="onTimerTimeChange"
              data-type="hours"
              class="time-input"
              maxlength="2"
             placeholder-class="input-placeholder"/>
          </view>
          <text class="time-separator">:</text>
          <view class="time-input-group">
            <text class="time-label">分钟</text>
            <input
              type="number"
              value="{{timer.minutes}}"
              bindinput="onTimerTimeChange"
              data-type="minutes"
              class="time-input"
              maxlength="2"
             placeholder-class="input-placeholder"/>
          </view>
          <text class="time-separator">:</text>
          <view class="time-input-group">
            <text class="time-label">秒</text>
            <input
              type="number"
              value="{{timer.seconds}}"
              bindinput="onTimerTimeChange"
              data-type="seconds"
              class="time-input"
              maxlength="2"
             placeholder-class="input-placeholder"/>
          </view>
        </view>
      </view>

      <view class="button-container">
        <view class="button-group">
          <button
            class="btn {{timer.isRunning ? (timer.isPaused ? 'start' : 'stop') : 'start'}}" hover-class="btn-hover"
            bindtap="toggleTimer"
          >
            {{timer.isRunning ? (timer.isPaused ? '继续' : '暂停') : '开始'}}
          </button>
          <button class="btn reset" hover-class="btn-hover" bindtap="resetTimer">重置</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 世界时钟 -->
  <view class="tab-content" hover-class="tab-hover" wx:if="{{activeTab === 2}}">
    <view class="world-clock-content">
      <text class="section-title">世界时间</text>
      <view class="world-clock">
        <view class="clock-grid">
          <view class="clock-card" hover-class="clock-card-hover">
            <view class="clock-header">
              <text class="clock-icon">🇨🇳</text>
              <text class="clock-label">北京时间</text>
            </view>
            <text class="clock-time">{{worldClock.beijing}}</text>
            <text class="clock-date">{{getCurrentDate('beijing')}}</text>
          </view>
          <view class="clock-card" hover-class="clock-card-hover">
            <view class="clock-header">
              <text class="clock-icon">🇯🇵</text>
              <text class="clock-label">东京时间</text>
            </view>
            <text class="clock-time">{{worldClock.tokyo}}</text>
            <text class="clock-date">{{getCurrentDate('tokyo')}}</text>
          </view>
          <view class="clock-card" hover-class="clock-card-hover">
            <view class="clock-header">
              <text class="clock-icon">🇬🇧</text>
              <text class="clock-label">伦敦时间</text>
            </view>
            <text class="clock-time">{{worldClock.london}}</text>
            <text class="clock-date">{{getCurrentDate('london')}}</text>
          </view>
          <view class="clock-card" hover-class="clock-card-hover">
            <view class="clock-header">
              <text class="clock-icon">🇺🇸</text>
              <text class="clock-label">纽约时间</text>
            </view>
            <text class="clock-time">{{worldClock.newYork}}</text>
            <text class="clock-date">{{getCurrentDate('newYork')}}</text>
          </view>
        </view>
      </view>
      
      <!-- 跳转链接 -->
      <view class="action-section">
        <view class="action-card" hover-class="action-card-hover" bindtap="gotoTimezoneConverter">
          <view class="action-icon">🌍</view>
          <view class="action-content">
            <text class="action-title">时区转换器</text>
            <text class="action-desc">更多时区转换功能</text>
          </view>
          <view class="action-arrow">›</view>
        </view>
      </view>
    </view>
  </view>
  <!-- 搴曢儴骞垮憡 -->
  <ad unit-id="adunit-07e9c9da9e4b8254" ad-intervals="30" binderror="onAdError" bindclose="onAdClose"></ad>
</view>
