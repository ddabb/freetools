/**packages/life/pages/time-tool/time-tool.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.container {
  padding: 15rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 标签页 */
.tabs {
  display: flex;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0.15) 100%);
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  width: 100%;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 25rpx 15rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
  border-radius: 16rpx;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  margin: 0 3rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
}

.tab.active {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  color: #f5576c;
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(245, 87, 108, 0.3);
  transform: translateY(-1rpx);
}

.tab-content-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.tab-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.tab-text {
  font-size: 26rpx;
  line-height: 1;
}

.tab-hover {
  transform: scale(0.95);
}

/* 标签页内容 */
.tab-content {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 25rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
}

/* 秒表内容容器 */
.stopwatch-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 40vh;
}

/* 计时器内容容器 */
.timer-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 40vh;
}

/* 显示容器 */
.display-container {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 25rpx;
  min-height: 120rpx;
}

/* 秒表显示 */
.stopwatch-display {
  font-size: 70rpx;
  font-weight: 800;
  color: #f5576c;
  text-align: center;
  font-family: 'Courier New', monospace;
  line-height: 1.2;
}

/* 计时器显示 */
.timer-display {
  font-size: 80rpx;
  font-weight: 800;
  color: #f5576c;
  text-align: center;
  font-family: 'Courier New', monospace;
  line-height: 1.2;
}

/* 按钮容器 */
.button-container {
  margin-bottom: 25rpx;
  flex-shrink: 0;
}

/* 按钮组 */
.button-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 0;
  flex-wrap: wrap;
}

.btn {
  flex: 1;
  min-width: 0;
  padding: 24rpx 8rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70rpx;
  transition: all 0.2s ease;
}

.btn.start {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  box-shadow: 0 6rpx 15rpx rgba(17, 153, 142, 0.4);
}

.btn.stop {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  box-shadow: 0 6rpx 15rpx rgba(245, 87, 108, 0.4);
}

.btn.lap {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 6rpx 15rpx rgba(102, 126, 234, 0.4);
}

.btn.reset {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  box-shadow: 0 6rpx 15rpx rgba(250, 112, 154, 0.4);
}

.btn-hover {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 分区标题 */
.section-title {
  font-size: 32rpx;
  color: #666;
  font-weight: 700;
  display: block;
  margin-bottom: 25rpx;
  text-align: center;
}

/* 计次记录区域 */
.laps-section {
  flex: 1;
  margin-top: 20rpx;
}

.laps-container {
  max-height: 40vh;
  padding-right: 10rpx;
}

.lap-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 25rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border-left: 6rpx solid #f5576c;
}

.lap-number {
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
}

.lap-time {
  font-size: 30rpx;
  color: #f5576c;
  font-weight: 700;
  font-family: 'Courier New', monospace;
}

/* 时间输入区域 */
.time-inputs-section {
  margin-bottom: 30rpx;
}

.time-inputs {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 0;
}

.time-input-group {
  text-align: center;
  flex: 1;
}

.time-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.time-input {
  width: 100%;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 3rpx solid #f5576c;
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #f5576c;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.time-separator {
  font-size: 40rpx;
  font-weight: 700;
  color: #f5576c;
  margin: 0 5rpx;
  line-height: 90rpx;
}

/* 世界时钟内容容器 */
.world-clock-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 40vh;
}

/* 世界时钟 */
.world-clock {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.clock-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
  width: 100%;
}

.clock-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 20rpx;
  padding: 25rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid rgba(245, 87, 108, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: all 0.3s ease;
}

.clock-card-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.15);
}

.clock-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 15rpx;
}

.clock-icon {
  font-size: 36rpx;
}

.clock-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
}

.clock-time {
  font-size: 32rpx;
  color: #f5576c;
  font-weight: 700;
  font-family: 'Courier New', monospace;
  margin-bottom: 8rpx;
}

.clock-date {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

/* 跳转链接区域 */
.action-section {
  width: 100%;
  margin-top: 20rpx;
  max-width: 100%;
}

.action-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 25rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.action-card-hover {
  transform: scale(0.98);
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.6);
}

.action-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.action-content {
  flex: 1;
}

.action-title {
  font-size: 30rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 5rpx;
}

.action-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

.action-arrow {
  font-size: 36rpx;
  font-weight: 700;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .stopwatch-display {
    font-size: 60rpx;
  }
  
  .timer-display {
    font-size: 70rpx;
  }
  
  .btn {
    font-size: 28rpx;
    padding: 24rpx 8rpx;
  }
  
  .time-input {
    height: 80rpx;
    font-size: 32rpx;
  }
  
  .clock-time {
    font-size: 32rpx;
  }
}
