/* packages/life/pages/answer-book/answer-book.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0c0c1e 0%, #1a1a3e 50%, #2d1b4e 100%);
  padding: 30rpx 30rpx 40rpx;
  box-sizing: border-box;
}

/* 头部 */
.header {
  text-align: center;
  padding: 20rpx 0 30rpx;
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #c084fc;
  text-shadow: 0 0 30rpx rgba(192, 132, 252, 0.5);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 10rpx;
}

/* 水晶球容器 */
.magic-ball-container {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 30rpx;
}

.magic-ball {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #2c1654, #4a2c7a, #6b3fa0);
  position: relative;
  box-shadow:
    0 0 60rpx rgba(155, 89, 182, 0.4),
    inset 0 -20rpx 40rpx rgba(0, 0, 0, 0.3),
    inset 0 20rpx 40rpx rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.5s ease;
}

.magic-ball.shake {
  animation: shake 1.2s ease-in-out;
}

.magic-ball.glow {
  box-shadow:
    0 0 100rpx rgba(155, 89, 182, 0.6),
    0 0 150rpx rgba(155, 89, 182, 0.4),
    inset 0 -20rpx 40rpx rgba(0, 0, 0, 0.3),
    inset 0 20rpx 40rpx rgba(255, 255, 255, 0.15);
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg) scale(1); }
  10% { transform: rotate(-20deg) scale(1.05); }
  20% { transform: rotate(20deg) scale(1.05); }
  30% { transform: rotate(-15deg) scale(1.03); }
  40% { transform: rotate(15deg) scale(1.03); }
  50% { transform: rotate(-10deg) scale(1.02); }
  60% { transform: rotate(10deg) scale(1.02); }
  70% { transform: rotate(-5deg) scale(1.01); }
  80% { transform: rotate(5deg) scale(1.01); }
  90% { transform: rotate(-2deg); }
}

.ball-shine {
  position: absolute;
  top: 35rpx;
  left: 55rpx;
  width: 50rpx;
  height: 35rpx;
  background: rgba(255, 255, 255, 0.35);
  border-radius: 50%;
  transform: rotate(-30deg);
  pointer-events: none;
}

.ball-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ball-icon {
  font-size: 80rpx;
}

/* 答案展示区域 */
.answer-section {
  margin: 0 10rpx 25rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.4s ease;
  pointer-events: none;
}

.answer-section.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.answer-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 30rpx;
  padding: 35rpx 30rpx;
  text-align: center;
  border: 2rpx solid rgba(192, 132, 252, 0.3);
}

.answer-card.positive {
  border-color: rgba(34, 197, 94, 0.4);
  background: rgba(34, 197, 94, 0.1);
}

.answer-card.negative {
  border-color: rgba(239, 68, 68, 0.4);
  background: rgba(239, 68, 68, 0.1);
}

.answer-card.mystical {
  border-color: rgba(251, 191, 36, 0.4);
  background: rgba(251, 191, 36, 0.1);
}

.answer-type-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  margin-bottom: 20rpx;
}

.type-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.type-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.answer-text {
  display: block;
  font-size: 38rpx;
  color: #fff;
  line-height: 1.6;
  letter-spacing: 2rpx;
  margin-bottom: 25rpx;
}

.answer-actions {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 15rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
}

.action-item:active {
  background: rgba(255, 255, 255, 0.2);
}

.action-item text:first-child {
  font-size: 30rpx;
  margin-right: 8rpx;
}

.action-item text:last-child {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 问题输入 */
.question-section {
  padding: 15rpx 5rpx 20rpx;
}

.question-input {
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(192, 132, 252, 0.3);
  border-radius: 25rpx;
  padding: 28rpx 35rpx;
  font-size: 30rpx;
  color: #fff;
  text-align: center;
}

.question-input::placeholder {
  color: rgba(255, 255, 255, 0.35);
}

.question-hint {
  text-align: center;
  margin-top: 15rpx;
}

.question-hint text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
}

/* 历史切换按钮 */
.history-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin: 15rpx 5rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 15rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.history-toggle:active {
  background: rgba(255, 255, 255, 0.08);
}

.history-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.history-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.toggle-icon {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-left: 10rpx;
  transition: transform 0.3s ease;
}

.toggle-icon.up {
  transform: rotate(180deg);
}

/* 历史面板 */
.history-panel {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 25rpx;
  margin: 0 5rpx;
  padding: 25rpx 20rpx;
  max-height: 380rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.history-title {
  font-size: 28rpx;
  color: #c084fc;
  font-weight: bold;
}

.history-clear {
  font-size: 24rpx;
  color: #ef4444;
}

.history-empty {
  text-align: center;
  padding: 40rpx;
  color: rgba(255, 255, 255, 0.35);
  font-size: 26rpx;
}

.history-list {
  max-height: 300rpx;
}

.history-item {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 15rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  border-left: 4rpx solid rgba(192, 132, 252, 0.4);
}

.history-item.positive {
  border-left-color: rgba(34, 197, 94, 0.6);
}

.history-item.negative {
  border-left-color: rgba(239, 68, 68, 0.6);
}

.history-item.mystical {
  border-left-color: rgba(251, 191, 36, 0.6);
}

.history-q {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.q-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.q-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
}

.history-a {
  display: flex;
  align-items: center;
  padding: 12rpx 15rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10rpx;
}

.a-type {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.a-text {
  font-size: 26rpx;
  color: #c084fc;
  line-height: 1.4;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  margin-top: 35rpx;
}

.footer-tip text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}
