/* packages/life/pages/answer-book/answer-book.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0c0c1e 0%, #1a1a3e 50%, #2d1b4e 100%);
  padding: 30rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* 头部 */
.header {
  text-align: center;
  padding: 20rpx 0 30rpx;
}

.header-main {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #c084fc;
  text-shadow: 0 0 30rpx rgba(192, 132, 252, 0.5);
  margin-right: 16rpx;
}

.header-icon {
  font-size: 48rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 设置栏 */
.settings-bar {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 30rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.setting-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.setting-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 水晶球容器 */
.magic-ball-container {
  display: flex;
  justify-content: center;
  padding: 30rpx 0 40rpx;
}

.magic-ball {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #2c1654, #4a2c7a, #6b3fa0);
  position: relative;
  box-shadow:
    0 0 80rpx rgba(155, 89, 182, 0.4),
    inset 0 -30rpx 60rpx rgba(0, 0, 0, 0.4),
    inset 0 30rpx 60rpx rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.5s ease;
}

.magic-ball.has-result {
  box-shadow:
    0 0 120rpx rgba(192, 132, 252, 0.6),
    0 0 180rpx rgba(192, 132, 252, 0.3),
    inset 0 -30rpx 60rpx rgba(0, 0, 0, 0.4),
    inset 0 30rpx 60rpx rgba(255, 255, 255, 0.15);
}

/* 摇动动画 */
.shake-animation {
  animation: shake 1.2s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg) scale(1); }
  5% { transform: rotate(-25deg) scale(1.08); }
  10% { transform: rotate(25deg) scale(1.08); }
  15% { transform: rotate(-20deg) scale(1.06); }
  20% { transform: rotate(20deg) scale(1.06); }
  25% { transform: rotate(-15deg) scale(1.04); }
  30% { transform: rotate(15deg) scale(1.04); }
  35% { transform: rotate(-10deg) scale(1.03); }
  40% { transform: rotate(10deg) scale(1.03); }
  45% { transform: rotate(-8deg) scale(1.02); }
  50% { transform: rotate(8deg) scale(1.02); }
  55% { transform: rotate(-5deg) scale(1.01); }
  60% { transform: rotate(5deg) scale(1.01); }
  65% { transform: rotate(-3deg) scale(1.005); }
  70% { transform: rotate(3deg) scale(1.005); }
  75% { transform: rotate(-2deg); }
  80% { transform: rotate(2deg); }
  85% { transform: rotate(-1deg); }
  90% { transform: rotate(1deg); }
}

/* 发光动画 */
.glow-animation {
  animation: glow 2s ease-in-out infinite alternate;
}

@keyframes glow {
  from {
    box-shadow:
      0 0 80rpx rgba(192, 132, 252, 0.5),
      0 0 120rpx rgba(192, 132, 252, 0.3);
  }
  to {
    box-shadow:
      0 0 120rpx rgba(192, 132, 252, 0.7),
      0 0 180rpx rgba(192, 132, 252, 0.4);
  }
}

.ball-shine {
  position: absolute;
  top: 40rpx;
  left: 60rpx;
  width: 60rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 50%;
  transform: rotate(-30deg);
  pointer-events: none;
}

.ball-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ball-icon {
  font-size: 90rpx;
  margin-bottom: 10rpx;
}

.ball-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 粒子效果 */
.particles {
  position: absolute;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.particle {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  opacity: 0;
}

.shake-animation .particle {
  animation: particle-float 1.2s ease-out;
}

.particle.p1 { top: 20%; left: 20%; animation-delay: 0s; }
.particle.p2 { top: 30%; right: 15%; animation-delay: 0.2s; }
.particle.p3 { bottom: 25%; left: 25%; animation-delay: 0.4s; }
.particle.p4 { bottom: 20%; right: 20%; animation-delay: 0.6s; }

@keyframes particle-float {
  0% { opacity: 0; transform: scale(0); }
  20% { opacity: 1; transform: scale(1); }
  80% { opacity: 1; transform: scale(1) translateY(-20rpx); }
  100% { opacity: 0; transform: scale(0) translateY(-40rpx); }
}

/* 答案展示区域 */
.answer-section {
  margin: 0 10rpx 30rpx;
  opacity: 0;
  transform: translateY(30rpx) scale(0.95);
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: none;
}

.answer-section.show {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: auto;
}

.answer-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  border: 2rpx solid rgba(192, 132, 252, 0.3);
  backdrop-filter: blur(10rpx);
}

.answer-card.positive {
  border-color: rgba(34, 197, 94, 0.5);
  background: rgba(34, 197, 94, 0.12);
}

.answer-card.negative {
  border-color: rgba(239, 68, 68, 0.5);
  background: rgba(239, 68, 68, 0.12);
}

.answer-card.mystical {
  border-color: rgba(245, 158, 11, 0.5);
  background: rgba(245, 158, 11, 0.12);
}

.answer-type-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  margin-bottom: 24rpx;
}

.type-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.type-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.answer-text {
  display: block;
  font-size: 42rpx;
  color: #fff;
  line-height: 1.6;
  letter-spacing: 2rpx;
  margin-bottom: 30rpx;
  font-weight: 500;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
}

.answer-actions {
  display: flex;
  justify-content: center;
  gap: 30rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 36rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  min-width: 120rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #c084fc 0%, #9333ea 100%);
}

.action-btn:active {
  transform: scale(0.95);
}

.btn-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.btn-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 问题输入 */
.question-section {
  padding: 20rpx 10rpx 30rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(192, 132, 252, 0.3);
  border-radius: 30rpx;
  padding: 24rpx 30rpx;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  opacity: 0.6;
}

.question-input {
  flex: 1;
  font-size: 32rpx;
  color: #fff;
  background: transparent;
}

.question-input::placeholder {
  color: rgba(255, 255, 255, 0.35);
}

.clear-btn {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  padding: 10rpx;
}

.question-hint {
  text-align: center;
  margin-top: 20rpx;
}

.question-hint text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 历史记录面板 */
.history-panel {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 25rpx;
  margin: 0 10rpx 30rpx;
  padding: 30rpx 25rpx;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: all 0.4s ease;
}

.history-panel.show {
  max-height: 600rpx;
  opacity: 1;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.history-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #c084fc;
  font-weight: bold;
}

.title-icon {
  margin-right: 12rpx;
}

.history-clear {
  font-size: 26rpx;
  color: #ef4444;
  padding: 10rpx 20rpx;
  background: rgba(239, 68, 68, 0.1);
  border-radius: 20rpx;
}

.history-empty {
  text-align: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 60rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.history-empty text:last-child {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

.history-list {
  max-height: 450rpx;
}

.history-item {
  background: rgba(0, 0, 0, 0.25);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid rgba(192, 132, 252, 0.5);
}

.history-item.positive {
  border-left-color: rgba(34, 197, 94, 0.7);
}

.history-item.negative {
  border-left-color: rgba(239, 68, 68, 0.7);
}

.history-item.mystical {
  border-left-color: rgba(245, 158, 11, 0.7);
}

.history-main {
  margin-bottom: 16rpx;
}

.history-q {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.q-icon {
  width: 40rpx;
  height: 40rpx;
  background: rgba(192, 132, 252, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #c084fc;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.q-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
  flex: 1;
}

.history-a {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
}

.a-type {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.a-text {
  font-size: 28rpx;
  color: #c084fc;
  line-height: 1.4;
  flex: 1;
}

.history-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}

.replay-hint {
  font-size: 22rpx;
  color: rgba(192, 132, 252, 0.7);
}

/* 答案类型说明 */
.type-legend {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 0 10rpx 30rpx;
}

.legend-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
  text-align: center;
}

.legend-items {
  display: flex;
  justify-content: space-around;
}

.legend-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.legend-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 10rpx;
}

.legend-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding-top: 20rpx;
}

.footer-tip text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.25);
}
