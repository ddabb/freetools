<view class="container">
  <!-- 顶部标题 -->
  <view class="hero-section">
    <view class="hero-badge">
      <text class="badge-icon">🎵</text>
      <text class="badge-text">电子木鱼</text>
    </view>
    <view class="hero-quote" bindtap="showRandomPhrase">
      <text class="quote-text">"{{currentText}}"</text>
      <text class="quote-hint">点击换一句</text>
    </view>
  </view>

  <!-- 功德统计卡片 -->
  <view class="merit-card">
    <view class="merit-main">
      <view class="merit-number">
        <text class="merit-count">{{meritCount}}</text>
      </view>
      <view class="merit-label">累计功德</view>
    </view>
    <view class="merit-divider"></view>
    <view class="merit-today">
      <text class="today-num">{{todayMerit}}</text>
      <text class="today-label">今日功德</text>
    </view>
  </view>

  <!-- 木鱼区域 -->
  <view class="woodfish-section">
    <!-- 涟漪效果 -->
    <view class="ripple-container" wx:if="{{showRipple}}">
      <view class="ripple ripple-1"></view>
      <view class="ripple ripple-2"></view>
      <view class="ripple ripple-3"></view>
    </view>

    <!-- 木鱼本体 -->
    <view class="woodfish-container" bindtap="strikeWoodfish">
      <view class="woodfish {{isStriking ? 'striking' : ''}}">
        <view class="woodfish-body">
          <text class="woodfish-emoji">🪘</text>
          <view class="woodfish-shine"></view>
        </view>
        <!-- 功德数字飘出 -->
        <view class="merit-popup" wx:if="{{isStriking}}">
          <text class="merit-pop-text">+1</text>
        </view>
      </view>
      <view class="strike-hint">点击敲击</view>
    </view>

    <!-- 敲击提示文案 -->
    <view class="phrase-display">
      <text class="phrase-text">{{currentText}}</text>
    </view>
  </view>

  <!-- 成就区域 -->
  <view class="achievement-section" bindtap="showAchievements">
    <view class="achievement-title">
      <text>🏅 成就一览</text>
      <text class="achievement-hint">点击查看</text>
    </view>
    <view class="achievement-badges">
      <block wx:if="{{earnedAchievements.length === 0}}">
        <view class="badge-empty">敲击1次解锁第一个成就 🌱</view>
      </block>
      <block wx:else>
        <view
          class="badge-item"
          wx:for="{{earnedAchievements}}"
          wx:key="id"
        >
          <text class="badge-icon">{{item.icon}}</text>
          <text class="badge-name">{{item.name}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions">
    <view class="action-btn" bindtap="showSettings">
      <text class="action-icon">⚙️</text>
      <text class="action-label">设置</text>
    </view>
  </view>

  <!-- 成就弹窗 -->
  <view class="modal" wx:if="{{showAchievements}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">🏅 成就一览</text>
        <text class="modal-close" bindtap="closeAchievements">×</text>
      </view>
      <scroll-view class="modal-body achievement-modal-body" scroll-y>
        <view class="achievement-list">
          <view
            class="achievement-row {{item.earned ? 'earned' : 'locked'}}"
            wx:for="{{achievementList}}"
            wx:key="id"
          >
            <text class="achievement-icon">{{item.earned ? item.icon : '🔒'}}</text>
            <view class="achievement-info">
              <text class="achievement-name">{{item.earned ? item.name : '???'}}</text>
              <text class="achievement-desc">{{item.earned ? item.desc : '继续敲击解锁'}}</text>
            </view>
            <text class="achievement-count" wx:if="{{item.earned}}">✓</text>
            <text class="achievement-count locked-text" wx:else>{{item.count}}次</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 设置弹窗 -->
  <view class="modal" wx:if="{{showSettings}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">⚙️ 设置</text>
        <text class="modal-close" bindtap="closeSettings">×</text>
      </view>
      <view class="modal-body settings-body">
        <view class="setting-item">
          <view class="setting-row">
            <text class="setting-label">音效震动</text>
            <switch
              checked="{{soundEnabled}}"
              bindchange="toggleSound"
              color="#c9a96e"
            />
          </view>
          <text class="setting-hint">敲击时产生轻微震动反馈</text>
        </view>
        <view class="setting-divider"></view>
        <button class="reset-btn" bindtap="resetData">🗑️ 重置功德数据</button>
      </view>
    </view>
  </view>

  <!-- 新成就弹窗 -->
  <view class="achievement-toast" wx:if="{{newAchievement}}">
    <view class="toast-content">
      <text class="toast-icon">{{newAchievement.icon}}</text>
      <view class="toast-text">
        <text class="toast-title">🎉 新成就解锁！</text>
        <text class="toast-name">{{newAchievement.name}}</text>
        <text class="toast-desc">{{newAchievement.desc}}</text>
      </view>
    </view>
  </view>
</view>
