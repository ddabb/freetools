.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #faf8f5 0%, #f5f0e8 50%, #faf8f5 100%);
  padding: 24rpx;
}

/* 顶部标题 */
.hero-section {
  margin-bottom: 24rpx;
}

.hero-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.badge-icon {
  font-size: 36rpx;
}

.badge-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #8b7355;
}

.hero-quote {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border-left: 4rpx solid #c9a96e;
}

.quote-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}

.quote-hint {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
  display: block;
}

/* 功德统计卡片 */
.merit-card {
  background: linear-gradient(135deg, #c9a96e, #b8956a);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(201, 169, 110, 0.3);
  display: flex;
  align-items: center;
}

.merit-main {
  flex: 1;
  text-align: center;
}

.merit-number {
  margin-bottom: 4rpx;
}

.merit-count {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.merit-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.merit-divider {
  width: 1px;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 32rpx;
}

.merit-today {
  text-align: center;
}

.today-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  line-height: 1;
  margin-bottom: 4rpx;
}

.today-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 木鱼区域 */
.woodfish-section {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  margin-bottom: 24rpx;
}

/* 涟漪效果 */
.ripple-container {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300rpx;
  height: 300rpx;
  pointer-events: none;
}

.ripple {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 2rpx solid rgba(201, 169, 110, 0.6);
  animation: ripple-expand 0.8s ease-out forwards;
}

.ripple-1 {
  width: 120rpx;
  height: 120rpx;
  animation-delay: 0s;
}

.ripple-2 {
  width: 200rpx;
  height: 200rpx;
  animation-delay: 0.1s;
}

.ripple-3 {
  width: 280rpx;
  height: 280rpx;
  animation-delay: 0.2s;
}

@keyframes ripple-expand {
  0% {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.5);
    opacity: 0;
  }
}

/* 木鱼本体 */
.woodfish-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.woodfish {
  position: relative;
  transition: transform 0.1s ease;
}

.woodfish.striking {
  animation: woodfish-strike 0.15s ease;
}

@keyframes woodfish-strike {
  0% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(8rpx) rotate(3deg); }
  100% { transform: translateY(0) rotate(0deg); }
}

.woodfish-body {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(145deg, #e8d5b0, #c9a96e, #a07850);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 12rpx 40rpx rgba(160, 120, 80, 0.4),
    inset 0 -8rpx 20rpx rgba(0, 0, 0, 0.15),
    inset 0 8rpx 20rpx rgba(255, 255, 255, 0.2);
  position: relative;
}

.woodfish-emoji {
  font-size: 100rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.2));
}

.woodfish-shine {
  position: absolute;
  top: 20rpx;
  left: 30rpx;
  width: 40rpx;
  height: 40rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.6), transparent);
  border-radius: 50%;
}

.strike-hint {
  font-size: 22rpx;
  color: #b8956a;
  margin-top: 16rpx;
  opacity: 0.7;
}

/* 功德飘字 */
.merit-popup {
  position: absolute;
  top: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  animation: merit-float 0.6s ease-out forwards;
  pointer-events: none;
}

.merit-pop-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffd700;
  text-shadow: 0 2rpx 8rpx rgba(255, 215, 0, 0.5);
}

@keyframes merit-float {
  0% {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(0.5);
  }
  50% {
    opacity: 1;
    transform: translateX(-50%) translateY(-30rpx) scale(1.2);
  }
  100% {
    opacity: 0;
    transform: translateX(-50%) translateY(-60rpx) scale(1);
  }
}

/* 文案展示 */
.phrase-display {
  margin-top: 24rpx;
  padding: 12rpx 32rpx;
  background: rgba(201, 169, 110, 0.1);
  border-radius: 30rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.3);
}

.phrase-text {
  font-size: 26rpx;
  color: #8b7355;
  font-weight: 500;
}

/* 成就区域 */
.achievement-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.achievement-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.achievement-hint {
  font-size: 22rpx;
  color: #aaa;
  font-weight: normal;
}

.achievement-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.badge-empty {
  font-size: 24rpx;
  color: #bbb;
  padding: 16rpx 0;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  background: linear-gradient(135deg, #fef9f0, #f5efe5);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  border: 1px solid rgba(201, 169, 110, 0.3);
  transition: transform 0.2s;
}

.badge-item:active {
  transform: scale(0.95);
}

.badge-icon {
  font-size: 40rpx;
}

.badge-name {
  font-size: 20rpx;
  color: #8b7355;
  font-weight: 500;
}

/* 底部操作 */
.bottom-actions {
  display: flex;
  justify-content: center;
  padding: 16rpx 0;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 16rpx 40rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-btn:active {
  transform: scale(0.95);
  background: #f5f5f5;
}

.action-icon {
  font-size: 32rpx;
}

.action-label {
  font-size: 22rpx;
  color: #888;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1px solid #f0f0f0;
}

.modal-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #bbb;
  line-height: 1;
  padding: 0 8rpx;
}

.modal-body {
  padding: 28rpx 32rpx;
}

/* 成就列表 */
.achievement-modal-body {
  max-height: 60vh;
  padding: 0 32rpx 32rpx;
}

.achievement-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.achievement-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
  transition: all 0.2s;
}

.achievement-row.earned {
  background: linear-gradient(135deg, #fef9f0, #f5efe5);
  border: 1px solid rgba(201, 169, 110, 0.3);
}

.achievement-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  width: 60rpx;
  text-align: center;
}

.achievement-info {
  flex: 1;
}

.achievement-name {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
  display: block;
}

.achievement-desc {
  font-size: 22rpx;
  color: #888;
  display: block;
  margin-top: 2rpx;
}

.achievement-count {
  font-size: 24rpx;
  color: #c9a96e;
  font-weight: bold;
}

.achievement-count.locked-text {
  color: #ccc;
  font-weight: normal;
}

.achievement-row.locked .achievement-icon {
  filter: grayscale(1);
  opacity: 0.5;
}

.achievement-row.locked .achievement-name,
.achievement-row.locked .achievement-desc {
  color: #bbb;
}

/* 设置 */
.settings-body {
  padding: 28rpx 32rpx;
}

.setting-item {
  margin-bottom: 24rpx;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.setting-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.setting-hint {
  font-size: 22rpx;
  color: #aaa;
  display: block;
}

.setting-divider {
  height: 1px;
  background: #f0f0f0;
  margin: 24rpx 0;
}

.reset-btn {
  background: #fff;
  color: #e53935;
  border: 1px solid #e53935;
  border-radius: 40rpx;
  height: 80rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reset-btn::after {
  border: none;
}

/* 新成就弹窗 */
.achievement-toast {
  position: fixed;
  top: 120rpx;
  left: 32rpx;
  right: 32rpx;
  background: linear-gradient(135deg, #fff9c4, #fff5d4);
  border: 2rpx solid #c9a96e;
  border-radius: 20rpx;
  padding: 24rpx;
  z-index: 2000;
  box-shadow: 0 8rpx 32rpx rgba(201, 169, 110, 0.4);
  animation: toast-in 0.4s ease;
}

.toast-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toast-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}

.toast-text {
  flex: 1;
}

.toast-title {
  font-size: 22rpx;
  color: #b8956a;
  font-weight: bold;
  display: block;
}

.toast-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
}

.toast-desc {
  font-size: 22rpx;
  color: #888;
  display: block;
  margin-top: 2rpx;
}

@keyframes toast-in {
  0% {
    transform: translateY(-20rpx);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}
