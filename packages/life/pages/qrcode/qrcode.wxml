<view class="page-container">
  <!-- 简化顶部 -->
  <view class="header-bg">
    <view class="header-content">
      <text class="main-title">生成二维码器</text>
    </view>
  </view>

  <view class="content-wrapper">
    <!-- 配置卡片 -->
    <view class="config-card card-shadow">
      <view class="card-header">
        <text class="card-title">生成设置</text>
      </view>
      
      <view class="card-body">
        <!-- 内容类型选择 -->
        <view class="type-section">
          <text class="section-label">内容类型</text>
          <view class="type-tabs">
            <view 
              class="type-tab {{contentType === 'text' ? 'active' : ''}}" 
              bindtap="switchContentType" 
              data-type="text"
            >
              文本
            </view>
            <view 
              class="type-tab {{contentType === 'url' ? 'active' : ''}}" 
              bindtap="switchContentType" 
              data-type="url"
            >
              网址
            </view>
            <view 
              class="type-tab {{contentType === 'contact' ? 'active' : ''}}" 
              bindtap="switchContentType" 
              data-type="contact"
            >
              联系方式
            </view>
          </view>
        </view>

        <!-- 内容输入区 -->
        <view class="input-section">
          <view class="input-wrapper">
            <text class="input-label">{{getInputLabel()}}</text>
            <view class="input-container">
              <textarea
                class="modern-textarea"
                placeholder="{{getInputPlaceholder()}}"
                value="{{text}}"
                bindinput="onTextInput"
                maxlength="500"
                auto-height
                show-confirm-bar="false"
              />
              <view class="char-counter">
                <text class="counter-text {{text.length > 400 ? 'warning' : ''}}">{{text.length}}/500</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 样式设置 -->
        <view class="style-section">
          <text class="section-label">样式设置</text>
          
          <!-- 尺寸选择 -->
          <view class="option-row">
            <text class="option-label">尺寸</text>
            <view class="size-chips">
              <view 
                class="size-chip {{qrSize === 200 ? 'selected' : ''}}" 
                bindtap="changeQrSize" 
                data-size="200"
              >
                小
              </view>
              <view 
                class="size-chip {{qrSize === 280 ? 'selected' : ''}}" 
                bindtap="changeQrSize" 
                data-size="280"
              >
                中
              </view>
              <view 
                class="size-chip {{qrSize === 360 ? 'selected' : ''}}" 
                bindtap="changeQrSize" 
                data-size="360"
              >
                大
              </view>
            </view>
          </view>

          <!-- 容错级别 -->
          <view class="option-row">
            <text class="option-label">容错级别</text>
            <picker 
              range="{{errorLevels}}" 
              value="{{errorLevelIndex}}" 
              bindchange="onErrorLevelChange"
              class="level-picker"
            >
              <view class="picker-display">
                {{errorLevels[errorLevelIndex]}}
                <text class="arrow">▼</text>
              </view>
            </picker>
          </view>

          <!-- 中心图片 -->
          <view class="option-row">
            <text class="option-label">中心图片</text>
            <button 
              class="image-upload-btn {{centerImage ? 'has-image' : ''}}" 
              bindtap="uploadCenterImage"
            >
              <text class="upload-icon">📷</text>
              {{centerImage ? '更换' : '添加'}}
            </button>
            <button 
              class="secondary-btn" 
              bindtap="removeImage"
              wx:if="{{centerImage}}"
              style="margin-left: 12rpx;"
            >
              移除
            </button>
          </view>

          <!-- 图片大小 -->
          <view class="option-row" wx:if="{{centerImage}}">
            <text class="option-label">图片大小</text>
            <view class="size-chips">
              <view 
                class="size-chip {{imageSize === 40 ? 'selected' : ''}}" 
                bindtap="changeImageSize" 
                data-size="40"
              >
                小
              </view>
              <view 
                class="size-chip {{imageSize === 60 ? 'selected' : ''}}" 
                bindtap="changeImageSize" 
                data-size="60"
              >
                中
              </view>
              <view 
                class="size-chip {{imageSize === 80 ? 'selected' : ''}}" 
                bindtap="changeImageSize" 
                data-size="80"
              >
                大
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <button 
        class="primary-btn {{canGenerate ? 'ready' : ''}}"
        bindtap="generate"
        disabled="{{!canGenerate}}"
        hover-class="btn-primary-hover"
      >
        <text class="btn-icon">✨</text>
        <text class="btn-text">生成二维码</text>
      </button>
      
      <view class="secondary-actions">
        <button 
          class="secondary-btn" 
          bindtap="pasteFromClipboard"
          hover-class="btn-secondary-hover"
        >
          <text class="btn-icon">📋</text>
          粘贴
        </button>
        <button 
          class="secondary-btn" 
          bindtap="clear"
          wx:if="{{text}}"
          hover-class="btn-secondary-hover"
        >
          <text class="btn-icon">🗑️</text>
          清空
        </button>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-card card-shadow" wx:if="{{generating}}">
      <view class="loading-content">
        <view class="loading-spinner"></view>
        <text class="loading-text">正在生成中...</text>
      </view>
    </view>

    <!-- 二维码展示 -->
    <view wx:if="{{showQrcode}}" class="result-card card-shadow">
      <view class="result-header">
        <text class="card-title">生成结果</text>
      </view>
      
      <view class="qrcode-display">
        <view class="qrcode-wrapper" style="width: {{qrSize}}px; height: {{qrSize}}px;">
          <canvas 
            type="2d" 
            id="qrcodeCanvas" 
            class="qrcode-canvas"
            style="width: {{qrSize}}px; height: {{qrSize}}px;"
          />
        </view>
        
        <!-- 内容预览 -->
        <view class="content-preview">
          <text class="preview-label">内容预览</text>
          <text class="preview-text">{{getDisplayText()}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="result-actions">
        <button class="action-btn save-btn" bindtap="saveImage" hover-class="btn-action-hover">
          <text class="btn-icon">💾</text>
          <text>保存到相册</text>
        </button>
      </view>
    </view>

    <!-- 简单提示 -->
    <view class="tips-card card-shadow">
      <view class="tips-content">
        <text class="tips-text">支持文本、网址、联系方式，可自定义样式和中心图片</text>
      </view>
    </view>
  </view>
</view>