<!-- packages/copywriting/pages/copywriting/copywriting.wxml -->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        type="text" 
        placeholder="搜索文案关键词..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
       placeholder-class="input-placeholder"/>
      <view class="clear-btn" wx:if="{{searchKeyword}}" bindtap="clearSearch">
        <text>✕</text>
      </view>
      <view class="refresh-btn" hover-class="refresh-btn-hover" bindtap="refreshData">
        <text class="refresh-icon">🔄</text>
      </view>
      <navigator url="/packages/life/pages/text-to-image/text-to-image" class="image-btn">
        <text class="image-icon">🖼️</text>
      </navigator>
    </view>
  </view>

  <!-- 分类选择 -->
  <view class="category-section">
    <scroll-view 
      class="category-scroll" 
      scroll-y="true"
    >
      <view class="category-grid">
        <view 
          class="category-item {{selectedCategory === item.id ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          bindtap="selectCategory"
          data-category-id="{{item.id}}"
        >
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 文案列表 -->
  <view class="copywriting-section">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredCopywritings.length === 0}}">
      <text class="empty-icon">{{searchKeyword ? '🔍' : (selectedCategory ? '📝' : '👆')}}</text>
      <text class="empty-text">
        {{searchKeyword ? '没有找到相关文案' : (selectedCategory ? '该分类暂无文案' : '请选择分类或输入关键词搜索')}}
      </text>
    </view>

    <!-- 文案列表 -->
    <scroll-view 
      class="copywriting-list" 
      wx:else
      scroll-y="true"
      scroll-top="{{scrollTop}}"
      bindscroll="onScroll"
    >
      <view 
        class="copywriting-item" hover-class="copywriting-item-hover"
        wx:for="{{filteredCopywritings}}"
        wx:key="index"
        bindtap="copyCopywriting"
        data-index="{{index}}"
      >
        <view class="copywriting-content-wrapper">
          <text class="copywriting-content">{{item.text}}</text>
        </view>
        <view class="copywriting-item-bottom" hover-class="copywriting-item-hover">
          <text class="copywriting-from">—— {{item.from || '佚名'}}</text>
          <view class="copy-actions">
            <view class="copy-action" bindtap="copyCopywriting" data-index="{{index}}">
              <text class="copy-icon">📋</text>
              <text class="copy-text">复制</text>
            </view>
            <view class="copy-action" bindtap="downloadImage" data-index="{{index}}">
              <text class="copy-icon">📸</text>
              <text class="copy-text">下载图片</text>
            </view>
            <navigator url="/packages/life/pages/text-to-image/text-to-image?text={{item.text}}" class="copy-action">
              <text class="copy-icon">🖼️</text>
              <text class="copy-text">生成图片</text>
            </navigator>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 画布元素，用于生成图片 -->
  <canvas id="cvs1" type="2d" style="width: 375px; height: 667px; position: absolute; left: -9999rpx; top: -9999rpx;"></canvas>
  <!-- 搴曢儴骞垮憡 -->
  <ad unit-id="adunit-07e9c9da9e4b8254" ad-intervals="30" binderror="onAdError" bindclose="onAdClose"></ad>

</view>