<!--datediff.wxml-->
<view class="container">
  <view class="header">
    <text class="title">计算日期差</text>
  </view>
  <view class="content">
    <view class="input-section">
      <text class="label">开始日期：</text>
      <input type="date" bindinput="startDateChange" class="input"/>
    </view>
    <view class="input-section">
      <text class="label">结束日期：</text>
      <input type="date" bindinput="endDateChange" class="input"/>
    </view>
    <view class="button-section">
      <button bindtap="calculateDateDiff" class="button">计算</button>
    </view>
    <view wx:if="{{result !== ''}}" class="result-section">
      <text class="result-text">{{result}}</text>
    </view>
  </view>
</view>