/**datediff.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 16rpx;
  min-height: 100vh;
}

.result-section {
  margin-bottom: 32rpx;
}

/* 表单容器 */
.form-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

/* 表单标签 */
.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.required-mark {
  color: #ff4757;
  font-size: 28rpx;
  margin-left: 8rpx;
}

/* 性别选择 - 选择框样式 */
.form-picker {
  margin-top: 0;
}

.picker-display {
  background: #f8f9fa;
  padding: 24rpx 28rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  transition: all 0.3s ease;
}

.picker-display.placeholder {
  color: #adb5bd;
}

.picker-display-hover {
  border-color: #667eea;
  background: #fff;
}

/* 按钮表单项 */
.btn-item {
  margin-bottom: 0;
}

.full-width-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.full-width-btn-hover {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.btn-text {
  margin-left: 8rpx;
}

.result-box {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}

.result-item {
  text-align: center;
  margin-bottom: 20rpx;
}

.result-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.result-value {
  font-size: 40rpx;
  font-weight: 800;
}

.result-value.bmi {
  color: #667eea;
  font-size: 48rpx;
}
