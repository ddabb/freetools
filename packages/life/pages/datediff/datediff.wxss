/**datediff.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.5s ease-in-out;
}

/* 内容区域 */
.content-area {
  flex: 1;
  margin-bottom: 24rpx;
}

/* 页面标题 */
.page-title {
  text-align: center;
  margin-bottom: 40rpx;
  margin-top: 30rpx;
  animation: slideDown 0.6s ease-out;
}

.title-text {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 2rpx;
}

.title-subtext {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.result-section {
  margin-bottom: 32rpx;
  flex: 1;
}

/* 表单容器 */
.form-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.6s ease-out;
  animation-delay: 0.2s;
  animation-fill-mode: both;
}

/* 表单项 */
.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

/* 表单标签 */
.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.label-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 1rpx;
}

.required-mark {
  color: #ff4757;
  font-size: 28rpx;
  margin-left: 8rpx;
  animation: pulse 1.5s infinite;
}

/* 性别选择 - 选择框样式 */
.form-picker {
  margin-top: 0;
}

.picker-display {
  background: #f8f9fa;
  padding: 28rpx 32rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.picker-display::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(102, 126, 234, 0.1), transparent);
  transition: left 0.6s;
}

.picker-display:hover::before {
  left: 100%;
}

.picker-display.placeholder {
  color: #adb5bd;
}

.picker-display-hover {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
  transform: translateY(-2rpx);
}

/* 结果展示 */
.result-box {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  animation: fadeInUp 0.6s ease-out;
  animation-delay: 0.4s;
  animation-fill-mode: both;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.result-item {
  text-align: center;
  margin-bottom: 24rpx;
}

.result-label {
  font-size: 30rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.result-value {
  font-size: 44rpx;
  font-weight: 800;
}

.result-value.bmi {
  color: #667eea;
  font-size: 52rpx;
  text-shadow: 0 2rpx 4rpx rgba(102, 126, 234, 0.3);
  animation: glow 2s ease-in-out infinite alternate;
}

/* 内链区域 */
.links-section {
  margin-top: 24rpx;
  margin-bottom: 24rpx;
  animation: fadeIn 0.8s ease-out;
  animation-delay: 0.6s;
  animation-fill-mode: both;
  width: 100%;
}

.links-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
  display: block;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 1rpx;
}

.links-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  justify-items: center;
  margin-top: 16rpx;
}

.link-item {
  background: rgba(255, 255, 255, 0.92);
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  text-decoration: none;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  position: relative;
  overflow: hidden;
  width: 90%;
  text-align: center;
}

.link-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(102, 126, 234, 0.1), transparent);
  transition: left 0.6s;
}

.link-item:hover::before {
  left: 100%;
}

.link-item-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 10rpx 24rpx rgba(102, 126, 234, 0.25);
  background: rgba(255, 255, 255, 0.98);
  border-color: #667eea;
}

.link-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #667eea;
  letter-spacing: 1rpx;
  position: relative;
  z-index: 1;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes glow {
  from {
    text-shadow: 0 2rpx 4rpx rgba(102, 126, 234, 0.3);
  }
  to {
    text-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.6);
  }
}

/* 响应式调整 */
@media (max-width: 375px) {
  .container {
    padding: 16rpx;
  }
  
  .title-text {
    font-size: 38rpx;
  }
  
  .title-subtext {
    font-size: 24rpx;
  }
  
  .form-container {
    padding: 28rpx;
  }
  
  .label-text {
    font-size: 30rpx;
  }
  
  .picker-display {
    padding: 24rpx 28rpx;
    font-size: 30rpx;
  }
  
  .result-box {
    padding: 30rpx;
  }
  
  .result-value.bmi {
    font-size: 44rpx;
  }
  
  .link-item {
    padding: 18rpx 16rpx;
    width: 95%;
  }
  
  .link-text {
    font-size: 24rpx;
  }
  
  .links-container {
    gap: 12rpx;
  }
}

/* 深色模式适配 */
@media (prefers-color-scheme: dark) {
  .form-container {
    background: rgba(30, 30, 30, 0.95);
  }
  
  .label-text {
    color: #e0e0e0;
  }
  
  .picker-display {
    background: #333;
    border-color: #444;
    color: #e0e0e0;
  }
  
  .picker-display.placeholder {
    color: #777;
  }
  
  .result-box {
    background: rgba(30, 30, 30, 0.9);
  }
  
  .result-label {
    color: #aaa;
  }
  
  .link-item {
    background: rgba(40, 40, 40, 0.92);
    border-color: rgba(60, 60, 60, 0.5);
  }
  
  .link-item-hover {
    background: rgba(50, 50, 50, 0.98);
  }
}
