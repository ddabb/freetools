/* components/tool-card/tool-card.wxss */

/* 工具卡片 */
.tool-card {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(15px);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1px solid rgba(255, 220, 180, 0.6);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 16rpx rgba(255, 100, 60, 0.10);
}

.tool-card-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 14rpx 28rpx rgba(255, 100, 60, 0.22);
  background: rgba(255, 255, 255, 0.88);
}

.tool-main {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}

.tool-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 36rpx;
  flex-shrink: 0;
}

/* 图标背景色 */
.tool-icon-wrapper.text      { background: linear-gradient(135deg, #ff9a9e, #f77a8a); }
.tool-icon-wrapper.data      { background: linear-gradient(135deg, #ffd86f, #f7a440); }
.tool-icon-wrapper.developer { background: linear-gradient(135deg, #a8edea, #4ecdc4); }
.tool-icon-wrapper.design    { background: linear-gradient(135deg, #c3f0a2, #56c870); }
.tool-icon-wrapper.chart    { background: linear-gradient(135deg, #fbc2eb, #a78bfa); }
.tool-icon-wrapper.math      { background: linear-gradient(135deg, #89f7fe, #66a6ff); }
.tool-icon-wrapper.life      { background: linear-gradient(135deg, #ffd1dc, #ffadc6); }
.tool-icon-wrapper.health    { background: linear-gradient(135deg, #d4fc79, #96e6a1); }
.tool-icon-wrapper.travel    { background: linear-gradient(135deg, #f6d365, #fda085); }
.tool-icon-wrapper.unit      { background: linear-gradient(135deg, #e0c3fc, #8ec5fc); }

.tool-info {
  flex: 1;
  min-width: 0;
}

.tool-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tool-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #3d1a06;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-frequency {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.frequency-label {
  font-size: 24rpx;
  color: rgba(180, 80, 40, 0.7);
  font-weight: 500;
}

.frequency-bar {
  width: 80rpx;
  height: 10rpx;
  background: rgba(255, 180, 120, 0.3);
  border-radius: 5rpx;
  overflow: hidden;
}

.frequency-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff9a9e, #ffd86f);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.tool-desc {
  font-size: 28rpx;
  color: rgba(100, 50, 20, 0.8);
  line-height: 1.5;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tool-action {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.start-btn {
  background: linear-gradient(135deg, #ff9a9e, #ff6b6b);
  border: none;
  border-radius: 28rpx;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 14rpx rgba(255, 100, 80, 0.38);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.btn-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 20rpx rgba(255, 100, 80, 0.50);
}

.btn-text {
  color: white;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-icon {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
}
