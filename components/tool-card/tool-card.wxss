/* components/tool-card/tool-card.wxss */
.tool-card {
  background: transparent;
  border-radius: 24rpx;
  display: flex;
  position: relative;
  overflow: hidden;
  z-index: 1;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.tool-card-hover {
  transform: translateY(-4rpx) scale(1.05);
}

/* 工具卡片点击动画 */
.tool-card:active {
  transform: scale(0.95);
  transition: transform 0.1s ease;
}

/* 中等尺寸 - 垂直布局：图标在上，文字在下 */
.tool-card.medium {
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 24rpx 16rpx;
  min-height: auto;
}

.tool-icon-container.medium {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  flex-shrink: 0;
  margin-bottom: 14rpx;
}

.tool-text-container.medium {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-left: 0;
  min-height: auto;
  width: 100%;
}

/* 工具卡片点击波纹效果 */
.tool-card::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10rpx;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  transform: translate(-50%, -50%) scale(0);
  opacity: 0;
}

.tool-card:active::after {
  animation: ripple 0.6s ease-out;
}

@keyframes ripple {
  0% {
    transform: translate(-50%, -50%) scale(0);
    opacity: 0.5;
  }
  100% {
    transform: translate(-50%, -50%) scale(20);
    opacity: 0;
  }
}

/* 大尺寸 - 垂直布局：图标在上，文字在下 */
.tool-card.large {
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 16rpx 6rpx;
  min-height: auto;
  aspect-ratio: 1;
}

.tool-icon-container.large {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  flex-shrink: 0;
  margin-bottom: 8rpx;
  padding-top: 0;
}

.tool-text-container.large {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-left: 0;
  min-height: auto;
  width: 100%;
}

/* 小尺寸 - 垂直布局：图标在上，文字在下 */
.tool-card.small {
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  min-height: auto;
}

.tool-icon-container.small {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  flex-shrink: 0;
  margin-bottom: 12rpx;
}

.tool-text-container.small {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-left: 0;
  min-height: auto;
  width: 100%;
}

.tool-card.small .tool-name {
  font-size: 22rpx;
  color: #2c3e50;
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tool-card.small .tool-desc {
  display: none;
}

.tool-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-card.large .tool-icon-wrapper {
  margin-bottom: 0;
}

.tool-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.tool-icon.blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.tool-icon.green {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.tool-icon.orange {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.tool-icon.purple {
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
}

.tool-icon.teal {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.tool-icon.red {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
}

.tool-icon.yellow {
  background: linear-gradient(135deg, #fad0c4 0%, #ffd1ff 100%);
}

.tool-icon.gray {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.tool-card.large .tool-info,
.tool-card.small .tool-info,
.tool-card.medium .tool-info {
  /* 隐藏旧的 tool-info 结构，使用新的 tool-text-container */
  display: none;
}

/* 文字横向排列样式 - 名称和描述在同一行 */
.tool-text-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 100%;
  flex-wrap: nowrap;
}

.tool-card.large .tool-text-row {
  max-width: 100%;
}

.tool-card.large .tool-name {
  font-size: 22rpx;
  color: #2c3e50;
  font-weight: 600;
  line-height: 1.3;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex-shrink: 1;
  min-width: 0;
}

.tool-card.large .tool-desc {
  display: none;
}

.tool-card.medium .tool-text-row {
  max-width: 100%;
}

.tool-card.medium .tool-name {
  font-size: 24rpx;
  color: #2c3e50;
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex-shrink: 1;
  min-width: 0;
}

.tool-card.medium .tool-desc {
  font-size: 20rpx;
  color: #5a6c7d;
  line-height: 1.4;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex-shrink: 0;
  margin-left: 6rpx;
}

.tool-name {
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: 600;
  line-height: 1.4;
}

.tool-desc {
  font-size: 22rpx;
  color: #5a6c7d;
  margin-top: 8rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
