<!-- components/tool-detail-modal/tool-detail-modal.wxml -->
<view class="detail-modal {{show ? 'show' : ''}} {{animationClass}}" catchtap="onMaskTap">
  <view class="detail-box" catchtap="onBoxTap">
    <!-- 关闭按钮 -->
    <view wx:if="{{showClose}}" class="detail-close" bindtap="onClose">✕</view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="detail-loading">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 内容区域 -->
    <block wx:elif="{{displayData}}">
      <!-- 头部：图标 + 标题 + 副标题 -->
      <view class="detail-header">
        <text wx:if="{{displayData.icon}}" class="detail-icon">{{displayData.icon}}</text>
        <view class="detail-title-wrap">
          <text class="detail-title">{{title || displayData.title}}</text>
          <text wx:if="{{subtitle || displayData.subtitle}}" class="detail-subtitle">{{subtitle || displayData.subtitle}}</text>
        </view>
      </view>

      <!-- 标签列表 -->
      <view wx:if="{{displayData.tags && displayData.tags.length > 0}}" class="detail-tags">
        <view 
          class="detail-tag" 
          wx:for="{{displayData.tags}}" 
          wx:key="index"
          data-tag="{{item}}"
          bindtap="onTagTap"
        >{{item}}</view>
      </view>

      <!-- 内容区块 -->
      <scroll-view class="detail-scroll" scroll-y enhanced show-scrollbar="false">
        <view class="detail-sections">
          <view 
            class="detail-section" 
            wx:for="{{displayData.sections}}" 
            wx:key="key"
            wx:for-item="section"
          >
            <view class="detail-section-header">
              <text class="detail-section-title">{{section.title}}</text>
              <view 
                wx:if="{{section.showCopy && showCopy}}" 
                class="detail-copy-btn" 
                hover-class="detail-copy-btn-hover"
                data-key="{{section.key}}"
                bindtap="onCopyTap"
              >{{copyText}}</view>
            </view>
            <text class="detail-section-content">{{section.content}}</text>
          </view>
        </view>

        <!-- 底部操作区 -->
        <view class="detail-footer">
          <view wx:if="{{showCopy && displayData.sections.length > 1}}" class="detail-copy-all" bindtap="onCopyAll">
            <text class="detail-copy-all-text">📋 复制全部内容</text>
          </view>
        </view>
      </scroll-view>

      <!-- 操作按钮 -->
      <view wx:if="{{showAction}}" class="detail-action-bar">
        <button class="detail-action-btn" bindtap="onActionTap">{{actionText}}</button>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:else class="detail-empty">
      <text class="detail-empty-icon">📭</text>
      <text class="detail-empty-text">暂无详情</text>
    </view>
  </view>
</view>
