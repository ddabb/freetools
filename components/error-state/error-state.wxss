.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  background-color: #fff;
  min-height: 400rpx;
}

.error-icon {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.error-default-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.error-default-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.error-image {
  border-radius: 8rpx;
}

.error-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  text-align: center;
}

.error-subtext {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
  text-align: center;
  line-height: 1.4;
}

.error-button {
  margin-bottom: 16rpx;
  width: 100%;
  max-width: 300rpx;
}

.error-button button {
  width: 100%;
}

.error-secondary-button {
  width: 100%;
  max-width: 300rpx;
}

.error-secondary-button button {
  width: 100%;
}