/* components/category-card/category-card.wxss */
.category-card {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.7) 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  z-index: 1;
}

.category-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  pointer-events: none;
}

.category-card.blue::after {
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.category-card.green::after {
  background: linear-gradient(90deg, #11998e, #38ef7d);
}

.category-card.orange::after {
  background: linear-gradient(90deg, #f093fb, #f5576c);
}

.category-card.purple::after {
  background: linear-gradient(90deg, #a18cd1, #fbc2eb);
}

.category-card.red::after {
  background: linear-gradient(90deg, #ff9a9e, #fecfef);
}

.category-card.teal::after {
  background: linear-gradient(90deg, #4facfe, #00f2fe);
}

.category-card.yellow::after {
  background: linear-gradient(90deg, #fad0c4, #ffd1ff);
}

.category-card.gray::after {
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.category-card-hover {
  transform: translateY(-5rpx);
  box-shadow: 0 15rpx 35rpx rgba(0, 0, 0, 0.2);
}

/* 分类卡片点击动画 */
.category-card:active {
  transform: translateX(10rpx);
  transition: transform 0.1s ease;
}

/* 分类卡片箭头动画 */
.category-card:active .category-arrow {
  transform: translateX(10rpx);
  color: #3498db;
}

.category-arrow {
  transition: transform 0.1s ease, color 0.1s ease;
}

/* 分类卡片边框动画 */
.category-card:active::after {
  height: 10rpx;
  background: linear-gradient(90deg, #3498db, #2980b9);
  transition: height 0.1s ease, background 0.1s ease;
}

/* 小尺寸 */
.category-card.small {
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
}

.category-card.small .category-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
}

.category-card.small .category-icon {
  font-size: 28rpx;
}

.category-card.small .category-name {
  font-size: 24rpx;
}

.category-card.small .category-desc {
  display: none;
}

.category-card.small .category-arrow {
  font-size: 28rpx;
}

.category-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.category-icon-wrapper.blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.category-icon-wrapper.green {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.category-icon-wrapper.orange {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.category-icon-wrapper.purple {
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
}

.category-icon-wrapper.red {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
}

.category-icon-wrapper.teal {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.category-icon-wrapper.yellow {
  background: linear-gradient(135deg, #fad0c4 0%, #ffd1ff 100%);
}

.category-icon-wrapper.gray {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.category-icon {
  font-size: 36rpx;
  color: white;
}

.category-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.category-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
}

.category-name.blue { color: #667eea; }
.category-name.green { color: #11998e; }
.category-name.orange { color: #f5576c; }
.category-name.purple { color: #a18cd1; }
.category-name.red { color: #ff6b6b; }
.category-name.teal { color: #4facfe; }
.category-name.yellow { color: #f0ad4e; }
.category-name.gray { color: #999; }

.category-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-arrow {
  font-size: 32rpx;
  color: #999;
  margin-left: 10rpx;
  flex-shrink: 0;
}
