.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  margin-bottom: 30rpx;
}

.empty-image {
  object-fit: contain;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 40rpx;
  line-height: 1.4;
}

.empty-button {
  margin-top: 20rpx;
}

.empty-button .empty-button-btn {
  min-width: 200rpx;
}