<!-- packages/knowledge/pages/taglist/taglist.wxml -->

<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">知识库标签</text>
    <text class="page-subtitle">按标签浏览知识内容</text>
  </view>

  <!-- 搜索框 -->
  <view class="search-container" wx:if="{{!loading && !error}}">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索标签..." 
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
    </view>
  </view>



  <!-- 标签列表（可滚动） -->
  <scroll-view class="tag-scroll" scroll-y style="height: {{scrollHeight}}px;">
    <view class="tag-list">
      <!-- 加载状态 -->
      <view class="loading-state" wx:if="{{loading && tags.length > 0}}">
        <text>加载中...</text>
      </view>

      <!-- 错误提示 -->
      <view class="error-state" wx:if="{{error}}">
        <text class="error-text">{{errorMsg}}</text>
        <button class="retry-btn" bindtap="loadTags">重试</button>
      </view>

      <!-- 标签网格 -->
      <view class="tag-container" wx:if="{{!loading && !error && displayTags.length > 0}}">
        <view
          class="tag-item" hover-class="tag-item-hover"
          wx:for="{{displayTags}}"
          wx:key="name"
          data-tag="{{item.name}}"
          bindtap="onTagTap"
        >
          <text class="tag-name">#{{item.name}}</text>
          <text class="tag-count">{{item.count}}</text>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{hasMore && !loading && !error}}" bindtap="loadMore">
        <text class="load-more-text">加载更多标签</text>
      </view>

      <!-- 搜索结果为空 -->
      <view class="empty-state" wx:if="{{!loading && !error && searchKeyword && displayTags.length === 0}}">
        <text class="empty-icon">🔍</text>
        <text class="empty-text">没有找到相关标签</text>
        <text class="empty-subtext">请尝试其他关键词</text>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!loading && !error && !searchKeyword && tags.length === 0}}">
        <text class="empty-icon">🏷️</text>
        <text class="empty-text">暂无标签</text>
      </view>
    </view>
  </scroll-view>
</view>
