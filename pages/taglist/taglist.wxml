<!-- 面包屑导航 -->
<view class="breadcrumb">
  <text class="breadcrumb-item" hover-class="breadcrumb-item-hover" bindtap="goToKnowledgeList">📚 知识库</text>
  <text class="breadcrumb-sep">/</text>
  <text class="breadcrumb-current">标签列表</text>
</view>

<view class="container">
  <view class="search-container" wx:if="{{!loading && !error}}">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索标签..." 
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <view class="alphabet-filter" wx:if="{{!loading && !error && sortedLetters.length > 0}}">
    <scroll-view class="alphabet-scroll" scroll-x="true" scroll-with-animation="true">
      <view class="alphabet-list">
        <view 
          class="alphabet-item {{activeLetter === item ? 'active' : ''}}" 
          wx:for="{{sortedLetters}}" 
          wx:key="*this"
          data-letter="{{item}}"
          bindtap="onLetterTap"
        >
          <text>{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view class="tag-scroll" scroll-y style="height: {{scrollHeight}}px;" bindscrolltolower="loadMore">
    <view class="tag-list">
      <view class="loading-state" wx:if="{{loading && tags.length === 0}}">
        <text>加载中...</text>
      </view>

      <view class="error-state" wx:if="{{error}}">
        <text class="error-text">{{errorMsg}}</text>
        <button class="retry-btn" bindtap="loadTags">重试</button>
      </view>

      <view class="tag-container" wx:if="{{!loading && !error && displayTags.length > 0}}">
        <view
          class="tag-item" 
          hover-class="tag-item-hover"
          wx:for="{{displayTags}}"
          wx:key="name"
          data-tag="{{item.name}}"
          bindtap="onTagTap"
        >
          <text class="tag-name">#{{item.name}}</text>
          <text class="tag-count">{{item.count}}</text>
        </view>

        <!-- 加载更多提示 -->
        <view class="loading-more" wx:if="{{loadingMore}}">
          <text>加载更多...</text>
        </view>

        <view class="no-more" wx:if="{{!loadingMore && !hasMore && displayTags.length > 0}}">
          <text>没有更多标签了</text>
        </view>
      </view>

      <view class="empty-state" wx:if="{{!loading && !error && displayTags.length === 0}}">
        <text class="empty-icon">🏷️</text>
        <text class="empty-text">暂无标签</text>
        <text class="empty-subtext" wx:if="{{searchKeyword}}">请尝试其他关键词</text>
      </view>
    </view>
  </scroll-view>
</view>
