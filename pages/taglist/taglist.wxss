/* packages/knowledge/pages/taglist/taglist.wxss */

/* ========== 基础样式 ========== */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

/* ========== 页面标题 ========== */
.page-header {
  text-align: center;
  margin-bottom: 24rpx;
  padding: 32rpx 0 0;
  flex-shrink: 0;
}

/* ========== 搜索框 ========== */
.search-container {
  margin-bottom: 24rpx;
  flex-shrink: 0;
}

.search-box {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  transition: all 0.3s ease;
}

.search-box:focus-within {
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.25);
  transform: translateY(-2rpx);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #999;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  padding: 8rpx 0;
  outline: none;
}

.search-placeholder {
  color: #999;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  margin-left: 12rpx;
  padding: 4rpx 8rpx;
  border-radius: 50%;
  background: #f0f0f0;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.search-clear-hover {
  background: #e0e0e0;
  color: #666;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 10rpx;
  display: block;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
}

/* ========== 标签滚动区 ========== */
.tag-scroll {
  flex: 1;
  /* 确保滚动条显示 */
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.tag-list {
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.2);
  min-height: 200rpx;
}

/* ========== 页面加载动画 ========== */
.page-loading {
  position: absolute;
  top: 400rpx;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  opacity: 0;
  animation: pageLoadingFadeIn 0.5s ease-out forwards;
  border-radius: 0 0 24rpx 24rpx;
}

.loading-spinner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.spinner-circle {
  width: 120rpx;
  height: 120rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.3);
  border-top: 8rpx solid white;
  border-radius: 50%;
  animation: spinnerRotate 1.5s linear infinite;
}

.spinner-text {
  font-size: 32rpx;
  color: white;
  font-weight: 500;
  text-align: center;
  animation: textPulse 2s ease-in-out infinite;
}

@keyframes pageLoadingFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes spinnerRotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

@keyframes textPulse {
  0%, 100% {
    opacity: 0.8;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 32rpx;
  gap: 16rpx;
}

.loading-state::before {
  content: '';
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.2);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  display: inline-block;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ========== 错误状态 ========== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.error-text {
  color: #e74c3c;
  font-size: 32rpx;
  text-align: center;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.retry-btn::after { border: none; }

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  font-size: 34rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

/* ========== 标签网格 ========== */
.tag-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 16rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.tag-item-hover {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  transform: scale(0.97);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.25);
}

.tag-name {
  font-size: 30rpx;
  color: #667eea;
  font-weight: 500;
  margin-right: 12rpx;
  transition: color 0.3s ease;
}

.tag-item-hover .tag-name {
  color: white;
}

.tag-count {
  font-size: 24rpx;
  color: #999;
  background: white;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  min-width: 40rpx;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tag-item-hover .tag-count {
  background: rgba(255, 255, 255, 0.25);
  color: white;
  box-shadow: none;
}
