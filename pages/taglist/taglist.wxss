/* packages/knowledge/pages/taglist/taglist.wxss */
/* 水墨屏/泛黄纸张风格 - 浅色协调版 */

page {
  /* 泛黄纸张背景 */
  background: linear-gradient(160deg, #FBF4E3 0%, #F9EFDE 50%, #F6E9D0 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', serif;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

.page-header {
  text-align: center;
  margin-bottom: 24rpx;
  padding: 32rpx 0 0;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A3F35;
  margin-bottom: 10rpx;
  display: block;
  letter-spacing: 2rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #A89078;
  display: block;
}

.search-container {
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  border-radius: 40rpx;
  padding: 14rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(120, 100, 75, 0.06);
  border: 1rpx solid #E0D4C4;
}

.search-icon {
  font-size: 30rpx;
  margin-right: 10rpx;
  color: #A89078;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #4A3F35;
  padding: 6rpx 0;
  background: transparent;
}

.search-placeholder {
  color: #C0B0A0;
}

.search-clear {
  font-size: 26rpx;
  color: #C0B0A0;
  margin-left: 10rpx;
  padding: 4rpx 8rpx;
  border-radius: 50%;
  background: rgba(168, 144, 120, 0.1);
  flex-shrink: 0;
}

.alphabet-filter {
  width: 100%;
  position: relative;
  margin-bottom: 24rpx;
}

.alphabet-scroll {
  width: 100%;
  white-space: nowrap;
  padding: 0;
  margin: 0;
  height: 80rpx;
  flex-shrink: 0;
}

.alphabet-list {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  height: 80rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

/* 隐藏滚动条但保持滚动功能 */
.alphabet-scroll::-webkit-scrollbar {
  display: none;
}

.alphabet-scroll {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.alphabet-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 250, 235, 0.9);
  color: #6D5D4D;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  flex-shrink: 0;
  flex: none;
  margin-right: 10rpx;
  box-shadow: 0 2rpx 6rpx rgba(120, 100, 75, 0.06);
  border: 1rpx solid #D8CDB8;
}

.alphabet-item.active {
  background: #E8A090;
  color: #FFFDF8;
  box-shadow: 0 4rpx 12rpx rgba(212, 133, 106, 0.2);
  border-color: #D4856A;
}

.alphabet-item:hover {
  background: rgba(255, 248, 225, 0.95);
  border-color: #D4856A;
  transform: scale(1.05);
}

.alphabet-item.active:hover {
  background: #E8A090;
  transform: scale(1.05);
}

.tag-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.tag-list {
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  border-radius: 20rpx;
  padding: 22rpx;
  box-shadow: 0 4rpx 20rpx rgba(120, 100, 75, 0.06);
  min-height: 200rpx;
  border: 1rpx solid #E0D4C4;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #A89078;
  font-size: 30rpx;
  gap: 16rpx;
}

.loading-state::before {
  content: '';
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(212, 133, 106, 0.2);
  border-top-color: #D4856A;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  display: inline-block;
}

@keyframes spin { to { transform: rotate(360deg); } }

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.error-text {
  color: #D4856A;
  font-size: 30rpx;
  text-align: center;
}

.retry-btn {
  padding: 14rpx 40rpx;
  background: #D4856A;
  color: #FFFDF8;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(212, 133, 106, 0.2);
}

.retry-btn::after { border: none; }

.tag-container {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 0;
}

.tag-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx;
  background: rgba(255, 250, 235, 0.7);
  border: 1rpx solid #E0D4C4;
  border-radius: 14rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 6rpx rgba(120, 100, 75, 0.03);
}

.tag-item-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 6rpx 20rpx rgba(120, 100, 75, 0.08);
  background: rgba(255, 248, 225, 0.9);
  border-color: #D4856A;
}

.tag-name {
  font-size: 28rpx;
  color: #4A3F35;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 1rpx;
}

.tag-count {
  font-size: 22rpx;
  color: #A89078;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 14rpx;
}

.empty-icon {
  font-size: 96rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6D5D4D;
  font-weight: 600;
}

.empty-subtext {
  font-size: 26rpx;
  color: #A89078;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  color: #A89078;
  font-size: 26rpx;
  gap: 12rpx;
}

.loading-more::before {
  content: '';
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid rgba(212, 133, 106, 0.2);
  border-top-color: #D4856A;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  display: inline-block;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  color: #A89078;
  font-size: 26rpx;
}
