<!--qrcode.wxml-->
<view class="container">
  <!-- 输入内容 -->
  <view class="section">
    <text class="section-title">输入内容</text>
    <view class="input-box">
      <input type="text" placeholder="请输入文本或网址" value="{{inputContent}}" bindinput="setInputContent" class="input"/>
    </view>
  </view>

  <!-- 二维码类型 -->
  <view class="section">
    <text class="section-title">二维码类型</text>
    <view class="qrcode-type">
      <view class="type-item {{qrcodeType === 'text' ? 'active' : ''}}" bindtap="setQrcodeType" data-type="text">文本</view>
      <view class="type-item {{qrcodeType === 'url' ? 'active' : ''}}" bindtap="setQrcodeType" data-type="url">网址</view>
      <view class="type-item {{qrcodeType === 'card' ? 'active' : ''}}" bindtap="setQrcodeType" data-type="card">名片</view>
    </view>
  </view>

  <!-- 生成按钮 -->
  <view class="section">
    <button class="generate-btn" bindtap="generate">生成二维码</button>
  </view>

  <!-- 二维码展示 -->
  <view class="section" wx:if="{{showQrcode}}">
    <view class="qrcode-box">
      <view class="qrcode-image">
        <canvas type="2d" id="qrcodeCanvas" class="qrcode-canvas"></canvas>
      </view>
      <view class="qrcode-buttons">
        <button class="save-btn" bindtap="saveQrcode">保存</button>
        <button class="share-btn" bindtap="shareQrcode">分享</button>
      </view>
    </view>
  </view>
</view>