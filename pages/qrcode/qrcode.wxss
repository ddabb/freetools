/**qrcode.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  padding: 40rpx 30rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.input-box {
  background: rgba(255, 255, 255, 0.95);
  padding: 28rpx 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
}

.input {
  width: 100%;
  font-size: 30rpx;
  border: none;
  outline: none;
  color: #333;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.qrcode-type {
  display: flex;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.9);
  padding: 22rpx 0;
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.type-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.type-item.active {
  color: white;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 28rpx rgba(102, 126, 234, 0.4);
}

.type-item.active::before {
  opacity: 1;
}

.type-item text {
  position: relative;
  z-index: 1;
}

.generate-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.35);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.generate-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.generate-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.25);
}

.generate-btn:active::after {
  left: 100%;
}

.qrcode-box {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(20rpx);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.qrcode-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.qrcode-image {
  width: 480rpx;
  height: 480rpx;
  background: linear-gradient(145deg, #f8f9ff 0%, #f0f4ff 100%);
  margin: 0 auto 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.qrcode-image::after {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  border: 2rpx dashed rgba(102, 126, 234, 0.1);
  border-radius: 20rpx;
  pointer-events: none;
}

.qrcode-canvas {
  width: 600rpx;
  height: 600rpx;
  border-radius: 24rpx;
}

.qrcode-buttons {
  display: flex;
  gap: 20rpx;
}

.save-btn, .share-btn {
  flex: 1;
  border: none;
  border-radius: 20rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.save-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  box-shadow: 0 6rpx 24rpx rgba(245, 87, 108, 0.3);
}

.save-btn:active {
  transform: scale(0.96);
  box-shadow: 0 3rpx 16rpx rgba(245, 87, 108, 0.2);
}

.share-btn {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: white;
  box-shadow: 0 6rpx 24rpx rgba(17, 153, 142, 0.3);
}

.share-btn:active {
  transform: scale(0.96);
  box-shadow: 0 3rpx 16rpx rgba(17, 153, 142, 0.2);
}
