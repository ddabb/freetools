/**qrcode.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
}

.container {
  padding: 20rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.input-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
}

.input {
  width: 100%;
  font-size: 32rpx;
  border: none;
  outline: none;
  color: #333;
  font-weight: 500;
}

.qrcode-type {
  display: flex;
  gap: 20rpx;
}

.type-item {
  flex: 1;
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  transition: all 0.3s ease;
}

.type-item.active {
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
  color: white;
  box-shadow: 0 10rpx 30rpx rgba(161, 140, 209, 0.4);
}

.generate-btn {
  width: 100%;
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 30rpx rgba(161, 140, 209, 0.4);
  transition: all 0.3s ease;
}

.generate-btn:active {
  transform: scale(0.98);
}

.qrcode-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.qrcode-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #a18cd1, #fbc2eb);
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
  margin: 0 auto 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  box-shadow: inset 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.qrcode-placeholder {
  font-size: 160rpx;
}

.qrcode-buttons {
  display: flex;
  gap: 20rpx;
}

.save-btn, .share-btn {
  flex: 1;
  border: none;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 32rpx;
  font-weight: 800;
  transition: all 0.3s ease;
}

.save-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  box-shadow: 0 8rpx 25rpx rgba(245, 87, 108, 0.4);
}

.share-btn {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: white;
  box-shadow: 0 8rpx 25rpx rgba(17, 153, 142, 0.4);
}
