/**unit-converter.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
}

.container {
  padding: 20rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.unit-types {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-item {
  flex: 1;
  min-width: 160rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  padding: 20rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  transition: all 0.3s ease;
}

.type-item.active {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
  color: white;
  box-shadow: 0 10rpx 30rpx rgba(255, 154, 158, 0.4);
}

.input-box, .result-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.input {
  flex: 1;
  font-size: 32rpx;
  border: none;
  outline: none;
  color: #333;
  font-weight: 500;
}

.result-value {
  flex: 1;
  font-size: 32rpx;
  font-weight: 800;
  color: #ff6b6b;
}

.unit-picker {
  font-size: 32rpx;
  color: #666;
  padding-left: 20rpx;
  border-left: 2rpx solid #eee;
  font-weight: 600;
}

.common-conversions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15rpx;
}

.conversion-item {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  padding: 20rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
}
