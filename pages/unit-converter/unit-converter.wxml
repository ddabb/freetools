<!--unit-converter.wxml-->
<view class="container">
  <!-- 单位类型 -->
  <view class="section">
    <text class="section-title">单位类型</text>
    <view class="unit-types">
      <view class="type-item {{unitType === 'length' ? 'active' : ''}}" bindtap="setUnitType" data-type="length">长度</view>
      <view class="type-item {{unitType === 'area' ? 'active' : ''}}" bindtap="setUnitType" data-type="area">面积</view>
      <view class="type-item {{unitType === 'weight' ? 'active' : ''}}" bindtap="setUnitType" data-type="weight">重量</view>
      <view class="type-item {{unitType === 'temperature' ? 'active' : ''}}" bindtap="setUnitType" data-type="temperature">温度</view>
    </view>
  </view>
  
  <!-- 输入数值 -->
  <view class="section">
    <text class="section-title">输入数值</text>
    <view class="input-box">
      <input type="number" value="{{inputValue}}" bindinput="setInputValue" class="input"/>
      <picker bindchange="setFromUnit" value="{{fromUnitIndex}}" range="{{fromUnits}}">
        <view class="unit-picker">{{fromUnits[fromUnitIndex]}}</view>
      </picker>
    </view>
  </view>
  
  <!-- 转换结果 -->
  <view class="section">
    <text class="section-title">转换结果</text>
    <view class="result-box">
      <text class="result-value">{{resultValue}}</text>
      <picker bindchange="setToUnit" value="{{toUnitIndex}}" range="{{toUnits}}">
        <view class="unit-picker">{{toUnits[toUnitIndex]}}</view>
      </picker>
    </view>
  </view>
  
  <!-- 常用转换 -->
  <view class="section">
    <text class="section-title">常用转换</text>
    <view class="common-conversions">
      <view class="conversion-item">1米 = 3.28英尺</view>
      <view class="conversion-item">1公斤 = 2.2磅</view>
      <view class="conversion-item">1摄氏度 = 33.8华氏度</view>
    </view>
  </view>
</view>