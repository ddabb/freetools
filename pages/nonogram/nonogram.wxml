<view class="container">
  <!-- 难度 -->
  <view class="diff-bar">
    <view class="pill {{difficulty==='easy'?'on':''}}" bindtap="setDifficulty" data-diff="easy">简单</view>
    <view class="pill {{difficulty==='medium'?'on':''}}" bindtap="setDifficulty" data-diff="medium">中等</view>
    <view class="pill {{difficulty==='hard'?'on':''}}" bindtap="setDifficulty" data-diff="hard">困难</view>
  </view>

  <!-- 顶栏 -->
  <view class="top-info">
    <view class="level-btn" bindtap="openLevelSelector">
      <text class="level-num">第 {{currentLevel}} 关</text>
      <text class="level-arrow">▼</text>
    </view>
    <view class="mode-toggle">
      <view class="mode-btn {{mode==='fill'?'on':''}}" bindtap="setMode" data-mode="fill">● 填充</view>
      <view class="mode-btn {{mode==='mark'?'on':''}}" bindtap="setMode" data-mode="mark">✕ 标记</view>
    </view>
    <view class="info-right">
      <text class="timer">⏱ {{timerText}}</text>
      <text class="progress">{{filledCount}}/{{totalFill}}</text>
    </view>
  </view>

  <!-- 加载 -->
  <view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>

  <!-- 棋盘 -->
  <view class="board-wrap" wx:else>
    <view class="board" style="width:{{boardPx}}px;">
      <!-- 列提示 -->
      <view class="col-hints-row">
        <view class="corner" style="width:{{hintPx}}px;height:{{colHintH}}px;"></view>
        <view class="col-hint" wx:for="{{colHints}}" wx:key="idx" style="width:{{cellPx}}px;height:{{colHintH}}px;">
          <text class="hn" wx:for="{{item}}" wx:for-item="n" wx:key="*this">{{n}}</text>
        </view>
      </view>
      <!-- 行 -->
      <view class="row-group" wx:for="{{rowGroups}}" wx:key="ri">
        <view class="row-hint" style="width:{{hintPx}}px;height:{{cellPx}}px;">
          <text class="hn" wx:for="{{rowHints[item.ri]}}" wx:for-item="n" wx:key="*this">{{n}}</text>
        </view>
        <view
          wx:for="{{item.cells}}"
          wx:for-item="cell"
          wx:key="ci"
          class="{{cell.cls}}"
          style="width:{{cellPx}}px;height:{{cellPx}}px;"
          catchtouchstart="onTouchStart"
          catchtouchmove="onTouchMove"
          catchtouchend="onTouchEnd"
          data-row="{{item.ri}}"
          data-col="{{cell.ci}}"
        >
          <text wx:if="{{cell.s === 2}}" class="mark-x">✕</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作 -->
  <view class="action-bar" wx:if="{{!loading}}">
    <view class="btn" bindtap="undo">↩ 重来</view>
  </view>

  <!-- 通关弹窗 -->
  <view class="mask" wx:if="{{showWin}}" bindtap="closeWin">
    <view class="card" catchtap="">
      <view class="card-icon">🎉</view>
      <view class="card-title">通关！</view>
      <view class="card-time">用时 {{timerText}}</view>
      <view class="card-btn" bindtap="nextLevel">下一关 ▶</view>
    </view>
  </view>

  <!-- 关卡选择器 -->
  <view class="mask" wx:if="{{showLevelSelector}}" bindtap="closeLevelSelector">
    <view class="level-card" catchtap="">
      <view class="level-card-header">
        <text class="level-card-title">{{difficultyText}} · {{completedCount}}关已完成</text>
        <view class="level-close" bindtap="closeLevelSelector">✕</view>
      </view>
      <scroll-view class="level-scroll" scroll-y>
        <view class="level-grid">
          <view
            class="level-item {{isCompleted(n)?'done':''}} {{n===currentLevel?'curr':''}}"
            wx:for="{{levelNumbers}}"
            wx:for-item="n"
            wx:key="*this"
            bindtap="selectLevel"
            data-l="{{n}}"
          >{{n}}<text class="done-mark" wx:if="{{isCompleted(n)}}">✓</text></view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
