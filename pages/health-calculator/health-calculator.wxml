<!--health-calculator.wxml-->
<view class="container">
  <!-- 身高输入 -->
  <view class="section">
    <text class="section-title">身高（cm）</text>
    <view class="input-box">
      <input type="number" value="{{height}}" bindinput="setHeight" class="input"/>
    </view>
  </view>
  
  <!-- 体重输入 -->
  <view class="section">
    <text class="section-title">体重（kg）</text>
    <view class="input-box">
      <input type="number" value="{{weight}}" bindinput="setWeight" class="input"/>
    </view>
  </view>
  
  <!-- 性别选择 -->
  <view class="section">
    <text class="section-title">性别</text>
    <view class="gender-select">
      <view class="gender-item {{gender === 'male' ? 'active' : ''}}" bindtap="setGender" data-gender="male">男</view>
      <view class="gender-item {{gender === 'female' ? 'active' : ''}}" bindtap="setGender" data-gender="female">女</view>
    </view>
  </view>
  
  <!-- 计算按钮 -->
  <view class="section">
    <button class="calculate-btn" bindtap="calculate">计算</button>
  </view>
  
  <!-- 结果展示 -->
  <view class="section" wx:if="{{showResult}}">
    <view class="result-box">
      <view class="result-item">
        <text class="result-label">BMI指数</text>
        <text class="result-value bmi">{{bmi}}</text>
        <text class="bmi-status">{{bmiStatus}}</text>
      </view>
      <view class="result-divider"></view>
      <view class="result-row">
        <view class="result-item">
          <text class="result-label">理想体重</text>
          <text class="result-value ideal-weight">{{idealWeight}} kg</text>
        </view>
        <view class="result-item">
          <text class="result-label">健康建议</text>
          <text class="result-value suggestion">{{suggestion}}</text>
        </view>
      </view>
    </view>
  </view>
</view>