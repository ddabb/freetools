page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

.page-header {
  text-align: center;
  margin-bottom: 24rpx;
  padding: 32rpx 0 0;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 10rpx;
  display: block;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
}

.search-container {
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #999;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  padding: 8rpx 0;
}

.search-placeholder {
  color: #999;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  margin-left: 12rpx;
  padding: 4rpx 8rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.alphabet-filter {
  width: 100%;
  position: relative;
  margin-bottom: 24rpx;
}

.alphabet-scroll {
  width: 100%;
  white-space: nowrap;
  padding: 0;
  margin: 0;
  height: 88rpx;
  flex-shrink: 0;
}

.alphabet-list {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  height: 88rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

/* 隐藏滚动条但保持滚动功能 */
.alphabet-scroll::-webkit-scrollbar {
  display: none;
}

.alphabet-scroll {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.alphabet-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  flex-shrink: 0;
  flex: none;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.alphabet-item.active {
  background: white;
  color: #667eea;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  border-color: white;
}

.alphabet-item:hover {
  background: rgba(255, 255, 255, 0.4);
  transform: scale(1.05);
}

.alphabet-item.active:hover {
  background: white;
  transform: scale(1.05);
}

.category-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.category-list {
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.2);
  min-height: 200rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 32rpx;
  gap: 16rpx;
}

.loading-state::before {
  content: '';
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.2);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  display: inline-block;
}

@keyframes spin { to { transform: rotate(360deg); } }

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.error-text {
  color: #e74c3c;
  font-size: 32rpx;
  text-align: center;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.retry-btn::after { border: none; }

.category-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-card {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid rgba(102, 126, 234, 0.1);
}

.category-card-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-color: transparent;
}

.category-card-body {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.category-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.category-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-count {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  font-size: 34rpx;
  color: #666;
  font-weight: 600;
}

.empty-subtext {
  font-size: 28rpx;
  color: #999;
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0 16rpx;
}

.load-more-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
  padding: 12rpx 40rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.3);
  border-radius: 40rpx;
}

.list-end {
  text-align: center;
  padding: 32rpx 0 16rpx;
}

.end-text {
  font-size: 24rpx;
  color: #ccc;
}
