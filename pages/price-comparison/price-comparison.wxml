<!--price-comparison.wxml-->
<view class="container">
  <!-- 原价输入 -->
  <view class="section">
    <text class="section-title">原价（元）</text>
    <view class="input-box">
      <input type="number" value="{{originalPrice}}" bindinput="setOriginalPrice" class="input"/>
    </view>
  </view>
  
  <!-- 折扣输入 -->
  <view class="section">
    <text class="section-title">折扣（%）</text>
    <view class="input-box">
      <input type="number" value="{{discount}}" bindinput="setDiscount" class="input"/>
    </view>
  </view>
  
  <!-- 计算按钮 -->
  <view class="section">
    <button class="calculate-btn" bindtap="calculate">计算</button>
  </view>
  
  <!-- 结果展示 -->
  <view class="section" wx:if="{{showResult}}">
    <view class="result-box">
      <view class="result-item">
        <text class="result-label">折后价格</text>
        <text class="result-value price">{{discountedPrice}} 元</text>
      </view>
      <view class="result-divider"></view>
      <view class="result-row">
        <view class="result-item">
          <text class="result-label">节省金额</text>
          <text class="result-value saving">{{savingAmount}} 元</text>
        </view>
        <view class="result-item">
          <text class="result-label">折扣力度</text>
          <text class="result-value discount-rate">{{discountRate}} 折</text>
        </view>
      </view>
    </view>
  </view>
</view>