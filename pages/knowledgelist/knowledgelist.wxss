/* packages/knowledge/pages/knowledgelist/knowledgelist.wxss */
/* 水墨屏/泛黄纸张风格 - 浅色协调版 */

/* ========== 水墨风格配色变量 ========== */
page {
  /* 泛黄纸张背景 */
  background: linear-gradient(160deg, #FBF4E3 0%, #F9EFDE 50%, #F6E9D0 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', serif;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

/* ========== 顶部搜索栏和排序容器 ========== */
.search-sort-container {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx 12rpx;
  /* 淡米色卡片背景 */
  background: rgba(255, 252, 240, 0.9);
  margin: 0 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #E0D4C4;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(120, 100, 75, 0.06);
}

/* ========== 顶部搜索栏 ========== */
.search-bar {
  flex: 1;
  min-width: 0;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  /* 素色纸张背景 */
  background: rgba(255, 250, 235, 0.95);
  border-radius: 40rpx;
  padding: 0 32rpx;
  height: 80rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(120, 100, 75, 0.05);
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #D8CDB8;
}

.icon-search {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  color: #A89078;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #4A3F35;
  height: 80rpx;
  line-height: 80rpx;
  min-width: 0;
  padding: 0 16rpx;
  text-align: center;
  background: transparent;
}

.icon-clear {
  font-size: 28rpx;
  color: #B8A890;
  padding: 8rpx;
  flex-shrink: 0;
}

.search-count {
  font-size: 24rpx;
  color: #A89078;
  padding: 10rpx 0 14rpx;
  text-align: center;
}

/* ========== 分类导航 ========== */
.category-container {
  width: 100%;
  position: relative;
}

.category-nav {
  width: 100%;
  white-space: nowrap;
  padding: 0;
  margin: 16rpx 0 24rpx;
  height: 100rpx;
  flex-shrink: 0;
}

.category-nav-inner {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  height: 100rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

/* 隐藏滚动条但保持滚动功能 */
.category-nav::-webkit-scrollbar {
  display: none;
}

.category-nav {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  margin-right: 10rpx;
  /* 淡米色背景 */
  background: rgba(255, 250, 235, 0.9);
  border-radius: 20rpx;
  border: 1rpx solid #D8CDB8;
  transition: all 0.3s ease;
  flex-shrink: 0;
  flex: none;
  box-shadow: 0 2rpx 6rpx rgba(120, 100, 75, 0.06);
  height: 72rpx;
  box-sizing: border-box;
}

.category-item text {
  color: #6D5D4D;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}

.category-item .count {
  font-size: 22rpx;
  color: #A89078;
  margin-top: 2rpx;
}

.category-item.active {
  /* 柔和浅朱红色强调 */
  background: #E8A090;
  border-color: #D4856A;
  box-shadow: 0 4rpx 12rpx rgba(212, 133, 106, 0.2);
}

.category-item.active text {
  color: #FFFDF8;
}

.category-item.active .count {
  color: rgba(255, 253, 248, 0.8);
}

.category-tree-trigger {
  background: rgba(255, 250, 235, 0.9);
  position: relative;
  left: 24rpx;
  margin-right: 24rpx;
}

.category-tree-trigger.tree-open {
  background: rgba(255, 252, 240, 0.98);
  border-color: #D4856A;
  box-shadow: 0 4rpx 12rpx rgba(212, 133, 106, 0.12);
}

.category-tree-trigger.tree-open text {
  color: #D4856A;
}

/* ========== 排序按钮 ========== */
.sort-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  background: rgba(255, 250, 235, 0.9);
  border-radius: 16rpx;
  border: 1rpx solid #D8CDB8;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.sort-wrap-hover {
  background: rgba(255, 248, 225, 0.95);
  border-color: #D4856A;
}

.sort-icon {
  font-size: 20rpx;
  color: #A89078;
}

.sort-text {
  font-size: 22rpx;
  color: #6D5D4D;
  font-weight: 500;
}

/* ========== 文章列表滚动区 ========== */
.article-scroll {
  flex: 1;
  margin-top: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  gap: 20rpx;
}

.empty-icon {
  font-size: 96rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #6D5D4D;
  font-weight: 600;
}

.empty-hint {
  font-size: 24rpx;
  color: #A89078;
}

.empty-btn {
  margin-top: 16rpx;
  padding: 14rpx 40rpx;
  background: #D4856A;
  color: #FFFDF8;
  border: none;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.empty-btn::after { border: none; }

/* ========== 文章卡片列表 ========== */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0;
}

.article-card {
  width: 100%;
  padding: 0;
  box-sizing: border-box;
  background: transparent;
  position: relative;
}

.article-card .card-inner {
  /* 素色宣纸效果 */
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(120, 100, 75, 0.08);
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  border: 1rpx solid #E0D4C4;
}

.article-card .card-inner-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(120, 100, 75, 0.1);
}

.article-card .card-inner::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4rpx;
  /* 浅朱红上边框 */
  background: linear-gradient(90deg, #C9806E, #D4856A, #C9806E);
  border-radius: 16rpx 16rpx 0 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
  flex-shrink: 0;
}

.card-category {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: #D4856A;
  background: rgba(212, 133, 106, 0.1);
  border-radius: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160rpx;
  border: 1rpx solid rgba(212, 133, 106, 0.15);
}

.card-order {
  font-size: 22rpx;
  color: #C0B0A0;
  font-weight: 500;
  flex-shrink: 0;
}

.card-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 600;
  color: #4A3F35;
  line-height: 1.4;
  margin-bottom: 10rpx;
  flex-shrink: 0;
  /* 宋体/衬线字体效果 */
  letter-spacing: 1rpx;
}

.card-desc {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 26rpx;
  color: #6D5D4D;
  line-height: 1.5;
  margin-bottom: 14rpx;
  flex: 1;
}

.card-footer {
  flex-shrink: 0;
  margin-top: auto;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.card-tag {
  font-size: 22rpx;
  color: #6D5D4D;
  background: rgba(109, 93, 77, 0.06);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  border: 1rpx solid rgba(109, 93, 77, 0.08);
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 10rpx;
  border-top: 1rpx solid #E0D4C4;
}

.card-words,
.card-time {
  font-size: 22rpx;
  color: #A89078;
}

.card-decoration {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  opacity: 0.06;
  pointer-events: none;
}

.card-decoration.deco-1 { background: #6D5D4D; }
.card-decoration.deco-2 { background: #A89078; }
.card-decoration.deco-3 { background: #D4856A; }

/* ========== 加载状态 ========== */
.loading-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #A89078;
}

/* ========== 分类树加载状态 ========== */
.tree-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  gap: 24rpx;
}

.tree-loading-icon {
  font-size: 48rpx;
  color: rgba(212, 133, 106, 0.5);
  animation: treeLoading 1.5s ease-in-out infinite;
}

@keyframes treeLoading {
  0%, 100% {
    transform: scale(1);
    opacity: 0.5;
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
  }
}

.tree-loading-text {
  font-size: 26rpx;
  color: rgba(109, 93, 77, 0.6);
  font-weight: 500;
}

/* ========== 页面加载动画 ========== */
.page-loading {
  position: absolute;
  top: 320rpx;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(160deg, #FBF4E3 0%, #F9EFDE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  opacity: 0;
  animation: pageLoadingFadeIn 0.5s ease-out forwards;
  border-radius: 0 0 24rpx 24rpx;
}

.loading-spinner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.spinner-circle {
  width: 100rpx;
  height: 100rpx;
  border: 6rpx solid rgba(212, 133, 106, 0.2);
  border-top: 6rpx solid #D4856A;
  border-radius: 50%;
  animation: spinnerRotate 1.5s linear infinite;
}

.spinner-text {
  font-size: 30rpx;
  color: #6D5D4D;
  font-weight: 500;
  text-align: center;
  animation: textPulse 2s ease-in-out infinite;
}

@keyframes pageLoadingFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes spinnerRotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

@keyframes textPulse {
  0%, 100% {
    opacity: 0.8;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
}

/* ========== 列表结束 ========== */
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx 0 60rpx;
}

.end-line {
  width: 60rpx;
  height: 2rpx;
  background: #D8CDB8;
  border-radius: 1rpx;
}

.end-text {
  font-size: 22rpx;
  color: #C0B0A0;
  white-space: nowrap;
}

/* ========== 分类树弹窗 ========== */
.category-container {
  position: relative;
}

.category-tree-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  transform: translateY(100%);
  transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.category-tree-modal.show {
  opacity: 1;
  transform: translateY(0);
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(74, 63, 53, 0.4);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.category-tree-modal.show .modal-overlay {
  opacity: 1;
}

.modal-content {
  position: relative;
  background: linear-gradient(180deg, #FFFEF8 0%, #FFF5E8 100%);
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 80vh;
  box-shadow: 0 -8rpx 32rpx rgba(120, 100, 75, 0.1);
  z-index: 1000;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #E0D4C4;
  background: linear-gradient(135deg, #7A6658 0%, #6D5D4D 100%);
  border-radius: 32rpx 32rpx 0 0;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFDF8;
}

.modal-close {
  font-size: 32rpx;
  color: #FFFDF8;
  padding: 8rpx;
}

.tree-scroll {
  max-height: calc(80vh - 180rpx);
  padding: 20rpx 24rpx 28rpx;
  background: linear-gradient(180deg, rgba(255, 254, 248, 0.98) 0%, rgba(255, 245, 232, 0.98) 100%);
  box-sizing: border-box;
  opacity: 0;
  transform: translateY(20rpx);
  transition: opacity 0.4s ease 0.1s, transform 0.4s ease 0.1s;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.category-tree-modal.show .tree-scroll {
  opacity: 1;
  transform: translateY(0);
}

.tree-root-outer {
  position: relative;
}

.tree-root-children {
  margin-left: 28rpx;
  padding-left: 24rpx;
  border-left: 2rpx solid rgba(168, 144, 120, 0.25);
}

.tree-branch {
  position: relative;
}

.tree-branch.level-0 {
  margin-top: 16rpx;
}

.tree-branch.level-0:first-child {
  margin-top: 0;
}

.tree-children {
  margin-left: 28rpx;
  padding-left: 24rpx;
  border-left: 2rpx solid rgba(168, 144, 120, 0.2);
}

.tree-node {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  margin: 10rpx 0;
  border-radius: 16rpx;
  background: rgba(255, 252, 240, 0.96);
  border: 1rpx solid rgba(168, 144, 120, 0.12);
  box-shadow: 0 2rpx 8rpx rgba(120, 100, 75, 0.04);
  transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  opacity: 1;
}

.tree-node-root {
  background: linear-gradient(135deg, rgba(122, 102, 88, 0.08) 0%, rgba(109, 93, 77, 0.08) 100%);
  border-color: rgba(122, 102, 88, 0.15);
  box-shadow: 0 2rpx 10rpx rgba(122, 102, 88, 0.06);
}

.tree-node-hover {
  background-color: rgba(212, 133, 106, 0.05);
  transform: scale(0.995);
}

.tree-node.active {
  background: linear-gradient(135deg, #7A6658 0%, #6D5D4D 100%);
  border-color: transparent;
  box-shadow: 0 6rpx 20rpx rgba(122, 102, 88, 0.2);
}

.tree-node.active .tree-label,
.tree-node.active .tree-node-icon,
.tree-node.active .tree-count {
  color: #FFFDF8;
}

.tree-node.active .tree-count {
  background: rgba(255, 253, 248, 0.18);
}

.tree-node-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  flex: 1;
}

.tree-node-icon {
  font-size: 26rpx;
  color: #A89078;
  width: 32rpx;
  text-align: center;
  flex-shrink: 0;
  transition: transform 0.3s ease, color 0.3s ease;
}

.tree-node-hover .tree-node-icon {
  transform: scale(1.1);
}

.tree-label {
  font-size: 28rpx;
  color: #4A3F35;
  font-weight: 500;
  line-height: 1.4;
}

.tree-count {
  font-size: 22rpx;
  color: #A89078;
  background: rgba(168, 144, 120, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.modal-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 245, 232, 0.95) 0%, rgba(255, 243, 220, 0.98) 100%);
  border-top: 1rpx solid rgba(168, 144, 120, 0.1);
}

.modal-footer-text {
  font-size: 24rpx;
  color: #A89078;
  letter-spacing: 1rpx;
}

.category-item .icon {
  margin-left: 8rpx;
  font-size: 22rpx;
}
