/* packages/knowledge/pages/knowledgelist/knowledgelist.wxss */

/* ========== 基础样式 ========== */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

/* ========== 顶部搜索栏和排序容器 ========== */
.search-sort-container {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx 12rpx;
  background: rgba(255, 255, 255, 0.15);
  margin: 0 16rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  gap: 16rpx;
}

/* ========== 顶部搜索栏 ========== */
.search-bar {
  flex: 1;
  min-width: 0;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50rpx;
  padding: 0 40rpx;
  height: 88rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.icon-search {
  font-size: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  height: 80rpx;
  line-height: 80rpx;
  min-width: 0;
  padding: 0 16rpx;
  text-align: center;
}

.icon-clear {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
  flex-shrink: 0;
}

.search-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 10rpx 0 14rpx;
  text-align: center;
}

/* ========== 分类导航 ========== */
.category-container {
  width: 100%;
  position: relative;
}

.category-nav {
  width: 100%;
  white-space: nowrap;
  padding: 0;
  margin: 16rpx 0 24rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.category-nav-inner {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  height: 120rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

/* 隐藏滚动条但保持滚动功能 */
.category-nav::-webkit-scrollbar {
  display: none;
}

.category-nav {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  margin-right: 10rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
  flex-shrink: 0;
  flex: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  height: 88rpx;
  box-sizing: border-box;
}

.category-item text {
  color: #333333;
  font-size: 28rpx;
  font-weight: 500;
  white-space: nowrap;
}

.category-item .count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
}

.category-item.active {
  background: white;
  border-color: white;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.category-item.active text {
  color: #667eea;
}

.category-item.active .count {
  color: rgba(102, 126, 234, 0.6);
}

.category-tree-trigger {
  background: rgba(255, 255, 255, 0.22);
  position: relative;
  left: 24rpx;
  margin-right: 24rpx;
}

.category-tree-trigger.tree-open {
  background: rgba(255, 255, 255, 0.96);
  border-color: rgba(255, 255, 255, 0.96);
  box-shadow: 0 6rpx 18rpx rgba(48, 66, 134, 0.18);
}

.category-tree-trigger.tree-open text {
  color: #5a6dd8;
}


/* ========== 排序按钮 ========== */
.sort-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.sort-wrap-hover {
  background: rgba(255, 255, 255, 0.35);
}

.sort-icon {
  font-size: 22rpx;
  color: white;
}

.sort-text {
  font-size: 22rpx;
  color: white;
  font-weight: 500;
}

/* 删除重复的样式定义 */

/* ========== 文章列表滚动区 ========== */
.article-scroll {
  flex: 1;
  margin-top: 0;
  /* 确保滚动条显示 */
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  gap: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.empty-btn {
  margin-top: 16rpx;
  padding: 16rpx 48rpx;
  background: white;
  color: #667eea;
  border: none;
  border-radius: 50rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.empty-btn::after { border: none; }

/* ========== 文章卡片列表 ========== */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0;
}

.article-card {
  width: 100%;
  padding: 0;
  box-sizing: border-box;
  background: transparent;
  position: relative;
}

.article-card .card-inner {
  background: white;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.article-card .card-inner-hover {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
}

.article-card .card-inner::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 20rpx 20rpx 0 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.card-category {
  display: inline-block;
  padding: 4rpx 14rpx;
  font-size: 18rpx;
  color: white;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160rpx;
}

.card-category.category-product-usage { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
.card-category.category-product-design { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
.card-category.category-product-thinking { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
.card-category.category-dev-practice { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
.card-category.category-dev-story { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }
.card-category.category-project-mgmt { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.card-category.category-pmp { background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); }
.card-category.category-agile { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
.card-category.category-soft-exam { background: linear-gradient(135deg, #8e2de2 0%, #4a00e0 100%); }
.card-category.category-legal { background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%); }
.card-category.category-safety { background: linear-gradient(135deg, #00c6ff 0%, #0072ff 100%); }
.card-category.category-calculation { background: linear-gradient(135deg, #fc4a1a 0%, #f7b733 100%); }
.card-category.category-uncategorized { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); }


.card-order {
  font-size: 24rpx;
  color: #ccc;
  font-weight: 500;
  flex-shrink: 0;
}

.card-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 12rpx;
  flex-shrink: 0;
}

.card-desc {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  flex: 1;
}

.card-footer {
  flex-shrink: 0;
  margin-top: auto;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.card-tag {
  font-size: 24rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.08);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 10rpx;
  border-top: 1rpx solid #f0f0f0;
}

.card-words,
.card-time {
  font-size: 24rpx;
  color: #999;
}

.card-decoration {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  opacity: 0.08;
  pointer-events: none;
}

.card-decoration.deco-1 { background: #667eea; }
.card-decoration.deco-2 { background: #764ba2; }
.card-decoration.deco-3 { background: #f093fb; }

/* ========== 加载状态 ========== */
.loading-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ========== 分类树加载状态 ========== */
.tree-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  gap: 24rpx;
}

.tree-loading-icon {
  font-size: 48rpx;
  color: rgba(102, 126, 234, 0.6);
  animation: treeLoading 1.5s ease-in-out infinite;
}

@keyframes treeLoading {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
  }
}

.tree-loading-text {
  font-size: 26rpx;
  color: rgba(102, 126, 234, 0.7);
  font-weight: 500;
}

/* ========== 页面加载动画 ========== */
.page-loading {
  position: absolute;
  top: 320rpx;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  opacity: 0;
  animation: pageLoadingFadeIn 0.5s ease-out forwards;
  border-radius: 0 0 24rpx 24rpx;
}

.loading-spinner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.spinner-circle {
  width: 120rpx;
  height: 120rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.3);
  border-top: 8rpx solid white;
  border-radius: 50%;
  animation: spinnerRotate 1.5s linear infinite;
}

.spinner-text {
  font-size: 32rpx;
  color: white;
  font-weight: 500;
  text-align: center;
  animation: textPulse 2s ease-in-out infinite;
}

@keyframes pageLoadingFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes spinnerRotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

@keyframes textPulse {
  0%, 100% {
    opacity: 0.8;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
}

/* ========== 列表结束 ========== */
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx 0 60rpx;
}

.end-line {
  width: 80rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 1rpx;
}

.end-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  white-space: nowrap;
}

/* ========== 分类树弹窗 ========== */
.category-container {
  position: relative;
}

.category-tree-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  transform: translateY(100%);
  transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.category-tree-modal.show {
  opacity: 1;
  transform: translateY(0);
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.category-tree-modal.show .modal-overlay {
  opacity: 1;
}

.modal-content {
  position: relative;
  background: linear-gradient(180deg, #ffffff 0%, #f7f8ff 100%);
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 80vh;
  box-shadow: 0 -12rpx 40rpx rgba(50, 70, 140, 0.2);
  z-index: 1000;
  overflow: hidden;
}


.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 32rpx 32rpx 0 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: white;
}

.modal-close {
  font-size: 32rpx;
  color: white;
  padding: 8rpx;
}

.tree-scroll {
  max-height: calc(80vh - 180rpx);
  padding: 20rpx 24rpx 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(244, 246, 255, 0.96) 100%);
  box-sizing: border-box;
  opacity: 0;
  transform: translateY(20rpx);
  transition: opacity 0.4s ease 0.1s, transform 0.4s ease 0.1s;
  /* 确保滚动条显示 */
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.category-tree-modal.show .tree-scroll {
  opacity: 1;
  transform: translateY(0);
}

.tree-root-outer {
  position: relative;
}

.tree-root-children {
  margin-left: 28rpx;
  padding-left: 24rpx;
  border-left: 2rpx solid rgba(102, 126, 234, 0.2);
}

.tree-branch {
  position: relative;
}

.tree-branch.level-0 {
  margin-top: 16rpx;
}

.tree-branch.level-0:first-child {
  margin-top: 0;
}

.tree-children {
  margin-left: 28rpx;
  padding-left: 24rpx;
  border-left: 2rpx solid rgba(102, 126, 234, 0.16);
}

.tree-node {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  margin: 12rpx 0;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(102, 126, 234, 0.12);
  box-shadow: 0 8rpx 24rpx rgba(79, 101, 187, 0.08);
  transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  opacity: 1;
}


.tree-node-root {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.14) 0%, rgba(118, 75, 162, 0.14) 100%);
  border-color: rgba(102, 126, 234, 0.18);
  box-shadow: 0 10rpx 26rpx rgba(79, 101, 187, 0.12);
}


.tree-node-hover {
  background-color: rgba(102, 126, 234, 0.08);
  transform: scale(0.995);
}

.tree-node.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  box-shadow: 0 12rpx 28rpx rgba(84, 96, 205, 0.24);
}

.tree-node.active .tree-label,
.tree-node.active .tree-node-icon,
.tree-node.active .tree-count {
  color: #ffffff;
}

.tree-node.active .tree-count {
  background: rgba(255, 255, 255, 0.18);
}

.tree-node-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  flex: 1;
}

.tree-node-icon {
  font-size: 28rpx;
  color: #5c6ed6;
  width: 32rpx;
  text-align: center;
  flex-shrink: 0;
  transition: transform 0.3s ease, color 0.3s ease;
}

.tree-node-hover .tree-node-icon {
  transform: scale(1.1);
}

.tree-label {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  line-height: 1.4;
}

.tree-count {
  font-size: 24rpx;
  color: #5f6fa5;
  background: rgba(102, 126, 234, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.modal-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(245, 247, 255, 0.92) 0%, rgba(232, 238, 255, 0.98) 100%);
  border-top: 1rpx solid rgba(102, 126, 234, 0.12);
}

.modal-footer-text {
  font-size: 24rpx;
  color: #51628f;
  letter-spacing: 1rpx;
}

.category-item .icon {
  margin-left: 8rpx;
  font-size: 24rpx;
}


