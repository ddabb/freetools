/**mine.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  position: relative;
  padding-bottom: 60rpx;
}

/* 顶部背景 */
.top-bg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  height: 350rpx;
  position: relative;
  border-radius: 0 0 50rpx 50rpx;
}

/* 用户信息 */
.user-info {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin: -120rpx 30rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.user-info::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-right: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
}

.user-details {
  flex: 1;
}

.user-nickname {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
  display: block;
  color: #333;
}

.user-level {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 600;
}

/* 工具使用统计 */
.stats-card {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 24rpx;
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
  display: flex;
  justify-content: space-around;
  position: relative;
  overflow: hidden;
}

.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #4facfe, #00f2fe);
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-number {
  font-size: 40rpx;
  font-weight: 800;
  color: #667eea;
  display: block;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

/* 功能列表 */
.function-list {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 24rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  position: relative;
}

.function-list::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #4facfe, #00f2fe);
}

.function-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.function-item:last-child {
  border-bottom: none;
}

.function-item:hover {
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
}

.function-icon {
  font-size: 44rpx;
  margin-right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.3);
}

.function-name {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.function-arrow {
  font-size: 32rpx;
  color: #667eea;
  font-weight: bold;
}

/* 版本信息 */
.version-info {
  text-align: center;
  margin-top: 40rpx;
  padding-bottom: 20rpx;
}

.version-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}
