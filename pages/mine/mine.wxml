<!--mine.wxml-->
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <!-- 顶部背景 -->
    <view class="top-bg"></view>
    
    <!-- 用户信息 -->
    <view class="user-info">
      <view class="user-avatar">👤</view>
      <view class="user-details">
        <text class="user-nickname">用户昵称</text>
        <text class="user-level">普通会员</text>
      </view>
    </view>
    
    <!-- 工具使用统计 -->
    <view class="stats-card">
      <view class="stats-item">
        <text class="stats-number">12</text>
        <text class="stats-label">使用工具</text>
      </view>
      <view class="stats-item">
        <text class="stats-number">5</text>
        <text class="stats-label">收藏工具</text>
      </view>
      <view class="stats-item">
        <text class="stats-number">30</text>
        <text class="stats-label">总使用次数</text>
      </view>
    </view>
    
    <!-- 功能列表 -->
    <view class="function-list">
      <navigator url="#" class="function-item">
        <view class="function-icon">📋</view>
        <text class="function-name">历史记录</text>
        <text class="function-arrow">→</text>
      </navigator>
      <navigator url="#" class="function-item">
        <view class="function-icon">💎</view>
        <text class="function-name">会员中心</text>
        <text class="function-arrow">→</text>
      </navigator>
      <navigator url="#" class="function-item">
        <view class="function-icon">⭐</view>
        <text class="function-name">我的收藏</text>
        <text class="function-arrow">→</text>
      </navigator>
      <navigator url="#" class="function-item">
        <view class="function-icon">⚙️</view>
        <text class="function-name">设置</text>
        <text class="function-arrow">→</text>
      </navigator>
      <navigator url="#" class="function-item">
        <view class="function-icon">📤</view>
        <text class="function-name">意见反馈</text>
        <text class="function-arrow">→</text>
      </navigator>
      <navigator url="#" class="function-item">
        <view class="function-icon">ℹ️</view>
        <text class="function-name">关于我们</text>
        <text class="function-arrow">→</text>
      </navigator>
    </view>
    
    <!-- 版本信息 -->
    <view class="version-info">
      <text class="version-text">实用工具集合 v1.0.0</text>
    </view>
  </view>
</scroll-view>