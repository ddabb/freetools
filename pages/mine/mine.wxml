<!--mine.wxml-->
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <!-- 顶部背景已移除，由 page 背景统一 -->

    <!-- 通用欢迎区（无登录元素） -->
    <view class="user-info">
      <view class="user-avatar">
        <text class="default-avatar">🛠️</text>
      </view>
      <view class="user-details">
        <text class="user-nickname">欢迎使用实用工具</text>
        <text class="user-level">无需登录 · 即用即走</text>
      </view>
    </view>

    <!-- 工具统计（本地固定数据） -->
    <view class="stats-card">
      <view class="stats-item">
        <text class="stats-number">20+</text>
        <text class="stats-label">工具总数</text>
      </view>
      <view class="stats-item">
        <text class="stats-number">∞</text>
        <text class="stats-label">收藏工具</text>
      </view>
      <view class="stats-item">
        <text class="stats-number">∞</text>
        <text class="stats-label">使用次数</text>
      </view>
    </view>

    <!-- 菜单列表 -->
    <view class="menu-list">
      <view
        class="menu-item"
        wx:for="{{menuList}}"
        wx:key="title"
        bindtap="onMenuTap"
        data-index="{{index}}"
      >
        <view class="menu-icon">{{item.icon}}</view>
        <view class="menu-title">{{item.title}}</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>

    <!-- 功能按钮 -->
    <view class="action-buttons">
      <button class="action-btn" bindtap="onShareTap">
        <text class="btn-icon">📤</text>
        <text class="btn-text">分享给朋友</text>
      </button>
      <button class="action-btn" bindtap="onFeedbackTap">
        <text class="btn-icon">💬</text>
        <text class="btn-text">意见反馈</text>
      </button>
    </view>

    <!-- 版本信息 -->
    <view class="version-info">
      <text class="version-text">实用工具集合 v1.0.0</text>
    </view>
  </view>
</scroll-view>