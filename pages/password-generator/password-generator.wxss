/**password-generator.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.container {
  padding: 20rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.input-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
}

.input {
  width: 100%;
  font-size: 32rpx;
  border: none;
  outline: none;
  color: #333;
  font-weight: 500;
}

.checkbox-group {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  position: relative;
  overflow: hidden;
}

.checkbox-group::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #11998e, #38ef7d);
}

.checkbox-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.checkbox-item:last-child {
  border-bottom: none;
}

.checkbox {
  font-size: 36rpx;
  margin-right: 20rpx;
  color: #999;
  font-weight: bold;
}

.checkbox.checked {
  color: #11998e;
}

.checkbox-label {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.generate-btn {
  width: 100%;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 30rpx rgba(17, 153, 142, 0.4);
  transition: all 0.3s ease;
}

.generate-btn:active {
  transform: scale(0.98);
}

.password-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.password-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #11998e, #38ef7d);
}

.password {
  flex: 1;
  font-size: 32rpx;
  font-family: monospace;
  word-break: break-all;
  color: #333;
  font-weight: 600;
}

.copy-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 20rpx rgba(245, 87, 108, 0.3);
  transition: all 0.3s ease;
}

.copy-btn:active {
  transform: scale(0.95);
}

.strength-section {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
}

.strength-label {
  font-size: 28rpx;
  color: white;
  margin-right: 10rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.strength-value {
  font-size: 28rpx;
  font-weight: 800;
}

.strength-value.weak { color: #ff6b6b; }
.strength-value.medium { color: #feca57; }
.strength-value.strong { color: #ffffff; text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2); }
