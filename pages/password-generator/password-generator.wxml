<!--password-generator.wxml-->
<view class="container">
  <!-- 密码长度 -->
  <view class="section">
    <text class="section-title">密码长度</text>
    <view class="input-box">
      <input type="number" value="{{passwordLength}}" bindinput="setPasswordLength" class="input"/>
    </view>
  </view>
  
  <!-- 字符类型 -->
  <view class="section">
    <text class="section-title">字符类型</text>
    <view class="checkbox-group">
      <view class="checkbox-item">
        <text class="checkbox {{includeLowercase ? 'checked' : ''}}" bindtap="toggleLowercase">□</text>
        <text class="checkbox-label">小写字母</text>
      </view>
      <view class="checkbox-item">
        <text class="checkbox {{includeUppercase ? 'checked' : ''}}" bindtap="toggleUppercase">□</text>
        <text class="checkbox-label">大写字母</text>
      </view>
      <view class="checkbox-item">
        <text class="checkbox {{includeNumbers ? 'checked' : ''}}" bindtap="toggleNumbers">□</text>
        <text class="checkbox-label">数字</text>
      </view>
      <view class="checkbox-item">
        <text class="checkbox {{includeSymbols ? 'checked' : ''}}" bindtap="toggleSymbols">□</text>
        <text class="checkbox-label">特殊字符</text>
      </view>
    </view>
  </view>
  
  <!-- 生成按钮 -->
  <view class="section">
    <button class="generate-btn" bindtap="generate">生成密码</button>
  </view>
  
  <!-- 密码展示 -->
  <view class="section" wx:if="{{generatedPassword}}">
    <text class="section-title">生成的密码</text>
    <view class="password-box">
      <text class="password">{{generatedPassword}}</text>
      <button class="copy-btn" bindtap="copyPassword">复制</button>
    </view>
    
    <!-- 密码强度 -->
    <view class="strength-section">
      <text class="strength-label">密码强度：</text>
      <text class="strength-value {{passwordStrength}}">{{passwordStrengthText}}</text>
    </view>
  </view>
</view>