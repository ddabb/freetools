<!--time-tool.wxml-->
<view class="container">
  <!-- 工具选择 -->
  <view class="section">
    <view class="tool-tabs">
      <view class="tab-item {{activeTab === 'stopwatch' ? 'active' : ''}}" bindtap="setActiveTab" data-tab="stopwatch">秒表</view>
      <view class="tab-item {{activeTab === 'timer' ? 'active' : ''}}" bindtap="setActiveTab" data-tab="timer">计时器</view>
      <view class="tab-item {{activeTab === 'timezone' ? 'active' : ''}}" bindtap="setActiveTab" data-tab="timezone">时区转换</view>
    </view>
  </view>
  
  <!-- 秒表 -->
  <view class="section" wx:if="{{activeTab === 'stopwatch'}}">
    <view class="time-display">
      <text class="time-text">{{stopwatchTime}}</text>
    </view>
    <view class="control-buttons">
      <button class="control-btn start-btn" bindtap="startStopwatch">{{stopwatchRunning ? '暂停' : '开始'}}</button>
      <button class="control-btn reset-btn" bindtap="resetStopwatch">重置</button>
    </view>
  </view>
  
  <!-- 计时器 -->
  <view class="section" wx:if="{{activeTab === 'timer'}}">
    <view class="time-inputs">
      <view class="time-input-item">
        <input type="number" placeholder="小时" value="{{timerHours}}" bindinput="setTimerHours" class="time-input"/>
      </view>
      <view class="time-input-item">
        <input type="number" placeholder="分钟" value="{{timerMinutes}}" bindinput="setTimerMinutes" class="time-input"/>
      </view>
      <view class="time-input-item">
        <input type="number" placeholder="秒" value="{{timerSeconds}}" bindinput="setTimerSeconds" class="time-input"/>
      </view>
    </view>
    <view class="time-display">
      <text class="time-text">{{timerTime}}</text>
    </view>
    <view class="control-buttons">
      <button class="control-btn start-btn" bindtap="startTimer">{{timerRunning ? '暂停' : '开始'}}</button>
      <button class="control-btn reset-btn" bindtap="resetTimer">重置</button>
    </view>
  </view>
  
  <!-- 时区转换 -->
  <view class="section" wx:if="{{activeTab === 'timezone'}}">
    <view class="timezone-item">
      <text class="timezone-label">北京</text>
      <text class="timezone-time">{{beijingTime}}</text>
    </view>
    <view class="timezone-item">
      <text class="timezone-label">纽约</text>
      <text class="timezone-time">{{newYorkTime}}</text>
    </view>
    <view class="timezone-item">
      <text class="timezone-label">伦敦</text>
      <text class="timezone-time">{{londonTime}}</text>
    </view>
    <view class="timezone-item">
      <text class="timezone-label">东京</text>
      <text class="timezone-time">{{tokyoTime}}</text>
    </view>
  </view>
</view>