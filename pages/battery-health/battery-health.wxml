<!--battery-health.wxml-->
<view class="container">
  <!-- 电池状态 -->
  <view class="section">
    <view class="battery-status">
      <view class="battery-icon">🔋</view>
      <view class="battery-info">
        <text class="battery-level">{{batteryLevel}}%</text>
        <text class="battery-status-text">{{batteryStatus}}</text>
      </view>
    </view>
  </view>
  
  <!-- 电池健康度 -->
  <view class="section">
    <text class="section-title">电池健康度</text>
    <view class="health-bar">
      <view class="health-fill" style="width: {{batteryHealth}}%"></view>
    </view>
    <text class="health-text">{{batteryHealth}}%</text>
  </view>
  
  <!-- 电池使用建议 -->
  <view class="section">
    <text class="section-title">电池使用建议</text>
    <view class="suggestion-box">
      <view class="suggestion-item">
        <text class="suggestion-icon">✅</text>
        <text class="suggestion-text">避免过度充电</text>
      </view>
      <view class="suggestion-item">
        <text class="suggestion-icon">✅</text>
        <text class="suggestion-text">避免电池温度过高</text>
      </view>
      <view class="suggestion-item">
        <text class="suggestion-icon">✅</text>
        <text class="suggestion-text">定期深度放电和充电</text>
      </view>
      <view class="suggestion-item">
        <text class="suggestion-icon">✅</text>
        <text class="suggestion-text">使用原装充电器</text>
      </view>
    </view>
  </view>
</view>