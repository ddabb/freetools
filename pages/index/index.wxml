<!--index.wxml-->
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <!-- 搜索栏 -->
    <view class="search-bar">
      <view class="search-input">
        <text class="search-icon">🔍</text>
        <input
          placeholder="搜索工具"
          class="input"
          value="{{searchText}}"
          bindinput="onSearchInput"
        />
        <text wx:if="{{searchText}}" class="clear-icon" bindtap="onClearSearch">✕</text>
      </view>
    </view>

    <!-- 搜索结果 -->
    <view wx:if="{{showSearchResult}}" class="search-result">
      <text class="section-title">搜索结果</text>
      <view wx:if="{{filteredTools.length > 0 || filteredCategories.length > 0}}">
        <!-- 搜索到的工具 -->
        <view wx:if="{{filteredTools.length > 0}}" class="search-tools">
          <view class="tool-grid search-grid">
            <tool-card
              wx:for="{{filteredTools}}"
              wx:key="id"
              name="{{item.name}}"
              icon="{{item.icon}}"
              color="{{item.color}}"
              url="{{item.url}}"
              size="large"
            />
          </view>
        </view>
        <!-- 搜索到的分类 -->
        <view wx:if="{{filteredCategories.length > 0}}" class="search-categories">
          <view class="category-list">
            <category-card
              wx:for="{{filteredCategories}}"
              wx:key="name"
              name="{{item.name}}"
              icon="{{item.icon}}"
              color="{{item.color}}"
              url="{{item.url}}"
              description="{{item.description}}"
              size="small"
            />
          </view>
        </view>
      </view>
      <view wx:else class="no-result">
        <text class="no-result-text">未找到相关工具</text>
      </view>
    </view>

    <!-- 默认显示的常用工具（无搜索时显示） -->
    <view wx:else class="section">
      <text class="section-title">常用工具</text>
      <view class="tool-grid">
        <tool-card
          wx:for="{{commonTools}}"
          wx:key="id"
          name="{{item.name}}"
          icon="{{item.icon}}"
          color="{{item.color}}"
          url="{{item.url}}"
          size="large"
        />
      </view>
    </view>

    <!-- 默认显示的工具分类（无搜索时显示） -->
    <view wx:if="{{!showSearchResult}}" class="section">
      <text class="section-title">工具分类</text>
      <view class="category-list">
        <category-card
          wx:for="{{categories}}"
          wx:key="name"
          name="{{item.name}}"
          icon="{{item.icon}}"
          color="{{item.color}}"
          url="{{item.url}}"
          description="{{item.description}}"
          size="medium"
        />
      </view>
    </view>
  </view>
</scroll-view>
