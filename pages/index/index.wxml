<!--index.wxml-->
<view class="home-container">
  <!-- 顶部搜索栏 -->
  <search-bar 
    placeholder="搜索工具"
    value="{{searchText}}"
    bind:input="onSearchInput"
    bind:confirm="onSearchConfirm"
    bind:clear="onClearSearch"
  />
  
  <!-- 加载状态 -->
  <loading 
    wx:if="{{ loading }}"
    text="加载中..."
  />
  
  <!-- 空状态 -->
  <empty-state 
    wx:if="{{ !loading && showSearchResult && filteredTools.length === 0 }}"
    icon="search"
    text="未找到工具"
    subText="请尝试其他关键词"
  />
  
  <empty-state 
    wx:if="{{ !loading && !showSearchResult && currentCategoryTools.length === 0 }}"
    icon="info"
    text="该分类下暂无工具"
  />

  <!-- 点菜式主体布局 -->
  <view class="menu-layout">
    <!-- 左侧分类菜单 -->
    <view class="category-menu">
      <view class="menu-title">工具分类</view>
      <scroll-view class="category-list" scroll-y="{{true}}" enhanced="{{true}}" bounces="{{true}}">
        <view 
          wx:for="{{categories}}" 
          wx:key="name" 
          class="category-item {{activeCategory === item.name ? 'category-active' : ''}}"
          bindtap="switchCategory" 
          data-category="{{item.name}}"
        >
          <view class="category-icon">{{item.icon}}</view>
          <view class="category-info">
            <text class="category-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 右侧工具详情列表 -->
    <view class="tools-panel">
      <scroll-view class="tools-list" scroll-y="{{true}}" enhanced="{{true}}" bounces="{{true}}">
        <!-- 搜索结果 -->
        <view wx:if="{{showSearchResult}}">
          <text class="section-title">搜索结果</text>
          <view wx:if="{{filteredTools.length > 0}}">
            <tool-card 
              wx:for="{{filteredTools}}" 
              wx:key="id"
              id="{{item.id}}"
              name="{{item.name}}"
              icon="{{item.icon}}"
              description="{{item.description}}"
              url="{{item.url}}"
              frequency="{{toolFrequency[item.id] || 50}}"
              category="{{getToolCategory(item.id)}}"
              bind:tap="navigateToTool"
            />
          </view>
          <view wx:else class="no-result">
            <text class="no-result-text">未找到相关工具</text>
          </view>
        </view>

        <!-- 默认显示的工具列表 -->
        <view wx:else>
          <text class="section-title">{{activeCategory === '常用工具' ? '常用工具' : activeCategory}}</text>
          
          <!-- 常用工具 -->
          <view wx:if="{{activeCategory === '常用工具'}}">
            <tool-card 
              wx:for="{{commonTools}}" 
              wx:key="id"
              id="{{item.id}}"
              name="{{item.name}}"
              icon="{{item.icon}}"
              description="{{item.description}}"
              url="{{item.url}}"
              frequency="{{toolFrequency[item.id] || 50}}"
              category="{{getToolCategory(item.id)}}"
              bind:tap="navigateToTool"
            />
          </view>
          
          <!-- 分类工具 -->
          <view wx:else>
            <tool-card 
              wx:for="{{currentCategoryTools}}" 
              wx:key="id"
              id="{{item.id}}"
              name="{{item.name}}"
              icon="{{item.icon}}"
              description="{{item.description}}"
              url="{{item.url}}"
              frequency="{{toolFrequency[item.id] || 50}}"
              category="{{getToolCategory(item.id)}}"
              bind:tap="navigateToTool"
            />
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 最近使用工具栏 -->
  <view class="recent-section" wx:if="{{recentTools.length > 0}}">
    <view class="section-header">
      <view class="section-title">最近使用</view>
      <text class="clear-history" bindtap="clearRecentTools" >清空</text>
    </view>
    <scroll-view class="recent-list" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view 
        wx:for="{{recentTools}}" 
        wx:key="id" 
        class="recent-item" hover-class="recent-item-hover"
        bindtap="navigateToTool" 
        data-url="{{item.url}}"
        hover-class="recent-item-hover"
      >
        <view class="recent-icon">{{item.icon}}</view>
        <text class="recent-name">{{item.name}}</text>
      </view>
    </scroll-view>
  </view>
</view>
