/* index.wxss */
.home-container {
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 顶部搜索栏样式 */
.top-search {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  padding: 20rpx 40rpx;
  margin-bottom: 0;
}

.top-search .search-input {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 24rpx 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.3);
}

/* 点菜式主体布局 */
.menu-layout {
  flex: 1;
  display: flex;
  min-height: 0;
  box-sizing: border-box;
  width: 100%;
}

/* 左侧分类菜单 */
.category-menu {
  width: 240rpx;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(15px);
  border-right: 1px solid rgba(255, 255, 255, 0.15);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.menu-title {
  padding: 30rpx 24rpx 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  text-align: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.category-list {
  flex: 1;
  padding: 16rpx 0;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  margin: 8rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  cursor: pointer;
}

.category-item:hover {
  background: rgba(255, 255, 255, 0.1);
}

.category-active {
  background: rgba(255, 255, 255, 0.2) !important;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.category-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  width: 60rpx;
  text-align: center;
}

.category-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.category-name {
  font-size: 30rpx;
  color: white;
  font-weight: 500;
}

.category-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.category-arrow {
  font-size: 32rpx;
  color: #4ade80;
  font-weight: bold;
}

/* 右侧工具面板 */
.tools-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.08);
  min-width: 0;
  box-sizing: border-box;
}

.panel-header {
  padding: 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.panel-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 8rpx;
}

.panel-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.tools-list {
  flex: 1;
  padding: 16rpx;
  overflow-y: auto;  /* 添加垂直滚动条 */
  overflow-x: hidden; /* 隐藏水平滚动条 */
  -webkit-overflow-scrolling: touch; /* 支持弹性滚动 */
  box-sizing: border-box;
  width: 100%;
}

/* 搜索栏样式 */
.search-bar {
  margin-bottom: 24rpx;
}

.search-input {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 25rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  border: 1px solid rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  opacity: 0.7;
}

.input {
  flex: 1;
  color: white;
  font-size: 28rpx;
}

.input::placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.clear-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 8rpx;
  cursor: pointer;
}

/* 工具卡片样式 */
.tool-card-direct {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(15px);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: slideInUp 0.6s ease forwards;
  opacity: 0;
  transform: translateY(30rpx);
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.tool-card-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.2);
  background: rgba(255, 255, 255, 0.2);
}

/* 动画重置类 - 强制重排以重新触发动画 */
.animation-reset {
  animation: none !important;
  opacity: 0 !important;
  transform: translateY(30rpx) !important;
}

.tool-main {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}

.tool-icon-wrapper {
  width: 70rpx;
  height: 70rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 32rpx;
  flex-shrink: 0;
}

.tool-info {
  flex: 1;
  min-width: 0;
}

.tool-icon-wrapper.text { background: linear-gradient(135deg, #667eea, #764ba2); }
.tool-icon-wrapper.data { background: linear-gradient(135deg, #f093fb, #f5576c); }
.tool-icon-wrapper.developer { background: linear-gradient(135deg, #4facfe, #00f2fe); }
.tool-icon-wrapper.design { background: linear-gradient(135deg, #43e97b, #38f9d7); }
.tool-icon-wrapper.chart { background: linear-gradient(135deg, #fa709a, #fee140); }

.tool-info {
  flex: 1;
}

.tool-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tool-name {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-frequency {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.frequency-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.frequency-bar {
  width: 60rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
}

.frequency-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ade80, #22c55e);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.tool-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tool-action {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.start-btn {
  background: linear-gradient(135deg, #4ade80, #22c55e);
  border: none;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.4);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.btn-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(34, 197, 94, 0.5);
}

.btn-text {
  color: white;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-icon {
  color: white;
  font-size: 24rpx;
  font-weight: bold;
}

/* 搜索结果样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
  display: block;
}

.no-result {
  text-align: center;
  padding: 60rpx 20rpx;
}

.no-result-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

/* 分类卡片样式 */
.category-card-direct {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  border: 1px solid rgba(255, 255, 255, 0.15);
  transition: all 0.3s ease;
}

.category-card-direct:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.98);
}

/* 最近使用区域 */
.recent-section {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  padding: 24rpx 40rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.15);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: white;
}

.clear-history {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.clear-history:active {
  background: rgba(255, 255, 255, 0.1);
}

.recent-list {
  white-space: nowrap;
}

.recent-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
  min-width: 120rpx;
}

.recent-item:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.2);
}

.recent-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.recent-name {
  font-size: 22rpx;
  color: white;
  text-align: center;
  line-height: 1.2;
}

/* 动画效果 */
@keyframes slideInUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tool-card-direct:nth-child(1) { animation-delay: 0.1s; }
.tool-card-direct:nth-child(2) { animation-delay: 0.2s; }
.tool-card-direct:nth-child(3) { animation-delay: 0.3s; }
.tool-card-direct:nth-child(4) { animation-delay: 0.4s; }
.tool-card-direct:nth-child(5) { animation-delay: 0.5s; }