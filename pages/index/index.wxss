/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  min-height: 100vh;
}

.container {
  padding: 16rpx;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 0;
}

.search-input {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 50rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  /* 与透明风格一致，去掉厚重阴影 */
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  color: #667eea;
  margin-right: 16rpx;
  font-size: 30rpx;
}

.input {
  flex: 1;
  font-size: 30rpx;
  border: none;
  outline: none;
  color: #333;
}

.clear-icon {
  color: #999;
  font-size: 32rpx;
  margin-left: 8rpx;
  padding: 4rpx;
}

/* 搜索结果 */
.search-result {
  margin-bottom: 24rpx;
}

.search-grid {
  margin-bottom: 16rpx;
}

.no-result {
  text-align: center;
  padding: 32rpx 0;
}

.no-result-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
}

/* 响应式适配 */
@media screen and (max-width: 750rpx) {
  .container {
    padding: 12rpx;
  }
  
  .tool-grid {
    gap: 10rpx;
  }
}

@media screen and (max-width: 680rpx) {
  .tool-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 10rpx;
  }
}

@media screen and (max-width: 520rpx) {
  .tool-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 8rpx;
  }
  
  .container {
    padding: 8rpx;
  }
}

/* 常用工具 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 16rpx;
  /* 去掉文字阴影，更干净 */
  text-shadow: none;
  padding: 0 4rpx;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

/* 分类列表 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
