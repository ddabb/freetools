/* index.wxss */
.home-container {
  height: 100vh;
  background: linear-gradient(160deg, #ff9a9e 0%, #ffd86f 60%, #fc8c5a 100%);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 点菜式主体布局 */
.menu-layout {
  flex: 1;
  display: flex;
  min-height: 0;
  box-sizing: border-box;
  width: 100%;
}

/* 左侧分类菜单 */
.category-menu {
  width: 240rpx;
  background: rgba(255, 255, 255, 0.28);
  backdrop-filter: blur(15px);
  border-right: 1px solid rgba(255, 255, 255, 0.45);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.menu-title {
  padding: 30rpx 24rpx 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #c0392b;
  text-align: center;
  border-bottom: 1px solid rgba(255, 180, 150, 0.3);
  letter-spacing: 2rpx;
}

.category-list {
  flex: 1;
  padding: 16rpx 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  margin: 12rpx 16rpx;
  border-radius: 28rpx;
  transition: all 0.3s ease;
  cursor: pointer;
  width: calc(100% - 32rpx);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  text-align: center;
}

.category-active {
  background: rgba(255, 255, 255, 0.75) !important;
  box-shadow: 0 8rpx 24rpx rgba(255, 100, 80, 0.3);
  transform: translateY(-6rpx);
  font-weight: 700;
}

.category-active::before {
  content: '';
  position: absolute;
  top: 0;
  left: 10rpx;
  right: 10rpx;
  height: 8rpx;
  background: linear-gradient(135deg, #ff9a9e, #ff6b6b);
  border-radius: 28rpx 28rpx 0 0;
}

.category-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
  width: 64rpx;
  text-align: center;
}

.category-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.category-name {
  font-size: 32rpx;
  color: #5a2d0c;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.category-active .category-name {
  color: #e8420b;
}

/* 右侧工具面板 */
.tools-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.18);
  min-width: 0;
  box-sizing: border-box;
}

.tools-list {
  flex: 1;
  padding: 16rpx;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  box-sizing: border-box;
  width: 100%;
}

/* 搜索结果/区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8b2500;
  margin-bottom: 20rpx;
  display: block;
}

.no-result {
  text-align: center;
  padding: 60rpx 20rpx;
}

.no-result-text {
  color: rgba(180, 80, 40, 0.65);
  font-size: 28rpx;
}

/* 最近使用区域 */
.recent-section {
  background: rgba(255, 255, 255, 0.30);
  backdrop-filter: blur(10px);
  padding: 24rpx 40rpx;
  border-top: 1px solid rgba(255, 220, 180, 0.5);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.clear-history {
  font-size: 24rpx;
  color: rgba(180, 80, 40, 0.65);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.recent-list {
  white-space: nowrap;
}

.recent-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 28rpx;
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.55);
  border-radius: 24rpx;
  border: 1px solid rgba(255, 200, 160, 0.55);
  transition: all 0.3s ease;
  min-width: 140rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 100, 60, 0.10);
}

.recent-item-hover {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.75);
}

.recent-icon {
  font-size: 50rpx;
  margin-bottom: 12rpx;
}

.recent-name {
  font-size: 26rpx;
  color: #5a2d0c;
  text-align: center;
  line-height: 1.3;
  font-weight: 500;
}
