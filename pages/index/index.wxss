/* index.wxss */
.home-container {
  height: 100vh;
  background: linear-gradient(160deg, #ff9a9e 0%, #ffd86f 60%, #fc8c5a 100%);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 顶部搜索栏样式 */
.top-search {
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.5);
  padding: 20rpx 40rpx;
  margin-bottom: 0;
}

.top-search .search-input {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  padding: 24rpx 30rpx;
  border: 1px solid rgba(255, 180, 150, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(255, 100, 80, 0.12);
}

/* 点菜式主体布局 */
.menu-layout {
  flex: 1;
  display: flex;
  min-height: 0;
  box-sizing: border-box;
  width: 100%;
}

/* 左侧分类菜单 */
.category-menu {
  width: 240rpx;
  background: rgba(255, 255, 255, 0.28);
  backdrop-filter: blur(15px);
  border-right: 1px solid rgba(255, 255, 255, 0.45);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.menu-title {
  padding: 30rpx 24rpx 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #c0392b;
  text-align: center;
  border-bottom: 1px solid rgba(255, 180, 150, 0.3);
  letter-spacing: 2rpx;
}

.category-list {
  flex: 1;
  padding: 16rpx 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  margin: 12rpx 16rpx;
  border-radius: 28rpx;
  transition: all 0.3s ease;
  cursor: pointer;
  width: calc(100% - 32rpx);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  text-align: center;
}

.category-item:hover {
  background: rgba(255, 255, 255, 0.3);
  transform: translateY(-4rpx);
}

.category-active {
  background: rgba(255, 255, 255, 0.75) !important;
  box-shadow: 0 8rpx 24rpx rgba(255, 100, 80, 0.3);
  transform: translateY(-6rpx);
  font-weight: 700;
}

.category-active::before {
  content: '';
  position: absolute;
  top: 0;
  left: 10rpx;
  right: 10rpx;
  height: 8rpx;
  background: linear-gradient(135deg, #ff9a9e, #ff6b6b);
  border-radius: 28rpx 28rpx 0 0;
}

.category-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
  width: 64rpx;
  text-align: center;
}

.category-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.category-name {
  font-size: 32rpx;
  color: #5a2d0c;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.category-active .category-name {
  color: #e8420b;
}

.category-count {
  font-size: 24rpx;
  color: rgba(120, 60, 20, 0.7);
}

.category-arrow {
  font-size: 28rpx;
  color: #ff7043;
  font-weight: bold;
}

/* 右侧工具面板 */
.tools-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.18);
  min-width: 0;
  box-sizing: border-box;
}

.panel-header {
  padding: 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.3);
}

.panel-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #5a2d0c;
  display: block;
  margin-bottom: 8rpx;
}

.panel-desc {
  font-size: 26rpx;
  color: rgba(120, 60, 20, 0.7);
}

.tools-list {
  flex: 1;
  padding: 16rpx;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  box-sizing: border-box;
  width: 100%;
}

/* 搜索栏样式 */
.search-bar {
  margin-bottom: 24rpx;
}

.search-input {
  background: rgba(255, 255, 255, 0.45);
  border-radius: 30rpx;
  padding: 24rpx 36rpx;
  display: flex;
  align-items: center;
  border: 1px solid rgba(255, 200, 160, 0.5);
  backdrop-filter: blur(10px);
}

.search-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  opacity: 0.8;
}

.input {
  flex: 1;
  color: #5a2d0c;
  font-size: 32rpx;
}

.input::placeholder {
  color: rgba(180, 80, 40, 0.6);
  font-size: 32rpx;
}

.clear-icon {
  font-size: 32rpx;
  color: rgba(180, 80, 40, 0.7);
  padding: 12rpx;
  cursor: pointer;
}

/* 工具卡片样式 */
.tool-card-direct {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(15px);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1px solid rgba(255, 220, 180, 0.6);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: slideInUp 0.6s ease forwards;
  opacity: 0;
  transform: translateY(30rpx);
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4rpx 16rpx rgba(255, 100, 60, 0.10);
}

.tool-card-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 14rpx 28rpx rgba(255, 100, 60, 0.22);
  background: rgba(255, 255, 255, 0.88);
}

/* 动画重置类 */
.animation-reset {
  animation: none !important;
  opacity: 0 !important;
  transform: translateY(30rpx) !important;
}

.tool-main {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}

.tool-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 36rpx;
  flex-shrink: 0;
}

.tool-info {
  flex: 1;
  min-width: 0;
}

/* 图标背景色 - 活泼可爱版 */
.tool-icon-wrapper.text     { background: linear-gradient(135deg, #ff9a9e, #f77a8a); }
.tool-icon-wrapper.data     { background: linear-gradient(135deg, #ffd86f, #f7a440); }
.tool-icon-wrapper.developer { background: linear-gradient(135deg, #a8edea, #4ecdc4); }
.tool-icon-wrapper.design   { background: linear-gradient(135deg, #c3f0a2, #56c870); }
.tool-icon-wrapper.chart    { background: linear-gradient(135deg, #fbc2eb, #a78bfa); }

.tool-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tool-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #3d1a06;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-frequency {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.frequency-label {
  font-size: 24rpx;
  color: rgba(180, 80, 40, 0.7);
  font-weight: 500;
}

.frequency-bar {
  width: 80rpx;
  height: 10rpx;
  background: rgba(255, 180, 120, 0.3);
  border-radius: 5rpx;
  overflow: hidden;
}

.frequency-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff9a9e, #ffd86f);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.tool-desc {
  font-size: 28rpx;
  color: rgba(100, 50, 20, 0.8);
  line-height: 1.5;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tool-action {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.start-btn {
  background: linear-gradient(135deg, #ff9a9e, #ff6b6b);
  border: none;
  border-radius: 28rpx;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 14rpx rgba(255, 100, 80, 0.38);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.btn-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 20rpx rgba(255, 100, 80, 0.50);
}

.btn-text {
  color: white;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-icon {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
}

/* 搜索结果/区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8b2500;
  margin-bottom: 20rpx;
  display: block;
}

.no-result {
  text-align: center;
  padding: 60rpx 20rpx;
}

.no-result-text {
  color: rgba(180, 80, 40, 0.65);
  font-size: 28rpx;
}

/* 分类卡片样式 */
.category-card-direct {
  background: rgba(255, 255, 255, 0.55);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  border: 1px solid rgba(255, 210, 160, 0.5);
  transition: all 0.3s ease;
}

/* hover-class 样式替代 -hover */
.recent-item-hover {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.75);
}

.clear-history-hover {
  background: rgba(255, 200, 160, 0.25);
}

.category-card-direct-hover {
  background: rgba(255, 255, 255, 0.75);
  transform: scale(0.98);
}

/* 最近使用区域 */
.recent-section {
  background: rgba(255, 255, 255, 0.30);
  backdrop-filter: blur(10px);
  padding: 24rpx 40rpx;
  border-top: 1px solid rgba(255, 220, 180, 0.5);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #8b2500;
}

.clear-history {
  font-size: 24rpx;
  color: rgba(180, 80, 40, 0.65);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}



.recent-list {
  white-space: nowrap;
}

.recent-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 28rpx;
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.55);
  border-radius: 24rpx;
  border: 1px solid rgba(255, 200, 160, 0.55);
  transition: all 0.3s ease;
  min-width: 140rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 100, 60, 0.10);
}



.recent-icon {
  font-size: 50rpx;
  margin-bottom: 12rpx;
}

.recent-name {
  font-size: 26rpx;
  color: #5a2d0c;
  text-align: center;
  line-height: 1.3;
  font-weight: 500;
}

/* 动画效果 */
@keyframes slideInUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tool-card-direct:nth-child(1) { animation-delay: 0.1s; }
.tool-card-direct:nth-child(2) { animation-delay: 0.2s; }
.tool-card-direct:nth-child(3) { animation-delay: 0.3s; }
.tool-card-direct:nth-child(4) { animation-delay: 0.4s; }
.tool-card-direct:nth-child(5) { animation-delay: 0.5s; }
