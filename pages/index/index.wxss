/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  padding: 30rpx 0;
}

.search-input {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.search-icon {
  color: #667eea;
  margin-right: 20rpx;
  font-size: 32rpx;
}

.input {
  flex: 1;
  font-size: 32rpx;
  border: none;
  outline: none;
  color: #333;
}

.clear-icon {
  color: #999;
  font-size: 36rpx;
  margin-left: 10rpx;
  padding: 5rpx;
}

/* 搜索结果 */
.search-result {
  margin-bottom: 40rpx;
}

.search-grid {
  margin-bottom: 30rpx;
}

.no-result {
  text-align: center;
  padding: 60rpx 0;
}

.no-result-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 32rpx;
}

/* 常用工具 */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
  color: white;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

/* 分类列表 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
