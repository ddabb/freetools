/* pages/knowledge/categorylist/categorylist.wxss */

/* ========== 基础样式 ========== */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

/* ========== 页面标题 ========== */
.page-header {
  text-align: center;
  margin-bottom: 32rpx;
  padding: 32rpx 0 0;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 10rpx;
  display: block;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
}

/* ========== 分类滚动区 ========== */
.category-scroll {
  flex: 1;
  /* 确保滚动条显示 */
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ========== 分类列表容器 ========== */
.category-list {
  background: white;
  border-radius: 24rpx;
  padding: 12rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.2);
  min-height: 200rpx;
}

/* ========== 页面加载动画 ========== */
.page-loading {
  position: absolute;
  top: 180rpx;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  opacity: 0;
  animation: pageLoadingFadeIn 0.5s ease-out forwards;
  border-radius: 0 0 24rpx 24rpx;
}

.loading-spinner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.spinner-circle {
  width: 120rpx;
  height: 120rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.3);
  border-top: 8rpx solid white;
  border-radius: 50%;
  animation: spinnerRotate 1.5s linear infinite;
}

.spinner-text {
  font-size: 32rpx;
  color: white;
  font-weight: 500;
  text-align: center;
  animation: textPulse 2s ease-in-out infinite;
}

@keyframes pageLoadingFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes spinnerRotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

@keyframes textPulse {
  0%, 100% {
    opacity: 0.8;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 32rpx;
  gap: 16rpx;
}

.loading-state::before {
  content: '';
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.2);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  display: inline-block;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ========== 错误状态 ========== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.error-text {
  color: #e74c3c;
  font-size: 32rpx;
  text-align: center;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.retry-btn::after { border: none; }

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  font-size: 34rpx;
  color: #666;
  font-weight: 600;
}

/* ========== 分类项 ========== */
.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
  border-radius: 0;
  margin: 0;
  background: white;
}

.category-item:first-child {
  border-radius: 16rpx 16rpx 0 0;
}

.category-item:last-child {
  border-bottom: none;
  border-radius: 0 0 16rpx 16rpx;
}

.category-item:active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  transform: scale(0.99);
}

.category-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.category-name {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-count {
  font-size: 26rpx;
  color: #999;
}

.category-arrow {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: 16rpx;
  transition: all 0.3s ease;
}

.category-item:active .category-arrow {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.arrow {
  font-size: 28rpx;
  color: #667eea;
  transition: all 0.3s ease;
}

.category-item:active .arrow {
  color: white;
  transform: translateX(4rpx);
}
