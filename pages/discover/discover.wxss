/**discover.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  min-height: 100vh;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 工具列表 */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
  color: white;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.tool-item {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  padding: 30rpx 20rpx;
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  overflow: hidden;
}

.tool-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #f093fb, #f5576c);
}

.tool-item:hover {
  transform: translateY(-12rpx) scale(1.02);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.25);
}

.tool-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.tool-icon.blue { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.tool-icon.green { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
.tool-icon.orange { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
.tool-icon.purple { background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%); }
.tool-icon.teal { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
.tool-icon.red { background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%); }

.tool-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
}
