/* pages/discover/discover.wxss - 完全独立的发现页样式 */
/* 所有类名使用 disc- 前缀，完全隔离于首页 */

/* 重置页面 */
page {
  background: #f5f6f8;
  min-height: 100vh;
}

/* 主容器 */
.disc-container {
  min-height: 100vh;
  background: #f5f6f8;
  display: flex;
  flex-direction: column;
}

/* ==================== 顶部栏 ==================== */
.disc-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.disc-logo {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-right: 20rpx;
  white-space: nowrap;
}

.disc-search-bar {
  flex: 1;
  height: 64rpx;
  background: #f5f6f8;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.disc-search-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
}

.disc-search-placeholder {
  font-size: 26rpx;
  color: #999;
}

.disc-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-left: 20rpx;
}

/* ==================== 快捷分类导航 ==================== */
.disc-nav {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.disc-nav-scroll {
  padding: 16rpx 0;
  white-space: nowrap;
}

.disc-nav-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.disc-nav-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.disc-nav-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.disc-nav-name {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
}

.disc-nav-item.disc-nav-active {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.disc-nav-item.disc-nav-active .disc-nav-name {
  color: #fff;
  font-weight: 600;
}

/* ==================== 搜索面板 ==================== */
.disc-search-panel {
  background: #fff;
  position: sticky;
  top: 104rpx;
  z-index: 99;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.disc-search-input-wrap {
  display: flex;
  align-items: center;
  margin: 20rpx 30rpx;
  padding: 16rpx 24rpx;
  background: #f5f6f8;
  border-radius: 36rpx;
}

.disc-search-input {
  flex: 1;
  font-size: 28rpx;
  height: 48rpx;
}

.disc-search-cancel {
  font-size: 26rpx;
  color: #667eea;
  padding-left: 20rpx;
  font-weight: 500;
}

.disc-search-results {
  max-height: 65vh;
  padding: 0 30rpx 20rpx;
}

/* ==================== 内容区域 ==================== */
.disc-content {
  flex: 1;
  padding: 30rpx;
  height: calc(100vh - 200rpx);
  box-sizing: border-box;
}

/* ==================== 区块 ==================== */
.disc-section {
  margin-bottom: 40rpx;
}

.disc-section-all {
  margin-top: 20rpx;
}

.disc-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.disc-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.disc-section-more {
  font-size: 24rpx;
  color: #999;
}

.disc-section-count {
  font-size: 24rpx;
  color: #999;
}

/* ==================== 工具卡片 ==================== */
.disc-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
  transition: transform 0.2s, box-shadow 0.2s;
}

.disc-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 卡片左侧颜色块 */
.disc-card-left {
  width: 120rpx;
  min-height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.disc-card-color-0 { background: linear-gradient(135deg, #667eea, #764ba2); }
.disc-card-color-1 { background: linear-gradient(135deg, #f093fb, #f5576c); }
.disc-card-color-2 { background: linear-gradient(135deg, #4facfe, #00f2fe); }
.disc-card-color-3 { background: linear-gradient(135deg, #43e97b, #38f9d7); }
.disc-card-color-4 { background: linear-gradient(135deg, #fa709a, #fee140); }
.disc-card-color-5 { background: linear-gradient(135deg, #30cfd0, #330867); }
.disc-card-color-6 { background: linear-gradient(135deg, #a8edea, #fed6e3); }
.disc-card-color-7 { background: linear-gradient(135deg, #ff9a9e, #fecfef); }
.disc-card-color-8 { background: linear-gradient(135deg, #ffecd2, #fcb69f); }
.disc-card-color-9 { background: linear-gradient(135deg, #667eea, #f093fb); }

.disc-card-icon {
  font-size: 52rpx;
}

/* 卡片内容 */
.disc-card-body {
  flex: 1;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.disc-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.disc-card-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 卡片按钮 */
.disc-card-btn {
  padding: 12rpx 24rpx;
  display: flex;
  align-items: center;
  margin: auto 20rpx;
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 24rpx;
  white-space: nowrap;
}

.disc-card-action {
  display: flex;
  align-items: center;
  padding-right: 24rpx;
  font-size: 40rpx;
  color: #ccc;
}

/* 空状态 */
.disc-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.disc-bottom-space {
  height: 60rpx;
}
