/**discover.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  min-height: 100vh;
}

.container {
  padding: 40rpx 20rpx 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 工具列表 */
.section {
  margin-bottom: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 20rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10px);
  box-sizing: border-box;
  width: 100%;
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #333333;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  padding: 0 8rpx;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

/* 工具卡片样式 */
.tool-card-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  cursor: pointer;
}

.tool-card-item:active {
  transform: scale(0.96);
  background: rgba(102, 126, 234, 0.08);
}

.tool-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.tool-icon {
  font-size: 40rpx;
}

.tool-name {
  font-size: 22rpx;
  color: #333333;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 80rpx 20rpx;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}

/* 响应式适配 - 保持手机端统一设计 */
@media screen and (max-width: 750rpx) {
  .container {
    padding: 12rpx 12rpx;
  }
  
  .tool-grid {
    gap: 6rpx;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
}
