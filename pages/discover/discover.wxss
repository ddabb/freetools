/**discover.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  min-height: 100vh;
}

.container {
  padding: 40rpx 20rpx 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 工具列表 */
.section {
  margin-bottom: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10px);
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #333333;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  padding: 0 8rpx;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 响应式适配 */
@media screen and (max-width: 750rpx) {
  .container {
    padding: 12rpx 6rpx;
  }
  
  .tool-grid {
    gap: 6rpx;
  }
}

@media screen and (max-width: 680rpx) {
  .tool-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 6rpx;
  }
}

@media screen and (max-width: 520rpx) {
  .tool-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 4rpx;
  }
  
  .container {
    padding: 8rpx 4rpx;
  }
}
