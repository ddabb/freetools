<view class="disc-container">
  <!-- 顶部搜索栏 -->
  <view class="disc-header">
    <view class="disc-logo">🧰 工具箱</view>
    <view class="disc-search-bar" bindtap="toggleSearch">
      <text class="disc-search-icon">🔍</text>
      <text class="disc-search-placeholder">{{searchText || '搜索工具'}}</text>
    </view>
    <view class="disc-avatar">👤</view>
  </view>

  <!-- 快捷分类入口 - 独立组件 -->
  <view class="disc-nav">
    <scroll-view class="disc-nav-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="disc-nav-list">
        <view class="disc-nav-item {{activeCategory === '' ? 'disc-nav-active' : ''}}" bindtap="switchCategory" data-category="">
          <text class="disc-nav-icon">🏠</text>
          <text class="disc-nav-name">推荐</text>
        </view>
        <view class="disc-nav-item {{activeCategory === '常用工具' ? 'disc-nav-active' : ''}}" bindtap="switchCategory" data-category="常用工具">
          <text class="disc-nav-icon">⭐</text>
          <text class="disc-nav-name">常用</text>
        </view>
        <view class="disc-nav-item {{activeCategory === '文字工具' ? 'disc-nav-active' : ''}}" bindtap="switchCategory" data-category="文字工具">
          <text class="disc-nav-icon">✏️</text>
          <text class="disc-nav-name">文字</text>
        </view>
        <view class="disc-nav-item {{activeCategory === '生活工具' ? 'disc-nav-active' : ''}}" bindtap="switchCategory" data-category="生活工具">
          <text class="disc-nav-icon">🏠</text>
          <text class="disc-nav-name">生活</text>
        </view>
        <view class="disc-nav-item {{activeCategory === '数学工具' ? 'disc-nav-active' : ''}}" bindtap="switchCategory" data-category="数学工具">
          <text class="disc-nav-icon">🔢</text>
          <text class="disc-nav-name">数学</text>
        </view>
        <view class="disc-nav-item {{activeCategory === '开发工具' ? 'disc-nav-active' : ''}}" bindtap="switchCategory" data-category="开发工具">
          <text class="disc-nav-icon">💻</text>
          <text class="disc-nav-name">开发</text>
        </view>
        <view class="disc-nav-item {{activeCategory === '财务工具' ? 'disc-nav-active' : ''}}" bindtap="switchCategory" data-category="财务工具">
          <text class="disc-nav-icon">💰</text>
          <text class="disc-nav-name">财务</text>
        </view>
        <view class="disc-nav-item {{activeCategory === '健康工具' ? 'disc-nav-active' : ''}}" bindtap="switchCategory" data-category="健康工具">
          <text class="disc-nav-icon">❤️</text>
          <text class="disc-nav-name">健康</text>
        </view>
        <view class="disc-nav-item {{activeCategory === '学习工具' ? 'disc-nav-active' : ''}}" bindtap="switchCategory" data-category="学习工具">
          <text class="disc-nav-icon">📚</text>
          <text class="disc-nav-name">学习</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 搜索区域 - 独立组件 -->
  <view class="disc-search-panel" wx:if="{{showSearch}}">
    <view class="disc-search-input-wrap">
      <text class="disc-search-icon">🔍</text>
      <input 
        class="disc-search-input" 
        placeholder="搜索工具名称..."
        value="{{searchText}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        focus="{{true}}"
      />
      <text class="disc-search-cancel" bindtap="closeSearch">取消</text>
    </view>
    
    <!-- 搜索结果 -->
    <scroll-view class="disc-search-results" scroll-y="{{true}}" wx:if="{{searchText}}">
      <view class="disc-card" wx:for="{{searchResults}}" wx:key="id" bindtap="navigateToTool" data-url="{{item.url}}">
        <view class="disc-card-left disc-card-color-{{item.colorIndex || 0}}">
          <text class="disc-card-icon">{{item.icon}}</text>
        </view>
        <view class="disc-card-body">
          <text class="disc-card-title">{{item.name}}</text>
          <text class="disc-card-desc">{{item.description}}</text>
        </view>
        <view class="disc-card-action">›</view>
      </view>
      <view class="disc-empty" wx:if="{{searchResults.length === 0}}">
        <text>未找到相关工具</text>
      </view>
    </scroll-view>
  </view>

  <!-- 主内容区域 - 独立组件 -->
  <scroll-view class="disc-content" scroll-y="{{true}}" wx:if="{{!showSearch}}">
    <!-- 推荐/热门区域 -->
    <view class="disc-section" wx:if="{{activeCategory === ''}}">
      <view class="disc-section-header">
        <text class="disc-section-title">🔥 热门工具</text>
        <text class="disc-section-more">更多 ›</text>
      </view>
      <view class="disc-card" wx:for="{{hotTools}}" wx:key="id" bindtap="navigateToTool" data-url="{{item.url}}">
        <view class="disc-card-left disc-card-color-{{item.colorIndex || 0}}">
          <text class="disc-card-icon">{{item.icon}}</text>
        </view>
        <view class="disc-card-body">
          <text class="disc-card-title">{{item.name}}</text>
          <text class="disc-card-desc">{{item.description}}</text>
        </view>
        <view class="disc-card-btn">使用</view>
      </view>
    </view>

    <!-- 分类工具列表 -->
    <view class="disc-section" wx:if="{{activeCategory !== ''}}">
      <view class="disc-section-header">
        <text class="disc-section-title">{{activeCategory}}</text>
        <text class="disc-section-count">{{categoryTools.length}} 个工具</text>
      </view>
      <view class="disc-card" wx:for="{{categoryTools}}" wx:key="id" bindtap="navigateToTool" data-url="{{item.url}}">
        <view class="disc-card-left disc-card-color-{{item.colorIndex || 0}}">
          <text class="disc-card-icon">{{item.icon}}</text>
        </view>
        <view class="disc-card-body">
          <text class="disc-card-title">{{item.name}}</text>
          <text class="disc-card-desc">{{item.description}}</text>
        </view>
        <view class="disc-card-btn">使用</view>
      </view>
    </view>

    <!-- 全部工具入口 -->
    <view class="disc-section disc-section-all" wx:if="{{activeCategory === ''}}">
      <view class="disc-section-header">
        <text class="disc-section-title">📂 全部工具</text>
        <text class="disc-section-count">{{allTools.length}} 个工具</text>
      </view>
      <view class="disc-card" wx:for="{{allTools}}" wx:key="id" bindtap="navigateToTool" data-url="{{item.url}}">
        <view class="disc-card-left disc-card-color-{{item.colorIndex || 0}}">
          <text class="disc-card-icon">{{item.icon}}</text>
        </view>
        <view class="disc-card-body">
          <text class="disc-card-title">{{item.name}}</text>
          <text class="disc-card-desc">{{item.description}}</text>
        </view>
        <view class="disc-card-btn">使用</view>
      </view>
    </view>

    <view class="disc-bottom-space"></view>
  </scroll-view>
</view>
