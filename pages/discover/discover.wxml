<!--discover.wxml-->
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <!-- 工具列表 -->
    <view class="section">
      <text class="section-title">{{currentCategory || '全部工具'}}</text>
      <view class="tool-grid">
        <tool-card
          wx:for="{{filteredTools}}"
          wx:key="id"
          name="{{item.name}}"
          icon="{{item.icon}}"
          color="{{item.color}}"
          url="{{item.url}}"
          size="large"
        />
      </view>
      <view wx:if="{{filteredTools.length === 0}}" class="empty-state">
        <text class="empty-text">该分类下暂无工具</text>
      </view>
    </view>
  </view>
</scroll-view>