/* pages/relative-export/relative-export.wxss */

page {
  background: #f5f6f8;
  min-height: 100vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.container {
  min-height: 100vh;
  padding: 30rpx 20rpx 40rpx;
}

/* 加载状态 */
.status-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 300rpx 0;
  min-height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #8b5cf6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #e74c3c;
}

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #8b5cf6, #7c3aed);
  border-radius: 20rpx;
  padding: 35rpx;
  box-shadow: 0 8rpx 30rpx rgba(139, 92, 246, 0.3);
  margin-bottom: 30rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.header-stats {
  display: flex;
  gap: 30rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

/* 导出按钮 */
.export-section {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 25rpx;
  padding-top: 25rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.guide-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 40rpx;
  padding: 18rpx 32rpx;
  font-size: 26rpx;
  color: #fff;
  transition: all 0.3s ease;
}

.guide-btn-hover {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.3);
}

.guide-btn::after {
  border: none;
}

.guide-icon {
  font-size: 26rpx;
}

.guide-text {
  font-weight: 500;
}

.export-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #27ae60, #2ecc71);
  border: none;
  border-radius: 40rpx;
  padding: 18rpx 36rpx;
  font-size: 26rpx;
  color: #fff;
  box-shadow: 0 4rpx 15rpx rgba(39, 174, 96, 0.3);
  transition: all 0.3s ease;
}

.export-btn-hover {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(39, 174, 96, 0.5);
}

.export-btn::after {
  border: none;
}

.export-btn.loading {
  background: #95a5a6;
  box-shadow: none;
}

.export-icon {
  font-size: 28rpx;
}

.export-text {
  font-weight: 600;
}

/* 表格区域 */
.table-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.table-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.table {
  min-width: 100%;
  border-collapse: collapse;
  font-size: 22rpx;
}

.table-th {
  background: #f3f4f6;
  color: #666;
  font-weight: 600;
  padding: 16rpx 20rpx;
  text-align: center;
  border: 1rpx solid #e5e7eb;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 1;
}

.table-th.first-col {
  position: sticky;
  left: 0;
  z-index: 2;
  background: #f3f4f6;
}

.table-td {
  padding: 14rpx 20rpx;
  text-align: center;
  border: 1rpx solid #e5e7eb;
  color: #333;
  white-space: nowrap;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.table-td.first-col {
  position: sticky;
  left: 0;
  z-index: 1;
  background: #fafafa;
  font-weight: 600;
  color: #8b5cf6;
  background: #f9f5ff;
}

.table-td.empty {
  color: #ccc;
}

.table-tr:nth-child(even) .table-td {
  background: #fafafa;
}

.table-tr:nth-child(even) .table-td.first-col {
  background: #f5f0ff;
}
