<view class="container">
  <!-- 加载状态 -->
  <view class="status-section" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="status-section error" wx:if="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
  </view>

  <!-- 内容区域 -->
  <block wx:if="{{!loading && !error && tableData}}">
    <!-- 头部卡片 -->
    <view class="header-card">
      <view class="header-top">
        <view>
          <view class="header-title">亲戚关系对照表</view>
          <view class="header-desc">完整的中国亲戚称呼对照表<br/>可导出为 Excel 方便查看</view>
        </view>
      </view>
      <view class="header-stats">
        <view class="stat-item">
          <text class="stat-num">{{rowCount}}</text>
          <text class="stat-label">角色</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{colCount}}</text>
          <text class="stat-label">关系维度</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">~{{cellCount}}</text>
          <text class="stat-label">数据单元</text>
        </view>
      </view>
      <view class="export-section">
        <button class="export-btn {{exporting ? 'loading' : ''}}" bindtap="onExportExcel" loading="{{exporting}}" disabled="{{exporting}}">
          <text class="export-icon">📊</text>
          <text class="export-text">{{exporting ? '导出中...' : '导出Excel'}}</text>
        </button>
      </view>
    </view>

    <!-- 表格预览 -->
    <view class="table-section">
      <view class="table-hint">👆 左右滑动查看完整表格，共 {{rowCount}} 行 × {{colCount}} 列</view>
      <scroll-view scroll-x="true" class="table-scroll">
        <view class="table">
          <!-- 表头 -->
          <view class="table-tr">
            <view class="table-th first-col">角色</view>
            <view class="table-th" wx:for="{{cols}}" wx:for-item="col" wx:key="*this">{{col}}</view>
          </view>
          <!-- 数据行 -->
          <view class="table-tr" wx:for="{{rows}}" wx:for-item="row" wx:key="*this">
            <view class="table-td first-col">{{row[0]}}</view>
            <view class="table-td {{cell === '' ? 'empty' : ''}}" wx:for="{{row}}" wx:for-item="cell" wx:key="*this" wx:if="{{index > 0}}">{{cell || '-'}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </block>
</view>
