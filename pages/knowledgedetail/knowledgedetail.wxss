/* packages/knowledge/pages/knowledgedetail/knowledgedetail.wxss */
/* 水墨屏/泛黄纸张风格 - 浅色协调版 */

/* ========== 基础样式 ========== */
page {
  /* 泛黄纸张背景 */
  background: linear-gradient(160deg, #FBF4E3 0%, #F9EFDE 50%, #F6E9D0 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', serif;
  overflow-x: hidden;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  padding: 0;
  margin: 0;
}

/* ========== 文章滚动区 ========== */
.article-scroll {
  flex: 1;
  min-height: 300rpx;
  padding-top: 20rpx;
  padding-bottom: 0;
  box-sizing: border-box;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.article-wrapper {
  margin: 0 20rpx 20rpx;
  animation: slideUp 0.6s ease;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ========== 底部留白 ========== */
.bottom-spacer {
  height: 20rpx;
}

/* ========== 加载状态 ========== */
.loading-state {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  background: linear-gradient(160deg, #FBF4E3 0%, #F9EFDE 100%);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(212, 133, 106, 0.2);
  border-top-color: #D4856A;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  color: #6D5D4D;
  font-size: 28rpx;
  font-weight: 500;
}

/* ========== 错误状态 ========== */
.error-state {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  background: linear-gradient(160deg, #FBF4E3 0%, #F9EFDE 100%);
}

.error-icon {
  font-size: 120rpx;
  animation: bounce 1s ease-in-out;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-20rpx); }
  60% { transform: translateY(-10rpx); }
}

.error-text {
  color: #6D5D4D;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 0 60rpx;
}

.retry-btn {
  margin-top: 20rpx;
  padding: 20rpx 56rpx;
  background: #D4856A;
  color: #FFFDF8;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(212, 133, 106, 0.2);
}

.retry-btn::after { border: none; }

/* ========== 英雄区域 (头部) ========== */
.article-hero {
  /* 素色宣纸卡片效果 */
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  border-radius: 20rpx;
  padding: 36rpx;
  margin: 20rpx 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(120, 100, 75, 0.08);
  position: relative;
  overflow: hidden;
  animation: slideUp 0.6s ease;
  flex-shrink: 0;
  width: calc(100% - 40rpx);
  box-sizing: border-box;
  border: 1rpx solid #E0D4C4;
}

.article-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 5rpx;
  background: linear-gradient(90deg, #C9806E, #D4856A, #C9806E);
  border-radius: 20rpx 20rpx 0 0;
}

/* 分类标签 */
.hero-category {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 20rpx;
  margin-bottom: 0;
  background: rgba(212, 133, 106, 0.1);
  border: 1rpx solid rgba(212, 133, 106, 0.12);
}

.hero-category-hover {
  opacity: 0.8;
  transform: scale(0.95);
}

.category-icon { font-size: 22rpx; color: #6D5D4D; }
.category-name { color: #D4856A; font-size: 22rpx; font-weight: 600; user-select: text; }
.category-arrow-left { font-size: 26rpx; color: #6D5D4D; opacity: 0.5; }

/* 标题和元信息容器 */
.hero-title-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 标题 */
.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A3F35;
  line-height: 1.35;
  letter-spacing: 2rpx;
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
  user-select: text;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 14rpx;
  background: rgba(168, 144, 120, 0.06);
  border-radius: 16rpx;
  border: 1rpx solid rgba(168, 144, 120, 0.1);
}

.meta-icon { font-size: 20rpx; color: #A89078; }
.meta-value { font-size: 22rpx; color: #6D5D4D; font-weight: 500; }
.meta-divider {
  width: 1rpx;
  height: 18rpx;
  background: #D8CDB8;
}

/* 分类行 - 包含分类列表按钮和当前分类标签 */
.category-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

/* 分类列表按钮 */
.category-list-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 18rpx;
  background: #7A6658;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(122, 102, 88, 0.15);
  flex-shrink: 0;
}

.category-list-btn-hover {
  opacity: 0.8;
  transform: scale(0.95);
}

.category-list-icon {
  font-size: 22rpx;
  color: #FFFDF8;
}

.category-list-text {
  font-size: 22rpx;
  color: #FFFDF8;
  font-weight: 600;
}

/* ========== 描述卡片 ========== */
.article-desc-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  background: linear-gradient(135deg, #7A6658 0%, #6D5D4D 100%);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(122, 102, 88, 0.15);
}

.desc-icon { font-size: 40rpx; flex-shrink: 0; }

.desc-text {
  color: #FFFDF8;
  font-size: 26rpx;
  line-height: 1.65;
  user-select: text;
}

/* ========== 文章正文 ========== */
.article-body {
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(120, 100, 75, 0.06);
  border: 1rpx solid #E0D4C4;
}

.content-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  gap: 20rpx;
  padding-bottom: 18rpx;
  border-bottom: 2rpx solid #E0D4C4;
}

.content-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(to right, transparent, #D4856A, transparent);
  border-radius: 2rpx;
}

.content-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #D4856A;
  white-space: nowrap;
  padding: 0 14rpx;
}

/* towxml 渲染内容 */
.content-body {
  font-size: 30rpx;
  line-height: 1.85;
  color: #4A3F35;
  user-select: text;
}

/* 回退：原始 Markdown 文本 */
.content-fallback .md-raw {
  display: block;
  white-space: pre-wrap;
  word-break: break-all;
  font-size: 30rpx;
  line-height: 1.85;
  color: #4A3F35;
}

/* towxml 默认节点样式增强 */
.content-body .h2w__h1 {
  font-size: 38rpx;
  font-weight: 700;
  color: #4A3F35;
  margin: 36rpx 0 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid #D4856A;
  display: block;
  letter-spacing: 1rpx;
}

/* ========== markdown-it 表格样式 ========== */
.content-body table {
  width: 100%;
  border-collapse: collapse;
  margin: 24rpx 0;
  font-size: 26rpx;
  box-shadow: 0 2rpx 12rpx rgba(120, 100, 75, 0.05);
  border-radius: 10rpx;
  overflow: hidden;
  border: 1rpx solid #D8CDB8;
  background: #FFFEF8;
}

.content-body thead {
  background: linear-gradient(135deg, #7A6658 0%, #6D5D4D 100%);
}

.content-body th {
  padding: 18rpx 14rpx;
  text-align: left;
  font-weight: 600;
  color: #FFFDF8;
  border-right: 1rpx solid rgba(255, 253, 248, 0.25);
  position: relative;
}

.content-body th:last-child {
  border-right: none;
}

.content-body td {
  padding: 16rpx 14rpx;
  border: 1rpx solid #E0D4C4;
  border-top: none;
  border-left: none;
  position: relative;
  color: #4A3F35;
}

.content-body td:last-child {
  border-right: none;
}

.content-body tr:nth-child(even) {
  background: rgba(168, 144, 120, 0.03);
}

.content-body tr:hover {
  background: rgba(212, 133, 106, 0.04);
  transition: background 0.3s ease;
}

/* ========== rich-text 组件样式 ========== */
.content-rich {
  font-size: 30rpx;
  line-height: 1.85;
  color: #4A3F35;
  user-select: text;
}

/* rich-text 中段落样式 */
.content-rich p {
  margin: 14rpx 0;
  text-align: justify;
}

/* rich-text 中标题样式 */
.content-rich h1 {
  font-size: 38rpx;
  font-weight: 700;
  color: #4A3F35;
  margin: 36rpx 0 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid #D4856A;
  letter-spacing: 1rpx;
}

.content-rich h2 {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A3F35;
  margin: 28rpx 0 14rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #D4856A;
}

.content-rich h3 {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A3F35;
  margin: 22rpx 0 10rpx;
}

/* rich-text 中列表样式 */
.content-rich ul,
.content-rich ol {
  margin: 14rpx 0;
  padding-left: 40rpx;
}

.content-rich li {
  margin: 8rpx 0;
}

.content-rich ul li {
  list-style-type: disc;
}

.content-rich ol li {
  list-style-type: decimal;
}

/* rich-text 中代码样式 */
.content-rich code {
  background: rgba(168, 144, 120, 0.08);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
  color: #A06850;
}

.content-rich pre {
  background: #4A3F35;
  color: #FFFDF8;
  padding: 20rpx;
  border-radius: 12rpx;
  overflow-x: auto;
  margin: 20rpx 0;
}

.content-rich pre code {
  background: none;
  color: inherit;
  padding: 0;
  font-size: 26rpx;
}

/* rich-text 中引用样式 */
.content-rich blockquote {
  margin: 20rpx 0;
  padding: 18rpx 24rpx;
  background: rgba(168, 144, 120, 0.05);
  border-left: 4rpx solid #D4856A;
  border-radius: 0 12rpx 12rpx 0;
  color: #6D5D4D;
  font-style: italic;
}

/* ========== rich-text 中表格的样式 ========== */
.content-rich table,
.content-rich .md-table {
  width: 100%;
  border-collapse: collapse;
  margin: 28rpx 0;
  font-size: 26rpx;
  box-shadow: 0 2rpx 12rpx rgba(120, 100, 75, 0.06);
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #D8CDB8;
  background: #FFFEF8;
  transition: all 0.3s ease;
}

.content-rich table:hover,
.content-rich .md-table:hover {
  box-shadow: 0 4rpx 16rpx rgba(120, 100, 75, 0.1);
  transform: translateY(-2rpx);
}

.content-rich thead,
.content-rich .md-thead {
  background: linear-gradient(135deg, #7A6658 0%, #6D5D4D 100%);
}

.content-rich th,
.content-rich .md-th {
  padding: 20rpx 16rpx;
  text-align: left;
  font-weight: 600;
  color: #FFFDF8;
  border-right: 1rpx solid rgba(255, 253, 248, 0.25);
  border-bottom: 1rpx solid rgba(255, 253, 248, 0.25);
  position: relative;
  font-size: 24rpx;
}

.content-rich th:last-child,
.content-rich .md-th:last-child {
  border-right: none;
}

.content-rich td,
.content-rich .md-td {
  padding: 18rpx 16rpx;
  border: 1rpx solid #E0D4C4;
  position: relative;
  font-size: 24rpx;
  line-height: 1.5;
  color: #4A3F35;
}

.content-rich tr:nth-child(even),
.content-rich .md-tr:nth-child(even) {
  background: rgba(168, 144, 120, 0.02);
}

.content-rich tr:hover,
.content-rich .md-tr:hover {
  background: rgba(212, 133, 106, 0.03);
  transition: background 0.3s ease;
}

.content-body .h2w__h2 {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A3F35;
  margin: 28rpx 0 14rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #D4856A;
  display: block;
}

.content-body .h2w__h3 {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A3F35;
  margin: 22rpx 0 10rpx;
  display: block;
}

.content-body .h2w__p {
  margin: 14rpx 0;
  text-align: justify;
  display: block;
}

.content-body .h2w__ul,
.content-body .h2w__ol {
  margin: 14rpx 0;
  padding-left: 40rpx;
  display: block;
}

.content-body .h2w__li {
  margin: 8rpx 0;
  display: list-item;
}

.content-body .h2w__ul .h2w__li { list-style-type: disc; }
.content-body .h2w__ol .h2w__li { list-style-type: decimal; }

.content-body .h2w__table {
  width: 100%;
  border-collapse: collapse;
  margin: 24rpx 0;
  font-size: 26rpx;
  box-shadow: 0 2rpx 10rpx rgba(120, 100, 75, 0.04);
  border-radius: 10rpx;
  overflow: hidden;
  display: table;
  border: 1rpx solid #D8CDB8;
}

.content-body .h2w__thead,
.content-body .h2w__tbody,
.content-body .h2w__tr { display: table-row; }
.content-body .h2w__th,
.content-body .h2w__td {
  border: 1rpx solid #E0D4C4;
  padding: 14rpx;
  text-align: left;
  display: table-cell;
  color: #4A3F35;
}

.content-body .h2w__th {
  background: linear-gradient(135deg, #7A6658 0%, #6D5D4D 100%);
  font-weight: 600;
  color: #FFFDF8;
}

.content-body .h2w__blockquote {
  margin: 20rpx 0;
  padding: 18rpx 24rpx;
  background: rgba(168, 144, 120, 0.05);
  border-left: 4rpx solid #D4856A;
  border-radius: 0 12rpx 12rpx 0;
  color: #6D5D4D;
  font-style: italic;
  display: block;
}

.content-body .h2w__code {
  background: rgba(168, 144, 120, 0.08);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
  color: #A06850;
  display: inline;
}

.content-body .h2w__pre {
  background: #4A3F35;
  color: #FFFDF8;
  padding: 20rpx;
  border-radius: 12rpx;
  overflow-x: auto;
  margin: 20rpx 0;
  display: block;
}

.content-body .h2w__pre .h2w__code {
  background: none;
  color: inherit;
  padding: 0;
  font-size: 26rpx;
  display: block;
}

.content-body .h2w__a {
  color: #D4856A;
  text-decoration: underline;
  display: inline;
}

/* ========== 标签区域 ========== */
.tags-area {
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(120, 100, 75, 0.06);
  border: 1rpx solid #E0D4C4;
}

.tags-header {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.tags-title-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  background: rgba(212, 133, 106, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(212, 133, 106, 0.1);
}

.tags-title-left-hover {
  background: rgba(212, 133, 106, 0.12);
}

.tags-title-icon {
  font-size: 22rpx;
}

.tags-title-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #D4856A;
}

.tags-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(to right, #D4856A, #D8CDB8);
  border-radius: 2rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 10rpx 18rpx;
  background: rgba(122, 102, 88, 0.05);
  border: 1rpx solid rgba(122, 102, 88, 0.1);
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.tag-item-hover {
  background: #7A6658;
  border-color: #6D5D4D;
}

.tag-item-hover .tag-hash,
.tag-item-hover .tag-text {
  color: #FFFDF8;
}

.tag-hash {
  font-size: 22rpx;
  color: #D4856A;
  margin-right: 4rpx;
  font-weight: 600;
}

.tag-text {
  font-size: 24rpx;
  color: #6D5D4D;
  font-weight: 500;
}

/* ========== 相关推荐 ========== */
.related-section {
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(120, 100, 75, 0.06);
  border: 1rpx solid #E0D4C4;
}

.related-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #E0D4C4;
}

.related-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #4A3F35;
}

.related-count {
  font-size: 22rpx;
  color: #A89078;
  font-weight: 500;
}

.related-scroll {
  white-space: nowrap;
  padding: 4rpx 0;
  height: auto;
}

.related-card {
  display: inline-block;
  width: 280rpx;
  padding: 22rpx;
  margin-right: 18rpx;
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  border-radius: 16rpx;
  vertical-align: top;
  box-shadow: 0 2rpx 10rpx rgba(120, 100, 75, 0.05);
  border: 1rpx solid #E0D4C4;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.related-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #C9806E, #D4856A, #C9806E);
  border-radius: 16rpx 16rpx 0 0;
}

.related-card-hover {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(120, 100, 75, 0.1);
}

.related-category {
  display: inline-block;
  padding: 4rpx 14rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFDF8;
  background: linear-gradient(135deg, #7A6658 0%, #6D5D4D 100%);
  border-radius: 10rpx;
  margin-bottom: 14rpx;
}

.related-card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #4A3F35;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
  letter-spacing: 1rpx;
}

.related-card-desc {
  display: block;
  font-size: 22rpx;
  color: #6D5D4D;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.5;
}

/* ========== 底部操作栏 ========== */
.action-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 18rpx;
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  padding: 18rpx 28rpx;
  margin-top: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(120, 100, 75, 0.06);
  border: 1rpx solid #E0D4C4;
  animation: slideUp 0.8s ease;
}

.action-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(120, 100, 75, 0.06);
}

.action-btn::after { border: none; }

.copy-btn {
  background: linear-gradient(135deg, #7A6658 0%, #6D5D4D 100%);
  color: #FFFDF8;
}

.share-btn {
  background: linear-gradient(135deg, #D4856A 0%, #C9806E 100%);
  color: #FFFDF8;
}

/* ========== 调试区域样式 ========== */
.debug-area {
  background: rgba(168, 144, 120, 0.04);
  border: 1rpx solid #E0D4C4;
  border-radius: 14rpx;
  margin: 28rpx 0;
  padding: 18rpx;
  box-shadow: 0 2rpx 8rpx rgba(120, 100, 75, 0.03);
}

.debug-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #E0D4C4;
}

.debug-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #6D5D4D;
}

.debug-copy-btn {
  background: linear-gradient(135deg, #6B8E6B 0%, #5A7D5A 100%);
  color: #FFFDF8;
  border: none;
  border-radius: 8rpx;
  padding: 8rpx 14rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.debug-copy-btn-hover {
  opacity: 0.8;
  transform: scale(0.98);
}

.debug-content {
  background: #FFFEF8;
  border-radius: 8rpx;
  padding: 18rpx;
  max-height: 360rpx;
  overflow-y: auto;
  border: 1rpx solid #E0D4C4;
}

.debug-text {
  font-size: 22rpx;
  font-family: 'Courier New', monospace;
  color: #6D5D4D;
  line-height: 1.4;
  word-break: break-all;
  white-space: pre-wrap;
}

/* 调试按钮样式 */
.debug-btn {
  background: linear-gradient(135deg, #6B8EAE 0%, #5A7D9A 100%);
  color: #FFFDF8;
}

/* ========== Rich-text 内容样式 ========== */
.content-rich {
  font-size: 30rpx;
  line-height: 1.85;
  color: #4A3F35;
}

/* 标题样式 */
.content-rich h1 {
  font-size: 38rpx;
  font-weight: bold;
  color: #4A3F35;
  margin: 36rpx 0 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid #D4856A;
  letter-spacing: 1rpx;
}

.content-rich h2 {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A3F35;
  margin: 28rpx 0 14rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #D4856A;
}

.content-rich h3 {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A3F35;
  margin: 22rpx 0 10rpx;
}

.content-rich h4 {
  font-size: 26rpx;
  font-weight: 600;
  color: #4A3F35;
  margin: 20rpx 0 10rpx;
}

/* 段落和列表样式 */
.content-rich p {
  margin: 14rpx 0;
  text-align: justify;
}

.content-rich ul, .content-rich ol {
  margin: 14rpx 0;
  padding-left: 36rpx;
}

.content-rich li {
  margin: 8rpx 0;
  line-height: 1.6;
}

.content-rich blockquote {
  background: rgba(168, 144, 120, 0.05);
  border-left: 4rpx solid #D4856A;
  margin: 20rpx 0;
  padding: 18rpx 24rpx;
  border-radius: 0 12rpx 12rpx 0;
  font-style: italic;
  color: #6D5D4D;
}

/* 代码块样式 */
.content-rich pre {
  background: #4A3F35;
  color: #FFFDF8;
  padding: 20rpx;
  border-radius: 10rpx;
  margin: 20rpx 0;
  overflow-x: auto;
  overflow-y: hidden;
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  line-height: 1.5;
  white-space: pre;
  max-width: 100%;
  -webkit-overflow-scrolling: touch;
}

/* 确保代码块内容可以横向滚动 */
.content-rich pre code {
  display: block;
  min-width: max-content;
  white-space: pre;
}

.content-rich code {
  background: rgba(168, 144, 120, 0.08);
  color: #A06850;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
}

/* ========== 表格样式优化 ========== */
.content-rich table {
  width: 100%;
  border-collapse: collapse;
  margin: 28rpx 0;
  background: #FFFEF8;
  border: 1rpx solid #D8CDB8;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(120, 100, 75, 0.04);
}

/* 表头样式 */
.content-rich thead {
  background: linear-gradient(135deg, #7A6658 0%, #6D5D4D 100%);
}

.content-rich th {
  padding: 18rpx 14rpx;
  text-align: left;
  font-weight: 600;
  color: #FFFDF8;
  font-size: 26rpx;
  border-bottom: 2rpx solid #6D5D4D;
  border-right: 1rpx solid rgba(255, 253, 248, 0.25);
}

.content-rich th:last-child {
  border-right: none;
}

/* 单元格样式 */
.content-rich td {
  padding: 16rpx 14rpx;
  border-bottom: 1rpx solid #E0D4C4;
  border-right: 1rpx solid #E0D4C4;
  font-size: 26rpx;
  line-height: 1.5;
  color: #4A3F35;
}

.content-rich td:last-child {
  border-right: none;
}

/* 最后一行单元格取消底部边框 */
.content-rich tr:last-child td {
  border-bottom: none;
}

/* 隔行变色效果 */
.content-rich tbody tr:nth-child(even) {
  background: rgba(168, 144, 120, 0.02);
}

.content-rich tbody tr:nth-child(odd) {
  background: #FFFEF8;
}

/* 响应式表格 */
@media (max-width: 750rpx) {
  .content-rich table {
    font-size: 24rpx;
  }
  
  .content-rich th,
  .content-rich td {
    padding: 14rpx 10rpx;
    font-size: 24rpx;
  }
}

/* 分隔线样式 */
.content-rich hr {
  border: none;
  height: 2rpx;
  background: linear-gradient(to right, transparent, #D4856A, transparent);
  margin: 32rpx 0;
  border-radius: 1rpx;
}

/* 强调文本样式 */
.content-rich strong {
  color: #A06850;
  font-weight: 600;
}

.content-rich em {
  color: #6D5D4D;
  font-style: italic;
}
