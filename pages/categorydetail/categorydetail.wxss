/* packages/knowledge/pages/categorydetail/categorydetail.wxss */
/* 水墨屏/泛黄纸张风格 - 浅色协调版 */

page {
  /* 泛黄纸张背景 */
  background: linear-gradient(160deg, #FBF4E3 0%, #F9EFDE 50%, #F6E9D0 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', serif;
}

/* 面包屑导航 */
.breadcrumb {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  border-bottom: 1rpx solid #f0ebe3;
}

.breadcrumb-item {
  font-size: 26rpx;
  color: #576b95;
}

.breadcrumb-item-hover {
  opacity: 0.7;
}

.breadcrumb-sep {
  font-size: 24rpx;
  color: #bbb;
  margin: 0 12rpx;
}

.breadcrumb-current {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 420rpx;
}

.container {
  min-height: 100vh;
  padding: 76rpx 0 0;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(120, 100, 75, 0.05);
  gap: 22rpx;
  border: 1rpx solid #E0D4C4;
}

.loading-spinner {
  width: 52rpx;
  height: 52rpx;
  border: 4rpx solid rgba(212, 133, 106, 0.15);
  border-top: 4rpx solid #D4856A;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  font-size: 26rpx;
  color: #6D5D4D;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(120, 100, 75, 0.05);
  gap: 18rpx;
  border: 1rpx solid #E0D4C4;
}

.empty-icon {
  font-size: 90rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #4A3F35;
  font-weight: 600;
}

.empty-subtext {
  font-size: 24rpx;
  color: #A89078;
  text-align: center;
  padding: 0 36rpx;
}

/* 文章列表 */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 20rpx;
}

.article-card {
  width: 100%;
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(120, 100, 75, 0.05);
  transition: all 0.25s ease;
  border: 1rpx solid #E0D4C4;
}

.article-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(122, 102, 88, 0.1);
}

.card-inner {
  padding: 26rpx;
  position: relative;
}

.card-inner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, #C9806E, #D4856A);
  border-radius: 16rpx 0 0 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-category {
  display: inline-block;
  padding: 4rpx 14rpx;
  font-size: 20rpx;
  color: #D4856A;
  background: rgba(212, 133, 106, 0.1);
  border-radius: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160rpx;
  font-weight: 500;
  border: 1rpx solid rgba(212, 133, 106, 0.12);
}

.card-order {
  font-size: 20rpx;
  color: #C0B0A0;
  font-weight: 500;
}

.card-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 600;
  color: #4A3F35;
  line-height: 1.4;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.card-desc {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 24rpx;
  color: #6D5D4D;
  line-height: 1.5;
  margin-bottom: 14rpx;
}

.card-footer {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #E0D4C4;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.card-tag {
  font-size: 22rpx;
  color: #6D5D4D;
  background: rgba(122, 102, 88, 0.05);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  max-width: 130rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: all 0.2s ease;
  border: 1rpx solid rgba(122, 102, 88, 0.08);
}

.card-tag:active {
  background: rgba(212, 133, 106, 0.1);
  color: #D4856A;
  transform: scale(1.02);
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #A89078;
}

.card-meta .card-words {
  font-weight: 500;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 28rpx 0;
  background: linear-gradient(145deg, #FFFEF8 0%, #FFF5E8 100%);
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(120, 100, 75, 0.05);
  font-size: 24rpx;
  color: #D4856A;
  font-weight: 500;
  border: 1rpx solid #E0D4C4;
}

/* 结束提示 */
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 56rpx;
}

.end-text {
  font-size: 22rpx;
  color: #C0B0A0;
  white-space: nowrap;
  letter-spacing: 1rpx;
}
