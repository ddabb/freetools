page {
  background: #f5f5f5;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  padding: 0;
  box-sizing: border-box;
}

/* 分类头部 */
.category-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 40rpx 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  position: relative;
}

.header-content {
  position: relative;
  z-index: 2;
}

.back-button {
  position: absolute;
  top: -10rpx;
  left: 0;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.back-button:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(1.1);
}

.back-icon {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.category-title {
  font-size: 36rpx;
  font-weight: 700;
  margin: 20rpx 0 12rpx 70rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-title .icon {
  font-size: 40rpx;
}

.title-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.article-count {
  font-size: 24rpx;
  opacity: 0.9;
  margin: 0 0 0 70rpx;
}

/* 面包屑导航 */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background: white;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.breadcrumb-item {
  color: #667eea;
  transition: color 0.3s ease;
}

.breadcrumb-item:active {
  color: #764ba2;
}

.breadcrumb-item.active {
  color: #333;
  font-weight: 600;
}

.breadcrumb-separator {
  color: #999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: white;
  margin: 0 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  gap: 24rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(102, 126, 234, 0.2);
  border-top: 6rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: white;
  margin: 0 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  gap: 24rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  font-size: 34rpx;
  color: #333;
  font-weight: 600;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 0 40rpx;
}

/* 文章列表 */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx 24rpx;
}

.article-card {
  width: 100%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.article-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

.card-inner {
  padding: 24rpx;
  position: relative;
  overflow: hidden;
}

.card-inner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 20rpx 20rpx 0 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-category {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  color: white;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 180rpx;
}

.card-order {
  font-size: 24rpx;
  color: #ccc;
  font-weight: 500;
}

.card-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.card-desc {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.card-footer {
  margin-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.card-tag {
  font-size: 24rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.card-tag:active {
  background: rgba(102, 126, 234, 0.2);
  transform: scale(1.05);
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 30rpx 0;
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  font-size: 26rpx;
  color: #667eea;
}

/* 结束提示 */
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 60rpx;
}

.end-text {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
}
