/**mine.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  min-height: 100vh;
  -webkit-overflow-scrolling: touch;
}

.container {
  padding: 32rpx 20rpx;
  position: relative;
  max-width: 800rpx;
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
  min-height: 100vh;
}

/* 项目信息卡片 - 统一样式 */
.project-card {
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.project-header {
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.project-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: flex;
  align-items: center;
  letter-spacing: 0.5rpx;
}

.project-title-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.project-content {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.project-description {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  letter-spacing: 0.3rpx;
  text-align: left;
}

/* GitHub链接样式 */
.github-link {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  margin-top: 16rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.github-link:hover {
  background: rgba(255, 255, 255, 0.15);
  transform: translateY(-1rpx);
  border-color: rgba(255, 255, 255, 0.2);
}

.github-icon {
  font-size: 28rpx;
  color: #1a1a1a;
}

.github-url {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
  word-break: break-all;
}

.github-arrow {
  font-size: 24rpx;
  color: #666666;
  font-weight: bold;
  transition: transform 0.3s ease;
}

.github-link:hover .github-arrow {
  transform: translateX(3rpx);
}

/* ICP备案信息样式 */
.icp-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.icp-label {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
}

.icp-value {
  font-size: 24rpx;
  color: #1a1a1a;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* 分享区域样式 */
.share-section {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.share-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.share-description {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
  display: block;
  margin-bottom: 8rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
  transition: all 0.3s ease;
}

.share-btn-hover {
  background: linear-gradient(135deg, #45a049 0%, #3d8b40 100%);
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.4);
}

.share-icon {
  font-size: 26rpx;
}

.share-text {
  font-size: 26rpx;
  font-weight: 600;
}

/* 高亮文本样式 */
.highlight {
  color: #1a73e8;
  font-weight: 600;
}

/* 收藏区域样式 */
.favorite-section {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.favorite-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.favorite-description {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
  display: block;
  margin-bottom: 8rpx;
}

.favorite-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
  transition: all 0.3s ease;
}

.favorite-btn-hover {
  background: linear-gradient(135deg, #F57C00 0%, #E65100 100%);
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(255, 152, 0, 0.4);
}

.favorite-icon {
  font-size: 26rpx;
}

.favorite-text {
  font-size: 26rpx;
  font-weight: 600;
}

/* 版本信息 */
.version-info {
  text-align: center;
  margin-top: auto;
  padding: 30rpx 0 40rpx;
}

.version-text {
  font-size: 22rpx;
  color: #666666;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.version-text::before {
  content: "v";
  margin-right: 2rpx;
}

/* 小程序码样式 */
.mini-program-qr {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
}

.qr-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.mini-program-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  letter-spacing: 0.5rpx;
}

.mini-program-desc {
  font-size: 26rpx;
  color: #666666;
  text-align: center;
  line-height: 1.5;
  max-width: 80%;
}
