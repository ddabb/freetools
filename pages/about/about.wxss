/**mine.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  min-height: 100vh;
}

.container {
  padding: 16rpx;
  min-height: 100vh;
  position: relative;
}

/* 用户信息 - 无登录，只用本地 mock */
.user-info {
  background: transparent;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 20rpx 0 30rpx;
  display: flex;
  align-items: center;
  /* 无阴影、无边框，与页面背景融合 */
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  overflow: hidden;
}

.default-avatar {
  font-size: 60rpx;
  color: white;
}

.user-details {
  flex: 1;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 8rpx;
  display: block;
}

.user-level {
  font-size: 26rpx;
  color: #5a6c7d;
  font-weight: 600;
}

/* 工具使用统计 - 本地 mock */
.stats-card {
  background: transparent;
  border-radius: 24rpx;
  margin: 0 0 24rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-around;
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #2c3e50;
  display: block;
  margin-bottom: 6rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #5a6c7d;
  font-weight: 500;
}

/* 菜单列表 */
.menu-list {
  background: transparent;
  border-radius: 24rpx;
  margin: 0 0 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
  transition: background-color 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #667eea;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #2c3e50;
  font-weight: 600;
}

.menu-arrow {
  font-size: 28rpx;
  color: #5a6c7d;
  font-weight: bold;
}

/* 功能按钮 */
.action-buttons {
  margin: 0 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  background: transparent;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 28rpx;
  color: #5a6c7d;
  font-weight: bold;
}

/* 项目信息卡片 */
.project-card {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  margin: 0 0 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.project-header {
  margin-bottom: 16rpx;
  text-align: left;
}

.project-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: left;
}

.project-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  text-align: left;
}

.project-description {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
  text-align: left;
}

.github-link {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  margin-top: 8rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.github-link:hover {
  background: rgba(255, 255, 255, 0.2);
  transform: translateY(-2rpx);
}

.github-icon {
  font-size: 32rpx;
}

.github-url {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
  word-break: break-all;
}

.github-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: bold;
}

/* 隐私声明卡片 - 已统一使用 project-card 样式 */

/* 版本信息 */
.version-info {
  text-align: center;
  margin-top: 40rpx;
  padding-bottom: 20rpx;
}

.version-text {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}
