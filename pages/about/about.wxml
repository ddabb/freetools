<!-- mine.wxml -->
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <!-- 顶部背景已移除，由 page 背景统一 -->
    <!-- 通用欢迎区（无登录元素） -->
    <view class="user-info">
      <view class="user-avatar">
        <text class="default-avatar">🛠️</text>
      </view>
      <view class="user-details">
        <text class="user-nickname">欢迎使用免费工具箱</text>
        <text class="user-level">无需登录 · 即用即走</text>
      </view>
    </view>
    <!-- 项目信息卡片 -->
    <view class="project-card">
      <view class="project-header">
        <text class="project-title">🌐 关于项目</text>
      </view>
      <view class="project-content">
        <text class="project-description">这是一个 Vibe Coding 项目，专注于提供实用的工具集合。</text>
        <text class="project-description">我们致力于打造一个轻量级、无广告、功能丰富的工具箱，</text>
        <text class="project-description">涵盖生活、学习、工作等多个领域的实用工具。</text>
        <text class="project-description">欢迎提交 PR 和提出 Issue，一起完善这个项目！</text>
        <view class="github-link" bindtap="openGitHub">
          <text class="github-icon">🐙</text>
          <text class="github-url">https://github.com/ddabb/freetools.git</text>
          <text class="github-arrow">→</text>
        </view>
      </view>
    </view>
    <!-- 隐私声明卡片 -->
    <view class="project-card">
      <view class="project-header">
        <text class="project-title">🔒 隐私声明</text>
      </view>
      <view class="project-content">
        <text class="project-description">本项目不涉及数据收集、采集等功能，</text>
        <text class="project-description">无后台数据库，所有数据仅保存在本地，</text>
        <text class="project-description">请放心使用。</text>
      </view>
    </view>
    <!-- 版本信息 -->
    <view class="version-info">
      <text class="version-text">免费工具箱 v1.0.0</text>
    </view>
  </view>
</scroll-view>