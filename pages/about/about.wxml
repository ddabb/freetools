<!-- about.wxml -->
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <!-- 小程序码卡片 -->
    <view class="project-card">
      <view class="project-header">
        <text class="project-title">📱 小程序码</text>
      </view>
      <view class="project-content">
        <view class="mini-program-qr">
          <image class="qr-image" src="../../images/mini.png" mode="aspectFit"></image>
          <text class="mini-program-name">随身工具宝</text>
          <text class="mini-program-desc">扫描二维码，随时随地使用实用工具</text>
        </view>
      </view>
    </view>

    <!-- 项目信息卡片 -->
    <view class="project-card">
      <view class="project-header">
        <text class="project-title">🌟 关于我们</text>
      </view>
      <view class="project-content">
        <text class="project-description">欢迎使用「随身工具宝」小程序！</text>
        <text class="project-description">这是一款专为大众用户设计的实用工具集合，</text>
        <text class="project-description">涵盖生活、学习、工作等各个场景的便捷功能。</text>
        <text class="project-description">
          <text class="highlight">🎯 我们的特色：</text>
        </text>
        <text class="project-description">• 完全免费使用，无任何隐藏收费</text>
        <text class="project-description">• 界面简洁易用，操作简单快捷</text>
        <text class="project-description">• 无需下载安装，即开即用</text>
        <text class="project-description">• 数据本地存储，保护您的隐私</text>
        
        <text class="project-description">
          <text class="highlight">💡 主要功能：</text>
        </text>
        <text class="project-description">• 生活工具：日历查询、星座运势、生肖配对等</text>
        <text class="project-description">• 学习助手：文案创作、计算工具等</text>
        <text class="project-description">• 实用功能：更多实用工具持续更新中</text>
        
        <view class="share-section">
          <text class="share-title">📢 分享给好友</text>
          <text class="share-description">觉得好用吗？分享给身边的朋友吧！</text>
          <text class="share-description">让更多人一起享受便捷的工具服务！</text>
          <button class="share-btn" open-type="share" hover-class="share-btn-hover">
            <text class="share-icon">📤</text>
            <text class="share-text">分享给好友</text>
          </button>
        </view>
        
        <view class="favorite-section">
          <text class="favorite-title">⭐ 收藏小程序</text>
          <text class="favorite-description">收藏后可在微信首页下拉快速找到</text>
          <text class="favorite-description">方便下次使用，无需搜索！</text>
          <button class="favorite-btn" bindtap="addToFavorite" hover-class="favorite-btn-hover">
            <text class="favorite-icon">⭐</text>
            <text class="favorite-text">添加到我的小程序</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 版本与缓存卡片 -->
    <view class="project-card">
      <view class="project-header">
        <text class="project-title">🔧 版本与缓存</text>
      </view>
      <view class="project-content">
        <view class="version-info">
          <text class="version-label">当前版本：</text>
          <text class="version-value">v{{version}}</text>
        </view>
        
        <view class="upgrade-hint">
          <text class="hint-icon">💡</text>
          <text class="hint-text">版本升级后如遇数据异常，可尝试清除缓存</text>
        </view>
        
        <view class="cache-info">
          <text class="cache-label">CDN缓存状态：</text>
          <text class="cache-value {{cacheCleared ? 'success' : ''}}">{{cacheCleared ? '已清除' : '缓存正常'}}</text>
        </view>
        
        <view class="cache-hint">
          <text class="hint-icon">💡</text>
          <text class="hint-text">CDN缓存 key 统一使用 cdn_ 前缀</text>
        </view>
        
        <button class="cache-btn" bindtap="clearCache" hover-class="cache-btn-hover">
          <text class="cache-icon">🗑️</text>
          <text class="cache-text">清除 CDN 缓存</text>
        </button>
      </view>
    </view>

    <!-- 隐私声明卡片 -->
    <view class="project-card">
      <view class="project-header">
        <text class="project-title">🔒 隐私声明</text>
      </view>
      <view class="project-content">
        <text class="project-description">本项目不涉及数据收集、采集等功能，</text>
        <text class="project-description">无后台数据库，所有数据仅保存在本地，</text>
        <text class="project-description">请放心使用。</text>
      </view>
    </view>

    <!-- 联系我们卡片 -->
    <view class="project-card">
      <view class="project-header">
        <text class="project-title">📞 联系我们</text>
      </view>
      <view class="project-content">
        <view class="contact-item" bindtap="onCopyWechat">
          <text class="contact-icon">📱</text>
          <view class="contact-info">
            <text class="contact-label">微信公众号</text>
            <text class="contact-value">随身工具宝</text>
          </view>
          <text class="contact-arrow">›</text>
        </view>
        <view class="contact-item" bindtap="onCopyEmail">
          <text class="contact-icon">✉️</text>
          <view class="contact-info">
            <text class="contact-label">联系邮箱</text>
            <text class="contact-value">1011888891@qq.com</text>
          </view>
          <text class="contact-arrow">›</text>
        </view>
        <text class="contact-tip">💡 问题反馈、建议、商务合作欢迎来信</text>
      </view>
    </view>

    <!-- ICP备案信息卡片 -->
    <view class="project-card">
      <view class="project-header">
        <text class="project-title">📜 ICP备案信息</text>
      </view>
      <view class="project-content">
        <view class="icp-info">
          <text class="icp-label">备案/许可证编号：</text>
          <text class="icp-value">粤ICP备2026023418号</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
