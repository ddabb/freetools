/*idcard.wxss*/
.container {
  padding: 20rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header {
  padding: 30rpx 0;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.content {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
}

.card-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx 30rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: white;
}

.card-body {
  padding: 30rpx;
}

.input-group {
  margin-bottom: 24rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.input {
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 32rpx;
  width: 100%;
  box-sizing: border-box;
  background-color: #f9f9f9;
  transition: all 0.3s ease;
}

.input:focus {
  border-color: #667eea;
  background-color: white;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.button-section {
  margin-top: 10rpx;
}

.button {
  width: 100%;
  padding: 25rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 20rpx;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.button:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 15rpx 35rpx rgba(0, 0, 0, 0.2);
}

.result-card {
  margin-top: 10rpx;
}

.result-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  white-space: pre-wrap;
}

.tips {
  margin-top: 10rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 15rpx;
  border-left: 6rpx solid #667eea;
}

.tips-text {
  font-size: 20rpx;
  color: #666;
  line-height: 1.4;
}