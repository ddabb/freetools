<!--life-countdown.wxml-->
<view class="container">
  <!-- 出生日期输入 -->
  <view class="section">
    <text class="section-title">出生日期</text>
    <view class="input-box">
      <input type="date" value="{{birthDate}}" bindinput="setBirthDate" class="input"/>
    </view>
  </view>
  
  <!-- 预计寿命设置 -->
  <view class="section">
    <text class="section-title">预计寿命（岁）</text>
    <view class="input-box">
      <input type="number" value="{{expectedLifeYears}}" bindinput="setExpectedLifeYears" class="input"/>
    </view>
  </view>
  
  <!-- 计算按钮 -->
  <view class="section">
    <button class="calculate-btn" bindtap="calculate">计算</button>
  </view>
  
  <!-- 结果展示 -->
  <view class="section" wx:if="{{showResult}}">
    <view class="result-box">
      <view class="result-item">
        <text class="result-label">已活天数</text>
        <text class="result-value days-lived">{{daysLived}}</text>
      </view>
      <view class="result-row">
        <view class="result-item">
          <text class="result-label">剩余预期寿命</text>
          <text class="result-value life-left">{{lifeLeft}} 天</text>
        </view>
        <view class="result-item">
          <text class="result-label">人生进度</text>
          <text class="result-value progress">{{progress}}%</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 重要纪念日 -->
  <view class="section" wx:if="{{showResult}}">
    <text class="section-title">重要纪念日</text>
    <view class="anniversary-box">
      <view class="anniversary-item">
        <text class="anniversary-name">生日</text>
        <text class="anniversary-days">还有 {{birthdayDays}} 天</text>
      </view>
      <view class="anniversary-item">
        <text class="anniversary-name">结婚纪念日</text>
        <text class="anniversary-days">还有 {{weddingDays}} 天</text>
      </view>
      <view class="anniversary-item">
        <text class="anniversary-name">新年</text>
        <text class="anniversary-days">还有 {{newYearDays}} 天</text>
      </view>
    </view>
  </view>
</view>