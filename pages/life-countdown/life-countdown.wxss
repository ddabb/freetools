/**life-countdown.wxss**/
page {
  min-height: 100vh;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.container {
  padding: 20rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 输入框 */
.input-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
}

.input {
  width: 100%;
  font-size: 32rpx;
  border: none;
  outline: none;
  color: #333;
  font-weight: 500;
}

/* 日期选择器 */
.picker {
  width: 100%;
}

.picker-view {
  width: 100%;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  padding: 0;
  margin: 0;
}

/* 计算按钮 */
.calculate-btn {
  width: 100%;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 30rpx rgba(17, 153, 142, 0.4);
  transition: all 0.3s ease;
}

.calculate-btn:active {
  transform: scale(0.98);
}

/* 结果展示 */
.result-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.result-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #11998e, #38ef7d);
}

.result-item {
  text-align: center;
  margin-bottom: 20rpx;
}

.result-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.result-value {
  font-size: 40rpx;
  font-weight: 800;
}

.result-value.days-lived {
  color: #11998e;
  font-size: 56rpx;
}

.result-value.life-left {
  color: #38ef7d;
}

.result-value.progress {
  color: #f5576c;
}

.result-row {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.result-row .result-item {
  flex: 1;
  margin-bottom: 0;
}

/* 重要纪念日 */
.anniversary-box {
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.anniversary-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #11998e, #38ef7d);
}

.anniversary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.anniversary-item:last-child {
  border-bottom: none;
}

.anniversary-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.anniversary-days {
  font-size: 32rpx;
  color: #f5576c;
  font-weight: 800;
}
