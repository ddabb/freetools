<!-- 面包屑导航 -->
<view class="breadcrumb">
  <text class="breadcrumb-item" hover-class="breadcrumb-item-hover" bindtap="goToTagList">🏷️ 标签列表</text>
  <text class="breadcrumb-sep">/</text>
  <text class="breadcrumb-current">{{tagName}}</text>
</view>

<view class="container">
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading && articles.length === 0}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && articles.length === 0}}">
    <text class="empty-icon">📄</text>
    <text class="empty-text">暂无文章</text>
    <text class="empty-subtext">该标签下还没有文章</text>
  </view>

  <!-- 文章列表 -->
  <view class="article-list" wx:if="{{!loading && articles.length > 0}}">
    <view 
      class="article-card" 
      wx:for="{{articles}}" 
      wx:key="filename"
      bindtap="onArticleTap"
      data-filename="{{item.filename}}"
    >
      <view class="card-inner">
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="card-category">{{item.displayCategory || item.category}}</view>
          <text class="card-order">#{{item.order}}</text>
        </view>

        <!-- 卡片标题 -->
        <text class="card-title">{{item.title}}</text>

        <!-- 卡片描述 -->
        <text class="card-desc" wx:if="{{item.description}}">{{item.description}}</text>

        <!-- 卡片底部 -->
        <view class="card-footer">
          <view class="card-tags">
            <text 
              class="card-tag" 
              wx:for="{{item.tags}}" 
              wx:for-item="tag" 
              wx:key="*this"
              catchtap="onTagTap"
              data-tag="{{tag}}"
            >#{{tag}}</text>
          </view>
          <view class="card-meta">
            <text class="card-words">{{item.wordCount}}字</text>
            <text class="card-time" wx:if="{{item.updateTime}}">{{item.updateTime}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="loading-more" wx:if="{{loading && articles.length > 0}}">
    <text>加载中...</text>
  </view>

  <!-- 结束提示 -->
  <view class="list-end" wx:if="{{isOver && articles.length > 0}}">
    <text class="end-text">— 已加载全部 —</text>
  </view>
</view>
