page {
  background: #f8f9fa;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  padding: 0;
  box-sizing: border-box;
}

/* 标签头部 - 简洁清新风格 */
.tag-header {
  background: linear-gradient(135deg, #e74c3c 0%, #f39c12 100%);
  color: white;
  padding: 40rpx 32rpx 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(231, 76, 60, 0.25);
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tag-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.tag-title .icon {
  font-size: 44rpx;
}

.title-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.article-count {
  font-size: 26rpx;
  opacity: 0.85;
  margin-left: 60rpx;
  letter-spacing: 0.5rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: white;
  margin: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  gap: 24rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid rgba(231, 76, 60, 0.15);
  border-top: 5rpx solid #e74c3c;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: white;
  margin: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  gap: 20rpx;
}

.empty-icon {
  font-size: 96rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 0 40rpx;
}

/* 文章列表 */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 24rpx;
}

.article-card {
  width: 100%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.25s ease;
}

.article-card:active {
  transform: translateY(-3rpx);
  box-shadow: 0 6rpx 24rpx rgba(231, 76, 60, 0.12);
}

.card-inner {
  padding: 28rpx;
  position: relative;
}

.card-inner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, #e74c3c, #f39c12);
  border-radius: 20rpx 0 0 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-category {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.08);
  border-radius: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 180rpx;
  font-weight: 500;
}

.card-order {
  font-size: 22rpx;
  color: #bbb;
  font-weight: 500;
}

.card-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.45;
  margin-bottom: 12rpx;
}

.card-desc {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 26rpx;
  color: #666;
  line-height: 1.55;
  margin-bottom: 16rpx;
}

.card-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.card-tag {
  font-size: 24rpx;
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.06);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: all 0.2s ease;
}

.card-tag:active {
  background: rgba(231, 76, 60, 0.15);
  transform: scale(1.03);
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.card-meta .card-words {
  font-weight: 500;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 32rpx 0;
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  font-size: 26rpx;
  color: #e74c3c;
  font-weight: 500;
}

/* 结束提示 */
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0 64rpx;
}

.end-text {
  font-size: 24rpx;
  color: #bbb;
  white-space: nowrap;
  letter-spacing: 1rpx;
}
